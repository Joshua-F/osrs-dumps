// 1827
[clientscript,sanity_init](component $component0, component $component1, boolean $boolean)
def_component $universe = sanity:universe;
if_setontimer("responsive_interface_scaler($universe, -1)", $universe);
if_setonresize("sanity_init($component0, $component1, false)", $universe);
def_int $int4 = 135;
switch_int (%responsive_current_breakpoint) {
    case 1 :
        $int4 = 140;
    case 2 :
        $int4 = 180;
    case 3 :
        $int4 = 250;
}
def_int $int5 = 0;
if ($int4 ! if_getwidth(sanity:overlay)) {
    $int5 = 1;
}
if_setsize($int4, 50, ^setsize_abs, ^setsize_abs, sanity:overlay);
~interface_dodger_init($component0, $component1, setbit(setbit(52968, 12), 13), ^setpos_abs_left, ^setpos_abs_top, true);
if_setonvartransmit("sanity_update{whisperer}", sanity:sanity_bar);
if ($boolean = true | $int5 = 1) {
    ~sanity_update_bar(100, %sanity, sanity:sanity_percentage, sanity:sanity_bar_foreground, sanity:sanity_bar, sanity:sanity_icon, true);
