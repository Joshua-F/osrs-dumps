// 3452
[clientscript,deathkeep_opitem](component $component, int $int, string $string)
if (cc_find($component, $int) = true) {
    sound_synth(synth_2266, 1, 0);
    mes($string);
    cc_settrans(100);
    cc_setontimer("cc_settrans_temporarily_end(event_com, event_comsubid, 0, calc(clientclock + 10))");
}
