// 272
[clientscript,nzone_lobby_coffer_examine](int $int)
if ($int = -1) {
    mes("Your coffer is protected by your Bank PIN. You can unlock it at the eastern side of the enclosure.");
} else if ($int = 0) {
    mes("Your coffer is empty. You can deposit money into the pouch at the eastern side of the enclosure.");
} else {
    mes("You have <~tostring_spacer($int, ",")> coins in the coffer.");
}
