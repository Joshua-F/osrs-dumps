// 3645
[proc,script3645]()(int)
if (~on_mobile = false & ~on_enhanced_desktop = false) {
    return(4);
}
def_int $int = deviceoption_get(^deviceoption_fps_limit);
if ($int = 0) {
    return(4);
} else if ($int <= 15) {
    return(0);
} else if ($int <= 20) {
    return(1);
} else if ($int <= 30) {
    return(2);
} else if ($int <= 60) {
    return(3);
} else {
    return(4);
}
