[clientscript,ballot_list_select_poll](component $component, int $int1, int $int2, string $string)
sound_synth(synth_2266, 1, 0);
if (cc_find($component, $int1) = true & cc_find($component, cc_param(param_2359)) = true) {
    cc_settext("<col=ffffff>Loading...</col>");
    cc_setontimer("ballot_list_resetclick(event_com, event_comsubid, $string, calc(clientclock + 60))");
}
if_runscript*(ifscript_4281807917, ballot:list, -1)($int2);
