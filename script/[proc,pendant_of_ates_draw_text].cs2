// 6699
[proc,pendant_of_ates_draw_text](component $component, int $int1, string $string, int $int2, int $int3, int $int4, int $int5)(int)
if ($int1 = 0) {
    return($int4);
}
cc_create($component, ^iftype_text, $int4);
cc_setsize(4, 20, ^setsize_minus, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_bottom);
cc_settextfont(b12_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
if ($int2 = 1 | $int3 = 1) {
    cc_setcolour(^white);
} else {
    cc_setcolour(0xff981f);
}
if ($int3 = 1) {
    cc_settext("Please wait...");
} else {
    cc_settext("<tostring($int5)>: <$string>");
}
return(calc($int4 + 1));
