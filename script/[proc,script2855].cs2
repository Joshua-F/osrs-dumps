// 2855
[proc,script2855](component $component, obj $obj, int $int2, int $int3)
if ($obj ! null) {
    cc_setobject($obj, $int3);
    cc_setopbase("<col=ff9040><oc_name($obj)></col>");
    cc_settrans(0);
    cc_setop(1, "Value");
    cc_setop(2, "Pack-1");
    cc_setop(3, "Pack-5");
    cc_setop(4, "Pack-10");
    cc_setop(5, "Pack-All");
    cc_setop(6, "Pack-X");
    cc_setop(7, "Examine");
    cc_setonop("cc_settrans_temporarily(event_com, event_comsubid, 100, 0)");
    cc_setondragcomplete("script2856(event_com, event_comsubid, event_comsubid2)");
} else {
    cc_settrans(255);
    cc_setobject(blankobject, 1);
    cc_setondragcomplete(null);
}
