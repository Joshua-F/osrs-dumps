// 4197
[proc,script4197](dbrow $dbrow, int $int1)(boolean)
if ($int1 <= 0 | $dbrow = null) {
    return(false);
}
def_int $int2 = db_getfieldcount($dbrow, dbtable_44:col6);
def_int $int3 = 0;
while ($int3 < $int2) {
    if (db_getfield($dbrow, dbtable_44:col6, $int3) = $int1) {
        return(true);
    }
    $int3 = calc($int3 + 1);
}
return(false);
