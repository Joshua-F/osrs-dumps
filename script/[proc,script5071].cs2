// 5071
[proc,script5071](int $int, string $string0, string $string1)(string)
switch_int ($int) {
    case 0, 1 :
        return($string0);
    case 2 :
        return($string1);
    case default :
        ~debug_mes_warning("Pronouns not correctly set. Pronouns are set to <tostring($int)> but should be 0, 1 or 2.");
        return($string1);
}
