// 1221
[clientscript,zeah_fade_border](component $component, int $int)
if (if_gettrans($component) < 240) {
    if_settrans(calc(if_gettrans($component) + 5), $component);
    return;
}
if_setcolour(enum(int, int, enum_1279, $int), $component);
if_setontimer(null, $component);
if_settrans(0, $component);
