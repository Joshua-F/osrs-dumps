// 4085
[proc,collection_toggle_search](boolean $boolean)
def_component $content = collection:content;
def_component $content_search = collection:content_search;
def_component $search_button = collection:search_button;
if (if_gethide($content_search) = false | $boolean = true) {
    if_sethide(true, $content_search);
    if_sethide(true, $search_button);
    if_sethide(false, $content);
    ~chatdefault_restoreinput;
    %floater_is_searching = 0;
    %floater_search_listen_for_keyboard = 0;
    %league_tasks_is_searching = 0;
    %league_tasks_search_listen_for_keyboard = 0;
    if (~on_mobile = true) {
        ~keyboard_hide;
    }
    ~collection_search_button(1);
} else {
    if_sethide(true, $content);
    if_sethide(false, $content_search);
    if_sethide(false, $search_button);
    ~collection_search_button(0);
    %settings_search_string = "";
    ~collection_searchbar_set_text(collection:search_text);
    ~collection_searchbar_op(collection:search_container, collection:search_toggle);
}
