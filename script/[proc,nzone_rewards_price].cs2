// 275
[proc,nzone_rewards_price](obj $obj0)(string)
def_obj $obj1 = oc_uncert($obj0);
def_int $int = inv_total(inv_464, $obj1);
if ($int <= 0) {
    if ($obj1 = obj_20655) {
        $int = 725;
    } else if (oc_param($obj1, param_385) = 1) {
        $int = inv_total(inv_108, obj_11864);
    } else {
        $int = inv_total(inv_108, $obj1);
    }
    $int = calc($int * 1000);
}
return(~tostring_spacer($int, ","));
