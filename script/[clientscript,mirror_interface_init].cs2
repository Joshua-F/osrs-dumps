// 2896
[clientscript,mirror_interface_init](component $rotate, string $string0, component $remove, string $string1, component $close, component $close_graphic)
~mirror_interface_button_draw($rotate, $string0, false);
~mirror_interface_button_draw($remove, $string1, false);
if (~on_mobile = true) {
    return;
