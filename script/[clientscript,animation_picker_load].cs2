// 7707
[clientscript,animation_picker_load]
if_setonvartransmit("animation_picker_load{toggle_list}", animation_picker:infinity);
def_component $infinity = animation_picker:infinity;
if_setontimer("responsive_interface_scaler($infinity, -1)", $infinity);
if_setonresize("animation_picker_draw", $infinity);
if_setsize(250, 314, ^setsize_abs, ^setsize_abs, animation_picker:world);
~animation_picker_draw;
