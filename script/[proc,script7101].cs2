// 7101
[proc,script7101](component $master_slider_bobble)
if ($master_slider_bobble = settings_side:master_slider_bobble) {
    return;
}
if (%option_master_volume <= 0) {
    if_setgraphic("settings_slider,12", $master_slider_bobble);
} else {
    if_setgraphic("settings_slider,8", $master_slider_bobble);
}
