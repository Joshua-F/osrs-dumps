// 4367
[proc,clan_board_filterupdate](int $int)
if (testbit(%macro_bee_pos_3, $int) = ^true) {
    .cc_setgraphic("options_radio_buttons,2");
} else if (testbit(%macro_bee_pos_4, $int) = ^true) {
    .cc_setgraphic("options_radio_buttons,1");
} else {
    .cc_setgraphic("options_radio_buttons,0");
}
