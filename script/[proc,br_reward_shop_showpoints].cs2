// 3084
[proc,br_reward_shop_showpoints](component $component)
def_string $string = ",";
if (%varplayer_262 < 32767) {
    if_settext("Points: <col=ffffff><~tostring_spacer(%varplayer_261, $string)></col><br>Wins: <col=ffffff><~tostring_spacer(%varplayer_262, $string)></col>", $component);
} else {
    if_settext("Points: <col=ffffff><~tostring_spacer(%varplayer_261, $string)></col><br>Wins: <col=ffffff>Lots!</col>", $component);
}
