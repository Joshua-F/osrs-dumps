// 3084
[proc,br_reward_shop_showpoints](component $component)
def_string $string = ",";
if (%if2 < 32767) {
    if_settext("Points: <col=ffffff><~tostring_spacer(%if1, $string)></col><br>Wins: <col=ffffff><~tostring_spacer(%if2, $string)></col>", $component);
} else {
    if_settext("Points: <col=ffffff><~tostring_spacer(%if1, $string)></col><br>Wins: <col=ffffff>Lots!</col>", $component);
}
