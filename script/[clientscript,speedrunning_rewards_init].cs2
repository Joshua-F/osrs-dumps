// 6791
[clientscript,speedrunning_rewards_init](component $universe, component $rewards_text, component $rewards_select_frame, component $rewards_select, component $rewards_graphics, component $rewards_holder, component $rewards_button, component $rewards_btngfx, component $confirm, component $confirm_frame, component $confirm_text, component $confirm_button, component $confirm_cancel, component $rewards_scrollbar)
~speedrunning_reward_shop_showpoints($universe, $rewards_text, $rewards_select_frame, $rewards_select, $rewards_graphics, $rewards_holder, $rewards_button, $rewards_btngfx, $confirm, $confirm_frame, $confirm_text, $confirm_button, $confirm_cancel, $rewards_scrollbar);
if_setonvartransmit("speedrunning_reward_shop_showpoints($universe, $rewards_text, $rewards_select_frame, $rewards_select, $rewards_graphics, $rewards_holder, $rewards_button, $rewards_btngfx, $confirm, $confirm_frame, $confirm_text, $confirm_button, $confirm_cancel, $rewards_scrollbar){speedrun_points_currency}", $rewards_text);
~speedrunning_rewards_draw(-1, $universe, $rewards_text, $rewards_select_frame, $rewards_select, $rewards_graphics, $rewards_holder, $rewards_button, $rewards_btngfx, $confirm, $confirm_frame, $confirm_text, $confirm_button, $confirm_cancel, $rewards_scrollbar, 0);
