// 3387
[clientscript,tut2_progressbar_init](component $universe, component $dodger_bottom, component $dodger_top, component $progressbar_container, component $hint_layer, component $progressbar)
~interface_dodger_init($dodger_top, $hint_layer, 65256, ^setpos_abs_left, ^setpos_abs_top, false);
~interface_dodger_init($dodger_bottom, $progressbar_container, setbit(setbit(setbit(52960, 13), 12), 1), ^setpos_abs_centre, ^setpos_abs_bottom, false);
~tut2_progressbar_set($progressbar);
if_setonvartransmit("tut2_progressbar_set($progressbar){tut2_progress_overlay}", $universe);
