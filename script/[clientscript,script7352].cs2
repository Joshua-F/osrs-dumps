// 7352
[clientscript,script7352](obj $obj)
if (~is_prepot_device($obj) = true) {
    mes("Don't be silly.");
} else if (oc_param($obj, param_468) = 44) {
    mes("The chugging barrel can't hold that kind of drink.");
} else if (oc_param($obj, param_468) > 0) {
    mes("The chugging barrel can't hold that kind of potion.");
} else {
    mes("You can't store that in the chugging barrel.");
}
