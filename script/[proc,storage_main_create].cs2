// 1649
[proc,storage_main_create](enum $enum, component $component, obj $obj, string $string)
def_int $int = enum(obj, int, $enum, $obj);
if_setonmouserepeat("storage_main_recreate($enum, $component, $obj, $string, $int, true)", $component);
if_setonmouseleave("storage_main_recreate($enum, $component, $obj, $string, $int, false)", $component);
~storage_main_recreate($enum, $component, $obj, $string, $int, false);
