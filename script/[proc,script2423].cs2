// 2423
[proc,script2423](string $string, component $component)
~stonebutton_draw(true, "<col=ffffff><$string></col>", p12_full, 1, $component);
if_setop(1, removetags($string), $component);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_setontimer(null, $component);
