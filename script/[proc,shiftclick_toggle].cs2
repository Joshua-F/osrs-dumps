// 2359
[proc,shiftclick_toggle](boolean $boolean)
if (~on_mobile = true) {
    setsimulatedshiftactive($boolean);
    setshiftclickenabled(true);
} else {
    setshiftclickenabled($boolean);
    setsimulatedshiftactive(false);
}
~inventory_build(interface_149:com_0, inv_size(inv_93), true, null);
~script2386;
