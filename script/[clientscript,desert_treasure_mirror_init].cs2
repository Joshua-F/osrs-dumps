// 2528
[clientscript,desert_treasure_mirror_init](component $mirror_outer, component $mirror_inner, component $mirror_inner_mobile)
if_setmodeltransparent(true, $mirror_inner);
if_setmodelangle(0, 0, 480, 512, 0, 113, $mirror_outer);
if_setmodelangle(0, 0, 480, 512, 0, 113, $mirror_inner);
if (~on_mobile = true) {
    if_sethide(true, $mirror_inner);
    if_sethide(false, $mirror_inner_mobile);
} else {
    if_sethide(true, $mirror_inner_mobile);
    if_sethide(false, $mirror_inner);
}
