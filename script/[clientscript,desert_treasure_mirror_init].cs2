// 2528
[clientscript,desert_treasure_mirror_init](component $com_2, component $com_3, component $com_1)
if_setmodeltransparent(true, $com_3);
if_setmodelangle(0, 0, 480, 512, 0, 113, $com_2);
if_setmodelangle(0, 0, 480, 512, 0, 113, $com_3);
if (~on_mobile = true) {
    if_sethide(true, $com_3);
    if_sethide(false, $com_1);
} else {
    if_sethide(true, $com_1);
    if_sethide(false, $com_3);
}
