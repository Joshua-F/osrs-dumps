// 5029
[proc,script5029](int $int)(string)
switch_int ($int) {
    case 0 :
        return("He");
    case 1 :
        return("She");
    case 2 :
        return("They");
    case default :
        ~debug_mes_warning("Pronouns not correctly set. Pronouns are set to <tostring($int)> but should be 0, 1 or 2.");
        return("They");
}
