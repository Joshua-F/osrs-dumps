// 6997
[proc,lockpicking_initbutton](component $component, graphic $graphic, string $string)
~lockpicking_setbutton($component, $graphic, $string, false, 0);
if (~on_mobile = false) {
    if_setonmouserepeat("lockpicking_setbutton(event_com, $graphic, $string, true)", $component);
}
if_setonmouseleave("lockpicking_setbutton(event_com, $graphic, $string, false)", $component);
if_setop(1, removetags($string), $component);
if_setontimer(null, $component);
