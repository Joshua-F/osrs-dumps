// 6164
[clientscript,pvpa_legacyduel_options_init](component $universe, component $acceptdecline, component $accept, component $decline, component $acceptwarning)
if_sethide(false, $acceptdecline);
if_settext("", $acceptwarning);
~pvpa_legacyduel_options_drawconfirm($accept);
if_setonvartransmit("pvpa_legacyduel_options_drawconfirm($accept){pvpa_temp_transmit_1}", $universe);
~stonebutton_init("<col=ff0000>Decline</col>", $decline, p12_full, 0);
if_setonop("closebutton_click", $decline);
