// 5131
[clientscript,ge_offers_setup_updatestring](component $component, int $int, boolean $boolean, string $string)
if (cc_find($component, $int) = true) {
    cc_settext("<$string><~ge_offers_setup_customstring>");
    if ($boolean = true) {
        if (%ge_price_custom > 0) {
            cc_setop(1, "<$string><~ge_offers_setup_customstring>");
        } else {
            cc_setop(1, "");
        }
    }
}
