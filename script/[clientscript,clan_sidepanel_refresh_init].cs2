// 4402
[clientscript,clan_sidepanel_refresh_init](component $refresh)
cc_deleteall($refresh);
cc_create($refresh, ^iftype_graphic, 0);
cc_setsize(17, 18, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic("options_icons_small,10");
~clan_sidepanel_refresh_reset($refresh);
if_setop(1, "Refresh", $refresh);
if_setonop("clan_sidepanel_refresh_op(event_op, event_com, cc_getid)", $refresh);
