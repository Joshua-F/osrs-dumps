// 4402
[clientscript,clan_sidepanel_refresh_init](component $com_2)
cc_deleteall($com_2);
cc_create($com_2, ^iftype_graphic, 0);
cc_setsize(17, 18, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic("options_icons_small,10");
~clan_sidepanel_refresh_reset($com_2);
if_setop(1, "Refresh", $com_2);
if_setonop("clan_sidepanel_refresh_op(event_op, event_com, cc_getid)", $com_2);
