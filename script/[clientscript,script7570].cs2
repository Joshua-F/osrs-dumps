// 7570
[clientscript,script7570](int $int, enum $enum)
if (%osm_popout_state = 1 | %osm_popout_state = 2) {
    return;
}
if (%popout_open = $int) {
    return;
}
~toplevel_setup_popout_mobile_layout($enum);
if_setonvartransmit("script7570(%popout_open, $enum){toplevel_temp}", popout:mobile_toggle);
