// 9023
[proc,sailing_locked_mes]()(string)
def_boolean $boolean = false;
def_string $string = "";
$boolean, $string = ~script8948(sailing);
if ($boolean = true) {
    return($string);
}
if (%sailing_intro > 4) {
    return("You need to complete the Pandemonium quest to fully access the Sailing skill.");
}
return("You need to complete the Pandemonium quest to access the Sailing skill.");
