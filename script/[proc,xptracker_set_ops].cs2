// 5461
[proc,xptracker_set_ops](int $int, stat $stat)
def_string $string0 = enum(stat, string, enum_680, $stat);
def_string $string1 = "Pause";
if (~xptracker_get_paused($stat) = 1) {
    $string1 = "Unpause";
}
if (cc_find(interface_729:com_5, $int) = true) {
    cc_setopbase("<col=ff9040><$string0> Tracker</col>");
    cc_setop(6, "Reset");
    cc_setop(7, "Reset all but");
    cc_setop(8, "Close");
    cc_setop(9, "Close all but");
    cc_setop(10, $string1);
    cc_setonop("xptracker_ops(event_op, $stat)");
}
