// 4704
[proc,helper_generic_set_size](int $int0, int $int1)
def_enum $enum = ~toplevel_getcomponents;
def_component $component = enum(component, component, $enum, interface_161:com_12);
if ($component ! null) {
    if (~helper_generic_test_bit(0) = ^true) {
        $int0 = if_getwidth($component);
    }
    if (~helper_generic_test_bit(1) = ^true) {
        $int1 = if_getheight($component);
    }
    if_setsize($int0, $int1, ^setsize_abs, ^setsize_abs, $component);
}
