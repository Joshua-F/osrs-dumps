} else if ($int0 = 0) {
    $graphic4, $graphic5 = "tabs_modal_short,2", "tabs_modal_short,3";
} else if ($int0 = 2) {
    $graphic4, $graphic5 = "tabs_modal_short,4", "tabs_modal_short,5";
