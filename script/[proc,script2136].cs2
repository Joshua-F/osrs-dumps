// 2136
[proc,script2136](component $component0, string $string, component $component1)
~script2138(false, $component0, $string);
if_setonmouserepeat("script2137(true, $component0, $string)", $component0);
if_setonmouseleave("script2137(false, $component0, $string)", $component0);
if_setop(1, $string, $component0);
if_setonop("script2139(event_op, $component1)", $component0);
