// 2084
[proc,deadman_finallocation](component $component)
def_string $string = "North of Daimon's Crater";
if (~private_event_world = 4) {
    $string = "Falador Castle Courtyard";
} else if (~private_event_world = 1) {
    $string = "Fountain of Rune";
} else if (%deadman_tournament_finalarea = 2) {
    $string = "Demonic Ruins (Annakarl)";
}
if (~wildwars_world = true) {
    if_settext("The Graveyard of Shadows", $component);
} else {
    if_settext($string, $component);
}
