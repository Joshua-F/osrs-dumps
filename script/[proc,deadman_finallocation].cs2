// 2084
[proc,deadman_finallocation](component $component)
def_string $string = "North of Falador";
if (%varplayerbit_1497 = 2) {
    $string = "Demonic Ruins (Annakarl)";
}
if (~wildwars_world = true) {
    if_settext("The Graveyard of Shadows", $component);
} else {
    if_settext($string, $component);
}
