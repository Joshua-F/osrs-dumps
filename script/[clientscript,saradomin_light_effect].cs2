// 1068
[clientscript,saradomin_light_effect]
def_enum $enum = ~toplevel_getcomponents;
if ($enum = null) {
    return;
}
def_component $component = enum(component, component, $enum, toplevel_osrs_stretch:overlay_atmosphere);
if ($component = null) {
    return;
}
cc_deleteall($component);
cc_create($component, ^iftype_model, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setmodel(model_29403);
.cc_create($component, ^iftype_rectangle, 1);
.cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
.cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
.cc_setcolour(^white);
.cc_setfill(true);
cc_setontimer("saradomin_light_effect_update(event_com, event_comsubid, .cc_getid, clientclock)");
~saradomin_light_effect_update($component, 0);
