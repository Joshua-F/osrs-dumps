// 2257
[clientscript,music_init_counter](component $component)
if_setontimer(null, $component);
def_dbrow $dbrow = null;
def_int $int2 = 0;
def_int $int3 = db_find(dbtable_44:col8, false);
def_int $int4 = 0;
while ($int4 < $int3) {
    $dbrow = db_find_get($int4);
    if (~music_isunlocked($dbrow) = true) {
        $int2 = calc($int2 + 1);
    }
    $int4 = calc($int4 + 1);
}
if_settext("<~tostring_spacer(~min($int2, $int3), ",")> / <~tostring_spacer($int3, ",")>", $component);
