// 869
[proc,hud_clamp](component $component)
def_enum $enum = ~toplevel_getcomponents;
if ($enum = null) {
    return;
}
def_int $int2 = enum(enum, int, enum_1960, $enum);
def_int $int3 = enum(enum, int, enum_1961, $enum);
if_setposition($int2, $int3, ^setpos_abs_left, ^setpos_abs_top, $component);
if_setsize(calc($int2 + enum(enum, int, enum_1135, $enum)), calc($int3 + enum(enum, int, enum_1136, $enum)), ^setsize_minus, ^setsize_minus, $component);
