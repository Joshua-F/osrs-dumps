// 3120
[clientscript,poh_board_location_filter_clicked](component $location_filter, component $location_toggle, component $location_text)
if (%poh_board_filtered = 1) {
    %poh_board_filtered = 0;
} else {
    %poh_board_filtered = 1;
}
~poh_board_location_filter_activate($location_filter, $location_toggle, $location_text);
