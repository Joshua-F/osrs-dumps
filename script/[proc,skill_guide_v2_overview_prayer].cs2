// 9166
[proc,skill_guide_v2_overview_prayer](component $component)
~script9182($component, "", "Your Prayer level determines which prayers you can activate and for how long. Prayers provide powerful combat effects from large bonuses to combat skills to negating all damage of a certain type. Use the tabs on the left to see what level is required to activate certain prayers. The required Prayer level and the effects of each prayer can also be viewed in the ||side_panel:5::<5>::Prayer panel::.||<"||::p||">To level your Prayer, bury the bones and scatter the ashes of defeated enemies. Bones can also be offered at special ||::<101>::Altars||, such as the Gilded Altar in a player's house, for bonus XP.<"||::p||">||::hl||<"To activate a Prayer"><"||::/hl||">, open the ||side_panel:5::<5>::Prayer panel|| and <~text_device("click", "tap")> a prayer you have the level for. While active, prayers drain your Prayer points over time. Equipment with a Prayer bonus can be equipped to reduce the drain rate.<"||::p||">||::hl||<"To restore Prayer points"><"||::/hl||"> in combat, you can drink certain potions such as a Prayer Potion. Outside of combat, Prayer points can be fully restored by praying at an ||::<101>::Altar||.");
~script9182($component, "Getting Started", "To get started, bury the bones of defeated enemies to gain Prayer XP and activate prayers during combat for powerful bonuses. Cows and Goblins east of Lumbridge are a good place to start.<"||::p||">Some useful prayers to aim for are the Protection prayers which prevent certain types of damage while active. For example, Protect from Melee prevents you taking damage from most melee attacks.");
def_stringarray $stringarray = array_create(string, 1, -1);
$stringarray(0) = "||::hl||<"||::">300<"::Combat:::||"><"||::/hl||"> Prayers aid in combat and bones from defeated enemies can be buried for Prayer XP.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
