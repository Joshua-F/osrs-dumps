// 3779
[clientscript,gnome_cuisine_init](component $frame, component $confirmation, component $cuisine, component $cuisine_clickzone, component $ingredients, component $aluft_balck_rect)
cc_deleteall($confirmation);
def_enum $enum = ~gnome_cuisine_enum;
~steelborder($frame, ~gnome_cuisine_title, 0);
if_setonmouseover("gnome_cuisine_confirmation_in($confirmation)", $confirmation);
if_setonmouseleave("gnome_cuisine_confirmation_out($confirmation)", $confirmation);
if_setonvartransmit("gnome_cuisine_update_if($cuisine, $cuisine_clickzone, $ingredients, $aluft_balck_rect, $enum){canoeing_menu, gnome_cuisine_var}", $aluft_balck_rect);
if_setoninvtransmit("gnome_cuisine_update_if($cuisine, $cuisine_clickzone, $ingredients, $aluft_balck_rect, $enum){inv}", $aluft_balck_rect);
def_int $int = ~v2_stone_button_filled($confirmation);
cc_create($confirmation, ^iftype_text, $int);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0xff981f);
cc_settextfont(p12_full);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 10);
cc_settext("Create");
~gnome_show_cuisine($cuisine, $cuisine_clickzone, $ingredients, $aluft_balck_rect, $enum);
