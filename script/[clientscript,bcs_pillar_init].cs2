// 4562
[clientscript,bcs_pillar_init](component $rotate_clockwise, component $rotate_anticlockwise, component $confirm, component $emblem)
~bcs_pillar_initbutton_rotate($rotate_clockwise, "arrows_curved,0", "Rotate Clockwise", 1, $emblem);
~bcs_pillar_initbutton_rotate($rotate_anticlockwise, "arrows_curved,3", "Rotate Anticlockwise", -1, $emblem);
~bcs_pillar_initbutton_confirm($confirm, null, "Confirm");
if_setonvartransmit("script6031($emblem){bcs_primary}", $emblem);
~script6032($emblem);
