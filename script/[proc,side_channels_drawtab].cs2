// 4477
[proc,side_channels_drawtab](component $component, graphic $graphic1, graphic $graphic2)
if (cc_find($component, 0) = true) {
    cc_setgraphic($graphic1);
}
if (cc_find($component, 1) = true) {
    cc_setgraphic($graphic1);
}
if (cc_find($component, 2) = true) {
    cc_setgraphic($graphic2);
}
