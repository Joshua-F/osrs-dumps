// 4240
[proc,script4240](component $component, int $int1, int $int2, int $int3, int $int4)
if (~on_mobile = false) {
    if_setonmouserepeat("clan_members_filter_hover(true, event_com, $int1, $int2, $int3)", $component);
}
if_setonmouseleave("clan_members_filter_hover(false, event_com, $int1, $int2, $int3)", $component);
if_setonop("clan_members_filter_op(event_op, event_com, $int1, $int2, $int3, $int4)", $component);
