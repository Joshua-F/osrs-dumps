// 6546
[proc,script6546](entityoverlay $entityoverlay, npc_uid $npc_uid, int $int2, int $int3)
if ($entityoverlay = null) {
    return;
}
highlight_npc_off($npc_uid, $int2, 9);
cc_deleteall_entityoverlay($entityoverlay);
if (~script6545($int3) ! $npc_uid) {
    return;
}
if (%cluehelper_infobox_clue ! %cluehelper_npc_current_clue) {
    return;
}
~loadnpc_cluehelper_kill_target_overlay($entityoverlay, $npc_uid, $int2);
