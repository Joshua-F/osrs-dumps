// 1673
[clientscript,displayname_button_op](int $int, component $component, string $string)
if ($int ! 1) {
    return;
}
sound_synth(synth_2266, 1, 0);
~displayname_button_draw($component, $string, true);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_setontimer("displayname_button_reset(event_com, $string, calc(clientclock + 40))", $component);
