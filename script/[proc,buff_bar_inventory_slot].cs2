// 5341
[proc,buff_bar_inventory_slot](struct $struct)(int, obj, boolean)
def_inv $inv = struct_param($struct, param_1283);
if ($inv = null) {
    return(0, null, false);
}
def_obj $obj = inv_getobj($inv, struct_param($struct, param_1351));
if ($obj = null) {
    return(0, null, false);
}
def_int $int = inv_getnum($inv, struct_param($struct, param_1351));
if ($int <= 0) {
    return(0, null, false);
}
if (struct_param($struct, param_1352) = true & oc_stackable($obj) = false) {
    return(0, null, false);
}
return($int, $obj, true);
