// 1035
[clientscript,xpdrops_setup_display_dropdown_hover](boolean $boolean, component $component, int $int2, int $int3, int $rgb)
if (cc_find($component, $int2) = true & .cc_find($component, $int3) = true) {
    if ($boolean = true) {
        cc_setcolour(0xffb83f);
        .cc_sethide(false);
        .cc_setposition(cc_getx, cc_gety, ^setpos_abs_left, ^setpos_abs_top);
    } else {
        cc_setcolour($rgb);
        .cc_sethide(true);
    }
}
