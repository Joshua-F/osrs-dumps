// 3956
[proc,settings_op_checker](struct $struct)(boolean)
def_boolean $boolean = ~settings_dependency_checker($struct);
~settings_op_sound($boolean);
def_string $string = "";
if ($boolean = false) {
    if (~on_mobile = true & string_length(struct_param($struct, param_1117)) > 0) {
        $string = struct_param($struct, param_1117);
    } else {
        $string = struct_param($struct, param_1116);
    }
    mes($string);
}
return($boolean);
