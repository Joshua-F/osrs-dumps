// 884
[clientscript,castlewars_hud_init](component $dodger_side, component $dodger_top, component $dodger_timer, component $sidebox, component $content_top, component $timer)
~interface_dodger_init($dodger_top, $content_top, clearbit(65256, 7), ^setpos_abs_left, ^setpos_abs_top, true);
~interface_dodger_init($dodger_side, $sidebox, 65256, ^setpos_abs_left, ^setpos_abs_top, true);
~interface_dodger_init($dodger_timer, $timer, setbit(setbit(0, 12), 13), ^setpos_abs_right, ^setpos_abs_bottom, false);
