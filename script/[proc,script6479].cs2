    .cc_settrans(225);
    .cc_create($component0, ^iftype_graphic, 1);
    .cc_setposition(0, calc($int2 + cc_getheight / 2 - 7), ^setpos_abs_right, ^setpos_abs_top);
    .cc_setsize(14, 14, ^setsize_abs, ^setsize_abs);
    .cc_setgraphic("worldmap_marker_mini,2");
}
