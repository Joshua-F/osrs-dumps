// 4406
[clientscript,clan_events_init](component $universe, component $frame, component $list_contents, component $list_scrollbar, component $exit, component $edit, component $create)
~scrollbar_vertical($list_scrollbar, $list_contents, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~stonebutton_init("<col=ff0000>Back</col>", $exit, p12_full, 0);
def_int $int7 = %clan_editing_permitted;
if_setonop("opsound(event_op, 2)", $exit);
if (%clan_editing_permitted = 1) {
    ~stonebutton_init("<col=ff0000>Finished</col>", $edit, p12_full, 0);
} else if (~clan_events_has_permission(chat_playername) = 1) {
    ~stonebutton_init("<col=0dc10d>Edit Mode</col>", $edit, p12_full, 0);
} else {
    ~stonebutton_init("<col=9f9f9f>Edit Mode</col>", $edit, p12_full, 0);
}
if_setonop("opsound(event_op, 2)", $edit);
if ($int7 = 1) {
    ~stonebutton_init("<col=0dc10d>Create</col>", $create, p12_full, 0);
} else {
    ~stonebutton_init("<col=9f9f9f>Create</col>", $create, p12_full, 0);
}
if_setonop("opsound(event_op, 2)", $create);
def_int $int8 = ~steelborder($frame, "", 0);
if (%clan_affinitystatus = 3 & activeclansettings_find_affined(^clantype_clan) = true & cc_find($frame, $int8) = true) {
    cc_settext("<activeclansettings_getclanname>: Events");
}
def_int $int9 = 16384;
def_int $int10 = 70;
cc_deleteall($list_contents);
def_int $int11 = 0;
def_int $int12 = 0;
while ($int12 < 10) {
    cc_create($list_contents, ^iftype_rectangle, $int11);
    $int11 = calc($int11 + 1);
    cc_sethide(true);
    cc_setsize($int9, $int10, ^setsize_rel, ^setsize_abs);
    cc_setfill(true);
    cc_setcolour(^white);
    if ($int7 = 1) {
        cc_setop(1, "Edit");
    }
    $int12 = calc($int12 + 1);
}
$int12 = 0;
while ($int12 < 10) {
    cc_create($list_contents, ^iftype_text, $int11);
    $int11 = calc($int11 + 1);
    cc_sethide(true);
    cc_setsize($int9, $int10, ^setsize_rel, ^setsize_abs);
    cc_setcolour(0xff981f);
    cc_settextfont(p12_full);
    cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
    cc_settextshadow(true);
    $int12 = calc($int12 + 1);
}
cc_create($list_contents, ^iftype_text, $int11);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setcolour(0xffb83f);
cc_settextfont(p12_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_settext("No events to show.");
