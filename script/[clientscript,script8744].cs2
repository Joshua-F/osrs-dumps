// 8744
[clientscript,script8744](int $int0, component $component, int $int2)
if (cc_find($component, $int0) = true) {
    $int2 = calc($int2 + 650);
    if ($int2 > 65535) {
        $int2 = calc($int2 - 65535);
    }
    cc_set2dangle($int2);
    cc_setontimer("script8744($int0, $component, $int2)");
}
