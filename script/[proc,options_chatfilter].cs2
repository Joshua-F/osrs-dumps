// 374
[proc,options_chatfilter](component $component0, component $component1)
def_string $string = "Profanity filter<br>(currently on)";
if (%varplayer_1074 <= 0) {
    if_setgraphic("options_boxes,1", $component0);
} else {
    $string = "Profanity filter<br>(currently off)";
    if_setgraphic("options_boxes,0", $component0);
}
if_setonmouserepeat("tooltip_mouserepeat($component0, -1, $component1, $string, 25, 190)", $component0);
%varclient_2 = 0;
