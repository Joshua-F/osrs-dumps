// 2160
[proc,fossil_mushtree_button_init](component $component, string $string)
~v2_stone_button($component);
if_setonmouserepeat("v2_stone_button_in($component)", $component);
if_setonmouseleave("v2_stone_button($component)", $component);
if_setonkey("fossil_mushtree_button_keypress(event_keychar, $component, $string)", $component);
if_setontimer(null, $component);
