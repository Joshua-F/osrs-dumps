// 2715
[clientscript,1v1arena_hud_resetbutton](component $component, int $int1, int $int2)
if (clientclock < $int2) {
    return;
}
if (cc_find($component, $int1) = true) {
    cc_setcolour(0xff981f);
    if_setonmouserepeat("cc_colour_swapper(event_com, cc_getid, ^white)", $component);
    if_setonmouseleave("cc_colour_swapper(event_com, cc_getid, 0xff981f)", $component);
    if_setonop("1v1arena_hud_button(event_op, $component, cc_getid)", $component);
}
if_setontimer(null, $component);
