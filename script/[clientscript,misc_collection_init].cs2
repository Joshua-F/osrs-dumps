// 492
[clientscript,misc_collection_init](component $universe, component $items, component $scrollbar)
~scrollbar_vertical($scrollbar, $items, "scrollbar_parchment_dragger_v2,3", "scrollbar_parchment_dragger_v2,0", "scrollbar_parchment_dragger_v2,1", "scrollbar_parchment_dragger_v2,2", "scrollbar_parchment_v2,0", "scrollbar_parchment_v2,1");
def_int $int3 = inv_size(misc_resources_collected);
def_int $int4 = calc(if_getwidth($items) / 9 - 36);
def_int $int5 = calc($int4 / 2);
~misc_collection_draw($int3, $int4, $int5, $items, $scrollbar);
if_setoninvtransmit("misc_collection_draw($int3, $int4, $int5, $items, $scrollbar){misc_resources_collected}", $universe);
