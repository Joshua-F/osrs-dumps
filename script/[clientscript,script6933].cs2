// 6933
[clientscript,script6933](int $int, int $rgb)
if (cc_find(fsw_optin:fs_info_more_button, calc($int + 1)) = true) {
    cc_setcolour($rgb);
}
if (cc_find(fsw_optin:fs_info_more_button, calc($int + 11)) = true) {
    cc_setcolour($rgb);
}
if (cc_find(fsw_optin:fs_info_more_button, calc($int + 12)) = true) {
    cc_setcolour($rgb);
}
if_setcolour($rgb, fsw_optin:fs_info_more_text);
