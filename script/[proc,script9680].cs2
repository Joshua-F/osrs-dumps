// 9680
[proc,script9680](component $component)
cc_create($component, ^iftype_rectangle, 0);
cc_settrans(255);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize(1, 1, ^setsize_abs, ^setsize_abs);
cc_setonstattransmit("herbiboar_helper_stattransmit($component, stat(hunter), stat(herblore)){hunter, herblore}");
