// 2710
[clientscript,1v1arena_results_init](component $clear)
def_string $string = "Clear";
cc_deleteall($clear);
def_int $int = 0;
.cc_create($clear, ^iftype_rectangle, $int);
$int = calc($int + 1);
.cc_setsize(0, 0, ^setsize_abs, ^setsize_abs);
.cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
.cc_sethide(true);
$int = ~options_button_off($clear, $int);
cc_create($clear, ^iftype_text, $int);
$int = calc($int + 1);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settextshadow(true);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settext($string);
if_setop(1, $string, $clear);
cc_setcolour(0xff981f);
if_setonmouserepeat("cc_colour_swapper(event_com, cc_getid, 16777215)", $clear);
if_setonmouseleave("cc_colour_swapper(event_com, cc_getid, 16750623)", $clear);
if_setonop("1v1arena_clear_opbutton($clear, .cc_getid, cc_getid)", $clear);
if_setontimer(null, $clear);
