// 749
[clientscript,tutorial_progressbar_init](component $universe, component $dodger_top, component $dodger_bottom, component $hint_layer, component $progressbar_container, component $progressbar)
~interface_dodger_init($dodger_top, $hint_layer, 65256, ^setpos_abs_left, ^setpos_abs_top, false);
~interface_dodger_init($dodger_bottom, $progressbar_container, setbit(setbit(setbit(52960, 13), 12), 1), ^setpos_abs_centre, ^setpos_abs_bottom, false);
~tutorial_progressbar_set($progressbar);
if_setonvartransmit("tutorial_progressbar_set($progressbar){tutorial_progress_overlay}", $universe);
