// 1225
[clientscript,zeah_overlay_shrink_it](component $component)
def_int $int1 = ~max(calc(if_getwidth($component) - 5), 120);
def_int $int2 = ~max(calc(if_getheight($component) - 2), 60);
if_setsize($int1, $int2, ^setsize_abs, ^setsize_abs, $component);
if ($int1 <= 120 & $int2 <= 60) {
    if_setontimer(null, $component);
}
