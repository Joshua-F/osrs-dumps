// 5301
[clientscript,side_channels_large_init](component $universe, component $tab_0, component $tab_1, component $tab_2, component $tab_3, component $tab_gim, component $tab_line)
~side_channels_tabinit($tab_0, 0);
~side_channels_tabinit($tab_1, 1);
~side_channels_tabinit($tab_2, 2);
~side_channels_tabinit($tab_3, 3);
if (%ironman = 4) {
    ~side_channels_tabinit($tab_gim, 4);
} else if (%ironman = 6) {
    ~side_channels_tabinit($tab_gim, 6);
} else {
    ~side_channels_tabinit($tab_gim, 5);
}
~side_channels_setall($tab_0, $tab_1, $tab_2, $tab_3, $tab_gim, $tab_line);
if_setonvartransmit("side_channels_setall($tab_0, $tab_1, $tab_2, $tab_3, $tab_gim, $tab_line){chat_filter_clan, chat_filter_assist}", $universe);
