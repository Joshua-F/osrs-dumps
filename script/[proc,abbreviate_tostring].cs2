// 7396
[proc,abbreviate_tostring](int $int0, int $int1, int $int2, string $string)(string)
if ($int0 >= max(1000000, $int2)) {
    return("<~tostring_spacer(calc($int0 / 1000000), $string)>m");
}
if ($int0 >= max(1000, $int1)) {
    return("<~tostring_spacer(calc($int0 / 1000), $string)>k");
}
return(~tostring_spacer($int0, $string));
