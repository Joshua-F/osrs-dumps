// 3148
[proc,script3148](component $component)
def_int $int = scale(60, 100, calc(%varplayerbit_9500 * 8));
~script3150($int, $component);
if ($int > 0) {
    if_setontimer("script3149(calc(clientclock + 50), calc($int - 1), $component)", $component);
} else {
    if_setontimer(null, $component);
}
