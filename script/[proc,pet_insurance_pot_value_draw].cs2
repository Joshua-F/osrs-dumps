// 6128
[proc,pet_insurance_pot_value_draw](component $component)
if (%pet_insurance_credits_processed = 0 & %pet_insurance_discounted = 0) {
    if_settext("None", $component);
    if_setcolour(0x9f9f9f, $component);
    return;
}
def_string $string = "";
if (%pet_insurance_discounted = 1) {
    $string = ".5";
}
if_settext("<tostring(%pet_insurance_credits_processed)><$string>", pet_insurance:insurance_credits_value);
if_setcolour(^white, $component);
