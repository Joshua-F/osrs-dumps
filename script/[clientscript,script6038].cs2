// 6038
[clientscript,script6038](component $tint_box)
if (if_gettrans($tint_box) > %bcs_overlay_fade) {
    if_settrans(~max(50, calc(if_gettrans($tint_box) - 1)), $tint_box);
} else if (if_gettrans($tint_box) < %bcs_overlay_fade) {
    if_settrans(~min(255, calc(if_gettrans($tint_box) + 1)), $tint_box);
}
