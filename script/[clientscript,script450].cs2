// 450
[clientscript,script450](component $com_26, component $com_25, int $int)
if ($int = 1 | calc(clientclock % 100) = 0) {
    if (~high_risk_world = true) {
        if_settrans(0, $com_26);
        if_settrans(100, $com_25);
    } else {
        if_settrans(255, $com_26);
        if_settrans(0, $com_25);
    }
}
