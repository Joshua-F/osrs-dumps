// 2505
[proc,account_inbox_update]
def_component $com_43 = interface_109:com_43;
def_component $com_48 = interface_109:com_48;
def_component $com_46 = interface_109:com_46;
def_component $com_47 = interface_109:com_47;
if (%varclient_228 = true) {
    if_settext("Email: <col=ff0000>Unlinked</col>", $com_43);
    if_settext("Link Email", $com_48);
    if_setgraphic("acc_man_icons,4", $com_46);
    if_setgraphic("acc_man_icons,4", $com_47);
    return;
}
def_string $string = "Inbox: 0 unread messages";
if (%varplayer_1781 > 9999) {
    $string = "Inbox: 9999+ unread messages";
} else if (%varplayer_1781 = 1) {
    $string = "Inbox: 1 unread message";
} else {
    $string = "Inbox: <tostring(%varplayer_1781)> unread messages";
}
if_settext($string, $com_43);
if_settext("View Inbox", $com_48);
if_setgraphic("acc_man_icons,2", $com_46);
if_setgraphic("acc_man_icons,2", $com_47);
