// 4040
[clientscript,bolt_pouch_init](component $current_bolt, component $bolt_1, component $bolt_2, component $bolt_3, component $bolt_4, component $current_bolt_holder, component $bolt_1_holder, component $bolt_2_holder, component $bolt_3_holder, component $bolt_4_holder, component $stored_bolts, component $close)
~bolt_pouch_setup_entry(0, $current_bolt, $current_bolt_holder, $stored_bolts);
if_setoninvtransmit("bolt_pouch_setup_entry(0, $current_bolt, $current_bolt_holder, $stored_bolts){worn}", $current_bolt_holder);
~bolt_pouch_setup_entry(1, $bolt_1, $bolt_1_holder, $stored_bolts);
if_setonvartransmit("bolt_pouch_setup_entry(1, $bolt_1, $bolt_1_holder, $stored_bolts){xbows_pouch1, xbows_pouch_number1}", $bolt_1_holder);
~bolt_pouch_setup_entry(2, $bolt_2, $bolt_2_holder, $stored_bolts);
if_setonvartransmit("bolt_pouch_setup_entry(2, $bolt_2, $bolt_2_holder, $stored_bolts){xbows_pouch1, xbows_pouch_number1}", $bolt_2_holder);
~bolt_pouch_setup_entry(3, $bolt_3, $bolt_3_holder, $stored_bolts);
if_setonvartransmit("bolt_pouch_setup_entry(3, $bolt_3, $bolt_3_holder, $stored_bolts){xbows_pouch2, xbows_pouch_number2}", $bolt_3_holder);
~bolt_pouch_setup_entry(4, $bolt_4, $bolt_4_holder, $stored_bolts);
if_setonvartransmit("bolt_pouch_setup_entry(4, $bolt_4, $bolt_4_holder, $stored_bolts){xbows_pouch2, xbows_pouch_number2}", $bolt_4_holder);
if_setopkey(1, ^key_escape, 0, $close);
