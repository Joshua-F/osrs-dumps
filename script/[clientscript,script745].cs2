// 745
[clientscript,script745]
def_enum $enum = ~toplevel_getcomponents;
if ($enum = null) {
    return;
}
def_component $component = enum(component, component, $enum, interface_161:com_6);
if ($component = null) {
    return;
}
cc_deleteall($component);
cc_create($component, ^iftype_text, 0);
cc_setsize(0, 40, ^setsize_minus, ^setsize_abs);
cc_setposition(0, -120, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0x005014);
cc_settextfont(quill_oblique_large);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settext("THE");
cc_setontimer("script1340(event_com, event_comsubid, calc(clientclock + 40))");
