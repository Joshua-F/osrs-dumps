// 4293
[proc,script4293](component $component, int $int1, int $int2, int $int3)
if_setonop("clan_info_editable_op(event_op, event_com, $int1, $int2, $int3)", $component);
if (~on_mobile = false) {
    if_setonmouserepeat("clan_info_editable_hover(true, event_com, $int1, $int2, $int3)", $component);
}
if_setonmouseleave("clan_info_editable_hover(false, event_com, $int1, $int2, $int3)", $component);
