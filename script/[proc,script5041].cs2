// 5041
[proc,script5041](int $int)(string)
switch_int ($int) {
    case 0 :
        return("His");
    case 1 :
        return("Hers");
    case 2 :
        return("Theirs");
    case default :
        ~debug_mes_warning("Pronouns not correctly set. Pronouns are set to <tostring($int)> but should be 0, 1 or 2.");
        return("Theirs");
}
