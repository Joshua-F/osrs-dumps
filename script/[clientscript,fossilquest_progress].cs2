// 1994
[clientscript,fossilquest_progress](component $progress_filled, component $progress_empty, component $progress_bar)
def_int $int = interpolate(0, if_getwidth($progress_bar), 0, 100, %fossilquest_sailing_progress);
if_setsize($int, 0, ^setsize_abs, ^setsize_minus, $progress_filled);
if_setsize(calc(if_getwidth($progress_bar) - $int), 0, ^setsize_abs, ^setsize_minus, $progress_empty);
if ($int < calc(if_getwidth($progress_bar) / 4)) {
    if_setcolour(0xee1111, $progress_filled);
} else if ($int < calc(if_getwidth($progress_bar) / 2)) {
    if_setcolour(0xeeee11, $progress_filled);
} else {
    if_setcolour(0x11ee11, $progress_filled);
}
