[clientscript,my2arm_boatride_init](component $universe, component $dodger, component $canvas, component $map, component $blackout)
~interface_dodger_init($dodger, $canvas, setbit(setbit(setbit(0, 3), 13), 12), ^setpos_abs_left, ^setpos_abs_top, true);
~my2arm_boatride_setanim($map, $blackout);
if_setonvartransmit("my2arm_boatride_setanim($map, $blackout){journey_number}", $universe);
