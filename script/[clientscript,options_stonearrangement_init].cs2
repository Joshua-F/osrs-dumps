// 848
[clientscript,options_stonearrangement_init](component $com_19, component $com_21, component $com_22)
if_setonmouseleave("deltooltip($com_22)", $com_19);
if_setop(1, "Side-stones arrangement", $com_19);
if_setop(1, "Hotkeys Behaviour", $com_21);
~options_gfx_togglebox($com_21, "Side-panels...", "Can be closed by the hotkeys.", "In resizable mode, if the stone buttons are arranged along the bottom of the screen, should it be possible to shut a side-panel by pressing its hotkey?", $com_22);
~options_stonearrangement($com_19, $com_21, $com_22);
if_setonvartransmit("options_stonearrangement_resynch($com_19, $com_21, $com_22){varplayer_1055}", $com_19);
if_setonop("options_stonearrangement_op(event_op, false, $com_19, $com_21, $com_22)", $com_19);
