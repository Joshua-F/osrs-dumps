// 848
[clientscript,options_stonearrangement_init](component $com_21, component $com_23, component $com_24)
if_setonmouseleave("deltooltip($com_24)", $com_21);
if_setop(1, "Side-stones arrangement", $com_21);
if_setop(1, "Hotkeys Behaviour", $com_23);
~options_gfx_togglebox($com_23, "Side-panels...", "Can be closed by the hotkeys.", "In resizable mode, if the stone buttons are arranged along the bottom of the screen, should it be possible to shut a side-panel by pressing its hotkey?", $com_24);
~options_stonearrangement($com_21, $com_23, $com_24);
if_setonvartransmit("options_stonearrangement_resynch($com_21, $com_23, $com_24){varplayer_1055}", $com_21);
if_setonop("options_stonearrangement_op(event_op, false, $com_21, $com_23, $com_24)", $com_21);
