// 848
[clientscript,options_stonearrangement_init](component $com_15, component $com_17, component $com_18)
if_setonmouseleave("deltooltip($com_18)", $com_15);
if_setop(1, "Side-stones arrangement", $com_15);
if_setop(1, "Hotkeys Behaviour", $com_17);
~options_gfx_togglebox($com_17, "Side-panels...", "Can be closed by the hotkeys.", "In resizable mode, if the stone buttons are arranged along the bottom of the screen, should it be possible to shut a side-panel by pressing its hotkey?", $com_18);
~options_stonearrangement($com_15, $com_17, $com_18);
if_setonvartransmit("options_stonearrangement_resynch($com_15, $com_17, $com_18){varplayer_1055}", $com_15);
if_setonop("options_stonearrangement_op(event_op, false, $com_15, $com_17, $com_18)", $com_15);
