// 848
[clientscript,options_stonearrangement_init](component $com_25, component $com_27, component $com_28)
if_setonmouseleave("deltooltip($com_28)", $com_25);
if_setop(1, "Side-stones arrangement", $com_25);
if_setop(1, "Hotkeys Behaviour", $com_27);
~options_gfx_togglebox($com_27, "Side-panels...", "Can be closed by the hotkeys.", "In resizable mode, if the stone buttons are arranged along the bottom of the screen, should it be possible to shut a side-panel by pressing its hotkey?", $com_28);
~options_stonearrangement($com_25, $com_27, $com_28);
if_setonvartransmit("options_stonearrangement_resynch($com_25, $com_27, $com_28){varplayer_1055}", $com_25);
if_setonop("options_stonearrangement_op(event_op, false, $com_25, $com_27, $com_28)", $com_25);
