// 848
[clientscript,options_stonearrangement_init](component $com_23, component $com_25, component $com_26)
if_setonmouseleave("deltooltip($com_26)", $com_23);
if_setop(1, "Side-stones arrangement", $com_23);
if_setop(1, "Hotkeys Behaviour", $com_25);
~options_gfx_togglebox($com_25, "Side-panels...", "Can be closed by the hotkeys.", "In resizable mode, if the stone buttons are arranged along the bottom of the screen, should it be possible to shut a side-panel by pressing its hotkey?", $com_26);
~options_stonearrangement($com_23, $com_25, $com_26);
if_setonvartransmit("options_stonearrangement_resynch($com_23, $com_25, $com_26){varplayer_1055}", $com_23);
if_setonop("options_stonearrangement_op(event_op, false, $com_23, $com_25, $com_26)", $com_23);
