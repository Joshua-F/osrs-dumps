// 2013
[clientscript,fossil_pool_init](component $small_gfx, component $small_text, component $medium_gfx, component $medium_text, component $large_gfx, component $large_text, component $plant_gfx, component $plant_text, component $rare_gfx, component $rare_text, component $unid_gfx, component $unid_text, component $calcium_text, component $phosphate_text)
if_setobject_nonum(fossil_small_1, 0, $small_gfx);
if_setobject_nonum(fossil_medium_1, 0, $medium_gfx);
if_setobject_nonum(fossil_large_1, 0, $large_gfx);
if_setobject_nonum(fossil_rare_1, 0, $rare_gfx);
if_setobject_nonum(fossil_plant_1, 0, $plant_gfx);
if_setobject_nonum(fossil_small_unid, 0, $unid_gfx);
def_int $int14 = calc(inv_total(inv, fossil_small_1) + inv_total(inv, fossil_small_2) + inv_total(inv, fossil_small_3) + inv_total(inv, fossil_small_4) + inv_total(inv, fossil_small_5));
def_int $int15 = calc(inv_total(inv, fossil_medium_1) + inv_total(inv, fossil_medium_2) + inv_total(inv, fossil_medium_3) + inv_total(inv, fossil_medium_4) + inv_total(inv, fossil_medium_5));
def_int $int16 = calc(inv_total(inv, fossil_large_1) + inv_total(inv, fossil_large_2) + inv_total(inv, fossil_large_3) + inv_total(inv, fossil_large_4) + inv_total(inv, fossil_large_5));
def_int $int17 = calc(inv_total(inv, fossil_plant_1) + inv_total(inv, fossil_plant_2) + inv_total(inv, fossil_plant_3) + inv_total(inv, fossil_plant_4) + inv_total(inv, fossil_plant_5));
def_int $int18 = calc(inv_total(inv, fossil_rare_1) + inv_total(inv, fossil_rare_2) + inv_total(inv, fossil_rare_3) + inv_total(inv, fossil_rare_4) + inv_total(inv, fossil_rare_5));
def_int $int19 = inv_total(inv, fossil_small_unid);
def_int $int20 = inv_total(inv, fossil_medium_unid);
def_int $int21 = inv_total(inv, fossil_large_unid);
def_int $int22 = inv_total(inv, fossil_rare_unid);
def_int $int23 = calc($int19 + $int20 + $int21 + $int22);
def_int $int24 = inv_total(inv, fossil_calcite);
def_int $int25 = inv_total(inv, fossil_pyrophosphite);
if ($int14 > 0 | $int19 > 0) {
    if_setcolour(^green, $small_text);
} else {
    if_setcolour(0xff981f, $small_text);
}
if ($int15 > 0 | $int20 > 0) {
    if_setcolour(^green, $medium_text);
} else {
    if_setcolour(0xff981f, $medium_text);
}
if ($int16 > 0 | $int21 > 0) {
    if_setcolour(^green, $large_text);
} else {
    if_setcolour(0xff981f, $large_text);
}
if ($int18 > 0 | $int22 > 0) {
    if_setcolour(^green, $rare_text);
} else {
    if_setcolour(0xff981f, $rare_text);
}
if ($int17 > 0) {
    if_setcolour(^green, $plant_text);
} else {
    if_setcolour(0xff981f, $plant_text);
}
if ($int19 > 0 | $int20 > 0 | $int21 > 0 | $int22 > 0) {
    if_setcolour(^green, $unid_text);
} else {
    if_setcolour(0xff981f, $unid_text);
}
if ($int24 > 0) {
    if_setcolour(^green, $calcium_text);
} else {
    if_setcolour(0xff981f, $calcium_text);
}
if ($int25 > 0) {
    if_setcolour(^green, $phosphate_text);
} else {
    if_setcolour(0xff981f, $phosphate_text);
}
