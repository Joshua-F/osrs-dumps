// 407
[proc,slayer_rewards_tabs](component $component0, component $component1, component $component2, component $component3, component $component4, component $component5, component $component6)
cc_deleteall($component0);
def_int $int7 = 0;
def_int $int8 = 0;
$int7, $int8 = ~slayer_rewards_tab($component0, $component1, "Unlock", $int7, $int8, $component1, $component2, $component3, $component4, $component5, $component6);
$int7, $int8 = ~slayer_rewards_tab($component0, $component2, "Extend", $int7, $int8, $component1, $component2, $component3, $component4, $component5, $component6);
$int7, $int8 = ~slayer_rewards_tab($component0, $component3, "Buy", $int7, $int8, $component1, $component2, $component3, $component4, $component5, $component6);
$int7, $int8 = ~slayer_rewards_tab($component0, $component4, "Tasks", $int7, $int8, $component1, $component2, $component3, $component4, $component5, $component6);
$int7, $int8 = ~slayer_rewards_tab($component0, $component5, "Cosmetics", $int7, $int8, $component1, $component2, $component3, $component4, $component5, $component6);
cc_create($component0, ^iftype_text, $int7);
cc_setposition(0, 0, ^setpos_abs_right, ^setpos_abs_top);
cc_setsize($int8, 0, ^setsize_minus, ^setsize_minus);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_setcolour(0xff981f);
cc_settextshadow(true);
~slayer_rewards_setpoints;
cc_setonvartransmit("slayer_rewards_setpoints(event_com, event_comsubid){slayer_killerwatt_var}");
if_sethide(false, $component6);
if ($component6 ! $component1) {
    if_sethide(true, $component1);
} else {
    %slayer_rewards_tab_last_opened = 0;
}
if ($component6 ! $component2) {
    if_sethide(true, $component2);
} else {
    %slayer_rewards_tab_last_opened = 1;
}
if ($component6 ! $component3) {
    if_sethide(true, $component3);
} else {
    %slayer_rewards_tab_last_opened = 2;
}
if ($component6 ! $component4) {
    if_sethide(true, $component4);
} else {
    %slayer_rewards_tab_last_opened = 3;
}
if ($component6 ! $component5) {
    if_sethide(true, $component5);
} else {
    %slayer_rewards_tab_last_opened = 4;
}
