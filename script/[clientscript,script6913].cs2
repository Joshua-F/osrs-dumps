// 6913
[clientscript,script6913](component $component, int $int1, int $int2, int $rgb)
if (cc_find($component, calc($int1 + 1)) = true) {
    cc_setcolour($int2);
}
if (cc_find($component, calc($int1 + 11)) = true) {
    cc_setcolour($int2);
}
if (cc_find($component, calc($int1 + 12)) = true) {
    cc_setcolour($rgb);
}
