// 2713
[clientscript,1v1arena_hud_init](component $com_0, component $com_1, component $com_5, component $com_2, component $com_6, component $com_7)
~1v1arena_hud_toggle(false, $com_1, $com_5, $com_2);
def_string $string = "Spectator";
cc_deleteall($com_6);
def_int $int = ~options_button_off($com_6, 0);
cc_create($com_6, ^iftype_text, $int);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settextshadow(true);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settext($string);
if_setop(1, $string, $com_6);
cc_setcolour(0xff981f);
if_setonmouserepeat("cc_colour_swapper(event_com, cc_getid, ^white)", $com_6);
if_setonmouseleave("cc_colour_swapper(event_com, cc_getid, 0xff981f)", $com_6);
if_setonop("1v1arena_hud_button(event_op, $com_6, cc_getid)", $com_6);
if_setontimer(null, $com_6);
$string = "Start All";
cc_deleteall($com_7);
$int = ~options_button_off($com_7, 0);
cc_create($com_7, ^iftype_text, $int);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settextshadow(true);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settext($string);
if_setop(1, $string, $com_7);
cc_setcolour(0xff981f);
if_setonmouserepeat("cc_colour_swapper(event_com, cc_getid, ^white)", $com_7);
if_setonmouseleave("cc_colour_swapper(event_com, cc_getid, 0xff981f)", $com_7);
if_setonop("1v1arena_hud_button(event_op, $com_7, cc_getid)", $com_7);
if_setontimer(null, $com_7);
