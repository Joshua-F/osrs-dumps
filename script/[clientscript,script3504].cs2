// 3504
[clientscript,script3504](int $int, component $component)
if ($int ! 1) {
    return;
}
sound_synth(synth_2266, 1, 0);
~script3503($component, false, true);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_setontimer("script3500(calc(clientclock + 20), $component)", $component);
