// 4888
[clientscript,script4888](boolean $boolean, component $component)
~bankside_runepouch_loadout_button_draw($boolean, $component);
if ($boolean = true) {
    if_setontimer("bankside_runepouch_loadout_button_hoverreset(calc(clientclock + 2), event_com)", $component);
} else {
    if_setontimer(null, $component);
}
