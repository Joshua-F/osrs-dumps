// 203
[proc,script203](int $int)(string)
if ($int = 0) {
    return("Not in clan");
}
if ($int = 1) {
    return("Recruit");
}
if ($int = 2) {
    return("Corporal");
}
if ($int = 3) {
    return("Sergeant");
}
if ($int = 4) {
    return("Lieutenant");
}
if ($int = 5) {
    return("Captain");
}
if ($int = 6) {
    return("General");
}
