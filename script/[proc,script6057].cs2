// 6057
[proc,script6057]
def_component $health_regen = orbs:health_regen;
if (~on_mobile = false & ~toplevel_getcomponents ! enum_1129 & %minimap_toggle = 1) {
    $health_regen = orbs_nomap:health_regen;
} else if (~on_mobile = true & %osm_minimap_toggle = 1) {
    $health_regen = orbs_osm_nomap:health_regen;
}
cc_deleteall($health_regen);
if_setontimer(null, $health_regen);
