// 5217
[proc,script5217](string $string)(boolean)
if (compare($string, chat_playername) = 0) {
    return(true);
}
if (friend_test($string) = true) {
    return(true);
} else if (~script5215($string, ^clantype_clan) = true) {
    if (ignore_test($string) = false) {
        return(true);
    }
} else {
    return(false);
}
