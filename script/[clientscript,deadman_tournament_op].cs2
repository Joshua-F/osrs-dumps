// 1267
[clientscript,deadman_tournament_op](int $int0, string $string, component $component, int $int2)
if (cc_find($component, $int2) = true) {
    sound_synth(synth_2266, 1, 0);
    cc_setcolour(0x8f8f8f);
    cc_setontimer("deadman_tournament_submit(calc(clientclock + 30), $string, $component, $int2)");
}
