// 4927
[proc,script4927]
def_component $tab_content_1 = colosseum_reward_chest_2:tab_content_1;
def_component $tab_content_2 = colosseum_reward_chest_2:tab_content_2;
if_sethide(true, $tab_content_1);
if_sethide(true, $tab_content_2);
switch_int (%colosseum_reward_chest_2_tab) {
    case 0 :
        if_sethide(false, $tab_content_2);
    case 1 :
        if_sethide(false, $tab_content_1);
}
