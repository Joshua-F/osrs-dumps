// 3100
[proc,canoe_location_setup](component $component, string $string0, int $int, string $string1, interface $interface)
if ($int = 0) {
    if_setop(1, append("Travel to<col=ff9040> ", $string0), $component);
    if_setonkey("script7885(event_keychar, $component, $string1, $interface)", $component);
} else {
    if_setop(1, "", $component);
    if_setonkey(null, $component);
}
