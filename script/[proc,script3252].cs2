// 3252
[proc,script3252](component $component)
def_int $int = 0;
def_namedobj $namedobj = null;
if (%ii_elnex = 0) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $namedobj = enum(int, namedobj, enum_2750, %ii_elnex);
    $int = ~v2_stone_button_filled($component);
}
cc_create($component, ^iftype_text, $int);
cc_setsize(if_getwidth($component), if_getheight($component), ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextfont(p11_full);
cc_setcolour(0xff981f);
cc_settextshadow(true);
if (%ii_elnex = 0) {
    cc_settext("Select an item");
} else {
    if ($namedobj ! null) {
        cc_settext("Confirm: <col=ffffff><oc_name($namedobj)> x<tostring(enum(namedobj, int, enum_2751, $namedobj))>");
    } else {
        cc_settext("Confirm");
    }
    cc_setonmouseleave("v2_stone_button_change_out($component, 0)");
    cc_setonmouserepeat("v2_stone_button_change_in($component, 0)");
    cc_setop(1, "Confirm");
}
