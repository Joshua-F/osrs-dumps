// 3730
[proc,start_slideshow](component $component, enum $enum, int $int2, int $int3, int $int4)
cc_deleteall($component);
def_graphic $graphic = enum(int, graphic, $enum, 0);
cc_create($component, ^iftype_graphic, 0);
cc_setsize(1, 1, ^setsize_abs, ^setsize_abs);
cc_settrans(255);
cc_create($component, ^iftype_graphic, 1);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setgraphic($graphic);
cc_create($component, ^iftype_graphic, 2);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_settrans(255);
if_setontimer("slideshow_timer($component, $enum, $int2, $int3, clientclock)", $component);
if ($int4 = 1) {
    if_setop(1, "View Next Image", $component);
    if_setonop("slideshow_skip($component, $enum, $int2, $int3)", $component);
}
