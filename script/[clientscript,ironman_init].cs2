// 687
[clientscript,ironman_init](component $com_0, component $com_2, component $com_14, component $com_18, component $com_22, component $com_26, component $com_37, component $com_41, component $com_1, component $com_42)
~steelborder($com_2, "<text_bodytype("Iron Man", "Iron Woman")> Setup", 0);
if_settext("<text_bodytype("Iron Man", "Iron Woman")> Mode", $com_14);
if_settext("<col=ffffff>Standard <text_bodytype("Iron Man", "Iron Woman")></col><br>An <text_bodytype("Iron Man", "Iron Woman")> does not receive items or assistance from other players. They cannot trade, stake, receive PK loot, scavenge dropped items, nor play certain multiplayer minigames.", $com_18);
if_settext("<col=ffffff>Ultimate <text_bodytype("Iron Man", "Iron Woman")></col><br>In addition to the standard <text_bodytype("Iron Man", "Iron Woman")> rules, an Ultimate <text_bodytype("Iron Man", "Iron Woman")> cannot use banks, nor retain any items on death in dangerous areas.", $com_22);
if_settext("<col=ffffff>None</col> - No <text_bodytype("Iron Man", "Iron Woman")> restrictions will apply to this account.", $com_26);
if_settext("<col=ffffff>PIN</col><br>You must enter your Bank PIN to request that <text_bodytype("Iron Man", "Iron Woman")> restrictions be removed. Changes take effect after a <tostring(7)>-day delay, in case you change your mind.", $com_37);
if_settext("<col=ffffff>Permanent</col> - The <text_bodytype("Iron Man", "Iron Woman")> restrictions can never be removed.", $com_41);
~script689($com_0, $com_1, $com_42);
if_setonvartransmit("script688($com_0, $com_1, $com_42){varplayer_499, varplayer_281}", $com_0);
