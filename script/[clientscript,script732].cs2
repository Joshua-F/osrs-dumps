if_setoninvtransmit("script2850(interface_477:com_13, interface_477:com_14, interface_477:com_15, interface_477:com_16, interface_477:com_12, interface_477:com_10, interface_477:com_11, interface_477:com_9, interface_477:com_7, interface_477:com_8){inv_93}", $com_6);
