// 732
[clientscript,script732](component $com_1, component $com_6, component $com_3)
~steelborder($com_1, "Custom Fur Clothing", 0);
def_int $int = 0;
$int = ~script2848($com_6, 0, 7, 0, 5, $int);
$int = ~script2848($com_6, 8, 16, 72, 5, $int);
$int = ~script2848($com_6, 17, 19, 144, 40, $int);
cc_create($com_3, ^iftype_text, 0);
