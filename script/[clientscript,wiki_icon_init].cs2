// 3304
[clientscript,wiki_icon_init](component $wiki, component $wiki_icon, component $wiki_icon_graphic, boolean $boolean)
if_setnoclickthrough(true, $wiki_icon);
if_setontargetenter("wiki_entity_lookup_target($wiki_icon, $wiki_icon_graphic, true)", $wiki_icon);
if_setontargetleave("wiki_entity_lookup_target($wiki_icon, $wiki_icon_graphic, false)", $wiki_icon);
if_setonvartransmit("wiki_icon_update($wiki, $wiki_icon, $wiki_icon_graphic, $boolean){chat_filter_assist, mobile_options_transmit, chat_filter_clan}", $wiki);
~wiki_icon_update($wiki, $wiki_icon, $wiki_icon_graphic, $boolean);
