// 7219
[proc,script7219](int $int, stringvector $stringvector)
mes("You are trying to add too many entries to this list. Please consider cutting your list down if you would like to add any more to it.");
if ($int = 1 & $stringvector ! null) {
    mes("Any entries after <stringvector_get($stringvector, calc(stringvector_size($stringvector) - 1))> will be ignored.");
}
