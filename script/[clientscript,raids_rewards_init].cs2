// 1579
[clientscript,raids_rewards_init](component $universe, component $items)
def_int $int = inv_size(raids_rewards);
~raids_rewards_build($items, $int);
if_setoninvtransmit("raids_rewards_build($items, $int){raids_rewards}", $universe);
if_setonvartransmit("raids_rewards_build($items, $int){raids_temp_transmit3}", $universe);
