// 749
[proc,script749]()(int, int)
def_int $int0 = cc_getx;
def_int $int1 = cc_gety;
def_component $component = cc_getlayer;
while ($component ! null) {
    $int0 = calc($int0 + if_getx($component) - if_getscrollx($component));
    $int1 = calc($int1 + if_gety($component) - if_getscrolly($component));
    $component = if_getlayer($component);
}
return($int0, $int1);
