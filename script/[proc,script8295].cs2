// 8295
[proc,script8295](int $int)(string)
if (calc($int % 10) = 1) {
    if (calc($int % 100) ! 11) {
        return(append(tostring($int), "st"));
    }
} else if (calc($int % 10) = 2) {
    if (calc($int % 100) ! 12) {
        return(append(tostring($int), "nd"));
    }
} else if (calc($int % 10) = 3 & calc($int % 100) ! 13) {
    return(append(tostring($int), "rd"));
}
return(append(tostring($int), "th"));
