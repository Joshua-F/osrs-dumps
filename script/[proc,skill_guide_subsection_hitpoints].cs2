// 7895
[proc,skill_guide_subsection_hitpoints](int $int)(string, boolean)
switch_int ($int) {
    case 0 :
        return("Hitpoints", false);
    case 1 :
        return("Healing", false);
    case 2 :
        return("Equipment", true);
    case 3 :
        return("Hitsplats", false);
        return("", null);
}
return("", null);
