// 5893
[proc,speedrunning_total_trophies]()(int)
def_int $int = ~min(%speedrunning_bronze_trophies, 60000);
$int = calc($int + ~min(%speedrunning_silver_trophies, 60000));
$int = calc($int + ~min(%speedrunning_gold_trophies, 60000));
$int = calc($int + ~min(%speedrunning_platinum_trophies, 60000));
$int = calc($int + ~min(%speedrunning_diamond_trophies, 60000));
return($int);
