// 7213
[proc,script7213](component $component, stringvector $stringvector)
cc_deleteall($component);
def_int $int = ~thinbox($component, $int);
~script7210($component, $int, 4, 4, ^setsize_minus, ^setsize_minus, 0, 0, 1, 1);
cc_settext(~script7212($stringvector));
cc_input_setonsubmit("ground_items_confirm");
cc_input_setonfocuschanged("ground_items_focus_changed(event_com, event_comsubid, $stringvector)");
