// 3006
[clientscript,adventurepath_say_item](obj $obj, int $int, boolean $boolean)
if ($obj = obj_20594) {
    mes("There are no rewards of this type.");
} else if ($boolean = true) {
    mes("Members: <oc_name($obj)> x<tostring($int)>");
} else {
    mes("Non Members: <oc_name($obj)> x<tostring($int)>");
}
