// 3930
[clientscript,script3930](component $component0, int $int, component $component2)
~settings_side_op_sound;
%tooltip_built = 0;
if ($int = 0) {
    ~script3932($component0, 1, $component2);
    %music_unlock_text_toggle = 1;
} else {
    ~script3932($component0, 0, $component2);
    %music_unlock_text_toggle = 0;
}
