// 865
[clientscript,pvp_icons_layout_init](component $universe, component $safezone, component $hud_container, component $deadman_dodger, component $kd_dodger, component $icons_dodger, component $chestannounce_dodger, component $kd_container)
~interface_dodger_init($safezone, $universe, setbit(0, 13), ^setpos_abs_left, ^setpos_abs_top, false);
~interface_dodger_init($hud_container, $universe, setbit(0, 12), ^setpos_abs_left, ^setpos_abs_top, false);
~interface_dodger_init($chestannounce_dodger, pvp_icons:deadman_chestannounce_boundinglayer, clearbit(clearbit(52968, 12), 13), ^setpos_abs_centre, ^setpos_abs_top, false);
~interface_dodger_init($deadman_dodger, pvp_icons:deadman_final, clearbit(clearbit(36582, 12), 13), ^setpos_abs_right, ^setpos_abs_top, false);
~interface_dodger_init($kd_dodger, $kd_container, 52968, ^setpos_abs_left, ^setpos_abs_top, true);
if (~on_mobile = true) {
    ~interface_dodger_init($icons_dodger, pvp_icons:icons, setbit(36578, 12), ^setpos_abs_right, ^setpos_abs_bottom, false);
} else if (getwindowmode = ^windowmode_small) {
    ~interface_dodger_init($icons_dodger, pvp_icons:icons, 36578, ^setpos_abs_right, ^setpos_abs_bottom, false);
} else {
    ~interface_dodger_init($icons_dodger, pvp_icons:icons, clearbit(36578, 7), ^setpos_abs_right, ^setpos_abs_bottom, false);
}
if_setontimer("pvp_icons_layout(false)", $universe);
if_setonresize("pvp_icons_layout(true)", $universe);
if_setonsubchange("pvp_icons_layout(true)", $universe);
if_setonvartransmit("pvp_icons_layout(true){deadman, deadman2, deadman3, deadman_tournament_mode_pl, deadman_transmitting_perm, br_temp_1, br_temp_2, wildwars_temptransmit, wildwars_temptransmit2, deadman_teleblock_transmit, toplevel_temp, gravestone_varp, sote_pillars_light_level_1_a, farming_tools2, spectator_mode, pvpa_temp_transmit_0}", $universe);
if_setonmouseleave("deltooltip(pvp_icons:tooltip)", pvp_icons:pvp);
cc_deleteall($kd_container);
cc_create($kd_container, ^iftype_text, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_sethide(false);
cc_setcolour(^yellow);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_left, ^settextalign_top, 0);
cc_settextshadow(true);
cc_setonvartransmit("kdr_update(event_com, event_comsubid){wilderness_statistics, zeah_temp_2, pest_instance, deadman_transmitting_perm}");
~kdr_update;
~pvp_icons_layout;
