// 5720
[clientscript,helper_agility_vartransmit](entityoverlay $entityoverlay, int $int1, int $int2, loc $loc, coord $coord)
if ($int1 = %agility_helper_highlight_shortcuts & $int2 = %agility_helper_highlight_shortcuts_overlay_disabled) {
    return;
}
~script5724($entityoverlay, $loc, $coord);
if (if_find_entityoverlay($entityoverlay) = true) {
    ~helper_agility_vartransmit($entityoverlay, $loc, $coord);
}
