[proc,clan_applicants_framedraw](component $component, int $int)
if (%varplayerbit_933 = 3 & activeclansettings_find_affined(^clantype_clan) = true) {
    if (cc_find($component, $int) = true) {
        cc_settext("<activeclansettings_getclanname>: Applicants");
    }
} else if (cc_find($component, $int) = true) {
    cc_settext(~script4287);
}
