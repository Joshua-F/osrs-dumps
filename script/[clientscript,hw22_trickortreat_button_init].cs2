// 6921
[clientscript,hw22_trickortreat_button_init](component $component)
~v2_stone_button_filled($component);
if (~on_mobile = false) {
    if_setonmouserepeat("script6922(true, false, $component)", $component);
}
if_setonmouseleave("script6922(false, false, $component)", $component);
if_setonhold("script6922(false, true, $component)", $component);
if_setonrelease("script6922(true, false, $component)", $component);
