// 6192
[proc,script6192](int $int, component $component)
if (testbit(%duelwornoptions, $int) = ^true) {
    cc_setgraphic(stop);
    cc_setonmouserepeat("tooltip_mouserepeat(event_com, event_comsubid, $component, enum(int, string, enum_4388, $int), 25, 300)");
} else {
    cc_setgraphic(null);
}
cc_setonmouseleave("deltooltip($component)");
