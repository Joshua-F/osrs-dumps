// 4572
[clientscript,settings_side_dropdown_timer](component $component, int $int1, enum $enum, int $int3, struct $struct)
$int1 = calc(1 + $int1);
if ($int1 > 30) {
    if_setontimer(null, $component);
    ~settings_side_dropdown_update($component, $enum, $int3, $struct);
} else {
    if_setontimer("settings_side_dropdown_timer($component, $int1, $enum, $int3, $struct)", $component);
}
