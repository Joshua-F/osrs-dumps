// 5996
[proc,questlist_settings_button_init](component $component)
def_int $int = ~v2_stone_button_filled($component);
cc_create($component, ^iftype_graphic, $int);
cc_setsize(22, 22, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic("acc_man_icons,7");
if (~on_mobile = false) {
    if_setonmouserepeat("v2_stone_button_change_in($component, 0)", $component);
    if_setonmouseleave("v2_stone_button_change_out($component, 0)", $component);
}
if_setonop("settings_side_op_sound", $component);
