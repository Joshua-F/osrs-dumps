// 2140
[clientscript,fossil_driftnet_store_init](component $universe, component $head, component $store)
if_setnpchead(fossil_mermaid_driftnets, $head);
if_setmodelanim(chatidleneu1, $head);
cc_deleteall($store);
cc_create($store, ^iftype_graphic, 0);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
cc_setoutline(1);
cc_setgraphicshadow(0x333333);
cc_setop(1, "Withdraw-1");
cc_setop(2, "Withdraw-5");
cc_setop(3, "Withdraw-X");
cc_setop(4, "Withdraw-All");
cc_setop(9, "Banknote-All");
cc_setop(10, "Examine");
cc_setopbase("<col=ff9040><oc_name(fossil_drift_net)></col>");
~fossil_driftnet_store_update;
if_setonvartransmit("fossil_driftnet_store_update($store, cc_getid){fossil_perm_transmit}", $universe);
