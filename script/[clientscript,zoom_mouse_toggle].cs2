// 43
[clientscript,zoom_mouse_toggle](component $zoom_toggle, component $mouse_zoom_disable, int $int, component $tooltip)
~settings_side_op_sound;
%varclient_2 = 0;
def_string $string = "<~text_device("Click", "Tap")> here to enable zooming using <~text_device("the mouse scroll wheel", "the pinch gesture")>.";
if ($int = 1) {
    %camera_zoom_mouse_disabled = calc(1 - %camera_zoom_mouse_disabled);
    if (%camera_zoom_mouse_disabled = 0) {
        if_sethide(true, $mouse_zoom_disable);
        if_setop(1, "Disable", $zoom_toggle);
        $string = "<~text_device("Click", "Tap")> here to disable zooming using <~text_device("the mouse scroll wheel", "the pinch gesture")>.";
    } else {
        if_setop(1, "Enable", $zoom_toggle);
        if_sethide(false, $mouse_zoom_disable);
    }
    if_setonmouserepeat("tooltip_mouserepeat($zoom_toggle, -1, $tooltip, $string, 25, 190)", $zoom_toggle);
    if_setonmouseleave("deltooltip($tooltip)", $zoom_toggle);
} else if ($int = 2) {
    ~camera_do_zoom(512, 512);
}
