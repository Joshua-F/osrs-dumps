// 43
[clientscript,zoom_mouse_toggle](component $com_5, component $com_7, int $int, component $com_118)
def_string $string = "<~text_device("Click", "Tap")> here to enable zooming using <~text_device("the mouse scroll wheel", "the pinch gesture")>.";
if ($int = 1) {
    if (%varplayerbit_6357 = 0) {
        %varplayerbit_6357 = 1;
    } else {
        %varplayerbit_6357 = 0;
        $string = "<~text_device("Click", "Tap")> here to disable zooming using <~text_device("the mouse scroll wheel", "the pinch gesture")>.";
    }
    if (%varplayerbit_6357 = 0) {
        if_sethide(true, $com_7);
    } else if (%varplayerbit_6357 = 1) {
        if_sethide(false, $com_7);
    }
    if_setonmouserepeat("tooltip_mouserepeat($com_5, -1, $com_118, $string, 25, 190)", $com_5);
    if_setonmouseleave("deltooltip($com_118)", $com_5);
} else if ($int = 2) {
    ~camera_do_zoom(512, 512);
}
