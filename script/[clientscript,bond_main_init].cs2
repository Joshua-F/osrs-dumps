if_setposition(0, $int12, ^setpos_abs_centre, ^setpos_abs_top, $membership_store);
$int12 = calc($int12 + if_getheight($membership_store));
cc_deleteall($quantity_container);
$int11 = 0;
cc_create($quantity_container, ^iftype_graphic, $int11);
$int11 = calc($int11 + 1);
cc_setsize(2, 2, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic(tradebacking_light);
cc_settiling(true);
$int11 = ~thinbox($quantity_container, $int11);
cc_create($quantity_container, ^iftype_graphic, $int11);
def_int $int13 = $int11;
$int11 = calc($int11 + 1);
.cc_create($quantity_container, ^iftype_graphic, $int11);
def_int $int14 = $int11;
$int11 = calc($int11 + 1);
cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
.cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
cc_setposition(4, 4, ^setpos_abs_left, ^setpos_abs_top);
.cc_setposition(calc(4 + 36 - 6), 4, ^setpos_abs_left, ^setpos_abs_bottom);
cc_setgraphicshadow(0x333333);
.cc_setgraphicshadow(0x333333);
