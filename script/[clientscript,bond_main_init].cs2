// 1146
[clientscript,bond_main_init](component $universe, component $bond_pouch_top, component $info_container, component $bond_store, component $bond_pouch_body, component $membership_store, component $quantity_container, component $redeem_container, component $redeem_options, component $redeem_scrollbar)
%raids_scroll, %raids_count, %poll_scroll = 0, 0, 0;
