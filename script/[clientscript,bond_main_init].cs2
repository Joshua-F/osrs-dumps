if_setonvartransmit("script1276(event_com, $int13, $int14, $int11, $int10, $int15, $redeem_container, $redeem_options, $redeem_scrollbar){if1, if2}", $quantity_container);
def_component $component = if_getlayer($universe);
~bond_main_setsize($int12, $int16, if_getheight($component), $component, $universe, $quantity_container, $redeem_options, $redeem_scrollbar);
