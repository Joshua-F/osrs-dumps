// 6498
[proc,script6498](dbrow $dbrow, loc $loc, obj $obj2, coord $coord, obj $obj4)
def_entityoverlay $entityoverlay = null;
if (loc_find($coord, $loc) = true) {
    $entityoverlay = entityoverlay_get_loc(6);
    if ($entityoverlay = null) {
        $entityoverlay = entityoverlay_create_loc(6, ^overlaytype_top, 60, 60, 1);
    } else {
        cc_deleteall_entityoverlay($entityoverlay);
    }
    if (if_find_entityoverlay($entityoverlay) = true) {
        cc_setonvartransmit("script6499($entityoverlay, $dbrow, $loc, $obj2, $coord, $obj4, %varplayerbit_14189, %varplayerbit_14184, %varplayerbit_14182){varplayer_3546, varplayer_3543}");
    }
    if (%varplayerbit_14182 = 0) {
        highlight_loc_off($loc, $coord, 9, 1);
        return;
    }
    if (inv_total(inv_93, $obj2) > 0) {
        if (%varplayerbit_14189 = 1) {
            cc_create_entityoverlay($entityoverlay, ^iftype_graphic, 0);
            cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
            cc_setposition(4, 4, ^setpos_abs_centre, ^setpos_abs_centre);
            cc_setobject_nonum($obj4, 1);
            cc_setoutline(1);
            cc_create_entityoverlay($entityoverlay, ^iftype_graphic, 1);
            cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
            cc_setposition(-4, -4, ^setpos_abs_centre, ^setpos_abs_centre);
            cc_setobject_nonum(obj_7297, 1);
            cc_setoutline(1);
        }
        if (%varplayerbit_14184 = 1) {
            highlight_loc_on($loc, $coord, 9, 1);
        }
        if (if_find_entityoverlay($entityoverlay) = true) {
            cc_setoninvtransmit("script6500($dbrow, $loc, $obj2, $coord, $obj4, 1){inv_93}");
        }
    } else {
        highlight_loc_off($loc, $coord, 9, 1);
        if (if_find_entityoverlay($entityoverlay) = true) {
            cc_setoninvtransmit("script6500($dbrow, $loc, $obj2, $coord, $obj4, 0){inv_93}");
        }
    }
    highlight_loc_setup(9, ^green, 2, 30, 1);
}
