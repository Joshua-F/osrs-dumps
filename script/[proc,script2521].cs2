// 2521
[proc,script2521](dbrow $dbrow, string $string0)(string)
def_string $string1 = "";
if ($dbrow = null) {
    return("");
}
def_int $int = db_getfield($dbrow, sailing_boat_facility_stats:boat_ammo_save_percentage, 0);
if ($int > 0) {
    $string1 = "Ammo saving percentage: <$string0><tostring($int)>";
}
if (string_length($string1) > 0) {
    return($string1);
}
return("");
