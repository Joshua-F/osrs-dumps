// 1012
[clientscript,xpdrops_setup_display_hover](boolean $boolean, component $component)
if ($boolean = true) {
    if (cc_find($component, 0) = true) {
        cc_settrans(100);
    }
    if (cc_find($component, 3) = true) {
        cc_settrans(125);
        cc_setgraphic("scrollbar_v2,1");
    }
    if (cc_find($component, 4) = true) {
        cc_setcolour(0xffb83f);
    }
} else {
    ~xpdrops_setup_display_hoveroff($component);
}
