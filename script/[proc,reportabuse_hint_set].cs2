// 5095
[proc,reportabuse_hint_set](int $int)
def_string $string = "This form is for reporting players who are breaking the game's rules.<br>Using it sends us a snapshot of the last minute of activity.<br>";
if ($int = 1) {
    $string = append($string, "<col=ff0000>Enter the name of the offending player</col>, then <~text_device("click", "tap")> <col=7f0000>Next</col>.");
    if_setontimer("reportabuse_hint_reset(calc(clientclock + 20))", reportabuse:hint);
} else {
    $string = append($string, "Enter the name of the offending player, then <~text_device("click", "tap")> <col=7f0000>Next</col>.");
    if_setontimer(null, reportabuse:hint);
}
if_settext($string, reportabuse:hint);
