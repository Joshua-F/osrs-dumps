// 436
[clientscript,grouping_mouseover](component $component, int $int1, int $int2, boolean $boolean)
if (.cc_find($component, $int1) = true & cc_find($component, $int2) = true) {
    if ($boolean = true) {
        cc_setposition(.cc_getx, .cc_gety, ^setpos_abs_left, ^setpos_abs_top);
        cc_sethide(false);
    } else {
        cc_sethide(true);
    }
}
