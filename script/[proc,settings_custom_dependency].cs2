// 2520
[proc,settings_custom_dependency](struct $struct)(boolean)
def_int $int = struct_param($struct, param_1077);
switch_int ($int) {
    case 87, 89, 92, 94, 97, 99, 101, 103, 105, 107 :
        if (getwindowmode ! ^windowmode_small & %varplayerbit_4608 = 1) {
            return(false);
        } else {
            return(true);
        }
}
return(true);
