// 5861
[clientscript,lotg_makeover_confirm](component $confirm_button)
cc_deleteall($confirm_button);
~v2_stone_button_filled($confirm_button);
if (~on_mobile = false) {
    if_setonmouseleave("script5862($confirm_button, 0)", $confirm_button);
    if_setonmouserepeat("script5862($confirm_button, 1)", $confirm_button);
}
