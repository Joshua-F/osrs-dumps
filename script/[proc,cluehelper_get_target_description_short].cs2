// 6648
[proc,cluehelper_get_target_description_short](dbrow $dbrow)(string)
def_string $string = null;
switch_dbtable (db_getrowtable($dbrow)) {
    case cluehelper_target_coord :
        $string = db_getfield($dbrow, cluehelper_target_coord:description_short, 0);
}
if (string_length($string) = 0) {
    $string = ~cluehelper_get_target_description($dbrow);
}
return($string);
