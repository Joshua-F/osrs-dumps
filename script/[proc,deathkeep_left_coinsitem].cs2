// 980
[proc,deathkeep_left_coinsitem](obj $obj, int $int1, int $int2, int $int3, int $int4, int $int5, int $int6)(int, int)
cc_create(deathkeep:coins, ^iftype_graphic, $int6);
cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
def_int $int7 = calc(17 + $int6 / $int3 * (32 + $int4));
cc_setposition(calc($int5 + $int6 % $int3 * (36 + $int4)), $int7, ^setpos_abs_left, ^setpos_abs_top);
cc_setgraphicshadow(0x333333);
cc_setoutline(1);
cc_setobject($obj, $int1);
cc_setop(1, "Check");
cc_setopbase("<col=ff9040><oc_name($obj)></col>");
def_string $string = "";
if ($int1 > 1) {
    if (%ironman = 2) {
        $string = "<~tostring_spacer($int1, ",")> x <oc_name($obj)>: These items will be dropped as coins (<~tostring_spacer($int2, ",")>).";
    } else {
        $string = "<~tostring_spacer($int1, ",")> x <oc_name($obj)>: These items will be sent to your gravestone as coins (<~tostring_spacer($int2, ",")>).";
    }
} else if (%ironman = 2) {
    $string = "<oc_name($obj)>: This item will be dropped as coins (<~tostring_spacer($int2, ",")>).";
} else {
    $string = "<oc_name($obj)>: This item will be sent to your gravestone as coins (<~tostring_spacer($int2, ",")>).";
}
cc_setonop("deathkeep_opitem(event_com, event_comsubid, $string)");
return(calc($int6 + 1), $int7);
