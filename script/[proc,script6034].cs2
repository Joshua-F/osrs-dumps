// 6034
[proc,script6034](component $component, graphic $graphic, string $string, boolean $boolean)
sound_synth(synth_2400, 1, 0);
~bcs_pillar_setbutton($component, $graphic, $string, true, 1);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_clearops($component);
if_setontimer("script6035($component, $graphic, $string, calc(clientclock + 40), $boolean)", $component);
