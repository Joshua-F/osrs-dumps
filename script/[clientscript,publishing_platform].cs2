// 4035
[clientscript,publishing_platform]
def_string $string = "Unknown";
mes("Before type of platform call.");
def_int $platformtype = platformtype;
if ($platformtype = ^platformtype_steam) {
    $string = "Steam";
} else if ($platformtype = ^platformtype_default) {
    $string = "Default";
} else if ($platformtype = ^platformtype_android) {
    $string = "Android";
} else if ($platformtype = ^platformtype_apple) {
    $string = "Apple";
}
mes("Client: You are on platform type: <$string>");
