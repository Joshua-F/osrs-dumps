// 5958
[onclickobj,_]
if (~on_enhanced_mobile = false | %interact_entity_highlights_disabled = 1) {
    return;
}
~entity_highlight_clear(4);
def_entityoverlay $entityoverlay = null;
$entityoverlay = entityoverlay_create_player(0, ^overlaytype_middle, 1, 1, 0);
~entity_highlight_active_obj(4);
~interact_entity_highlight_pulse_start($entityoverlay);
