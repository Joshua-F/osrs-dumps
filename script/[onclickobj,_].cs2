// 5958
[onclickobj,_]
if (~on_enhanced_mobile = false | %varplayerbit_13666 = 1) {
    return;
}
~entity_highlight_clear(4);
def_entityoverlay $entityoverlay = null;
$entityoverlay = entityoverlay_create_coord(obj_coord, 7, ^overlaytype_middle, 1, 1, 0);
~interact_entity_highlight_pulse_start($entityoverlay);
~entity_highlight_active_obj(4);
