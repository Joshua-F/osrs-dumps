// 5513
[clientscript,gim_settings_editable_hover](boolean $boolean, component $component, int $int2, int $int3, int $int4)
if ($boolean = true) {
    if (cc_find($component, $int2) = true) {
        cc_settrans($int3);
    }
    if_setontimer("cc_settrans_temporarily_end(event_com, $int2, $int4, calc(clientclock + 2))", $component);
} else {
    if (cc_find($component, $int2) = true) {
        cc_settrans($int4);
    }
    if_setontimer(null, $component);
}
