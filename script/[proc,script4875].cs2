[proc,script4875](string $string, dbrow $dbrow, int $int)(string)
switch_dbrow ($dbrow) {
    case quest_whileguthixsleeps :
        if ($int = 0) {
            if (~script1788 = false) {
                $string = "<$string><col=800000>Warriors' Guild Access<br>";
            } else {
                $string = "<$string><str>Warriors' Guild Access<br>";
            }
        }
}
return($string);
