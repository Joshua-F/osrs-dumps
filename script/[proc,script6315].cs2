// 6315
[proc,script6315](boolean $boolean, component $component)
cc_deleteall($component);
def_int $int = 0;
if ($boolean = true) {
    $int = ~options_button_on($component, 0);
} else {
    $int = ~options_button_off($component, 0);
}
if_setontimer("script6316($boolean, event_com)", $component);
cc_create($component, ^iftype_graphic, $int);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setsize(29, 22, ^setsize_abs, ^setsize_abs);
cc_setgraphic("bankbuttons,2");
cc_settrans(0);
if_setonmouserepeat("cc_settrans(event_com, $int, 60, null)", $component);
if_setonmouseleave("cc_settrans(event_com, $int, 0, null)", $component);
if_setonop("script6317(event_op, event_com, $int, 150, 60, 0)", $component);
