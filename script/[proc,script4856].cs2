// 4856
[proc,script4856](component $component)
~collection_draw_combatachievements($component, false);
if_setonmouserepeat("collection_draw_combatachievements(event_com, true)", $component);
if_setonmouseleave("collection_draw_combatachievements(event_com, false)", $component);
if_setontimer(null, $component);
if_setonop("script4854(event_op, event_com)", $component);
