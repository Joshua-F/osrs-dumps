if_setonmouseleave("deltooltip($com_112)", $com_98);
~options_runmode($com_98, $com_100, $com_112);
if_setonvartransmit("options_runmode_resynch($com_98, $com_100, $com_112){varplayer_173}", $com_98);
if_setonmisctransmit("options_runmode_resynch($com_98, $com_100, $com_112)", $com_98);
if_setonop("options_runmode_op(event_op, $com_98, $com_100, $com_112)", $com_98);
