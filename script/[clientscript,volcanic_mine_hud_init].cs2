// 2016
[clientscript,volcanic_mine_hud_init](component $universe, component $dodger_left, component $dodger_right, component $main_info, component $vent_chambers_info)
~interface_dodger_init($dodger_left, $main_info, setbit(setbit(52960, 12), 13), ^setpos_abs_left, ^setpos_abs_centre, true);
~interface_dodger_init($dodger_right, $vent_chambers_info, setbit(setbit(36578, 12), 13), ^setpos_abs_right, ^setpos_abs_centre, false);
~volcanic_mine_set_venttext;
~volcanic_mine_set_chambertext;
~volcanic_mine_set_otherinfo;
if_setonvartransmit("volcanic_mine_updatehud{fossil_temp_transmit, fossil_temp_transmit2, fossil_temp_transmit3}", $universe);
