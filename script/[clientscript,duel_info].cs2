// 2476
[clientscript,duel_info](component $com_33)
def_string $string = "To stake <col=cccccc>platinum</col> or <col=ffff00>coins</col> use the buttons on the panel in the middle.<br><br>Tax is deducted from the combined stake.";
if (map_members = false) {
    $string = "To stake <col=ffff00>coins</col> use the buttons on the panel in the middle.<br><br>Tax is deducted from the combined stake.";
}
if_settext($string, $com_33);
