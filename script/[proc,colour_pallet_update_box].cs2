// 4188
[proc,colour_pallet_update_box](component $component, int $int, struct $struct)
if (cc_find($component, $int) = true) {
    if (%settings_colour_pallet_selected = -1) {
        cc_setcolour(struct_param($struct, param_1230));
    } else {
        cc_setcolour(%settings_colour_pallet_selected);
    }
}
