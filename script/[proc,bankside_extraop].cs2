// 2576
[proc,bankside_extraop](obj $obj, int $int)(string)
if (%bank_hidesideops = 1) {
    return("");
}
def_string $string = oc_param($obj, param_595);
switch_obj ($obj) {
    case rcu_pouch_small :
        if (testbit(%if1, 0) = ^true) {
            $string = "Empty";
        }
    case rcu_pouch_medium, rcu_pouch_medium_degrade :
        if (testbit(%if1, 1) = ^true) {
            $string = "Empty";
        }
    case rcu_pouch_large, rcu_pouch_large_degrade :
        if (testbit(%if1, 2) = ^true) {
            $string = "Empty";
        }
    case rcu_pouch_giant, rcu_pouch_giant_degrade :
        if (testbit(%if1, 3) = ^true) {
            $string = "Empty";
        }
    case rcu_pouch_colossal, rcu_pouch_colossal_degrade :
        if (testbit(%if1, 4) = ^true) {
            $string = "Empty";
        }
    case coal_bag, coal_bag_open :
        if (testbit(%if1, 5) = ^true) {
            $string = "Fill";
        }
    case default :
        if ((string_length($string) <= 0 | testbit(%if4, $int) = ^true) & (map_members = true | oc_members($obj) = 0)) {
            if (testbit(%if2, $int) = ^true) {
                $string = oc_iop($obj, oc_param($obj, param_148));
            } else if (testbit(%if3, $int) = ^true) {
                $string = oc_iop($obj, 1);
            } else if (testbit(%if4, $int) = ^true) {
                $string = "Fill";
            }
        }
}
return($string);
