[proc,bankside_extraop](obj $obj, int $int)(string)
if (%varplayerbit_10079 = 1) {
    return("");
}
def_string $string = oc_param($obj, param_595);
switch_obj ($obj) {
    case obj_5509 :
        if (testbit(%varplayer_261, 0) = ^true) {
            $string = "Empty";
        }
    case obj_5510, obj_5511 :
