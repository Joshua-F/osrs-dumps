// 7278
[clientscript,worldswitcher_options_filters_init](component $filter_member, component $filter_country, component $filter_theme, component $search, component $reset)
def_boolean $boolean = ~on_mobile;
~worldswitcher_options_filters_initbutton($filter_member, "Membership", $boolean, $filter_member, $filter_country, $filter_theme, $search, $reset);
~worldswitcher_options_filters_initbutton($filter_country, "Location", $boolean, $filter_member, $filter_country, $filter_theme, $search, $reset);
~worldswitcher_options_filters_initbutton($filter_theme, "Mode", $boolean, $filter_member, $filter_country, $filter_theme, $search, $reset);
~worldswitcher_options_filters_initbutton($search, "", $boolean, $filter_member, $filter_country, $filter_theme, $search, $reset);
~worldswitcher_options_filters_initbutton($reset, "Reset", $boolean, $filter_member, $filter_country, $filter_theme, $search, $reset);
