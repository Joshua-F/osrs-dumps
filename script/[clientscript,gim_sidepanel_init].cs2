// 5255
[clientscript,gim_sidepanel_init](component $universe, component $title, component $subtitle, component $members, component $invite, component $settings)
cc_deleteall($title);
cc_create($title, ^iftype_text, 0);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextfont(b12_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
def_int $int6 = cc_getid;
cc_create($title, ^iftype_graphic, 1);
cc_setsize(13, 13, ^setsize_abs, ^setsize_abs);
def_int $int7 = cc_getid;
cc_deleteall($subtitle);
cc_create($subtitle, ^iftype_text, 0);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
def_int $int8 = cc_getid;
cc_create($subtitle, ^iftype_graphic, 1);
cc_setsize(13, 13, ^setsize_abs, ^setsize_abs);
def_int $int9 = cc_getid;
cc_create($subtitle, ^iftype_text, 2);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
def_int $int10 = cc_getid;
cc_create($subtitle, ^iftype_graphic, 3);
cc_setsize(13, 13, ^setsize_abs, ^setsize_abs);
def_int $int11 = cc_getid;
~gim_sidepanel_draw($title, $int6, $int7, $subtitle, $int8, $int9, $int10, $int11, $members, $invite, $settings);
if_setonvartransmit("gim_sidepanel_draw($title, $int6, $int7, $subtitle, $int8, $int9, $int10, $int11, $members, $invite, $settings){gim_temp_1}", $universe);
if_setonclansettingstransmit("gim_sidepanel_draw($title, $int6, $int7, $subtitle, $int8, $int9, $int10, $int11, $members, $invite, $settings)", $universe);
if_setonclanchanneltransmit("gim_sidepanel_draw($title, $int6, $int7, $subtitle, $int8, $int9, $int10, $int11, $members, $invite, $settings)", $universe);
if_setonfriendtransmit("gim_sidepanel_draw($title, $int6, $int7, $subtitle, $int8, $int9, $int10, $int11, $members, $invite, $settings)", $universe);
