// 855
[clientscript,league_rankings_init](component $header, component $rankings, component $rankings_scrollbar, component $close_button)
~leagues_close_button($close_button, false, 0);
if_setposition(50, 5, ^setpos_abs_right, ^setpos_abs_top, $close_button);
~league_rankings_draw($header, $rankings, $rankings_scrollbar);
