// 7185
[proc,script7185]
def_graphic $graphic = null;
def_string $string = "";
if (%option_loottracker_display_ignored_entries = 1) {
    $graphic, $string = "icon_tracker_loot01_30x30,3", "Hide";
} else {
    $graphic, $string = "icon_tracker_loot01_30x30,2", "Show";
}
if_setop(1, $string, loottools:loottracker_display_buttons_switch_ignore_mode);
if_setgraphic($graphic, loottools:loottracker_display_buttons_switch_ignore_mode);
