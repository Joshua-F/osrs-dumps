// 1246
[proc,script1246](component $component, string $string)
if_sethide(false, $component);
if_setontimer(null, $component);
~script1248(false, $component, $string);
if_setonmouseover("script1247(true, $component, $string)", $component);
if_setonmouseleave("script1247(false, $component, $string)", $component);
if_setonclick("script1249($component, $string)", $component);
