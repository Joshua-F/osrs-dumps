// 6779
[proc,toa_midraidloot_drawbutton](component $component)
def_int $int = ~v2_stone_button_out_filled($component);
if (~on_mobile = false) {
    if_setonmouserepeat("toa_midraidloot_button_hover(true, $component)", $component);
    if_setonmouseleave("toa_midraidloot_button_hover(false, $component)", $component);
}
cc_create($component, ^iftype_text, $int);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0xff981f);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextfont(p12_full);
cc_settextshadow(true);
cc_settext("Choose");
