// 3952
[proc,script3952](component $component, int $int1, int $int2, int $int3, int $int4, string $string, int $int5)(int)
cc_create($component, ^iftype_rectangle, $int5);
cc_setsize($int3, $int4, ^setsize_abs, ^setsize_abs);
cc_setposition($int1, $int2, ^setpos_abs_left, ^setpos_abs_top);
cc_settrans(255);
if (string_length($string) > 0) {
    cc_setonop("button_select_sound");
    cc_setop(1, $string);
}
return(calc($int5 + 1));
