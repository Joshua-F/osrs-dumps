// 4189
[proc,colour_pallet_update_text](component $component, int $int, struct $struct)
def_string $string = "#";
if (cc_find($component, $int) = true) {
    if (%varplayer_3010 = -1) {
        cc_settext(append($string, ~colour_to_string(struct_param($struct, param_1230))));
    } else {
        cc_settext(append($string, ~colour_to_string(%varplayer_3010)));
    }
}
