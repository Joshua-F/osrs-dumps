// 2755
[proc,wint_timer_resynch](component $component)
if (%wint_transmit_respawndelay <= 0) {
    if_setontimer(null, $component);
    return;
}
def_int $int = calc(clientclock + %wint_transmit_respawndelay * 30);
~wint_timer_countdown($component, $int);
if_setontimer("wint_timer_countdown($component, $int)", $component);
