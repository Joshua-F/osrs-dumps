// 400
[clientscript,fairyrings_confirm_expire](component $component, int $int)
if (clientclock < $int) {
    return;
}
if_sethide(false, fairyrings:1_clockwise);
if_sethide(false, fairyrings:1_anticlockwise);
if_sethide(false, fairyrings:2_clockwise);
if_sethide(false, fairyrings:2_anticlockwise);
if_sethide(false, fairyrings:3_clockwise);
if_sethide(false, fairyrings:3_anticlockwise);
if_setontimer(null, $component);
