// 3476
[proc,gravestone_generic_parsecoffer](int $int)(string)
if ($int < 0) {
    return("Loading...");
}
if ($int = 0) {
    return("Death's Coffer: <col=ffffff>Empty</col><br>Discard items to reduce a fee.");
}
if ($int = 1) {
    return("Death's Coffer: <col=ffffff>1 coin</col><br>Discard items to reduce a fee.");
}
return("Death's Coffer: <col=ffffff><~tostring_spacer($int, ",")> coins</col><br>Discard items to reduce a fee.");
