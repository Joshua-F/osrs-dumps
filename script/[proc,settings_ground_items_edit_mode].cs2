// 7116
[proc,settings_ground_items_edit_mode](int $int)
if (~on_enhanced_any = false) {
    return;
}
if (~on_mobile = true) {
    %ground_items_edit_mode_enabled_mobile = ~minmax(0, 1, $int);
} else {
    %ground_items_edit_mode_enabled_desktop = ~minmax(0, 2, $int);
}
if (~toplevel_is_mobile(~toplevel_getcomponents) = true) {
    ~script7429(24);
}
