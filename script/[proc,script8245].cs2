// 8245
[proc,script8245](objarray $objarray)(stringarray)
def_int $int0 = array_size($objarray);
def_stringarray $stringarray = array_create(string, 0, $int0);
def_int $int1 = 0;
def_string $string = "";
while ($int1 < $int0) {
    $string = oc_name($objarray($int1));
    if (array_indexof($stringarray, $string, 0, -1) = -1) {
        array_push($stringarray, $string);
    }
    $int1 = calc($int1 + 1);
}
return($stringarray);
