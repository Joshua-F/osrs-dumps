// 3622
[proc,clan_stonebutton_init](string $string, component $component, graphic $graphic)
~clan_stonebutton_draw(false, $string, $graphic, $component);
if_setonmouserepeat("clan_stonebutton_draw(true, $string, $graphic, event_com)", $component);
if_setonmouseleave("clan_stonebutton_draw(false, $string, $graphic, event_com)", $component);
if_setop(1, removetags($string), $component);
