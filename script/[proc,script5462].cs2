// 5462
[proc,script5462](int $int)
def_string $string = "Pause";
if (~xptracker_get_paused(null) = 1) {
    $string = "Unpause";
}
if (cc_find(interface_729:com_5, $int) = true) {
    cc_setopbase("<col=ff9040>All Trackers</col>");
    cc_setop(7, "Close");
    cc_setop(8, $string);
    cc_setonop("script5464(event_op)");
}
