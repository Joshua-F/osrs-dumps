// 1298
[proc,slayer_rewards_unlock_desc](int $int)(string)
def_string $string = enum(int, string, enum_835, $int);
if (%mm2_slayer_master = 1) {
    $string = ~string_findandreplace($string, "Nieve", "Steve");
}
if (%wgs_hero_part_1_vis ! 0) {
    $string = ~string_findandreplace($string, "Duradel", "Kuradal");
}
return($string);
