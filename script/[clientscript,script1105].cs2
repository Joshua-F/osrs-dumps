// 1105
[clientscript,script1105](int $int)
switch_int ($int) {
    case 0 :
        %option_level_up_message_disabled, %option_level_up_popup_list = 1, 0;
    case default :
        %option_level_up_message_disabled, %option_level_up_popup_list = 0, 0;
    case 2 :
        %option_level_up_message_disabled, %option_level_up_popup_list = 0, 1;
}
