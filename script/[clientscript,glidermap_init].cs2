// 1286
[clientscript,glidermap_init](component $universe, component $close, component $ogrearea_container, component $apeatoll_container)
~glidermap_hideshow($close, $ogrearea_container, $apeatoll_container);
if_setonvartransmit("glidermap_hideshow($close, $ogrearea_container, $apeatoll_container){pilot_journey, onesmallfavour, mm2_quest}", $universe);
cc_deleteall($universe);
cc_create($universe, ^iftype_model, 0);
~glidermap_fly;
cc_setonvartransmit("glidermap_fly(event_com, event_comsubid){pilot_journey}");
