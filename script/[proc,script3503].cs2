// 3503
[proc,script3503](component $component, boolean $boolean1, boolean $boolean2)
def_int $int = 0;
if ($boolean1 = true | $boolean2 = true) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $int = ~v2_stone_button_filled($component);
}
cc_create($component, ^iftype_graphic, $int);
cc_setsize(29, 22, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic("bankbuttons,4");
if ($boolean2 = true) {
    cc_settrans(0);
} else {
    cc_settrans(50);
}
