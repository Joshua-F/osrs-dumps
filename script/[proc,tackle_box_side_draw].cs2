// 4063
[proc,tackle_box_side_draw](int $int0, component $component)
def_obj $obj = null;
def_int $int3 = 0;
while ($int3 < $int0) {
    if (cc_find($component, $int3) = true) {
        cc_clearops;
        cc_setontimer(null);
        cc_setposition(calc($int3 % 4 * 42), calc($int3 / 4 * 36), ^setpos_abs_left, ^setpos_abs_top);
        $obj = inv_getobj(inv_93, $int3);
        if ($obj ! null) {
            ~tackle_box_setsideitem($obj, inv_getnum(inv_93, $int3), $int0);
        } else {
            ~tackle_box_setblank;
        }
    }
    $int3 = calc($int3 + 1);
}
