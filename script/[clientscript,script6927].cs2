// 6927
[clientscript,script6927](component $default_build_mode_on, component $default_build_mode_off, int $int)
%poh_teleport_building_mode = $int;
if (%poh_teleport_building_mode = 1) {
    if_setgraphic("options_radio_buttons,2", $default_build_mode_on);
    if_setgraphic("options_radio_buttons,0", $default_build_mode_off);
} else {
    if_setgraphic("options_radio_buttons,0", $default_build_mode_on);
    if_setgraphic("options_radio_buttons,2", $default_build_mode_off);
}
