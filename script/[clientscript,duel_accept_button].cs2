// 1443
[clientscript,duel_accept_button](component $component, int $int)
if (clientclock < $int) {
    return;
} else {
    if_settext("Accept", $component);
    if_setcolour(~duel_colour_variation(3394560), $component);
    if_setonmouseover("text_colour_swapper(event_com, ~duel_colour_variation(10087936))", $component);
    if_setonmouseleave("text_colour_swapper(event_com, ~duel_colour_variation(3394560))", $component);
    if_setontimer(null, $component);
}
