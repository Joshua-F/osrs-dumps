// 2289
[clientscript,raids_overlay_timer](component $component, int $int1, int $int2)
if (%varplayerbit_5425 >= 5) {
    return;
}
if (calc(clientclock % 30) = 0) {
    %varplayerbit_6386 = calc(%varplayerbit_6386 + 1);
    if (cc_find($component, $int1) = true & .cc_find($component, $int2) = true) {
        ~raids_overlay_databox($component);
    }
}
