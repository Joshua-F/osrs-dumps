// 8474
[proc,ui_highlight_init_fx](dbrow $dbrow)
switch_dbtable (db_getrowtable($dbrow)) {
    case ui_highlighting_fx_pulse :
        cc_setontimer("ui_highlight_pulse(cc_getlayer, cc_getid, db_getfield($dbrow, ui_highlighting_fx_pulse:transparency_range, 0), db_getfield($dbrow, ui_highlighting_fx_pulse:step_duration, 0))");
}
