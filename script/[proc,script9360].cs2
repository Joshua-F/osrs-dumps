// 9360
[proc,script9360](component $component, int $int)
%talent_tree_horizontal_scroll_pos = calc(($int - if_getwidth($component)) / 2);
%talent_tree_vertical_scroll_pos = calc(($int - if_getheight($component)) / 2);
if_setscrollpos(%talent_tree_horizontal_scroll_pos, %talent_tree_vertical_scroll_pos, $component);
