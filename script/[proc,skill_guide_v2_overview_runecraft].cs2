// 9168
[proc,skill_guide_v2_overview_runecraft](component $component)
~script9182($component, "", "Runecraft is a skill about crafting magic runes at runic altars around Gielinor for use when casting spells with the ||skill:<4>::<6>::Magic skill||. Use the tabs on the left to see what Runecraft level is required for crafting certain runes.<"||::p||">To craft runes and level your Runecraft skill, you first need rune essence and a talisman of the rune you want to make. Use the talisman to both locate and access the runic altar, then use the your rune essence on the altar to turn it into runes.");
~script9182($component, "Getting Started", "To get started, first complete the <~script9191(quest_runemysteries)> which rewards an air talisman and grants access to the Rune Essence Mine. Then, mine some rune essence and use your Air Talisman to locate the Air Altar and craft Air Runes.<"||::p||">Other talismans can be found by defeating various enemies around Gielinor. For example, the wizards south of Falador have a chance to drop their corresponding elemental talisman.");
def_stringarray $stringarray = array_create(string, 2, -1);
$stringarray(0) = "||skill:<4>::<6>::Magic:::|| Runes crafted with the Runecraft skill can be used to cast spells.";
$stringarray(1) = "||skill:<13>::<14>::Mining:::|| Rune essence used for crafting runes can be mined in the rune essence mine.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
