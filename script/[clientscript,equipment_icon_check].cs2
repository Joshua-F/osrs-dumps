// 2642
[clientscript,equipment_icon_check](component $component)
if (%tutorial = 400) {
    if_setontimer("equipment_icon_flash($component)", $component);
} else if (%tutorial_2 = 400) {
    if_setontimer("equipment_icon_flash($component)", $component);
} else {
    if_setgraphic("options_icons,16", $component);
    if_setontimer(null, $component);
}
