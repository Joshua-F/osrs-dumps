// 2908
[clientscript,gauntlet_map_init](component $close_button, int $int)
def_graphic $graphic2 = "close_buttons,5";
def_graphic $graphic3 = "close_buttons,4";
if_setonmouseover("graphic_swapper(event_com, $graphic2)", $close_button);
if_setonmouseleave("graphic_swapper(event_com, $graphic3)", $close_button);
~gauntlet_map_update;
