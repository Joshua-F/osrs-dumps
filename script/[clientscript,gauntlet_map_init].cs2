// 2908
[clientscript,gauntlet_map_init](component $com_2, int $int)
def_graphic $graphic2 = "close_buttons,5";
def_graphic $graphic3 = "close_buttons,4";
if_setonmouseover("graphic_swapper(event_com, $graphic2)", $com_2);
if_setonmouseleave("graphic_swapper(event_com, $graphic3)", $com_2);
~gauntlet_map_update;
