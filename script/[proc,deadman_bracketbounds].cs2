// 5227
[proc,deadman_bracketbounds]()(int, int)
switch_int (%deadman_bracket_transmit) {
    case 9 :
        return(96, 126);
    case 8 :
        return(81, calc(96 - 1));
    case 7 :
        return(61, calc(81 - 1));
    case 6 :
        return(45, calc(61 - 1));
    case 3 :
        return(96, 126);
    case 2 :
        return(81, calc(96 - 1));
    case 1 :
        return(61, calc(81 - 1));
}
return(3, calc(61 - 1));
