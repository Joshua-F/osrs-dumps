// 928
[clientscript,smokeoverlay_init](component $com_0)
cc_deleteall($com_0);
def_int $int = 0;
while ($int < 7) {
    cc_create($com_0, ^iftype_rectangle, $int);
    cc_setcolour(0xb4b4b4);
    cc_setfill(true);
    cc_settrans(calc(182 + $int * 9));
    $int = calc($int + 1);
}
cc_create($com_0, ^iftype_text, $int);
cc_setsize(1, 1, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settext("");
~script930($com_0, if_getheight($com_0));
