// 7241
[proc,ground_items_edit_mode]()(boolean)
def_int $int = %ground_items_edit_mode_enabled_desktop;
if (~on_mobile = true) {
    $int = %ground_items_edit_mode_enabled_mobile;
}
if ($int = 0) {
    return(false);
} else if ($int = 1) {
    return(true);
} else if (keypressed(%ground_items_modifier_key) = true | keyheld(%ground_items_modifier_key) = true) {
    return(true);
}
return(false);
