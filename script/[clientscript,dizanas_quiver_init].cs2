// 4973
[clientscript,dizanas_quiver_init](component $universe, component $ammo_obj, component $ammo_slot, component $close)
~dizanas_quiver_draw($ammo_obj, $ammo_slot, $close);
if_setoninvtransmit("dizanas_quiver_draw($ammo_obj, $ammo_slot, $close){inv, worn}", $universe);
if_setonvartransmit("dizanas_quiver_draw($ammo_obj, $ammo_slot, $close){dizanas_quiver_temp_ammo_amount, dizanas_quiver_temp_ammo}", $universe);
if_setopkey(1, ^key_escape, 0, $close);
