// 3949
[clientscript,settings_attack_display_dropdown_hover](boolean $boolean, component $component, int $int2, int $int3)
if (cc_find($component, $int2) = true & .cc_find($component, $int3) = true) {
    if ($boolean = true) {
        cc_setcolour(0xffb83f);
        .cc_sethide(false);
        .cc_setposition(cc_getx, calc(cc_gety - 1), ^setpos_abs_left, ^setpos_abs_top);
    } else {
        cc_setcolour(0xff981f);
        .cc_sethide(true);
    }
}
