// 8649
[proc,sailing_boat_selection_draw_facility_icon](component $component, int $int1, int $int2, int $int3, graphic $graphic, string $string, int $int5, int $int6)(int, int, int)
$int1 = ~create_graphic($component, $int1, $graphic, $int2, calc($int3 - 2 + ($int5 - 16) / 2), ^setpos_abs_left, ^setpos_abs_top, 16, 16, ^setsize_abs, ^setsize_abs, false);
cc_setnoclickthrough(true);
$int2 = calc($int2 + 16 + 5);
$int6 = calc($int6 + 1);
~sailing_boat_selection_tooltip("Facility", $string, 0);
return($int1, $int2, $int6);
