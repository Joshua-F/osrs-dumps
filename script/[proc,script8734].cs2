// 8734
[proc,script8734](dbrow $dbrow)(graphic)
if ($dbrow = null) {
    return("icon_sailing_player_18x18,0");
}
if (db_getrowtable($dbrow) ! sailing_crew) {
    ~debug_mes_error("Crew data for facility", "DBTable was not sailing_crew.");
    return("icon_sailing_player_18x18,0");
}
return(db_getfield($dbrow, sailing_crew:sprite, 0));
