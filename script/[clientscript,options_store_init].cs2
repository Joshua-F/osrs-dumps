// 2358
[clientscript,options_store_init](component $com_82, component $com_91)
def_string $string = "Old School Bonds";
if (~on_mobile = true) {
    $string = "Old School Store";
    if_setop(1, "View Old School Store", $com_82);
}
if_setonmouseleave("deltooltip($com_91)", $com_82);
if_setonmouserepeat("tooltip_mouserepeat($com_82, -1, $com_91, $string, 25, 190)", $com_82);
