// 2358
[clientscript,options_store_init](component $com_83, component $com_92)
def_string $string = "Old School Bonds";
if (~on_mobile = true) {
    $string = "Old School Store";
    if_setop(1, "View Old School Store", $com_83);
}
if_setonmouseleave("deltooltip($com_92)", $com_83);
if_setonmouserepeat("tooltip_mouserepeat($com_83, -1, $com_92, $string, 25, 190)", $com_83);
