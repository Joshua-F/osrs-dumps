// 41
[proc,deltooltip_action](component $component)
if (~on_enhanced_any = false & $component ! null & if_find($component) = true) {
    cc_setparam(param_2352, null);
    cc_setparam(param_2353, -1);
    cc_setparam(param_2354, "");
    cc_setontimer(null);
}
cc_deleteall($component);
%tooltip_built = 0;
if (~on_enhanced_any = true) {
    ~mouseover_tooltip_setup("", "", -1, -1, $component, null, -1, 0, 0, 1);
}
