// 883
[clientscript,options_clickthroughchat_init](component $com_39, component $com_109)
if_setonmouseleave("deltooltip($com_109)", $com_39);
~options_clickthroughchat($com_39, $com_109);
if_setonvartransmit("options_clickthroughchat_resynch($com_39, $com_109){varplayer_1055}", $com_39);
if_setop(1, ~text_device("Click through chatbox", "Tap through chatbox"), $com_39);
if_setonop("options_clickthroughchat_op(event_op, $com_39, $com_109)", $com_39);
