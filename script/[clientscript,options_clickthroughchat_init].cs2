// 883
[clientscript,options_clickthroughchat_init](component $com_115, component $com_112)
if_setonmouseleave("deltooltip($com_112)", $com_115);
~options_clickthroughchat($com_115, $com_112);
if_setonvartransmit("options_clickthroughchat_resynch($com_115, $com_112){varplayer_1055}", $com_115);
if_setop(1, ~text_device("Click through chatbox", "Tap through chatbox"), $com_115);
if_setonop("options_clickthroughchat_op(event_op, $com_115, $com_112)", $com_115);
