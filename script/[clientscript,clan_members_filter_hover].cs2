// 4241
[clientscript,clan_members_filter_hover](boolean $boolean, component $component, int $int2, int $int3, int $int4)
if ($boolean = true) {
    if (cc_find($component, $int2) = true) {
        cc_settrans($int4);
    }
    if_setontimer("script4242(calc(clientclock + 2), event_com, $int2, $int3)", $component);
} else {
    if (cc_find($component, $int2) = true) {
        cc_settrans($int3);
    }
    if_setontimer(null, $component);
}
