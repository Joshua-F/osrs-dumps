// 5896
[proc,script5896](component $component, string $string0, string $string1)
def_int $int = db_getfield(%latest_speedrun_panel, quest:id, 0);
if ($int <= 0 | $int ! %current_speedrun) {
    if (%current_speedrun > 0) {
        ~speedrunning_button_draw($component, $string0, true, true);
    } else {
        ~speedrunning_button_init($component, $string0);
    }
    return;
}
~speedrunning_button_init($component, $string1);
