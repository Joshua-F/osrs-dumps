// 7534
[proc,script7534](int $int)
def_string $string = stringvector_get(stringvector_5, $int);
if (string_length($string) <= 0) {
    return;
}
hiscore_setapi(0);
hiscore_lookup($string, 0);
if_sethide(false, hiscores:loading_data);
cc_deleteall(hiscores:loading_data);
~loading_icon_init(hiscores:loading_data, null, enum_3789, 10, 500, 3000, 512, 1024, 0, 3, "");
if_setontimer("hiscores_poll($string, 1)", hiscores:content);
if_setontimer("hiscores_poll_secondary($int)", hiscores:content);
