// 1060
[proc,farming_tools_main_update](component $component, obj $obj1, string $string, int $int2)
def_int $int3 = 0;
def_obj $obj4 = null;
$int3, $obj4 = ~farming_tools_getstored($obj1);
def_int $rgb = 0x7f2000;
if ($int3 > 0) {
    $rgb = 0x40ff40;
}
if ($obj1 = obj_6797) {
    if ($obj4 = null) {
        $obj4 = obj_6797;
    }
    $string = oc_name($obj4);
}
if (cc_find($component, 0) = true & .cc_find($component, 1) = true) {
    cc_settext($string);
    cc_setcolour($rgb);
    .cc_setcolour($rgb);
    .cc_settext("<tostring($int3)>/<tostring($int2)>");
}
if (cc_find($component, 2) = true) {
    cc_setobject_nonum($obj4, $int3);
}
if_setopbase("<col=ff9040><oc_name($obj4)></col>", $component);
