// 3701
[proc,league_setup_display_hoveroff](component $component, int $rgb)
if (cc_find($component, 0) = true) {
    cc_settrans(0);
    if (~on_mobile = false) {
        cc_setonmouseover("league_setup_display_hover(true, $component, $rgb)");
        cc_setonmouseleave("league_setup_display_hover(false, $component, $rgb)");
    }
}
if (cc_find($component, 3) = true) {
    cc_settrans(0);
    cc_setgraphic("scrollbar_v2,1");
}
if (cc_find($component, 4) = true) {
    cc_setcolour($rgb);
}
