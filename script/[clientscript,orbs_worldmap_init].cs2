// 1492
[clientscript,orbs_worldmap_init](component $orb_worldmap, component $worldmap_backing, component $worldmap)
~orbs_worldmap_setup($orb_worldmap, $worldmap_backing, $worldmap);
if_setonsubchange("orbs_worldmap_setup($orb_worldmap, $worldmap_backing, $worldmap)", $orb_worldmap);
if_setonvartransmit("orbs_worldmap_setup($orb_worldmap, $worldmap_backing, $worldmap){toplevel_temp, chat_filter_clan}", $orb_worldmap);
if (~on_mobile = false) {
    if_setonkeydown("orbs_worldmap_key(event_keycode, $worldmap)", $orb_worldmap);
}
