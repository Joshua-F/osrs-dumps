// 2391
[clientscript,mobile_billing_open](int $int, boolean $boolean)
if (~on_mobile = true) {
    if ($int = 1 & ~bonds_hide = true) {
        $int, $boolean = 3, true;
    }
    if ($int = 0) {
        shop_open;
    } else if ($int = 5) {
        shop_opencategories(16, 16);
    } else {
        shop_opensubset($int, $boolean);
    }
}
