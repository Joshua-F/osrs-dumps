// 3058
[clientscript,macro_beekeeper_confirmbutton](boolean $boolean, component $component1, component $component2)
if ($boolean = true) {
    if_sethide(false, $component2);
    if_setcolour(^white, $component1);
} else {
    if_sethide(true, $component2);
    if_setcolour(0xffffc8, $component1);
}
