// 4791
[clientscript,ca_bosses_init](component $universe, component $bosses_list, component $bosses_background, component $bosses_progress, component $bosses_name, component $bosses_button, component $bosses_button_click, component $bosses_monster, component $bosses_description, component $bosses_icon, component $bosses_none, component $bosses_scrollbar, component $burger_btn_menu, component $burger_menu_frame, component $burger_menu_overlay, component $searchbar_image, component $search_text, component $bosses_button_click_pause)
~ca_searchbar_create($searchbar_image);
~ca_searchbar_setup_op($universe, $searchbar_image, $search_text, 1);
~script4767($burger_btn_menu, $burger_menu_frame, $burger_menu_overlay, 3);
~steelborder(ca_bosses:frame, "Combat Achievements - Bosses", 0);
~scrollbar_vertical($bosses_scrollbar, $bosses_list, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~ca_bosses_draw_list($universe, $bosses_list, $bosses_background, $bosses_progress, $bosses_name, $bosses_button, $bosses_button_click, $bosses_monster, $bosses_description, $bosses_icon, $bosses_none, $bosses_scrollbar, $bosses_button_click_pause);
