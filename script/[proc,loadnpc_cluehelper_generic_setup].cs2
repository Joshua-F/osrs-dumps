// 6719
[proc,loadnpc_cluehelper_generic_setup]
def_entityoverlay $entityoverlay = entityoverlay_create_npc(3, ^overlaytype_top, calc(36 * 2), calc(32 * 2), 1);
if (if_find_entityoverlay($entityoverlay) = true) {
    cc_setonvartransmit("loadnpc_cluehelper_generic_transmit($entityoverlay, %cluehelper_infobox_clue, npc_uid, npc_creationcycle, %option_cluehelper_overlay_enabled){cluehelper_infobox_clue, option_cluehelper}");
}
~loadnpc_cluehelper_generic($entityoverlay, %cluehelper_infobox_clue, npc_uid, npc_creationcycle);
