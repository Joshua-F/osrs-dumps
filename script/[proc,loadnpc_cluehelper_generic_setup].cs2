// 6719
[proc,loadnpc_cluehelper_generic_setup]
def_entityoverlay $entityoverlay = entityoverlay_create_npc(3, ^overlaytype_top, calc(36 * 2), calc(32 * 2), 1);
if (if_find_entityoverlay($entityoverlay) = true) {
    cc_setonvartransmit("loadnpc_cluehelper_generic_transmit($entityoverlay, %varplayer_3546, npc_uid, npc_creationcycle, %varplayerbit_14189){varplayer_3546, varplayer_3543}");
}
~loadnpc_cluehelper_generic($entityoverlay, %varplayer_3546, npc_uid, npc_creationcycle);
