// 8195
[proc,cc_set_button_highlight](int $int0)
def_component $component = cc_getlayer;
def_int $int2 = cc_getid;
def_int $int3 = cc_param(param_2344);
if (cc_find($component, $int3) = true) {
    cc_sethide(false);
    cc_setparam(param_2349, calc(clientclock + max($int0, 0)));
    cc_setontimer("script8196(event_com, event_comsubid)");
}
cc_find($component, $int2);
