// 1353
[proc,script1353](string $string)(boolean)
if (~is_group_iron = true & (string_indexof_string($string, "////", 0) = 0 | string_indexof_string(lowercase($string), "/g ", 0) = 0 | string_indexof_string(lowercase($string), "/@g ", 0) = 0 | %chatbox_mode = 4 | %chat_view = 6)) {
    return(true);
}
return(false);
