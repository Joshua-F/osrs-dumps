// 7178
[proc,loottracker_value_item](obj $obj)(int, int, int)
def_int $int1 = 0;
def_int $int2 = 0;
def_int $int3 = 0;
if (oc_param($obj, param_295) = 0) {
    $int1 = ~script7127(oc_cost($obj));
}
if (oc_stockmarket($obj) = true) {
    $int3, $int2 = oc_stockmarketvalue($obj);
    $int2 = max($int2, 0);
}
if ($obj = coins) {
    $int1 = 1;
    $int2 = 1;
}
return($int1, $int2, $int3);
