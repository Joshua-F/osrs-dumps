// 7079
[clientscript,makeover_hover_colour](component $component, int $int, boolean $boolean)
if (cc_find($component, $int) = true & cc_find($component, calc($int + 1)) = true) {
    if ($boolean = true) {
        cc_setcolour(^white);
    } else if (%makeover_current_colour = $int) {
        cc_setcolour(0xff981f);
    } else {
        cc_setcolour(0x0e0e0c);
    }
}
