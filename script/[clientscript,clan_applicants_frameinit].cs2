// 4389
[clientscript,clan_applicants_frameinit](component $frame)
def_int $int = ~steelborder($frame, "", 0);
~clan_applicants_framedraw($frame, $int);
if_setonvartransmit("clan_applicants_framedraw($frame, $int){clan_temp_transmit_0}", $frame);
if_setonclansettingstransmit("clan_applicants_framedraw($frame, $int)", $frame);
