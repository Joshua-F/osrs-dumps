// 9164
[proc,skill_guide_v2_overview_magic](component $component)
def_stringarray $stringarray = array_create(string, 3, -1);
$stringarray(0) = "Your Magic level unlocks the ability to use increasingly powerful weapons, armour and spells, and determines your accuracy and damage with combat spells, as well as your chance to block damage from magic attacks, negating the damage you would have taken.";
$stringarray(1) = "As you level your Magic skill, you'll unlock the ability to cast increasingly powerful combat spells, as well as a wide variety of useful utility spells including the ability to convert items into gold and teleport all over Gielinor. Use the tabs on the left to see what level is required to cast certain spells and use certain equipment.";
$stringarray(2) = "To level your Magic skill, attack enemies with combat spells or simply cast non-combat spells. Each spell requires certain runes to cast. These can be viewed in the ||side_panel:6::<301>::Magic panel|| or by <~text_device("clicking", "tapping")> a spell in the Spell tabs on the left of this guide.";
~script9182($component, "", string_join($stringarray, "||::p||"));
array_resize($stringarray, 2);
$stringarray(0) = "Certain pieces of equipment can be used in place of certain runes when casting spells. For example, equipped elemental staves, such as a Staff of Air, count as an infinite supply of the corresponding elemental rune.";
$stringarray(1) = "Equipping a staff also enables <"||::hl||">auto-casting combat spells<"||::/hl||"> so you don't need to keep <~text_device("clicking", "tapping")> it in the spellbook. To auto-cast a spell, equip a staff, select the Spell combat style in the ||side_panel:0::<300>::Combat Options panel|| then choose a spell to auto-cast.";
~script9182($component, "Magic Equipment", string_join($stringarray, "||::p||"));
~script9182($component, "Getting Started", "To get started, obtain some Mind and Air runes and attack enemies with the Wind Strike spell. The Cows and Goblins east of Lumbridge are a good place to start. The ||::<142>::Magic Combat Tutor|| outside Lumbridge Castle also offers these basic runes to get started.<"||::p||">Certain runes can be purchased from ||::<121>::Magic Shops|| and basic elemental staves can be purchased from ||::<135>::Staff Shops||. Both shops can be found in Varrock.");
array_resize($stringarray, 4);
$stringarray(0) = "||skill:<6>::<8>::Hitpoints:::|| Attacking enemies also grants Hitpoints XP.";
$stringarray(1) = "||skill:<20>::<20>::Slayer:::|| Higher combat skills aid in fighting harder Slayer monsters.";
$stringarray(2) = "||skill:<7>::<5>::Prayer:::|| Some prayers apply a bonus to your Magic level and bones dropped by defeated enemies can be buried for Prayer XP.";
$stringarray(3) = "||skill:<12>::<7>::Runecraft:::|| Runes crafted with the Runecraft skill can be used to cast spells.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
