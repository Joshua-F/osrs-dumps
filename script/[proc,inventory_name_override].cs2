// 1787
[proc,inventory_name_override](obj $obj)(string)
def_string $string = oc_name($obj);
switch_obj ($obj) {
    case obj_22517 :
        if (%varplayerbit_14838 = 1) {
            $string = "<$string> (Active)";
        } else {
            $string = "<$string> (Inactive)";
        }
}
return($string);
