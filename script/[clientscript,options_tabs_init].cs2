// 527
[clientscript,options_tabs_init](component $com_1, component $com_3, component $com_15, component $com_34, component $com_41)
def_int $int = calc((190 - 160) / 5);
cc_deleteall($com_1);
~options_tabs_create(0, $com_3, "Display", "options_icons,22", $int, $com_1, $com_3, $com_15, $com_34, $com_41);
~options_tabs_create(1, $com_15, "Audio", "options_icons,2", $int, $com_1, $com_3, $com_15, $com_34, $com_41);
~options_tabs_create(2, $com_34, "Chat", "options_icons,23", $int, $com_1, $com_3, $com_15, $com_34, $com_41);
~options_tabs_create(3, $com_41, "Controls", "options_icons,26", $int, $com_1, $com_3, $com_15, $com_34, $com_41);
~options_tabs_switch(0, $com_3, $com_1, $com_3, $com_15, $com_34, $com_41);
