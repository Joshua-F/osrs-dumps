// 4327
[clientscript,script4327]
def_enum $enum = enum_3799;
def_int $int1 = enum_getoutputcount($enum);
def_int $int2 = 0;
def_struct $struct = null;
while ($int2 < $int1) {
    $struct = enum(int, struct, $enum, $int2);
    if_setmodel(struct_param($struct, param_1237), struct_param($struct, param_1235));
    $int2 = calc($int2 + 1);
}
