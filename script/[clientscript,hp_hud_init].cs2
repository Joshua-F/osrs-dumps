// 2099
[clientscript,hp_hud_init](component $universe, component $hpdodgerside, component $hpdodger, component $hp, component $name_area, component $hp_bar, component $hp_bar_text, component $health_bar_back, component $health_bar_sliding, component $health_bar_remaining, component $creature_name, int $int11, int $int12, int $int13, component $health_bar_lower_threshold, component $health_bar_upper_threshold, component $hp_bar_1, component $hp_bar_2, component $hpcontentside)
~interface_dodger_init($hpdodgerside, $hpcontentside, setbit(65256, 17), ^setpos_abs_left, ^setpos_abs_top, true);
if_setonsubchange("hp_hud_pos(0, $universe, $hp, $name_area, $hp_bar, $creature_name, $hp_bar_text, $health_bar_back, $health_bar_sliding, $health_bar_remaining, $health_bar_lower_threshold, $health_bar_upper_threshold, $hp_bar_1, $hp_bar_2, %hpbar_hud_boss, $hpdodger, $hpcontentside, $hpdodgerside)", $universe);
if_setonvartransmit("hp_hud_update($hp, $hp_bar_text, $health_bar_back, $health_bar_sliding, $health_bar_remaining, $name_area, $creature_name, $health_bar_lower_threshold, $health_bar_upper_threshold, $hp_bar_1, $hp_bar_2, false){hpbar_hud_info, hpbar_hud_npc}", $hp_bar_text);
