// 8459
[proc,script8459]()(int, int)
def_int $int0 = .cc_getx;
def_int $int1 = .cc_gety;
def_component $component = .cc_getparentlayer;
while ($component ! null) {
    $int0 = calc($int0 + if_getx($component));
    $int1 = calc($int1 + if_gety($component));
    $component = if_getparentlayer($component);
}
return($int0, $int1);
