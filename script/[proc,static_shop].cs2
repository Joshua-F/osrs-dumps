// 5020
[proc,static_shop](inv $inv)(boolean)
if ($inv = null | $inv = roguetrader_alim_runedump) {
    return(false);
}
if (~speedrunning_world = true) {
    return(true);
}
if (~league_world = true) {
    return(true);
}
if (enum(inv, boolean, enum_1173, $inv) = true) {
    return(true);
}
if (enum(inv, boolean, enum_5412, $inv) = true) {
    return(true);
}
return(false);
