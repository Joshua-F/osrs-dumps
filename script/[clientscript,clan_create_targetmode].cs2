// 4455
[clientscript,clan_create_targetmode](boolean $boolean, component $component, string $string, graphic $graphic)
if ($boolean = true) {
    %varclient_454 = 1;
    sound_synth(synth_2266, 1, 0);
    mes("You're now in Invite Target Mode. <~text_device("Left click", "Tap")> someone to invite them.");
} else {
    %varclient_454 = 0;
    mes("You're no longer in Invite Target Mode.");
}
~clan_stonebutton_draw($boolean, "Invite", p12_full, $component);
