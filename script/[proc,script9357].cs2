// 9357
[proc,script9357](component $component, int $int1, int $setposh, int $setposv, int $int4, graphic $graphic)(int)
cc_create($component, ^iftype_graphic, $int1);
cc_setsize($int4, $int4, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, $setposh, $setposv);
cc_setgraphic($graphic);
return(calc($int1 + 1));
