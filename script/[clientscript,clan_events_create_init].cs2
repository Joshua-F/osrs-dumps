// 4413
[clientscript,clan_events_create_init](component $universe, component $frame, component $exit, component $create, int $int4, int $int5, int $int6, int $int7, int $int8, int $int9, int $int10, int $int11, component $delete)
~stonebutton_init("<col=ff0000>Back</col>", $exit, p12_full, 0);
if_setonop("opsound(event_op, 2)", $exit);
if (%clans_event_edit_menu_slot > 0) {
    ~stonebutton_init("<col=0dc10d>Save</col>", $create, p12_full, 0);
} else {
    ~stonebutton_init("<col=0dc10d>Create</col>", $create, p12_full, 0);
}
if_setonop("opsound(event_op, 2)", $create);
if (%clans_event_edit_menu_slot > 0) {
    ~stonebutton_init("<col=ff0000>Delete</col>", $delete, p12_full, 0);
    if_setonop("opsound(event_op, 2)", $delete);
} else {
    if_sethide(true, $delete);
}
def_int $int13 = ~steelborder($frame, "", 0);
if (%clan_affinitystatus = 3 & activeclansettings_find_affined(^clantype_clan) = true & cc_find($frame, $int13) = true) {
    cc_settext("<activeclansettings_getclanname>: Events");
}
