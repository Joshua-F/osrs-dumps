// 4490
[clientscript,tob_scoreboard_init](component $universe, component $story_tab, component $normal_tab, component $hard_tab)
if_setonvartransmit("tob_scoreboard_tab_update($story_tab, $normal_tab, $hard_tab){tob_perm_transmit_1}", $universe);
if_setonop("tob_scoreboard_tab_select($story_tab, $normal_tab, $hard_tab, 0)", $normal_tab);
if_setonop("tob_scoreboard_tab_select($story_tab, $normal_tab, $hard_tab, 1)", $story_tab);
if_setonop("tob_scoreboard_tab_select($story_tab, $normal_tab, $hard_tab, 2)", $hard_tab);
~tob_scoreboard_tab_update($story_tab, $normal_tab, $hard_tab);
