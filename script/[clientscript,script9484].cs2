// 9484
[clientscript,script9484](int $int, component $component)
if ($int = 1) {
    sound_synth(synth_2266, 1, 0);
    if (%sailing_sidepanel_boat_wind_charges > 0) {
        if_setgraphic("orb_filler,10", $component);
        if_setontimer("script9485(calc(clientclock + 10), $component)", $component);
    } else {
        ~script9483($component);
    }
}
