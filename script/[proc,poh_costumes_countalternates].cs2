// 3541
[proc,poh_costumes_countalternates](obj $obj)(int)
if (enum(obj, boolean, enum_3305, $obj) = true) {
    return(1);
}
if (enum(obj, namedobj, enum_3303, $obj) ! null) {
    return(2);
}
def_enum $enum = enum(obj, enum, enum_3304, $obj);
if ($enum ! null) {
    return(calc(1 + enum_getoutputcount($enum)));
}
return(1);
