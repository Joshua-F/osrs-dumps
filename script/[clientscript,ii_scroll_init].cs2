// 2534
[clientscript,ii_scroll_init](component $com_1, component $com_2)
def_int $setposv = ^setpos_abs_top;
if (~on_mobile = true) {
    $setposv = ^setpos_abs_bottom;
}
if_setposition(0, 0, ^setpos_abs_right, $setposv, $com_2);
~interface_dodger_init($com_1, $com_2, setbit(0, 1), ^setpos_abs_right, $setposv, false);
