// 2534
[clientscript,ii_scroll_init](component $dodger, component $content)
def_int $setposv = ^setpos_abs_top;
if (~on_mobile = true) {
    $setposv = ^setpos_abs_bottom;
}
if_setposition(0, 0, ^setpos_abs_right, $setposv, $content);
~interface_dodger_init($dodger, $content, setbit(0, 1), ^setpos_abs_right, $setposv, false);
