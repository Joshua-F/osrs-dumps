// 4334
[proc,clan_hall_settings_set_value](struct $struct, int $int)
switch_struct ($struct) {
    case struct_2917 :
        %clan_editing_hall_homeworld = $int;
    case struct_2919 :
        %clan_editing_hall_locked = $int;
    case struct_2918 :
        %clan_editing_hall_playercount = $int;
    case struct_2920 :
        %clan_editing_hall_theme = $int;
}
