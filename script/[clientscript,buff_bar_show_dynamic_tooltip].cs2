// 1782
[clientscript,buff_bar_show_dynamic_tooltip](struct $struct, component $component1, int $int2, component $component3, int $int4)
def_string $string = ~buff_bar_dynamic_tooltip(struct_param($struct, param_1275));
if (~on_mobile = true) {
    ~buff_bar_mobile_tooltip($component1, $int2, $component3, $string, $int4);
} else {
    ~tooltip_mouserepeat($component1, $int2, $component3, $string, 0, $int4);
}
