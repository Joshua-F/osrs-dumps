// 4816
[clientscript,ca_tasks_init](component $universe, component $frame, component $tasks_list, component $tasks_background, component $tasks_name, component $tasks_type, component $tasks_monster, component $tasks_description, component $tasks_expand, component $tasks_tier, component $tasks_none, component $tasks_scrollbar, component $burger_btn_menu, component $burger_menu_frame, component $burger_menu_overlay)
~script4767($burger_btn_menu, $burger_menu_frame, $burger_menu_overlay, 1);
def_int $int = ~steelborder($frame, "Combat Achievements - Tasks", 0);
if_setscrollpos(0, 0, $tasks_list);
cc_deleteall($tasks_scrollbar);
~scrollbar_vertical($tasks_scrollbar, $tasks_list, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
if_setontimer("ca_tasks_draw_list_timer(-1, $universe, $frame, $tasks_list, $tasks_background, $tasks_name, $tasks_type, $tasks_monster, $tasks_description, $tasks_expand, $tasks_tier, $tasks_none, $tasks_scrollbar, $int, clientclock)", $universe);
