// 1454
[clientscript,zmi_bank_payment_init](boolean $boolean, string $string0, string $string1)
def_component $frame = zmi_bank_payment:frame;
def_component $buttons_layer = zmi_bank_payment:buttons_layer;
def_component $info_text_layer = zmi_bank_payment:info_text_layer;
~steelborder($frame, $string0, 0);
if_setonvartransmit("bank_payment_draw($buttons_layer, -1, $boolean){rune_pouch_a, rune_pouch_b, rune_pouch_c, rune_pouch_d, league_general, league_relics}", $buttons_layer);
if_setoninvtransmit("bank_payment_draw($buttons_layer, -1, $boolean){inv}", $buttons_layer);
~bank_payment_draw($buttons_layer, -1, $boolean);
cc_create($info_text_layer, ^iftype_text, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_rel_centre, ^setpos_rel_centre);
cc_settext($string1);
cc_settextfont(b12_full);
cc_settextshadow(true);
cc_setcolour(0xff981f);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
