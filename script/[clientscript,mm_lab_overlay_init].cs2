// 7035
[clientscript,mm_lab_overlay_init](component $content, component $dodger, component $tooltip)
~interface_dodger_init($dodger, $content, 52968, ^setpos_abs_left, ^setpos_abs_top, true);
def_int $int = if_getheight($content);
~mm_lab_overlay_draw($content, $tooltip, $int);
if_setonvartransmit("mm_lab_overlay_draw($content, $tooltip, $int){mm_lab_orders, mm_lab_mixer, mm_lab_mixer_3, mm_lab_mixer_4}", $content);
if_setonstattransmit("mm_lab_overlay_draw($content, $tooltip, $int){herblore}", $content);
