// 1510
[clientscript,raids_overlay_databox](component $component, int $int1, int $int2)
if (cc_find($component, $int1) = true & .cc_find($component, $int2) = true) {
    ~raids_overlay_databox($component);
    if (%raids_timer > 0 & %raids_client_progress < 5) {
        cc_setontimer("raids_overlay_timer($component, $int1, $int2)");
    }
    if (%raids_client_progress >= 5) {
        cc_setontimer(null);
    }
}
