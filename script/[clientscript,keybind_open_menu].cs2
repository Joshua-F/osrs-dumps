// 985
[clientscript,keybind_open_menu](component $component0, component $dropdown, component $dropdown_bounding_box, component $dropdown_list, int $int4, int $int5, component $component6)
%keybinding_stone_selection = $int5;
~keybind_build_dropdown($dropdown, $dropdown_bounding_box, $dropdown_list, $int4);
def_component $component7 = if_getlayer($component0);
if_setposition(calc(if_getx($component7) + 40), calc(if_gety($component7) + 22), ^setpos_abs_left, ^setpos_abs_top, $dropdown);
if (calc(if_gety($dropdown) + if_getheight($dropdown)) > if_getheight($dropdown_bounding_box)) {
    if_setposition(if_getx($dropdown), calc(if_gety($component7) + 6 - if_getheight($dropdown)), ^setpos_abs_left, ^setpos_abs_top, $dropdown);
}
if (~on_mobile = true) {
    if_setgraphic("mobile_stones,1", $component6);
} else {
    if_setgraphic("pre_eoc_stones,1", $component6);
}
if_sethide(false, $dropdown_bounding_box);
if_setonclick("keybind_close_dropdown($dropdown_bounding_box, $component6)", $dropdown_bounding_box);
