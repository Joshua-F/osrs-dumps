// 3557
[proc,poh_costumes_buttons_toggle_reset](component $component, graphic $graphic)
def_boolean $boolean = ~int_to_bool(%poh_costumes_mode);
if_setonvartransmit("poh_costumes_buttons_toggle_reset($component, $graphic, 0){item_redemption}", $component);
~poh_costumes_buttons_draw($component, $graphic, null, $boolean);
if_setontimer(null, $component);
if_setonop("poh_costumes_buttons_toggle_op(event_op, $component, $graphic)", $component);
