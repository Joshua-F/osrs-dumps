    while ($int5 < 100 & $component ! null & $int0 >= 278) {
        if (~pm_filtertest($int5) = true) {
            $chattype = chat_gethistorytype($int5);
            if ($chattype = ^chattype_privatechat) {
                $int0 = calc($int0 - ~script203("From <chat_gethistoryname($int5)>:", chat_gethistorymessage($int5), $int1, $component, interface_548:com_75, $int7, 0, 13, $int0, 1));
