// 6012
[proc,inventory_setophelds](obj $obj, boolean $boolean)
cc_setop(enum(int, int, enum_4303, 1), oc_iop($obj, 1));
cc_setop(enum(int, int, enum_4303, 2), oc_iop($obj, 2));
cc_setop(enum(int, int, enum_4303, 3), oc_iop($obj, 3));
cc_setop(enum(int, int, enum_4303, 4), oc_iop($obj, 4));
cc_setop(enum(int, int, enum_4303, 5), oc_iop($obj, 5));
def_int $int = oc_shiftclickiop($obj);
if (%varplayerbit_5542 = 1 & ($boolean = true | getsimulatedshiftactive = true) & $int ! -1) {
    cc_setop(1, cc_getop(enum(int, int, enum_4303, $int)));
    cc_setop(enum(int, int, enum_4303, $int), "");
}
cc_setop(10, "Examine");
