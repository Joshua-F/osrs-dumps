// 1534
[clientscript,script1534](int $int0, component $component, int $int2, string $string)
if ($int0 ! 1) {
    return;
}
sound_synth(synth_2266, 1, 0);
if (cc_find($component, $int2) = true) {
    cc_setcolour(0x7f7f7f);
    cc_settext("...");
}
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_clearops($component);
if_setontimer("script1535($component, $int2, $string, calc(clientclock + 80))", $component);
if (cc_find(raids_lobby_partydetails:contents, enum(component, int, enum_1539, $component)) = true) {
    cc_resume_pausebutton;
}
