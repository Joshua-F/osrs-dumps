// 9167
[proc,skill_guide_v2_overview_ranged](component $component)
~script9182($component, "", "Your Ranged level determines your accuracy and damage with ranged weapons and unlocks the ability to use increasingly powerful ranged weapons, ammunition and armour. Use the tabs on the left to see what level is required to equip certain equipment.<"||::p||">To level your Ranged skill, attack enemies with a ranged weapon. Most ranged weapons require specific types of ammunition to be equipped, such as arrows when wielding a bow and bolts when wielding a crossbow. The ammunition a weapon can use is displayed alongside the weapon's entry in the tabs on the left.");
~script9182($component, "Getting Started", "To get started, equip a ranged weapon and respective ammunition then attack some enemies! Cows and Goblins east of Lumbridge are a good place to start.<"||::p||">Certain ranged weapons and ammunition can be purchased from ||::<103>::Archery Shops||, such as the one in Varrock. The ||::<142>::Ranged Combat Tutor|| outside Lumbridge Castle also offers basic ammunition to get started.");
def_stringarray $stringarray = array_create(string, 7, -1);
$stringarray(0) = "||skill:<6>::<8>::Hitpoints:::|| Attacking enemies also grants Hitpoints XP.";
$stringarray(1) = "||skill:<20>::<20>::Slayer:::|| Higher combat skills aid in fighting harder Slayer monsters.";
$stringarray(2) = "||skill:<7>::<5>::Prayer:::|| Some prayers apply a bonus to your Ranged level and bones dropped by defeated enemies can be buried for Prayer XP.";
$stringarray(3) = "||skill:<19>::<13>::Fletching:::|| Weapons and ammunition created with the Fletching skill can be used in ranged combat.";
$stringarray(4) = "||skill:<14>::<15>::Smithing:::|| Ammunition created with the Smithing skill can be used in ranged combat.";
$stringarray(5) = "||skill:<11>::<12>::Crafting:::|| Armour created with the Crafting skill provides boosts to ranged combat.";
$stringarray(6) = "||skill:<24>::<24>::Sailing:::|| Boat cannons can be operated with the Ranged skill.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
