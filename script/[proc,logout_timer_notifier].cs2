// 5326
[proc,logout_timer_notifier]
def_enum $enum = ~toplevel_getcomponents;
def_component $component = enum(component, component, $enum, toplevel_osrs_stretch:ehc_listener);
if (~on_enhanced_any = false | %logout_notification_disabled = 1) {
    if_setontimer(null, $component);
    return;
}
if_setontimer("logout_timer_notifier", $component);
