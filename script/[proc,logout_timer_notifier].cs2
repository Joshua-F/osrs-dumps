// 5326
[proc,logout_timer_notifier]
def_enum $enum = ~toplevel_getcomponents;
def_component $component = enum(component, component, $enum, interface_161:com_35);
if (~on_enhanced = false | %varplayerbit_13083 = 1 | ~on_mobile = true) {
    if_setontimer(null, $component);
    cc_deleteall($component);
    return;
}
if_setontimer("logout_timer_notifier", $component);
