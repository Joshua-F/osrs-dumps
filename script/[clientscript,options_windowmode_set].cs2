// 847
[clientscript,options_windowmode_set](int $windowmode, component $component1, component $component2, component $component3)
if (getwindowmode = $windowmode) {
    return;
}
sound_synth(synth_2266, 1, 0);
setwindowmode($windowmode);
if (getdefaultwindowmode ! $windowmode) {
    setdefaultwindowmode($windowmode);
}
~options_windowmode_draw($component1, $component2, $component3);
