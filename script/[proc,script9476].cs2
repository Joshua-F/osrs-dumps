// 9476
[proc,script9476](dbrow $dbrow)(dbrow, boolean)
switch_dbrow ($dbrow) {
    case skill_feature_magic_standard_48_home_teleport :
        if (%league_type = 6) {
            return(skill_feature_magic_standard_leagues_6_home_teleport, true);
        }
        if (%league_type = 1) {
            return(skill_feature_magic_standard_league_twisted_home_teleport, true);
        }
        if (%league_type = 3) {
            return(skill_feature_magic_standard_league_3_home_teleport, true);
        }
    case skill_feature_magic_ancient_01_zaros_home_tele :
        if (%league_type = 6) {
            return(skill_feature_magic_ancient_leagues_6_home_teleport, true);
        }
        if (%league_type = 3) {
            return(skill_feature_magic_ancient_league_3_home_teleport_2, true);
        }
    case skill_feature_magic_lunar_01_lunar_home_tele :
        if (%league_type = 6) {
            return(skill_feature_magic_lunar_leagues_6_home_teleport, true);
        }
        if (%league_type = 3) {
            return(skill_feature_magic_lunar_league_3_home_teleport_3, true);
        }
    case skill_feature_magic_arceuus_01_arceuus_home_teleport :
        if (%league_type = 6) {
            return(skill_feature_magic_arceuus_leagues_6_home_teleport, true);
        }
        if (%league_type = 3) {
            return(skill_feature_magic_arceuus_league_3_home_teleport_4, true);
        }
}
return($dbrow, false);
