// 9056
[proc,script9056](dbtable $dbtable, dbrow $dbrow)(int)
if ($dbtable = null) {
    $dbtable = db_getrowtable($dbrow);
}
switch_dbtable ($dbtable) {
    case sailing_boat_facility :
        return(db_getfield($dbrow, sailing_boat_facility:construction_requirement, 0));
    case sailing_boat_keel :
        return(db_getfield($dbrow, sailing_boat_keel:construction_requirement, 0));
    case sailing_boat_hull :
        return(db_getfield($dbrow, sailing_boat_hull:construction_requirement, 0));
    case sailing_boat_sail :
        return(db_getfield($dbrow, sailing_boat_sail:construction_requirement, 0));
    case sailing_boat_steering :
        return(db_getfield($dbrow, sailing_boat_steering:construction_requirement, 0));
    case sailing_boat_flag :
        return(db_getfield($dbrow, sailing_boat_flag:construction_requirement, 0));
    case sailing_boat_brazier :
        return(db_getfield($dbrow, sailing_boat_brazier:construction_requirement, 0));
    case sailing_boat_trim :
        return(db_getfield($dbrow, sailing_boat_trim:construction_requirement, 0));
    case default :
        return(-1);
}
