// 4620
[clientscript,ehc_rating_init](component $yes_button, component $no_button, component $ask_later_button, component $dont_ask_toggle, component $text, component $model_l, component $model_r)
~membership_benefits_prompt_button_init($yes_button, "Yes");
~membership_benefits_prompt_button_init($no_button, "No");
~membership_benefits_prompt_button_init($ask_later_button, "Skip");
if_setop(1, "Select", $dont_ask_toggle);
if_setonop("ehc_rating_toggle_prompt(ehc_rating:dont_ask_box)", $dont_ask_toggle);
if_setonvartransmit("ehc_rating_toggle_box(ehc_rating:dont_ask_box){ehc_rating_varp}", ehc_rating:dont_ask_box);
if_settext("We hope you're enjoying our game client!<br><br>Would you recommend it to a friend?", $text);
if_setmodel(model_36049, $model_l);
if_setmodel(model_36049, $model_r);
