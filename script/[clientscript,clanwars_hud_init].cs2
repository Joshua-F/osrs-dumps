// 593
[clientscript,clanwars_hud_init](component $universe, component $dodger_right, component $dodger_middle, component $info, component $countdown)
~interface_dodger_init($dodger_middle, $countdown, 52968, ^setpos_abs_centre, ^setpos_abs_top, false);
~interface_dodger_init($dodger_right, $info, 36580, ^setpos_abs_right, ^setpos_abs_top, false);
cc_deleteall($info);
cc_create($info, ^iftype_graphic, 0);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setgraphic(tradebacking_dark);
cc_settiling(true);
cc_settrans(100);
def_int $int5 = ~thinbox($info, 1);
cc_create($info, ^iftype_text, $int5);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_left, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_setcolour(0xff981f);
cc_create($info, ^iftype_text, calc($int5 + 1));
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_setcolour(0xcf0000);
cc_create($info, ^iftype_text, calc($int5 + 2));
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_setcolour(0x7f7fff);
cc_create($info, ^iftype_text, calc($int5 + 3));
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_setcolour(0xff981f);
~clanwars_hud_info_update($universe, $info, $int5);
cc_deleteall($countdown);
def_int $int6 = 0;
def_int $int7 = if_getwidth($countdown);
def_int $int8 = if_getheight($countdown);
cc_create($countdown, ^iftype_graphic, $int6);
$int6 = calc($int6 + 1);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize($int7, $int8, ^setsize_abs, ^setsize_abs);
cc_setgraphic(tradebacking_dark);
cc_settiling(true);
cc_settrans(100);
$int6 = ~thinbox($countdown, $int6);
cc_create($countdown, ^iftype_text, $int6);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize($int7, $int8, ^setsize_abs, ^setsize_abs);
cc_settextfont(quill_oblique_large);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
~clanwars_hud_countdown_update($universe, $countdown);
if_setonvartransmit("clanwars_hud_update($universe, $info, $int5, $countdown, $int6){prayer9, prayer10, prayer11, prayer12, prayer15}", $universe);
if_setonclansettingstransmit("clanwars_hud_update($universe, $info, $int5, $countdown, $int6)", $universe);
