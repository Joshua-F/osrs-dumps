// 4743
[proc,highlighting_channel_setup]
def_int $int = %varplayer_3108;
if (%varplayerbit_12342 = 0) {
    if ($int < 1) {
        $int = calc(struct_param(struct_3005, param_1230) + 1);
    }
    highlight_tile_setup(6, calc($int - 1), 2, 50, 90);
    clientop_tile_set(1, "Mark tile", script4762);
} else {
    highlight_tile_setup(6, null, 0, 0, 64);
    clientop_tile_del(1);
}
