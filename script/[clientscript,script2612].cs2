// 2612
[clientscript,script2612](obj $obj, component $component1, component $component2, int $int)
sound_synth(synth_2266, 1, 0);
cc_deleteall($component2);
if (%magic_spellbook_tooltip = $obj) {
    %magic_spellbook_tooltip = null;
    if_setontimer(null, $component1);
    return;
}
%magic_spellbook_tooltip = $obj;
if_setontimer("script2613($component1, $component2, $int)", $component1);
