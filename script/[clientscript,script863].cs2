// 863
[clientscript,script863](component $component, int $int)
if (clientclock < $int) {
    return;
}
cc_deleteall($component);
~options_button_off($component, 0);
if_setcolour(0xa6a692, favour_keyring:remove_text);
if_setonmouserepeat("text_colour_swapper(favour_keyring:remove_text, 16777215)", favour_keyring:remove);
if_setonmouseleave("text_colour_swapper(favour_keyring:remove_text, 10921618)", favour_keyring:remove);
if_setontimer(null, $component);
