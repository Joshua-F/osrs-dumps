// 688
[clientscript,trail_slidepuzzle_init](component $pieces, component $grid_standard, component $grid_mm, component $grid_background)
def_int $int4 = calc(37 + (if_getwidth($pieces) - 5 * 37) / (5 - 1));
def_int $int5 = calc(37 + (if_getheight($pieces) - 5 * 37) / (5 - 1));
def_int $int6 = pow(5, 2);
def_int $int7 = calc($int6 - 1);
cc_deleteall($pieces);
def_int $int8 = 0;
while ($int8 < $int6) {
    cc_create($pieces, ^iftype_text, $int8);
    cc_setsize(37, 37, ^setsize_abs, ^setsize_abs);
    cc_setposition(calc($int8 % 5 * $int4), calc($int8 / 5 * $int5), ^setpos_abs_left, ^setpos_abs_top);
    cc_setopbase("<col=ff9040>Sliding piece</col>");
    $int8 = calc($int8 + 1);
}
$int8 = 0;
while ($int8 < $int7) {
    cc_create($pieces, ^iftype_model, calc($int8 + $int6));
    cc_setsize(37, 37, ^setsize_abs, ^setsize_abs);
    cc_setmodelangle(0, 0, 513, 0, 0, 1800);
    $int8 = calc($int8 + 1);
}
~trail_slidepuzzle_synch($pieces, $int6, $int7, $int4, $int5, $grid_standard, $grid_mm, $grid_background);
if_setoninvtransmit("trail_slidepuzzle_synch(false, $pieces, $int6, $int7, $int4, $int5, $grid_standard, $grid_mm, $grid_background){trail_puzzleinv, reinitialisation_inv, reinitialisation_inv_inactive}", $pieces);
if_setonvartransmit("trail_slidepuzzle_synch(true, $pieces, $int6, $int7, $int4, $int5, $grid_standard, $grid_mm, $grid_background){if1}", $pieces);
