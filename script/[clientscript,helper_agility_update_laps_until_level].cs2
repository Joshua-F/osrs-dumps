// 5180
[clientscript,helper_agility_update_laps_until_level](int $int)
def_string $string = "...";
if (%helper_agility_laps_completed > 0) {
    $string = tostring(~max(%helper_agility_laps_until_level, 0));
}
if (%helper_agility_next_level <= 99) {
    ~helper_generic_update_text($int, $string);
} else {
    ~helper_agility_draw_content;
}
