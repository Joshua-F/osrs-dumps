// 5467
[proc,xptracker_pause_stat](stat $stat, int $int1)
~xptracker_set_paused($stat, $int1);
def_int $int2 = ~xptracker_get_id($stat);
if (cc_find(interface_729:com_5, $int2) = true) {
    if ($int1 = 1) {
        cc_setop(10, "Unpause");
    } else {
        cc_setop(10, "Pause");
    }
}
if (~xptracker_get_id($stat) > 0) {
    ~xptracker_update_stat_display($stat);
}
