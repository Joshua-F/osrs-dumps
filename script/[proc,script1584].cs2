// 1584
[proc,script1584](component $component, int $int)
cc_deleteall($component);
cc_create($component, ^iftype_graphic, 0);
cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
cc_setgraphicshadow(0x333333);
cc_setoutline(1);
cc_sethide(true);
.cc_create($component, ^iftype_text, 1);
.cc_setsize($int, 30, ^setsize_abs, ^setsize_abs);
.cc_settextfont(p11_full);
.cc_settextshadow(true);
.cc_setcolour(0xff981f);
.cc_settextalign(^settextalign_centre, ^settextalign_top, 0);
.cc_sethide(true);
