// 2036
[proc,agilityarena_rewards_gracefulbutton_drawcomponents](component $component, int $int, obj $obj, string $string, int $rgb)
cc_create($component, ^iftype_model, $int);
$int = calc($int + 1);
cc_setposition(0, 5, ^setpos_abs_centre, ^setpos_abs_bottom);
if ($obj = null) {
    cc_setsize(10, 30, ^setsize_minus, ^setsize_minus);
    cc_setmodel(model_32817);
    cc_setmodelangle(0, 90, 0, 117, 0, 720);
    cc_setmodelanim(human_ready);
} else {
    cc_setsize(50, 50, ^setsize_abs, ^setsize_abs);
    cc_setobject_nonum($obj, 1);
}
cc_create($component, ^iftype_text, $int);
$int = calc($int + 1);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_top);
cc_setsize(0, 25, ^setsize_minus, ^setsize_abs);
cc_settextfont(p11_full);
cc_settextalign(^settextalign_centre, ^settextalign_bottom, 0);
cc_setcolour($rgb);
cc_settextshadow(true);
cc_settext($string);
