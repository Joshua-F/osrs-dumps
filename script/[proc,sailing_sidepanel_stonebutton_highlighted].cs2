// 8756
[proc,sailing_sidepanel_stonebutton_highlighted](component $component, int $int, int $rgb)(int)
if (cc_find($component, calc($int + 0)) = true) {
    cc_setgraphic(tradebacking);
}
if (cc_find($component, calc($int + 1)) = true) {
    cc_setgraphic("v2_stone_button_small,8");
}
if (cc_find($component, calc($int + 2)) = true) {
    cc_setgraphic("v2_stone_button_small,9");
}
if (cc_find($component, calc($int + 3)) = true) {
    cc_setgraphic("v2_stone_button_small,10");
}
if (cc_find($component, calc($int + 4)) = true) {
    cc_setgraphic("v2_stone_button_small,11");
}
if (cc_find($component, calc($int + 5)) = true) {
    cc_setgraphic("v2_stone_button_small,12");
}
if (cc_find($component, calc($int + 6)) = true) {
    cc_setgraphic("v2_stone_button_small,13");
}
if (cc_find($component, calc($int + 7)) = true) {
    cc_setgraphic("v2_stone_button_small,14");
}
if (cc_find($component, calc($int + 8)) = true) {
    cc_setgraphic("v2_stone_button_small,15");
}
if (cc_find($component, calc($int + 10)) = true) {
    cc_setcolour($rgb);
}
