// 7592
[clientscript,combat_interface_init]
def_component $infobutton = combat_interface:infobutton;
def_component $glow = combat_interface:glow;
def_int $int = 0;
if (~on_mobile = true) {
    while ($int < 4) {
        cc_create($glow, ^iftype_rectangle, $int);
        cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
        cc_setsize(calc($int * 2), calc($int * 2), ^setsize_minus, ^setsize_minus);
        cc_setcolour(^white);
        cc_setfill(true);
        cc_settrans(220);
        $int = calc($int + 1);
    }
    ~combat_interface_info_toggle(false);
} else {
    if_sethide(true, $infobutton);
}
~combat_interface_setup;
