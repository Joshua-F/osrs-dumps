// 13
[clientscript,target_quitterwarning](component $quitterwarning)
if (~target_world = false) {
    if_settext("", $quitterwarning);
    if_setontimer(null, $quitterwarning);
    return;
}
def_int $int1 = calc(200 - %bh_lobby_timer);
$int1 = interpolate(0, 60, 0, 100, $int1);
def_int $int2 = clientclock;
if_setontimer("script14($quitterwarning, $int1, $int2)", $quitterwarning);
~script15($quitterwarning, $int1, $int2);
