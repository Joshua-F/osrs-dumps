// 1445
[clientscript,duel_options_exclamations](component $com_116)
def_int $int = 0;
cc_deleteall($com_116);
while ($int < 13) {
    cc_create($com_116, ^iftype_graphic, $int);
    cc_setsize(5, 16, ^setsize_abs, ^setsize_abs);
    cc_setposition(0, calc($int * 20), ^setpos_abs_left, ^setpos_abs_top);
    cc_setgraphic(exclamation_mark);
    cc_sethide(true);
    $int = calc($int + 1);
}
