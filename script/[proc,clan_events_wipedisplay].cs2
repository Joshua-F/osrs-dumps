// 4411
[proc,clan_events_wipedisplay](component $component, int $int1, string $string)
def_int $int2 = calc(2 * 10);
if (cc_find($component, $int2) = true) {
    cc_sethide(false);
    cc_settext($string);
}
while ($int2 > 0) {
    $int2 = calc($int2 - 1);
    if (cc_find($component, $int2) = true) {
        cc_sethide(true);
    }
}
