// 3568
[proc,hallowed_tools_main_create](component $component, obj $obj, string $string, int $int)
if_setonmouserepeat("hallowed_tools_main_recreate($component, $obj, $string, $int, true)", $component);
if_setonmouseleave("hallowed_tools_main_recreate($component, $obj, $string, $int, false)", $component);
~hallowed_tools_main_recreate($component, $obj, $string, $int, false);
