// 3485
[proc,death_coffer_inactivebutton](component $component0, string $string, int $int, component $component2)
if ($int = 1) {
    ~death_coffer_drawbutton(true, true, $component0, $string, $component2);
} else {
    ~death_coffer_drawbutton(false, false, $component0, $string, $component2);
}
if_setonmouserepeat(null, $component0);
if_setonmouseleave(null, $component0);
if_setonop(null, $component0);
