// 852
[proc,script852](component $component)
def_string $string = ",";
if ($component = soul_wars_rewards:total_zeal) {
    if_settext("Lifetime Zeal:<br> <col=ffffff><~tostring_spacer(%soul_wars_zeal, $string)></col>", $component);
} else if ($component = soul_wars_rewards:total_zeal_tokens) {
    if_settext("Zeal Tokens:<br> <col=ffffff><~tostring_spacer(%soul_wars_zeal_tokens, $string)></col>", $component);
}
