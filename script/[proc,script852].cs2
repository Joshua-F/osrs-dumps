// 852
[proc,script852](component $component)
def_string $string = ",";
if ($component = interface_442:com_26) {
    if_settext("Lifetime Zeal:<br> <col=ffffff><~tostring_spacer(%varplayer_2871, $string)></col>", $component);
} else if ($component = interface_442:com_27) {
    if_settext("Zeal Tokens:<br> <col=ffffff><~tostring_spacer(%varplayer_2876, $string)></col>", $component);
}
