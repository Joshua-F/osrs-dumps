// 6503
[proc,cluehelper_overlay_dig_draw](dbrow $dbrow, coord $coord, obj $obj)
def_entityoverlay $entityoverlay = null;
if (tile_find($coord) = true) {
    $entityoverlay = entityoverlay_get_coord($coord, 7);
    if ($entityoverlay = null) {
        $entityoverlay = entityoverlay_create_coord($coord, 7, ^overlaytype_top, 60, 60, 1);
    } else {
        cc_deleteall_entityoverlay($entityoverlay);
    }
    if (if_find_entityoverlay($entityoverlay) = true) {
        cc_setonvartransmit("cluehelper_overlay_dig_transmit($dbrow, $coord, $obj, %option_cluehelper_overlay_enabled, %cluehelper_npc_id, %cluehelper_npc_id2, %cluehelper_npc_id3, %cluehelper_npc_current_clue, %option_cluehelper_enabled, %option_cluehelper_target_highlight_enabled){cluehelper_infobox_clue, option_cluehelper, cluehelper_npc_id, cluehelper_npc_id2, cluehelper_npc_id3, cluehelper_npc_current_clue}");
    }
    if (%option_cluehelper_enabled = 0 | ~cluehelper_overlay_npc_active = 1) {
        highlight_tile_off($coord, 9, 1);
        return;
    }
    if (%option_cluehelper_overlay_enabled = 1) {
        cc_create_entityoverlay($entityoverlay, ^iftype_graphic, 0);
        cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
        cc_setposition(8, 3, ^setpos_abs_centre, ^setpos_abs_centre);
        cc_setobject_nonum($obj, 1);
        cc_setoutline(1);
        cc_create_entityoverlay($entityoverlay, ^iftype_graphic, 1);
        cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
        cc_setposition(-8, -3, ^setpos_abs_centre, ^setpos_abs_centre);
        cc_setobject_nonum(spade, 1);
        cc_setoutline(1);
    }
    if (%option_cluehelper_target_highlight_enabled = 1) {
        highlight_tile_on($coord, 9, 1);
    }
}
