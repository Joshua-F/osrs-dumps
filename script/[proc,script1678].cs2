// 1678
[proc,script1678](component $component)
if (clienttype = ^clienttype_ios) {
    if_sethide(true, $component);
    return;
}
if_sethide(false, $component);
~script1682($component, false);
if_setonmouserepeat("script1681(event_com, true)", $component);
if_setonmouseleave("script1681(event_com, false)", $component);
if_setonop("script1679(event_op, event_com)", $component);
if_setontimer(null, $component);
