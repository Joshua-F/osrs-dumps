[clientscript,clan_members_hover](boolean $boolean, component $component, int $int2, int $int3)
if (cc_find($component, $int2) = true) {
    if ($boolean = true) {
        cc_settrans(225);
        cc_setontimer("cc_settrans_temporarily_end(event_com, event_comsubid, $int3, calc(clientclock + 2))");
    } else {
        cc_settrans($int3);
        cc_setontimer(null);
    }
}
