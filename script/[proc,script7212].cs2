// 7212
[proc,script7212](stringvector $stringvector)(string)
def_int $int1 = 0;
def_int $int2 = stringvector_size($stringvector);
def_string $string = "";
while ($int1 < $int2) {
    $string = "<$string><stringvector_get($stringvector, $int1)>,";
    $int1 = calc($int1 + 1);
}
if ($int2 > 0) {
    $string = substring($string, 0, calc(string_length($string) - 1));
}
return($string);
