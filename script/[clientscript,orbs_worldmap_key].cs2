// 5141
[clientscript,orbs_worldmap_key](int $key, component $component)
if ($key ! ^key_m) {
    return;
}
if (%settings_world_map_hotkey_disabled = 1) {
    return;
}
if (keyheld(^key_control_left) = true) {
    if (string_length(if_getop(1, $component)) > 0) {
        if_triggerop($component, -1, 1);
    } else {
        if_triggerop($component, -1, 2);
    }
}
