// 6813
[clientscript,pendant_of_ates_op](component $component, int $int, string $string0, string $string1, string $string2)
if (cc_find($component, 0) = true & .cc_find(pendant_of_ates:universe, calc($int - 1)) = true) {
    ~pendant_of_ates_activate($component, $int, $string0, $string1, $string2);
}
