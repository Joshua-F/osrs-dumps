// 7844
[clientscript,poh_bookcase_hover](boolean $boolean, component $component, int $int)
if (cc_find($component, $int) = true) {
    if ($boolean = true) {
        cc_settrans(20);
        cc_setontimer("cc_settrans_temporarily_end(event_com, event_comsubid, 70, calc(clientclock + 2))");
    } else {
        cc_settrans(70);
        cc_setontimer(null);
    }
}
