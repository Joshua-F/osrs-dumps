// 6388
[proc,create_graphic_core](graphic $graphic, int $int1, int $int2, int $setposh, int $setposv, int $int5, int $int6, int $setsize7, int $setsize8, boolean $boolean)
cc_setposition($int1, $int2, $setposh, $setposv);
cc_setsize($int5, $int6, $setsize7, $setsize8);
cc_setgraphic($graphic);
cc_settiling($boolean);
