// 3258
[proc,magic_training_costs_background](component $component)(int)
cc_deleteall($component);
def_int $int = 0;
cc_create($component, ^iftype_rectangle, $int);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setfill(true);
cc_setcolour(^black);
$int = calc($int + 1);
$int = ~thinbox($component, $int);
return($int);
