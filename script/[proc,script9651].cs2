// 9651
[proc,script9651](component $component, graphic $graphic, string $string)
~script9657($component, $graphic, $string, 0, 0);
if_setonmouserepeat("script9656(event_com, $graphic, $string, 1)", $component);
if_setonmouseleave("script9656(event_com, $graphic, $string, 0)", $component);
if_setop(1, removetags($string), $component);
if_setontimer(null, $component);
