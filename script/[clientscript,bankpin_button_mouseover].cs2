// 684
[clientscript,bankpin_button_mouseover](boolean $boolean, component $component, int $int2, int $int3)
if (cc_find($component, $int2) = true & .cc_find($component, $int3) = true) {
    if ($boolean = true) {
        cc_settrans(255);
        .cc_sethide(false);
    } else {
        cc_settrans(245);
        .cc_sethide(true);
    }
}
