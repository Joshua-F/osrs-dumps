// 735
[clientscript,inferno_hud_init](component $dodger, component $hp, component $name_area, component $hp_bar_text, component $health_bar_remaining, component $creature_name)
~interface_dodger_init($dodger, $hp, 52968, ^setpos_abs_left, ^setpos_abs_top, true);
if_setonvartransmit("inferno_hud_update($hp_bar_text, $health_bar_remaining){inferno_temp_noprotect_transmit}", $hp_bar_text);
~inferno_hud_pos(0, $hp, $name_area, $creature_name, $hp_bar_text, $health_bar_remaining);
~inferno_hud_update($hp_bar_text, $health_bar_remaining);
