// 3644
[proc,script3644]
def_int $int = 0;
if (%option_areasounds > 0 & %option_master_volume > 0) {
    $int = ~divide_round(~minmax(100, calc(%option_areasounds * 100), scale(calc(%option_areasounds * 100), 10000, calc(%option_master_volume * 100))), 100);
}
$int = enum(int, int, enum_981, $int);
gameoption_set(^gameoption_ambient_volume, $int);
