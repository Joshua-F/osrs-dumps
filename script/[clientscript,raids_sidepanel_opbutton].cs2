// 1543
[clientscript,raids_sidepanel_opbutton](int $int, string $string, component $component)
if ($int ! 1) {
    return;
}
sound_synth(synth_2266, 1, 0);
~raids_sidepanel_drawbutton(true, "<col=ffffff>---</col>", $component);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_setontimer("raids_sidepanel_resetbutton(calc(clientclock + 50), $string, $component)", $component);
