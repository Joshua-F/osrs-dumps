// 4322
[proc,clan_piano_set_onkey](component $component, int $int, string $string, int $key)
cc_create($component, ^iftype_rectangle, $int);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize(1, 1, ^setsize_abs, ^setsize_abs);
if (~on_mobile = false) {
    cc_setonkey("script4323(event_keycode, event_keychar, $component, $int, $key, $string)");
}
cc_setontimer("clan_piano_clear_key($int, 0)");
