// 279
[proc,bankmain_filteritem](obj $obj, boolean $boolean, string $string0)(boolean)
def_string $string1 = "";
if ($boolean = true) {
    if ($obj = null) {
        return(false);
    }
    if (string_length($string0) > 0) {
        if ($obj ! null) {
            $string1 = lowercase(oc_name($obj));
        }
        if (string_indexof_string($string1, $string0, 0) ! -1) {
            return(true);
        }
        return(false);
    }
}
return(true);
