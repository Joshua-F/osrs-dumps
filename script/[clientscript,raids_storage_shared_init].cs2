// 1589
[clientscript,raids_storage_shared_init](component $universe, component $warning, component $items, component $scrollbar, component $occupiedslots, component $private)
~raids_storage_drawbutton("Private", $private, p11_full);
~raids_storage_shared_warning($warning);
if_setonvartransmit("raids_storage_shared_warning($warning){magic_carpet_var}", $warning);
~scrollbar_vertical($scrollbar, $items, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~raids_storage_shared_items($items, $scrollbar, $occupiedslots);
if_setoninvtransmit("raids_storage_shared_items($items, $scrollbar, $occupiedslots){raids_sharedstorage}", $universe);
