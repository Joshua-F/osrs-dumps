// 6902
[clientscript,script6902](component $com_18, component $com_16)
def_graphic $graphic2 = "close_buttons,4";
def_graphic $graphic3 = "close_buttons,5";
if (~on_mobile = false) {
    if_setonmouseover("graphic_swapper($com_16, $graphic3)", $com_18);
    if_setonmouseleave("graphic_swapper($com_16, $graphic2)", $com_18);
}
if_setonop("closebutton_click", $com_18);
