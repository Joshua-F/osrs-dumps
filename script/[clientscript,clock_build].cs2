// 2858
[clientscript,clock_build](component $com_2)
cc_deleteall($com_2);
cc_create($com_2, ^iftype_text, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_bottom, 0);
cc_setcolour(0xff981f);
cc_settextfont(b12_full);
cc_setontimer("clock_fake_update($com_2)");
cc_setonvartransmit("clock_update($com_2){varplayer_1042}");
