// 4037
[clientscript,bolt_pouch_extra_ammo_init](component $extra_ammo_slot, component $extra_ammo_link)
if_sethide(true, $extra_ammo_slot);
if_sethide(true, $extra_ammo_link);
if_setop(1, "", $extra_ammo_slot);
if (~deadman_world ! 0 | map_members = false) {
    return;
}
if_sethide(false, $extra_ammo_slot);
~bolt_pouch_extra_ammo_draw($extra_ammo_slot, $extra_ammo_link);
if_setoninvtransmit("bolt_pouch_extra_ammo_draw($extra_ammo_slot, $extra_ammo_link){inv, worn}", $extra_ammo_slot);
if_setonvartransmit("bolt_pouch_extra_ammo_draw($extra_ammo_slot, $extra_ammo_link){xbows_pouch_number1, xbows_pouch_number2, xbows_pouch1, xbows_pouch2}", $extra_ammo_slot);
