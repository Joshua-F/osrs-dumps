// 247
[proc,inzone](coord $coord0, coord $coord1, coord $coord2)(boolean)
def_int $int = coordx($coord2);
if ($int < coordx($coord0) | $int > coordx($coord1)) {
    return(false);
}
$int = coordy($coord2);
if ($int < coordy($coord0) | $int > coordy($coord1)) {
    return(false);
}
$int = coordz($coord2);
if ($int < coordz($coord0) | $int > coordz($coord1)) {
    return(false);
}
return(true);
