// 7840
[clientscript,poh_bookcase_indicate](boolean $boolean, component $component, int $int2)
def_int $int3 = 0;
while ($int3 < $int2) {
    if (cc_find($component, $int3) = true & .cc_find($component, calc($int2 + 2 * $int3)) = true) {
        ~poh_bookcase_indicate($boolean, $component);
    }
    $int3 = calc($int3 + 1);
}
