// 9379
[proc,script9379]
def_component $floating_panel_content = talent_tree:floating_panel_content;
def_int $int1 = 0;
def_int $int2 = 0;
$int1, $int2 = ~script9375("<col=e00a19>It's strongly reccomended you pick a Melee, Ranged or Magic style node</col>", 0xd97500, "Apply Changes", "Undo Changes");
if (cc_find($floating_panel_content, $int1) = true) {
    cc_setonop("script9380");
}
if (cc_find($floating_panel_content, $int2) = true) {
    cc_setonop("script9381");
}
