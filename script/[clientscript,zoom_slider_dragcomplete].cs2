// 1043
[clientscript,zoom_slider_dragcomplete](component $zoom_slider_bobble, component $component, int $int)
~settings_side_op_sound;
if ($zoom_slider_bobble ! settings_side:zoom_slider_bobble) {
    return;
}
if (%fov_clamp ! 0) {
    return;
}
~zoom_position_slider;
if_setontimer("zoom_timer(%camera_zoom_small, %camera_zoom_big)", settings_side:zoom_slider_bobble);
