// 2650
[clientscript,telenexus_radio_click](component $component0, component $component1, component $component2, component $component3, int $int, component $component5, component $component6)
if (($int = 1 | $int = 3) & %poh_nexus_left_click_temp < 150 & %poh_nexus_left_click_temp > 0) {
    %poh_nexus_left_click_temp = calc(%poh_nexus_left_click_temp + 150);
} else if (($int = 0 | $int = 2) & %poh_nexus_left_click_temp > 150) {
    %poh_nexus_left_click_temp = calc(%poh_nexus_left_click_temp - 150);
}
~telenexus_left_click($component0, $component1, $component2, $component5, $component6);
