// 9159
[proc,skill_guide_v2_overview_fishing](component $component)
~script9182($component, "", "Fishing is a skill about catching fish from bubbling ||::<113>::Fishing Spots|| all over Gielinor. Use the tabs on the left to see which level, tools and methods are required for catching certain fish. Many of these tools can be purchased from ||::<112>::Fishing Shops|| around the world.<"||::p||">Level up your Fishing skill by catching fish. This increases catch rate and unlocks more types of fish to catch as well as new methods to catch them.<"||::p||">||::hl||<"To catch fish"><"||::/hl||">, take the required equipment to a corresponding fishing spot then <~text_device("click", "tap")> the spot to start fishing. For example, a Small Fishing Net can be used to catch fish listed in the Small Net tab on the left and can be used on ||::<113>::Fishing Spots|| with the Net & Bait options.");
~script9182($component, "Getting Started", "To get started, visit the ||::<139>::Fishing Tutor|| south of Lumbridge. He'll give you a Small Fishing Net and show you how to use the ||::<113>::Fishing Spots|| found next to him, as well as give recommendations on what to catch for your level!");
def_stringarray $stringarray = array_create(string, 2, -1);
$stringarray(0) = "||skill:<16>::<17>::Cooking:::|| Fish caught with the Fishing skill can be cooked with the Cooking skill.";
$stringarray(1) = "||skill:<6>::<8>::Hitpoints:::|| Cooked fish can be eaten to recover Hitpoints during combat.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
