// 267
[proc,nzone_lobby_partystatus](int $int, component $component)
def_boolean $boolean = false;
if ($int = 0 & %nzone_controller_uid = -1) {
    $boolean = true;
    if_setontimer(null, $component);
} else {
    if_setontimer("nzone_lobby_partynames(event_com)", $component);
}
cc_create($component, ^iftype_rectangle, 0);
cc_sethide($boolean);
cc_setposition(2, 2, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize(125, 96, ^setsize_abs, ^setsize_abs);
cc_setcolour(0x7f460f);
cc_setfill(true);
cc_settrans(50);
cc_create($component, ^iftype_rectangle, 1);
cc_sethide($boolean);
cc_setposition(2, 2, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize(125, 96, ^setsize_abs, ^setsize_abs);
cc_setcolour(0x7f460f);
cc_setfill(false);
~create_graphic($component, 2, tradebacking_light, 4, 4, ^setpos_abs_left, ^setpos_abs_top, 121, 17, ^setsize_abs, ^setsize_abs, true);
cc_sethide($boolean);
cc_settrans(100);
cc_create($component, ^iftype_text, 3);
cc_sethide($boolean);
cc_setposition(4, 4, ^setpos_abs_left, ^setpos_abs_top);
cc_setsize(121, 17, ^setsize_abs, ^setsize_abs);
cc_settextfont(p12_full);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settext("Rumble Party");
~create_graphic($component, 4, tradebacking_dark, 4, 22, ^setpos_abs_left, ^setpos_abs_top, 121, 14, ^setsize_abs, ^setsize_abs, true);
cc_sethide($boolean);
cc_settrans(150);
~create_graphic($component, 5, tradebacking, 4, 37, ^setpos_abs_left, ^setpos_abs_top, 121, 14, ^setsize_abs, ^setsize_abs, true);
cc_sethide($boolean);
cc_settrans(150);
if ($int = 1) {
    cc_setop(1, "Kick player");
    cc_setonmouseover("cc_settrans(event_com, event_comsubid, 75, null)");
    cc_setonmouseleave("cc_settrans(event_com, event_comsubid, 150, null)");
}
~create_graphic($component, 6, tradebacking, 4, 52, ^setpos_abs_left, ^setpos_abs_top, 121, 14, ^setsize_abs, ^setsize_abs, true);
