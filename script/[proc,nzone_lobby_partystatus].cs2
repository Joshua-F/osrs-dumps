    cc_setonmouseover("cc_settrans(event_com, event_comsubid, 75, null)");
    cc_setonmouseleave("cc_settrans(event_com, event_comsubid, 150, null)");
}
~create_graphic($component, 7, tradebacking, 4, 67, ^setpos_abs_left, ^setpos_abs_top, 121, 14, ^setsize_abs, ^setsize_abs, true);
cc_sethide($boolean);
cc_settrans(150);
if ($int = 1) {
    cc_setop(1, "Kick player");
    cc_setonmouseover("cc_settrans(event_com, event_comsubid, 75, null)");
    cc_setonmouseleave("cc_settrans(event_com, event_comsubid, 150, null)");
}
~create_graphic($component, 8, tradebacking, 4, 82, ^setpos_abs_left, ^setpos_abs_top, 121, 14, ^setsize_abs, ^setsize_abs, true);
cc_sethide($boolean);
cc_settrans(150);
if ($int = 1) {
