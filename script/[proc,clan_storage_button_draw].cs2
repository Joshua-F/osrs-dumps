// 4353
[proc,clan_storage_button_draw](string $string, component $component, int $int1)
cc_deleteall($component);
def_int $int2 = 0;
if ($int1 = 1) {
    $int2 = ~v2_stone_button_in_filled($component);
} else {
    $int2 = ~v2_stone_button_out_filled($component);
}
cc_create($component, ^iftype_text, $int2);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setcolour(0xff981f);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_settextfont(p12_full);
cc_settext($string);
if (~on_mobile = false) {
    if_setonmouserepeat("cc_colour_swapper(event_com, $int2, ^white)", $component);
}
if_setonmouseleave("cc_colour_swapper(event_com, $int2, 0xff981f)", $component);
