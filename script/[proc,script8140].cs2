// 8140
[proc,script8140](int $int0, int $int1)(string)
def_intarray $intarray = ~script8271($int0, $int1);
def_string $string = "Invalid reward!";
def_int $int2 = array_size($intarray);
if ($int2 = 0) {
    return($string);
} else {
    $string = "";
}
def_int $int3 = 0;
while ($int3 < $int2) {
    $string = append($string, "<tostring($intarray($int3))>,");
    $int3 = calc($int3 + 1);
}
$string = substring($string, 0, calc(string_length($string) - 1));
return($string);
