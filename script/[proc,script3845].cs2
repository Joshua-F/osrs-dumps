// 3845
[proc,script3845](int $int)
def_string $string = "|";
$string = append($string, tostring($int));
if (string_indexof_string(%settings_show_more, $string, 0) = -1) {
    %settings_show_more = append(%settings_show_more, $string);
} else {
    %settings_show_more = ~string_findandreplace(%settings_show_more, $string, "");
}
