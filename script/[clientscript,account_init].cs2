// 2497
[clientscript,account_init](component $universe, component $tabs)
if_setonvartransmit("account_update_display{account_credit, account_messages, mobile_options_transmit, tob_temp_transmit_2, armourhitsound}", $universe);
~account_setup_tabs;
if_setonvartransmit("account_update_tabs{gargboss_perm_transmit, chat_filter_assist}", $tabs);
~account_update_tabs(%account_current_tab);
~account_update_display;
~script2833;
