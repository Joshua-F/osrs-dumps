// 1501
[proc,soul_wars_clan_games_button_draw](component $component, boolean $boolean)
if (%soul_wars_clan_challenge_accept = 1) {
    ~soul_wars_clan_games_confirm_pressed($component, "Waiting", 0);
} else if ($boolean = true) {
    ~soul_wars_clan_games_confirm_pressed($component, "Confirm", 1);
} else {
    ~soul_wars_clan_games_confirm_notpressed($component, "Confirm", 1);
}
