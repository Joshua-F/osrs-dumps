// 213
[proc,clanwars_hud_timeremaining_resynch]()(string)
def_int $int = 0;
if (%varplayerbit_4286 > 0) {
    $int = calc(%varplayerbit_4577 * 30);
    cc_setontimer(null);
} else {
    $int = calc(%varplayerbit_4577 * 30 - 10);
    cc_setontimer("clanwars_hud_timeremaining_tick(event_com, event_comsubid, $int)");
}
return(~clanwars_hud_timeremaining_gettext($int));
