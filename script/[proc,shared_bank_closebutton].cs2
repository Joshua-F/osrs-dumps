// 5308
[proc,shared_bank_closebutton](component $component)
if (%gim_shared_bank_hasedited = 1) {
    ~script4215($component, "Save and Close");
    if_setonop("opsound(event_op, 2)", $component);
    if_setonkey(null, $component);
    if (%keybinding_esc_to_close = 1) {
        if_setopkey(1, ^key_escape, 0, $component);
    }
} else {
    ~script4215($component, "Close");
    if_setonop("closebutton_click", $component);
    if_setonkey("closebutton_key(event_keycode)", $component);
}
