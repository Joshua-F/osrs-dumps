// 4654
[clientscript,helper_cox_op](string $string, boolean $boolean, component $component)
%cox_helper_show_less = calc(1 - %cox_helper_show_less);
if (%cox_helper_show_less = 0) {
    if_setop(1, "Show less", $component);
    if_setvflip(true, $component);
    if_sethflip(true, $component);
} else {
    if_setop(1, "Show more", $component);
    if_setvflip(false, $component);
    if_sethflip(false, $component);
}
~helper_cox_content($string, $boolean);
