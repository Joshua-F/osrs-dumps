// 747
[clientscript,worldswitcher_init](component $universe, component $title, component $middle, component $scrollarea, component $scrollbar, component $info, component $buttons, component $sortarea, component $sort_member, component $sort_number, component $sort_country, component $sort_players, component $sort_theme, component $bottom, component $favourite_1, component $favourite_2, component $nofavourites, component $tooltip)
if_settext(~text_device("Right-click on worlds to<br>set them as Favourites.", "<"Long press"> on worlds to<br>set them as Favourites."), $nofavourites);
def_int $int18 = 10;
if ($title ! null) {
    if_settext("<col=9f9f9f>Loading...</col>", $title);
    if_setonvartransmit(null, $title);
    if_setonsubchange(null, $title);
    $int18 = 0;
}
def_int $int19 = 16;
def_int $int20 = 11;
def_int $int21 = 32;
if (~on_mobile = true) {
    $int19, $int20, $int21 = 24, 21, 48;
}
if_setsize(calc($int18 * 2), $int21, ^setsize_minus, ^setsize_abs, $bottom);
if_setsize(calc($int18 * 2), calc(if_gety($middle) + $int21 + $int18), ^setsize_minus, ^setsize_minus, $middle);
if_setscrollpos(0, 0, $scrollarea);
if_sethide(true, $scrollarea);
cc_deleteall($scrollbar);
~scrollbar_vertical($scrollbar, $scrollarea, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
if_sethide(true, $sort_member);
if_sethide(true, $sort_number);
if_sethide(true, $sort_country);
if_sethide(true, $sort_players);
if_sethide(true, $sort_theme);
cc_deleteall($buttons);
def_int $int22 = 0;
while ($int22 <= 600) {
    cc_create($buttons, ^iftype_graphic, $int22);
    cc_setsize(0, $int19, ^setsize_minus, ^setsize_abs);
    cc_setop(1, "Switch");
    cc_setop(2, "Favourite");
    cc_setopbase("<col=ff9040><tostring($int22)></col>");
    cc_sethide(true);
    $int22 = calc($int22 + 1);
}
if (worldlist_fetch = true) {
    ~worldswitcher_loaded($universe, $title, $scrollarea, $scrollbar, $info, $buttons, $int19, $int21, $int20, $sortarea, $sort_member, $sort_number, $sort_country, $sort_players, $sort_theme, $favourite_1, $favourite_2, $nofavourites, $tooltip);
    if_setontimer(null, $universe);
} else {
    if_setontimer("worldswitcher_loading($universe, $title, $scrollarea, $scrollbar, $info, $buttons, $int19, $int21, $int20, $sortarea, $sort_member, $sort_number, $sort_country, $sort_players, $sort_theme, $favourite_1, $favourite_2, $nofavourites, $tooltip)", $universe);
}
