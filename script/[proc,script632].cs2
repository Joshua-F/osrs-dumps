// 632
[proc,script632](string $string)(string, string)
def_int $int0 = string_length($string);
if ($int0 <= 0) {
    return("", "");
}
def_int $int1 = string_indexof_string($string, "|", 0);
if ($int1 = -1) {
    return($string, "");
}
if ($int1 = 0) {
    return("", substring($string, 1, $int0));
}
if (calc($int1 + 1) >= $int0) {
    return(substring($string, 0, $int1), "");
}
return(substring($string, 0, $int1), substring($string, calc($int1 + 1), $int0));
