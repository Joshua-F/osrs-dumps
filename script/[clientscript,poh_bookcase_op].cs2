// 7845
[clientscript,poh_bookcase_op](int $int0, component $component, int $int2, boolean $boolean)
if ($int0 = 1 & cc_find($component, $int2) = true) {
    cc_settrans(0);
    cc_setonmouserepeat(null);
    cc_setonmouseleave(null);
    cc_setontimer("poh_bookcase_reset(event_com, event_comsubid, calc(clientclock + 20), $boolean)");
} else {
    sound_synth(synth_2266, 1, 0);
}
