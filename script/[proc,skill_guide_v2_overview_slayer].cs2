// 9170
[proc,skill_guide_v2_overview_slayer](component $component)
~script9182($component, "", "Slayer is a skill about fighting increasingly dangerous and lucrative monsters. Some monsters require a certain Slayer level to fight along with specialist Slayer equipment. Use the tabs on the left to see what monsters and equipment are available and the Slayer level required.<"||::p||">To level your Slayer, you need to take a a task from a ||::<133>::Slayer Master|| then defeat the assigned number of targets. Available Slayer Masters and their recommended combat level can be viewed in the ||tab:3::::Slayer Masters tab|| on the left. Slayer Masters also have advice on how to fight assigned monsters, including any special equipment required which can be purchased from them.<"||::p||">After completing your first five tasks, you'll start earning reward points which can be spent on various perks at a ||::<133>::Slayer Master||, such as the ability to skip or block tasks you don't want, as well as purchase new items and benefits.");
~script9182($component, "Getting Started", "To get started, complete the <~script9191(quest_porcineofinterest)> to hunt your first monster and gain access to the ||::<133>::Slayer Master|| in Draynor Village. Then, take a task from that Slayer Master and get slaying!");
def_stringarray $stringarray = array_create(string, 1, -1);
$stringarray(0) = "||::hl||<"All:"><"||::/hl||"> Many Slayer monsters drop useful equipment and resources to aid in combat or use in a variety of skills.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
