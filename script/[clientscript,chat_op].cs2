// 86
[clientscript,chat_op](int $int, string $string)
if ($int = 1) {
    opplayer(4, $string);
} else if ($int = 2) {
    opplayer(1, $string);
} else if ($int = 8) {
    %varclientstring_24 = $string;
} else if ($int = 9) {
    ~clan_sendkick($string);
} else if (friend_test($string) = true) {
    if ($int = 6 | $int = 7) {
        ~meslayer_mode6($string);
    }
} else if ($int = 6) {
    friend_add($string);
} else if ($int = 7) {
    ignore_add($string);
}
