// 7062
[proc,fade_component_increment](int $int0, int $int1, int $int2, int $int3, component $component)
if ($int3 <= 0) {
    if_settrans($int1, $component);
    if_setontimer(null, $component);
    return;
}
if_settrans(calc($int1 - interpolate(0, $int3, 0, $int2, calc($int1 - $int0))), $component);
