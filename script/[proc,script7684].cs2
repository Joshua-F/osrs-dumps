// 7684
[proc,script7684](int $rgb)
def_component $points_text = league_combat_mastery:points_text;
def_component $points_frame = league_combat_mastery:points_frame;
def_component $points_list = league_combat_mastery:points_list;
def_component $points_scrollbar = league_combat_mastery:points_scrollbar;
def_int $int = 0;
cc_create($points_frame, ^iftype_graphic, $int);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_setgraphic(tradebacking_dark);
cc_settiling(true);
$int = calc($int + 1);
~thinbox_light($points_frame, $int);
if_settextalign(^settextalign_centre, ^settextalign_centre, 20, $points_text);
if_setcolour($rgb, $points_text);
if_settextfont(b12_full, $points_text);
if_settextshadow(true, $points_text);
if_settext("Unlock combat mastery points by completing any of the following tasks. Once complete, the task will be highlighted below.", $points_text);
~league_combat_mastery_points_list($points_list, $points_scrollbar, $points_text, $rgb);
