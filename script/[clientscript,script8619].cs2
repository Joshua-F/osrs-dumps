[clientscript,script8619](boolean $boolean, int $int)
if ($boolean = false) {
    sound_synth(synth_2277, 1, 0);
    if ($int = 3) {
        mes("You cannot attempt the Marlin rank until you have achieved Shark rank.");
    } else if ($int = 2) {
        mes("You cannot attempt the Shark rank until you have achieved Swordfish rank.");
    } else {
        mes("You cannot attempt this rank until you have achieved the rank before it.");
