// 2056
[proc,skillmulti_quantitybutton_setup](int $int0, int $int1, component $com_12, int $int3, int $int4, int $int5)(int)
if_setposition($int5, 0, ^setpos_abs_left, ^setpos_abs_centre, $com_12);
def_string $string = "All";
if ($com_12 ! interface_270:com_12) {
    $string = tostring($int1);
}
if ($int0 = 1) {
    ~skillmulti_wipebutton($com_12);
    $string = "<col=ffffff><$string></col>";
    ~skillmulti_quantitybutton_draw(true, $string, $com_12);
} else {
    ~skillmulti_quantitybutton_draw(false, $string, $com_12);
    if_setonmouseover("skillmulti_quantitybutton_draw(true, $string, $com_12)", $com_12);
    if_setonmouseleave("skillmulti_quantitybutton_draw(false, $string, $com_12)", $com_12);
    if_setop(1, $string, $com_12);
    if_setonop("skillmulti_quantitybutton_op(event_op, $int1, $int3, $int4)", $com_12);
    if_setontimer(null, $com_12);
}
return(calc($int5 + if_getwidth($com_12) + 5));
