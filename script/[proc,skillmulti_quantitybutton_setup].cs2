// 2056
[proc,skillmulti_quantitybutton_setup](int $int0, int $int1, component $all, int $int3, int $int4, int $int5)(int)
if_setposition($int5, 0, ^setpos_abs_left, ^setpos_abs_centre, $all);
def_string $string = "All";
if ($all ! skillmulti:all) {
    $string = tostring($int1);
}
if ($int0 = 1) {
    ~skillmulti_wipebutton($all);
    $string = "<col=ffffff><$string></col>";
    ~skillmulti_quantitybutton_draw(true, $string, $all);
} else {
    ~skillmulti_quantitybutton_draw(false, $string, $all);
    if_setonmouseover("skillmulti_quantitybutton_draw(true, $string, $all)", $all);
    if_setonmouseleave("skillmulti_quantitybutton_draw(false, $string, $all)", $all);
    if_setop(1, $string, $all);
    if_setonop("skillmulti_quantitybutton_op(event_op, $int1, $int3, $int4)", $all);
    if_setontimer(null, $all);
}
return(calc($int5 + if_getwidth($all) + 5));
