// 877
[proc,br_hud_writetimer](component $component)
def_int $int = 0;
if (%varplayerbit_9407 <= 0) {
    if_settext("", $component);
} else {
    $int = calc((%varplayerbit_9407 - 1) / 2);
    if (%varplayerbit_9407 <= 1) {
        if_settext("<col=ff0000>0 mins</col>", $component);
    } else if ($int = 1) {
        if_settext("1 min", $component);
    } else {
        if_settext("<tostring($int)> mins", $component);
    }
}
