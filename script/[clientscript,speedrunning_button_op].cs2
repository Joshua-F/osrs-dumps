// 5901
[clientscript,speedrunning_button_op](component $component, string $string)
sound_synth(synth_2266, 1, 0);
if_setonhold(null, $component);
if_setonrelease(null, $component);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
~speedrunning_button_draw($component, $string, true, false);
if_setop(1, "", $component);
if_setontimer("speedrunning_button_reset($component, $string, calc(clientclock + 40))", $component);
