// 2566
[clientscript,membership_benefits_prompt_init](component $com_9, component $com_6, component $com_7, component $com_8)
~membership_benefits_prompt_button_init($com_9, "World Switcher");
~membership_benefits_prompt_button_init($com_6, "Learn More");
~membership_benefits_prompt_button_init($com_8, "Open Store");
if (~on_mobile = true & clienttype = ^clienttype_ios) {
    ~membership_benefits_prompt_hide_bonds;
} else {
    ~membership_benefits_prompt_button_init($com_7, "Bond Pouch");
}
