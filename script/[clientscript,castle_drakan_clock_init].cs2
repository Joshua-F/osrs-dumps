// 9649
[clientscript,castle_drakan_clock_init](component $big_rotate_clockwise, component $big_rotate_anticlockwise, component $small_rotate_clockwise, component $small_rotate_anticlockwise, component $big_hand, component $small_hand)
~script9650($big_rotate_clockwise, "miscgraphics3,2", "Rotate Clockwise", 1, $big_hand, $small_hand, 1);
~script9650($big_rotate_anticlockwise, "miscgraphics3,3", "Rotate Anticlockwise", -1, $big_hand, $small_hand, 1);
~script9650($small_rotate_clockwise, "miscgraphics3,2", "Rotate Clockwise", 1, $big_hand, $small_hand, 0);
~script9650($small_rotate_anticlockwise, "miscgraphics3,3", "Rotate Anticlockwise", -1, $big_hand, $small_hand, 0);
if_setonvartransmit("script9654($big_hand, $small_hand){castle_drakan_general_2}", $big_hand);
~script9655($big_hand, $small_hand);
