// 1892
[proc,pog_interface_inv_update](component $component, inv $inv)
cc_deleteall($component);
def_int $int2 = calc((if_getwidth($component) - 36 * 4) / 3);
def_int $int3 = calc((if_getheight($component) - 32 * 7) / 6);
def_int $int4 = 0;
while ($int4 <= 28) {
    cc_create($component, ^iftype_graphic, $int4);
    cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
    cc_setposition(calc((36 + $int2) * ($int4 % 4)), calc($int4 / 4 * (32 + $int3)), ^setpos_abs_left, ^setpos_abs_top);
    ~pog_interface_inv_draw_slot($inv, $int4, $component);
    $int4 = calc($int4 + 1);
}
