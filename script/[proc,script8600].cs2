// 8600
[proc,script8600](string $string0, string $string1, component $component)
if (~on_mobile = true) {
    cc_setop(1, "Inspect");
    if (string_length($string0) > 0) {
        cc_setopbase("<col=ff9040><$string0></col>");
    }
    cc_setonop("script8601($string1)");
    return;
}
cc_setonmouserepeat("tooltip_mouserepeat(event_com, event_comsubid, $component, $string1, 25, 512)");
cc_setonmouseleave("deltooltip($component)");
