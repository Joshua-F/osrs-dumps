// 6709
[clientscript,script6709](int $int, string $string, component $component, graphic $graphic)
sound_synth(synth_2266, 1, 0);
~clan_stonebutton_draw(true, $string, $graphic, $component);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setontimer("script6710(calc(clientclock + 20), $string, event_com, $graphic)", $component);
