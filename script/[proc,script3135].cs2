// 3135
[proc,script3135](component $component0, component $component1, int $int)
def_graphic $graphic = enum(int, graphic, enum_1386, $int);
if ($graphic = null) {
    if_sethide(false, $component1);
    if_sethide(true, $component0);
} else {
    if_sethide(true, $component1);
    if_sethide(false, $component0);
    if_setgraphic($graphic, $component0);
}
