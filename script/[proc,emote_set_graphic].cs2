[proc,emote_set_graphic](int $int)
def_graphic $graphic = null;
if ($int = 50) {
    switch_int (%varplayerbit_11757) {
        case 3 :
            $graphic = "emotes,49";
        case 6 :
            $graphic = "emotes,50";
        case 9 :
            $graphic = "emotes,52";
        case 12 :
            $graphic = "emotes,55";
        case 15 :
