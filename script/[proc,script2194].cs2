// 2194
[proc,script2194](component $component, int $int)
if ($int <= 80) {
    .cc_settrans(calc(255 - $int * 3));
    cc_setmodel(model_16238);
    return;
}
if ($int <= 110) {
    $int = calc($int - 30);
    .cc_settrans(calc(55 + $int * 4));
    cc_setmodel(model_39197);
    cc_settrans(255);
    cc_setmodelangle(-25, 30, 0, 1950, 0, calc(1050 - $int * 12));
    return;
}
cc_deleteall($component);
