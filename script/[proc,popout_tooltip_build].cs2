// 5543
[proc,popout_tooltip_build](component $component, int $int1, string $string)
def_int $int2 = 512;
def_int $int3 = 0;
~popout_tooltip_clear;
if (~on_mobile = true) {
    ~tooltip_build($component, $int1, interface_728:com_16, $string, $int2);
    if_setontimer("popout_tooltip_remove_delayed(calc(clientclock + 240))", interface_728:com_16);
} else {
    ~tooltip_mouserepeat($component, $int1, interface_728:com_16, $string, $int3, $int2);
}
