// 3551
[proc,poh_costumes_buttons_draw](component $component, graphic $graphic, obj $obj, boolean $boolean)
cc_deleteall($component);
def_int $int = 0;
if ($boolean = true) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $int = ~v2_stone_button_out_filled($component);
}
cc_create($component, ^iftype_graphic, $int);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
if ($obj ! null) {
    cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
    cc_setobject_nonum($obj, 1);
    cc_setoutline(1);
} else {
    cc_setsize(29, 22, ^setsize_abs, ^setsize_abs);
    cc_setgraphic($graphic);
}
cc_settrans(0);
if_setonmouserepeat("cc_settrans(event_com, $int, 100, null)", $component);
if_setonmouseleave("cc_settrans(event_com, $int, 0, null)", $component);
