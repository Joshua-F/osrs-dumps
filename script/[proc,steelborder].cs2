// 228
[proc,steelborder](component $component, string $string, int $int1)(int)
cc_deleteall($component);
~create_graphic($component, 0, tradebacking, 0, 0, ^setpos_abs_centre, ^setpos_abs_centre, 2, 2, ^setsize_minus, ^setsize_minus);
cc_create($component, ^iftype_text, 1);
cc_setposition(0, 6, ^setpos_abs_centre, ^setpos_abs_top);
cc_setsize(12, 24, ^setsize_minus, ^setsize_abs);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextfont(b12_full);
cc_settext($string);
def_int $int2 = cc_getid;
~create_graphic($component, 2, "steelborder,0", 0, 0, ^setpos_abs_left, ^setpos_abs_top, 25, 30, ^setsize_abs, ^setsize_abs);
~create_graphic($component, 3, "steelborder,1", 0, 0, ^setpos_abs_right, ^setpos_abs_top, 25, 30, ^setsize_abs, ^setsize_abs);
~create_graphic($component, 4, "steelborder,2", 0, 0, ^setpos_abs_left, ^setpos_abs_bottom, 25, 30, ^setsize_abs, ^setsize_abs);
~create_graphic($component, 5, "steelborder,3", 0, 0, ^setpos_abs_right, ^setpos_abs_bottom, 25, 30, ^setsize_abs, ^setsize_abs);
~create_graphic($component, 6, "steelborder2,0", 0, 14, ^setpos_abs_centre, ^setpos_abs_top, 12, 26, ^setsize_minus, ^setsize_abs);
~create_graphic($component, 7, "miscgraphics,2", -15, 0, ^setpos_abs_left, ^setpos_abs_centre, 36, 60, ^setsize_abs, ^setsize_minus);
~create_graphic($component, 8, "steelborder2,1", -15, 0, ^setpos_abs_right, ^setpos_abs_centre, 36, 60, ^setsize_abs, ^setsize_minus);
~create_graphic($component, 9, "steelborder2,0", 0, -15, ^setpos_abs_centre, ^setpos_abs_top, 50, 36, ^setsize_minus, ^setsize_abs);
~create_graphic($component, 10, "miscgraphics,3", 0, -15, ^setpos_abs_centre, ^setpos_abs_bottom, 50, 36, ^setsize_minus, ^setsize_abs);
def_graphic $graphic = "close_buttons,0";
if (testbit($int1, 0) = ^false) {
    ~create_graphic($component, 11, $graphic, 3, 6, ^setpos_abs_right, ^setpos_abs_top, 26, 23, ^setsize_abs, ^setsize_abs);
    cc_setonmouseleave("cc_graphic_swapper(event_com, event_comsubid, $graphic, null)");
    $graphic = "close_buttons,1";
    cc_setonmouseover("cc_graphic_swapper(event_com, event_comsubid, $graphic, null)");
    cc_setop(1, "Close");
    cc_setonop("closebutton_click");
}
return($int2);
