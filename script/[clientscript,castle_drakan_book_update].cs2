// 9643
[clientscript,castle_drakan_book_update](component $name, component $symbol, component $page_left_number, component $page_right_number)
if_settext(tostring(calc(%pagepos + 1)), $page_left_number);
if_settext(tostring(calc(%pagepos + 2)), $page_right_number);
switch_int (%pagepos) {
    case 0, 1 :
        if_settext("Alzeph", $name);
        if_setgraphic("vampyre_symbols,0", $symbol);
    case 2, 3 :
        if_settext("Drakan", $name);
        if_setgraphic("vampyre_symbols,1", $symbol);
    case 4, 5 :
        if_settext("Ghrazi", $name);
        if_setgraphic("vampyre_symbols,2", $symbol);
    case 6, 7 :
        if_settext("Jovkai", $name);
        if_setgraphic("vampyre_symbols,3", $symbol);
    case 8, 9 :
        if_settext("Myrmel", $name);
        if_setgraphic("vampyre_symbols,4", $symbol);
    case 10, 11 :
        if_settext("Pyrah", $name);
        if_setgraphic("vampyre_symbols,5", $symbol);
    case 12, 13 :
        if_settext("Shadum", $name);
        if_setgraphic("vampyre_symbols,6", $symbol);
    case 14, 15 :
        if_settext("Vitur", $name);
        if_setgraphic("vampyre_symbols,7", $symbol);
}
