// 3601
[proc,omnishop_currency_draw_title](string $string, component $component, int $int1, int $int2, int $int3, int $setposh, int $setposv, int $int6, int $int7, int $int8)(int)
cc_create($component, ^iftype_text, $int1);
cc_setposition($int2, $int3, $setposh, $setposv);
cc_setsize($int7, $int8, ^setsize_abs, ^setsize_abs);
cc_settext($string);
cc_settextfont(b12_full);
cc_settextshadow(true);
cc_setcolour(0xff981f);
cc_settextalign($int6, $int6, 0);
return(calc($int1 + 1));
