// 290
[proc,bankmain_itemnote](component $component)
if (%bank_withdrawnotes = 1) {
    if_setgraphic("miscgraphics,9", $component);
    if_setonop("bankmain_itemnote_op(event_op, $component, 0)", $component);
    if_setop(1, "Disable <col=ff9040>Notes", $component);
} else {
    if_setgraphic("miscgraphics,0", $component);
    if_setonop("bankmain_itemnote_op(event_op, $component, 1)", $component);
    if_setop(1, "Enable <col=ff9040>Notes", $component);
}
