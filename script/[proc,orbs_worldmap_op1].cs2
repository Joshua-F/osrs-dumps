// 2892
[proc,orbs_worldmap_op1](component $component)
if (%player_in_gauntlet = 1) {
    if_setop(1, "View <col=ff9040>Gauntlet Map</col>", $component);
} else if (%in_castle_drakan_instance = 1 & %myq6 <= 82) {
    if_setop(1, "View <col=ff9040>Castle Map</col>", $component);
} else if (%in_sangvesti_instance = 1 & %myq6 <= 88) {
    if_setop(1, "View <col=ff9040>Sangvesti Map</col>", $component);
}
