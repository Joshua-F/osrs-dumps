// 508
[proc,bankmain_tabicon_highlight](int $int)
if (%bank_currenttab = $int & %banktags_active_tag = -1) {
    .cc_setgraphic("banktabs,2");
    cc_setonmouserepeat(null);
    cc_setonmouseleave(null);
    return;
}
.cc_setgraphic("banktabs,0");
def_graphic $graphic = "banktabs,1";
cc_setonmouserepeat("cc_graphic_swapper(event_com, .cc_getid, $graphic, null)");
$graphic = "banktabs,0";
cc_setonmouseleave("cc_graphic_swapper(event_com, .cc_getid, $graphic, null)");
