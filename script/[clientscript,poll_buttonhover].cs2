// 607
[clientscript,poll_buttonhover](boolean $boolean, component $component, int $int2, int $int3)
if (cc_find($component, $int2) = true & .cc_find($component, $int3) = true) {
    if ($boolean = true) {
        cc_setgraphic("combatboxesmed,1");
        .cc_setcolour(^white);
    } else {
        cc_setgraphic("combatboxesmed,0");
        .cc_setcolour(0xff981f);
    }
}
