// 9173
[proc,skill_guide_v2_overview_thieving](component $component)
~script9182($component, "", "Thieving is a skill about stealing coins and items from the various inhabitants of Gielinor. Use the tabs on the left to see who and what you can steal from and the Thieving level required.<"||::p||">To level your Thieving, pickpocket people and monsters or steal from stalls. Increasing your Thieving level allows you to steal from more valuable sources and increases your chance to succeed.");
~script9182($component, "Getting Started", "To get started, pickpocket the citizens found in most towns, such as Lumbridge. ");
def_stringarray $stringarray = array_create(string, 1, -1);
$stringarray(0) = "||skill:<21>::<21>::Farming:::|| Seeds pickpocketed from Master Farmers or stolen from Seed Stalls can be grown with the Farming skill.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
