// 9356
[proc,script9356](component $component, int $int1, int $setposh, int $setposv, int $int4, int $int5, int $setsize6, int $setsize7, graphic $graphic)(int)
cc_create($component, ^iftype_graphic, $int1);
cc_setsize($int4, $int5, $setsize6, $setsize7);
cc_setposition(0, 0, $setposh, $setposv);
cc_setgraphic($graphic);
return(calc($int1 + 1));
