// 8278
[proc,script8278](dbrow $dbrow, int $int)(int)
if ($dbrow = null | db_getrowtable($dbrow) ! action) {
    ~script2075("Invalid action, or Invalid action table.");
    return(0);
}
if (db_getfield($dbrow, action:custom_tracking, 0) = true) {
    return(bitcount(~script8280($int, 0, 0)));
}
return(~script8280($int, 0, 0));
