// 3961
[proc,settings_get_slider](int $int)(int)
switch_int ($int) {
    case 310 :
        return(calc(minimap_getzoom - 2));
    case 15 :
        return(calc(deviceoption_get(^deviceoption_brightness) / 5));
    case 79 :
        return(%option_interface_scaling);
    case 168 :
        if (%settings_draw_distance < 25 | %settings_draw_distance > 90) {
            %settings_draw_distance = ~minmax(25, 90, deviceoption_get(^deviceoption_draw_distance));
        }
        return(~minmax(0, 32, interpolate(0, struct_param(struct_3656, param_1101), 25, 90, %settings_draw_distance)));
    case 393 :
        return(%settings_minimenu_spacing);
}
