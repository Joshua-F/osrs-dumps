// 9615
[proc,create_layer](component $component, int $int1, int $int2, int $int3, int $setposh, int $setposv, int $int6, int $int7, int $setsize8, int $setsize9)(int)
cc_create($component, ^iftype_layer, $int1);
cc_setposition($int2, $int3, $setposh, $setposv);
cc_setsize($int6, $int7, $setsize8, $setsize9);
return(calc($int1 + 1));
