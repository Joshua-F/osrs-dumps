[clientscript,account_summary_init](component $summary_contents, component $summary_click_layer, component $summary_player_name)
if_settext(chat_playername, $summary_player_name);
if_setonvartransmit("summary_sidepanel_draw($summary_contents, $summary_click_layer){qp, qp_total, qp_total2, speedrun_points, collection_count, collection_count_max, achievement_diary_taskcounts, achievement_diary_taskcounts2, achievement_diary_taskcounts3, achievement_diary_taskcounts4, achievement_diary_taskcounts5, achievement_diary_taskcounts6, achievement_diary, achievement_diary2, atjun_tasks_1, atjun_tasks_2, atjun_tasks_3, atjun_tasks_4, achievement_diary_rewards, achievement_diary_rewards2}", $summary_contents);
~summary_sidepanel_draw($summary_contents, $summary_click_layer);
