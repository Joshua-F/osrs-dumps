// 2618
[proc,magic_spellbook_hidespells](enum $enum)
def_int $int = 0;
def_obj $obj = enum(int, obj, $enum, $int);
while ($obj ! null) {
    if (~league_world = true) {
        $obj = ~script3159($obj);
    }
    if_sethide(true, oc_param($obj, param_596));
    $int = calc($int + 1);
    $obj = enum(int, obj, $enum, $int);
}
