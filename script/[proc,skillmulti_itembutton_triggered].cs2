// 2052
[proc,skillmulti_itembutton_triggered](obj $obj, component $component, string $string, int $key, int $int3, int $int4, int $int5)
~skillmulti_itembutton_draw(true, null, $component, $int4, $int5);
if_setonmouseover(null, $component);
if_setonmouseleave("deltooltip(skillmulti:tooltip)", $component);
if_setonop(null, $component);
if_setonkey(null, $component);
if_setontimer("skillmulti_itembutton_reset(calc(clientclock + 40), $obj, $component, $string, $key, $int3, $int4, $int5)", $component);
def_boolean $boolean = enum(int, boolean, enum_5178, $int3);
if ($boolean = false) {
    sound_synth(synth_2266, 1, 0);
    if (cc_find($component, 0) = true) {
        cc_resume_pausebutton;
    }
} else if (%skillmulti_quantity >= 1 & %skillmulti_quantity <= 28) {
    sound_synth(synth_2266, 1, 0);
    if (cc_find($component, %skillmulti_quantity) = true) {
        cc_resume_pausebutton;
    }
} else {
    sound_synth(synth_2277, 1, 0);
}
