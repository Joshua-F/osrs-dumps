// 2052
[proc,skillmulti_itembutton_triggered](obj $obj, component $component, string $string, int $key, int $int3, int $int4)
~skillmulti_itembutton_draw(true, null, $component, $int3, $int4);
if_setonmouseover(null, $component);
if_setonmouseleave("deltooltip(interface_270:com_24)", $component);
if_setonop(null, $component);
if_setonkey(null, $component);
if_setontimer("skillmulti_itembutton_reset(calc(clientclock + 40), $obj, $component, $string, $key, $int3, $int4)", $component);
if (%varclient_200 >= 1 & %varclient_200 <= 28) {
    sound_synth(synth_2266, 1, 0);
    if (cc_find($component, %varclient_200) = true) {
        cc_resume_pausebutton;
    }
} else {
    sound_synth(synth_2277, 1, 0);
}
