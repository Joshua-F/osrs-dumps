// 4203
[clientscript,audio_synth_play](enum $enum0, int $int, string $string, enum $enum2)
$int = calc($int - 2);
def_synth $synth = null;
if ($enum0 = null) {
    mes("No such enum.");
    return;
}
if ($int > calc(enum_getoutputcount($enum0) - 1)) {
    mes("No such index in enum.");
    return;
}
$synth = enum(int, synth, $enum0, $int);
if ($synth = null) {
    mes("Could not find synth.");
}
sound_synth($synth, 1, 0);
mes("Playing from Category: <$string> - Synth: <enum(int, string, $enum2, $int)> Menu index: <tostring(calc($int + 2))>");
