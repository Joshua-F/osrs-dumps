// 2287
[clientscript,bondif_redeem_hover](boolean $boolean, component $component, int $int)
if (cc_find($component, $int) = true) {
    if ($boolean = true) {
        cc_setgraphic(tradebacking_light);
        cc_settrans(~max(0, calc(cc_gettrans - 40)));
        cc_setontimer(null);
    } else if (cc_gettrans < 255) {
        cc_setgraphic(tradebacking_light);
        cc_setontimer("bondif_redeem_fadeend(event_com, event_comsubid)");
    }
}
