// 3603
[proc,omnishop_currency_draw_icon](graphic $graphic, component $component, int $int2, int $int3, int $int4, int $int5, int $int6, int $setposh, int $setposv, int $int9, int $int10)(int)
cc_create($component, ^iftype_graphic, $int2);
cc_setsize($int5, $int6, ^setsize_abs, ^setsize_abs);
cc_setposition(calc($int3 + $int9), calc($int4 + $int10), $setposh, $setposv);
cc_setgraphic($graphic);
return(calc($int2 + 1));
