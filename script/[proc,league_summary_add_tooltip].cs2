// 7739
[proc,league_summary_add_tooltip](string $string)
if (~on_mobile = true) {
    cc_setop(1, $string);
    cc_setonop("league_summary_tooltip_mobile($string)");
    return;
}
cc_setonmouserepeat("tooltip_mouserepeat(event_com, event_comsubid, league_summary:tooltip, $string, 25, 512)");
cc_setonmouseleave("deltooltip(league_summary:tooltip)");
