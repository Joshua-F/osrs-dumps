// 1363
[clientscript,trawler_activity](component $com_32, component $com_33, component $com_31)
def_int $int = interpolate(0, if_getwidth($com_31), 0, 255, %varplayerbit_3377);
if_setsize($int, 0, ^setsize_abs, ^setsize_minus, $com_32);
if_setsize(calc(if_getwidth($com_31) - $int), 0, ^setsize_abs, ^setsize_minus, $com_33);
if ($int < calc(if_getwidth($com_31) / 4)) {
    if_setcolour(0xee1111, $com_32);
} else if ($int < calc(if_getwidth($com_31) / 2)) {
    if_setcolour(0xeeee11, $com_32);
} else {
    if_setcolour(0x11ee11, $com_32);
}
