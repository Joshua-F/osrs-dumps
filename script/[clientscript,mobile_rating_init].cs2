// 2634
[clientscript,mobile_rating_init](component $yes_button, component $no_button, component $ask_later_button, component $text, component $model_l, component $model_r)
~membership_benefits_prompt_button_init($yes_button, "Yes");
~membership_benefits_prompt_button_init($no_button, "No");
~membership_benefits_prompt_button_init($ask_later_button, "Ask Me Later");
if_settext("Enjoying your time?<br><br>Would you like to take a moment to rate the app?", $text);
if_setmodel(model_36049, $model_l);
if_setmodel(model_36049, $model_r);
