// 2634
[clientscript,mobile_rating_init](component $com_4, component $com_3, component $com_2, component $com_1)
~membership_benefits_prompt_button_init($com_4, "Yes");
~membership_benefits_prompt_button_init($com_3, "No");
~membership_benefits_prompt_button_init($com_2, "Ask Me Later");
if_settext("Enjoying your time?<br><br>Would you like to take a moment to rate the app?", $com_1);
