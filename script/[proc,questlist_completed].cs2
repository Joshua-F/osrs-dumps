// 5995
[proc,questlist_completed](component $component)
def_string $string = ",";
if (~speedrunning_world = false) {
    if_settext("Completed: <~tostring_spacer(%quests_completed_count, $string)>/<~tostring_spacer(%quests_total_count, $string)>", $component);
} else {
    if_settext("Speedrun Points: <~tostring_spacer(~min(%speedrun_points, 800000), $string)>", $component);
}
