// 5995
[proc,questlist_completed](component $component)
def_string $string = ",";
if (~speedrunning_world = false) {
    if_settext("Completed: <~tostring_spacer(%varplayerbit_6347, $string)>/<~tostring_spacer(%varplayerbit_11877, $string)>", $component);
} else {
    if_settext("Speedrun Points: <~tostring_spacer(~min(%varplayer_3365, 800000), $string)>", $component);
}
