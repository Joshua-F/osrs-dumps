// 4901
[proc,league_get_league_name_short]()(string)
if (%league_type = 0 | %league_type > 6) {
    ~debug_mes("League variable was incorrectly set. Previous value: <tostring(%league_type)>. New Value: <tostring(6)>.");
    %league_type = 6;
}
def_string $string = struct_param(enum(int, struct, enum_2670, %league_type), param_1882);
if (string_length($string) > 0) {
    return($string);
} else {
    return(~league_get_league_name);
}
