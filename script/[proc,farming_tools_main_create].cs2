// 1057
[proc,farming_tools_main_create](component $component, obj $obj, string $string, int $int)
if_setonmouserepeat("farming_tools_main_recreate($component, $obj, $string, $int, true)", $component);
if_setonmouseleave("farming_tools_main_recreate($component, $obj, $string, $int, false)", $component);
~farming_tools_main_recreate($component, $obj, $string, $int, false);
