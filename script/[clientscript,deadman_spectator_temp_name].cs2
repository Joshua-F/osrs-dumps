// 2202
[clientscript,deadman_spectator_temp_name](string $string)
if (string_length(%varclient_364) ! 0 & compare(%varclient_364, $string) ! 0) {
    friend_del(%varclient_364);
}
if (string_length($string) = 0) {
    return;
}
if (friend_test($string) = true) {
    return;
}
friend_add($string);
%varclient_364 = $string;
