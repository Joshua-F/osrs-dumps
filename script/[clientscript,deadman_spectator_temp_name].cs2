// 2202
[clientscript,deadman_spectator_temp_name](string $string)
if (string_length(%spectator_name) ! 0 & compare(%spectator_name, $string) ! 0) {
    friend_del(%spectator_name);
}
if (string_length($string) = 0) {
    return;
}
if (friend_test($string) = true) {
    return;
}
friend_add($string);
%spectator_name = $string;
