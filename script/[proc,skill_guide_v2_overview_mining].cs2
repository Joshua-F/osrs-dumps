// 9165
[proc,skill_guide_v2_overview_mining](component $component)
~script9182($component, "", "Mining is a skill about gathering ores from the ||::<123>::Mines|| around Gielinor. Use the tabs on the left to see which rocks can be mined and the Mining level required to mine them.<"||::p||">Level up your Mining skill by mining rocks. This increases your chance to successfully mine the resource and unlocks more types of rocks to mine as well as better pickaxes to mine with.<"||::p||">||::hl||<"To mine a rock"><"||::/hl||">, you need a pickaxe which can be equipped or automatically used from your inventory. Pickaxes can be purchased from ||::<122>::Mining Shops||, such as the one in the Dwarven Mine north of Falador, or dropped by some monsters. A better pickaxe increases your chance to successfully mine the resources.<"||::p||">Once you have a pickaxe, simply <~text_device("click", "tap")> on the type of rock you want to mine. Once mined, the rock will be depleted for a short period of time.");
~script9182($component, "Getting Started", "To get started, visit the ||::<138>::Mining Tutor|| at the ||::<123>::Mine|| south of Lumbridge. He'll give you a Bronze Pickaxe and show you how to mine the Tin and Copper Rocks found in that mine.");
def_stringarray $stringarray = array_create(string, 2, -1);
$stringarray(0) = "||skill:<14>::<15>::Smithing:::|| Ores mined with the Mining skill can be smelted into bars with the Smithing skill.";
$stringarray(1) = "||skill:<11>::<12>::Crafting:::|| Ores, gems and clay mined with the Mining skill can be used for a wide range of crafts with the Crafting skill.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
