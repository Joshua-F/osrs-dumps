// 729
[proc,script729](boolean $boolean, component $component, string $string)
def_int $int = 0;
if ($boolean = true) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $int = ~v2_stone_button_out_filled($component);
}
cc_create($component, ^iftype_text, $int);
cc_setsize(if_getwidth($component), if_getheight($component));
cc_setposition(0, 0);
cc_settextfont(p12_full);
cc_settextshadow(true);
cc_setcolour(0xff981f);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settext($string);
