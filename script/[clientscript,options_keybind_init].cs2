// 2004
[clientscript,options_keybind_init](component $com_84, component $com_85, component $com_118)
if_setgraphic(~graphic_device("options_icons,32", "options_icons,42"), $com_85);
if_setonmouseleave("deltooltip($com_118)", $com_84);
~options_keybind($com_84, $com_118);
if_setonop("options_keybind_op(event_op, $com_84, $com_118)", $com_84);
