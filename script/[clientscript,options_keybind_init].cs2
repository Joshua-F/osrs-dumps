// 2004
[clientscript,options_keybind_init](component $com_78, component $com_79, component $com_112)
if_setgraphic(~graphic_device("options_icons,32", "options_icons,42"), $com_79);
if_setonmouseleave("deltooltip($com_112)", $com_78);
~options_keybind($com_78, $com_112);
if_setonop("options_keybind_op(event_op, $com_78, $com_112)", $com_78);
