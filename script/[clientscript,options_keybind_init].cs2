// 2004
[clientscript,options_keybind_init](component $com_65, component $com_66, component $com_91)
if_setgraphic(~graphic_device("options_icons,32", "options_icons,42"), $com_66);
if_setonmouseleave("deltooltip($com_91)", $com_65);
~options_keybind($com_65, $com_91);
if_setonop("options_keybind_op(event_op, $com_65, $com_91)", $com_65);
