// 2004
[clientscript,options_keybind_init](component $com_66, component $com_67, component $com_92)
if_setgraphic(~graphic_device("options_icons,32", "options_icons,42"), $com_67);
if_setonmouseleave("deltooltip($com_92)", $com_66);
~options_keybind($com_66, $com_92);
if_setonop("options_keybind_op(event_op, $com_66, $com_92)", $com_66);
