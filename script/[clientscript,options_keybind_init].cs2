// 2004
[clientscript,options_keybind_init](component $com_77, component $com_78, component $com_111)
if_setgraphic(~graphic_device("options_icons,32", "options_icons,42"), $com_78);
if_setonmouseleave("deltooltip($com_111)", $com_77);
~options_keybind($com_77, $com_111);
if_setonop("options_keybind_op(event_op, $com_77, $com_111)", $com_77);
