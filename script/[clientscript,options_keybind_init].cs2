// 2004
[clientscript,options_keybind_init](component $com_83, component $com_84, component $com_109)
if_setgraphic(~graphic_device("options_icons,32", "options_icons,42"), $com_84);
if_setonmouseleave("deltooltip($com_109)", $com_83);
~options_keybind($com_83, $com_109);
if_setonop("options_keybind_op(event_op, $com_83, $com_109)", $com_83);
