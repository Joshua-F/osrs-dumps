// 2004
[clientscript,options_keybind_init](component $com_63, component $com_64, component $com_88)
if_setgraphic(~graphic_device("options_icons,32", "options_icons,42"), $com_64);
if_setonmouseleave("deltooltip($com_88)", $com_63);
~options_keybind($com_63, $com_88);
if_setonop("options_keybind_op(event_op, $com_63, $com_88)", $com_63);
