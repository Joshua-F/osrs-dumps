// 2585
[proc,tutorial_hint_chatbox]
def_string $string = "bottom";
if (~on_mobile = true) {
    $string = "top";
}
if_settext("Follow the instructions in the <col=ffffff>chatbox<col=ff981f>", interface_614:com_8);
if_settext("to complete the tutorial.", interface_614:com_9);
if_settext("The <col=ffffff>chatbox<col=ff981f> can be found at the", interface_614:com_10);
if_settext("<col=ffffff><$string><col=ff981f> of the screen.", interface_614:com_11);
