// 4352
[proc,clan_storage_button_reset](string $string, component $component)
if_setopbase("<col=ff9040><$string></col>", $component);
~clan_storage_button_draw($string, $component, 0);
if_setontimer(null, $component);
if_setonop("clan_storage_button_op(event_op, $string, $component)", $component);
