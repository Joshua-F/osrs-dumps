// 57
[clientscript,chatbox_keyinput_listener](int $key0, char $char, component $component, int $int3, int $key4, string $string0, string $string1, int $rgb, int $int6)
if (clientclock < $int6) {
    return;
}
def_int $int7 = 0;
if ($key0 ! null & $key0 = $key4) {
    $int7 = 1;
} else if ($char ! null & (string_indexof_char($string0, $char) ! -1 | string_indexof_char($string1, $char) ! -1)) {
    $int7 = 1;
} else {
    return;
}
if ($int3 ! -1 & cc_find($component, $int3) = true) {
    if (string_length(cc_gettext) > 0) {
        cc_resume_pausebutton;
        cc_settext("Please wait...");
        cc_setcolour($rgb);
    }
    cc_setonkey("chatbox_keyinput_listener(event_keycode, event_keychar, event_com, event_comsubid, $key4, $string0, $string1, $rgb, calc(clientclock + 20))");
} else {
    if (string_length(if_gettext($component)) > 0) {
        if_resume_pausebutton($component);
        if_settext("Please wait...", $component);
        if_setcolour($rgb, $component);
    }
    if_setonkey("chatbox_keyinput_listener(event_keycode, event_keychar, event_com, -1, $key4, $string0, $string1, $rgb, calc(clientclock + 20))", $component);
}
