// 3131
[clientscript,screen_glow_fadeout](int $int0, int $int1, int $rgb, component $component, boolean $boolean)
if (cc_find($component, 0) = true) {
    if (clientclock < $int0) {
        return;
    }
    if (clientclock >= $int1) {
        cc_setontimer(null);
        if ($boolean = true) {
            cc_delete;
        }
        return;
    }
    cc_setcolour($rgb);
    cc_setblendcolour($rgb);
    cc_settrans(interpolate(0, 255, $int0, $int1, clientclock));
    cc_setblendtrans(255);
}
