// 4127
[proc,side_container_reload](component $component)
cc_deleteall($component);
if (%side_container_steel = 0) {
    ~stonebox($component, 1, 0);
    if_setsize(204, 275, ^setsize_abs, ^setsize_abs, $component);
} else {
    ~steelbox($component, 0, 0);
    if_setsize(202, 273, ^setsize_abs, ^setsize_abs, $component);
}
