// 671
[proc,rune_pouch_drawinventory_slot](obj $obj, int $int)
cc_clearops;
cc_setontimer(null);
if ($obj ! null) {
    if (enum(obj, int, enum_55, $obj) ! 0) {
        cc_settrans(0);
        cc_setobject($obj, $int);
        cc_setopbase("<col=ff9040><oc_name($obj)></col>");
        cc_setop(1, "Store-1");
        cc_setop(2, "Store-5");
        cc_setop(3, "Store-All");
        cc_setop(4, "Store-X");
        cc_setop(10, "Examine");
        cc_setonop("cc_settrans_temporarily(event_com, event_comsubid, 100, 0)");
        cc_setondragcomplete("rune_pouch_inventoryreorder(event_com, event_com2, event_comsubid, event_comsubid2, 255, 0)");
    } else {
        cc_settrans(150);
        cc_setobject($obj, $int);
        cc_setopbase("<col=ff9040><oc_name($obj)></col>");
        cc_setop(1, "Store");
        cc_setop(10, "Examine");
        cc_setonop("cc_settrans_temporarily(event_com, event_comsubid, 175, 150)");
        cc_setondragcomplete("rune_pouch_inventoryreorder(event_com, event_com2, event_comsubid, event_comsubid2, 255, 150)");
    }
} else {
    cc_settrans(0);
    cc_setobject(obj_6512, 1);
    cc_setonop(null);
    cc_setondragcomplete(null);
}
