// 38
[clientscript,addtooltip](component $component, component $tooltip, string $string, int $int2, int $int3)
if (~on_mobile = true) {
    return;
}
if (~on_enhanced_any = true) {
    ~mouseover_tooltip_setup($string, "", mouse_getx, mouse_gety, $tooltip, $component, -1, 0, 0, 1);
    return;
}
def_int $int4 = 0;
def_int $int5 = 0;
if (%tooltip_time < calc(clientclock + $int2)) {
    if (%tooltip_time < clientclock) {
        %tooltip_time = clientclock;
    }
    %tooltip_time = calc(%tooltip_time + 2);
    return;
}
%tooltip_time = calc(clientclock + $int2 + 10);
if (%tooltip_built = 0) {
    if ($int3 > if_getwidth(if_getlayer($tooltip))) {
        $int3 = if_getwidth(if_getlayer($tooltip));
    }
    $int3 = calc($int3 - 4);
    if_setsize(calc(4 + parawidth($string, $int3, p12_full)), calc(4 + 13 * paraheight($string, $int3, p12_full)), ^setsize_abs, ^setsize_abs, $tooltip);
    $int4 = calc(if_getx($component) + 5);
    $int5 = calc(if_gety($component) + if_getheight($component) + 5);
    if (if_getlayer($tooltip) ! null) {
        if ($int4 > calc(if_getwidth(if_getlayer($tooltip)) - if_getwidth($tooltip))) {
            $int4 = calc(if_getwidth(if_getlayer($tooltip)) - if_getwidth($tooltip));
        }
        if ($int5 > calc(if_getheight(if_getlayer($tooltip)) - if_getheight($tooltip))) {
            $int5 = calc(if_gety($component) - if_getheight($tooltip) - 5);
        }
    }
    if_setposition($int4, $int5, ^setpos_abs_left, ^setpos_abs_top, $tooltip);
    cc_deleteall($tooltip);
    cc_create($tooltip, ^iftype_rectangle, 0);
    cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
    cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
    cc_setfill(true);
    cc_setcolour(0xffffa0);
    cc_create($tooltip, ^iftype_rectangle, 1);
    cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
    cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
    cc_setfill(false);
    cc_setcolour(^black);
    cc_create($tooltip, ^iftype_text, 2);
    cc_setsize(4, 0, ^setsize_minus, ^setsize_minus);
    cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
    cc_settext($string);
    cc_settextalign(^settextalign_left, ^settextalign_centre, 0);
    cc_settextfont(p12_full);
    cc_setcolour(^black);
    %tooltip_built = 1;
}
