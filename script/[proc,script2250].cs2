// 2250
[proc,script2250](component $com_26)
if (~on_mobile = false) {
    return;
}
def_int $int = if_getwidth(interface_601:com_16);
if ($int >= 1000) {
    if_setsize(15064, 15858, ^setsize_rel, ^setsize_rel, $com_26);
    if ($com_26 = interface_601:com_26) {
        if_setsize(90, 90, ^setsize_abs, ^setsize_abs, interface_601:com_1);
    }
} else {
    if_setsize(16064, 16258, ^setsize_rel, ^setsize_rel, $com_26);
}
