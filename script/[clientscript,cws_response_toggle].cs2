// 1440
[clientscript,cws_response_toggle](component $component, int $int1, int $int2, int $int3, int $int4)
if (cc_find($component, $int1) = true & .cc_find($component, $int3) = true) {
    sound_synth(synth_2266, 1, 0);
    ~cws_set_toggle($component, $int2, $int3, $int4);
    .cc_resume_pausebutton;
}
