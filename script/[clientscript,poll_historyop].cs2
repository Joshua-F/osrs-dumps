// 628
[clientscript,poll_historyop](component $component, int $int1, int $int2, string $string)
sound_synth(synth_2266, 1, 0);
if (cc_find($component, $int2) = true) {
    cc_settext("<col=ffffff>Loading...</col>");
    cc_setontimer("poll_historyreset(event_com, event_comsubid, $string, calc(clientclock + 30))");
}
if (cc_find($component, $int1) = true) {
    cc_resume_pausebutton;
}
