// 214
[clientscript,clan_op](string $string, int $int)
if ($int = 6 & ~wildwars_world = false) {
    ~clan_sendkick($string);
} else if ($int = 7) {
    friend_add($string);
} else if ($int = 8) {
    ignore_add($string);
} else if ($int = 9) {
    friend_del($string);
} else if ($int = 10) {
    ignore_del($string);
}
