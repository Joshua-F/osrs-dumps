// 1132
[clientscript,script1132](component $noshake, component $background)
if_setnoclickthrough(true, $background);
if_setonclick("opsound(0, 0)", $background);
if_setopbase("<col=ff8040>Camera motion</col>", $noshake);
~script1135($noshake, $background);
if_setonvartransmit("script1133($noshake, $background){musicloop}", $noshake);
