// 1786
[proc,inventory_op_override](obj $obj, int $int)(string)
def_string $string = oc_iop($obj, $int);
if (map_members = true | oc_members($obj) = 0) {
    switch_obj ($obj) {
        case obj_22517 :
            if ($int = 3) {
                if (%varplayerbit_14838 = 1) {
                    $string = "Disable-autotele";
                } else {
                    $string = "Enable-autotele";
                }
            }
        case obj_28767 :
            if ($int = 1 & %varplayer_4034 ! null) {
                $string = "all";
                if (%varplayerbit_17306 = 0) {
                    if (%varplayerbit_17307 > 0 & %varplayerbit_17307 < 27) {
                        $string = tostring(%varplayerbit_17307);
                    }
                    $string = "Note-<$string>";
                } else {
                    if (%varplayerbit_9536 > 0 & %varplayerbit_9536 < 27) {
                        $string = tostring(%varplayerbit_9536);
                    }
                    $string = "Un-note-<$string>";
                }
            }
        case obj_28769 :
            if ($int = 3) {
                if (%varplayerbit_17308 = 1) {
                    $string = "Enable-multi-attack";
                } else {
                    $string = "Disable-multi-attack";
                }
            }
    }
}
return($string);
