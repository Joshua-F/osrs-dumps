// 1462
[proc,lumbridge_alchemy_invtransmit](component $component, int $int1)
def_obj $obj = null;
def_int $int3 = $int1;
while ($int3 > 0) {
    $int3 = calc($int3 - 1);
    if (cc_find($component, $int3) = true) {
        $obj = inv_getobj(inv, $int3);
        if ($obj ! null) {
            cc_sethide(false);
            cc_setobject($obj, inv_getnum(inv, $int3));
            cc_setopbase("<col=ff9040><oc_name($obj)></col>");
        } else {
            cc_sethide(true);
        }
    }
}
