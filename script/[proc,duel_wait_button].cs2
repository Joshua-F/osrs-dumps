// 1442
[proc,duel_wait_button](component $component, int $int)
if_settext("Wait...", $component);
if_setcolour(~duel_colour_variation(16750879), $component);
if_setonmouseover(null, $component);
if_setonmouseleave(null, $component);
if_setontimer("duel_accept_button($component, calc(clientclock + $int * 30))", $component);
