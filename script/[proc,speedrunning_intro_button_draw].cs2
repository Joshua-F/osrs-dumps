// 5876
[proc,speedrunning_intro_button_draw](component $component, string $string)
if_sethide(false, $component);
def_int $int = ~v2_stone_button_filled($component);
cc_create($component, ^iftype_text, $int);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_setcolour(^white);
cc_settextshadow(true);
cc_settextfont(p12_full);
if (string_length($string) > 0) {
    cc_settext($string);
    if_setop(1, removetags($string), $component);
}
if (~on_mobile = false) {
    if_setonmouseleave("speedrunning_intro_button_hover($component, 0, $string)", $component);
    if_setonmouserepeat("speedrunning_intro_button_hover($component, 1, $string)", $component);
}
if_setonop("speedrunning_intro_button_op(event_op, $component, $string)", $component);
if_setontimer(null, $component);
