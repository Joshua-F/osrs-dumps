// 1093
[clientscript,bugreport_init](component $universe, component $introduction, component $continue, component $home, component $form, component $description_text, component $description_scrollbar, component $next, component $form_repro, component $reproduction_text, component $reproduction_scrollbar, component $back, component $submit)
~chatdefault_stopinput;
%bugreport_desc, %bugreport_repro = "", "";
if_sethide(false, $introduction);
if_sethide(true, $form);
def_string $string = "Continue";
~bugreport_drawbutton(false, $continue, $string);
if_setonmouseover("bugreport_drawbutton(true, event_com, $string)", $continue);
if_setonmouseleave("bugreport_drawbutton(false, event_com, $string)", $continue);
if_setonclick("bugreport_continue($introduction, $form)", $continue);
$string = "Back";
~bugreport_drawbutton(false, $home, $string);
if_setonmouseover("bugreport_drawbutton(true, event_com, $string)", $home);
if_setonmouseleave("bugreport_drawbutton(false, event_com, $string)", $home);
if_setonclick("bugreport_home($introduction, $form)", $home);
$string = "Submit";
~bugreport_drawbutton(false, $submit, $string);
if_setonmouseover("bugreport_drawbutton(true, event_com, $string)", $submit);
if_setonmouseleave("bugreport_drawbutton(false, event_com, $string)", $submit);
if_setonclick("bugreport_submit", $submit);
if_clearops($submit);
if_setonop(null, $submit);
~scrollbar_vertical($description_scrollbar, $description_text, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~scrollbar_vertical($reproduction_scrollbar, $reproduction_text, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~bugreport_init_textinput($description_text);
~bugreport_init_textinput($reproduction_text);
~bugreport_switch_textinput($description_text, $description_scrollbar, $reproduction_text, $reproduction_scrollbar, $form, $description_text, $reproduction_text, $submit);
$string = "Next";
~bugreport_drawbutton(false, $next, $string);
if_setonmouseover("bugreport_drawbutton(true, event_com, $string)", $next);
if_setonmouseleave("bugreport_drawbutton(false, event_com, $string)", $next);
if_setonclick("bugreport_next($form, $form_repro, $description_text, $description_scrollbar, $reproduction_text, $reproduction_scrollbar, $form, $description_text, $reproduction_text, $submit)", $next);
if_clearops($next);
if_setonop(null, $next);
$string = "Back";
~bugreport_drawbutton(false, $back, $string);
if_setonmouseover("bugreport_drawbutton(true, event_com, $string)", $back);
if_setonmouseleave("bugreport_drawbutton(false, event_com, $string)", $back);
if_setonclick("bugreport_back($form, $form_repro, $description_text, $description_scrollbar, $reproduction_text, $reproduction_scrollbar, $form, $description_text, $reproduction_text, $submit)", $back);
if_clearops($back);
if_setonop(null, $back);
