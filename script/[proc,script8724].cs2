// 8724
[proc,script8724](component $component)
def_int $int1 = %sailing_sidepanel_boat_hp_max;
def_int $int2 = %sailing_sidepanel_boat_hp;
def_int $int3 = %sailing_last_boat_hp;
if (%sailing_player_is_on_player_boat = 0 & %sailing_sidepanel_shipyard_mode = 0) {
    $int2, $int1, $int3 = 0, 0, 0;
}
~healthbar_draw_animated($component, 0, $int2, $int1, $int3);
%sailing_last_boat_hp = $int2;
if_setonvartransmit("script8723($component){sailing_sidepanel_facility_states_0, sailing_sidepanel_facility_states_1}", $component);
