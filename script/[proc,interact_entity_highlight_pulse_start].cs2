// 5961
[proc,interact_entity_highlight_pulse_start](entityoverlay $entityoverlay)
if (~on_enhanced_mobile = false) {
    return;
}
~entity_highlight_setup(4, 2, 128, ~script758);
def_int $int = clientclock;
if (if_find_entityoverlay($entityoverlay) = true) {
    cc_setontimer("interact_entity_highlight_pulse($int, $entityoverlay, %varclient_973, %varclient_974, %varclient_975, %varclient_976, %varclient_977, %varclient_978, %varclient_979)");
}
