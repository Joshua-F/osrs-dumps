// 5961
[proc,interact_entity_highlight_pulse_start]
if (~on_enhanced_mobile = false) {
    return;
}
~entity_highlight_setup(4, 2, 128);
def_enum $enum = ~toplevel_getcomponents;
def_component $component = enum(component, component, $enum, interface_161:com_36);
def_int $int = clientclock;
if_setontimer("interact_entity_highlight_pulse($int)", $component);
