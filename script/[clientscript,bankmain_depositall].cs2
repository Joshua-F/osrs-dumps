// 292
[clientscript,bankmain_depositall](component $component, graphic $graphic1, graphic $graphic2, int $int)
if ($int ! 1) {
    return;
}
if_setgraphic($graphic1, $component);
sound_synth(synth_2266, 1, 0);
if_setontimer("bankmain_depositall_end(event_com, $graphic2, calc(clientclock + 20))", $component);
