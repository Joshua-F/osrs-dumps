// 6633
[proc,cluehelper_infobox_draw_content]
def_dbrow $dbrow = %cluehelper_infobox_clue;
~helper_generic_setup(1, 1, 1);
switch_dbtable (db_getrowtable($dbrow)) {
    case cluehelper_clue_cryptic :
        ~cluehelper_infobox_draw_content_cryptic($dbrow);
    case cluehelper_clue_anagram :
        ~cluehelper_infobox_draw_content_anagram($dbrow);
    case cluehelper_clue_map :
        ~cluehelper_infobox_draw_content_map($dbrow);
    case cluehelper_clue_hotcold :
        ~cluehelper_infobox_draw_content_hotcold($dbrow);
    case cluehelper_clue_emote :
        ~cluehelper_infobox_draw_content_emote($dbrow);
    case cluehelper_clue_coordinate :
        ~cluehelper_infobox_draw_content_coordinate($dbrow);
    case cluehelper_clue_skillchallenge :
        ~cluehelper_infobox_draw_content_skillchallenge($dbrow);
    case cluehelper_clue_music :
        ~cluehelper_infobox_draw_content_music($dbrow);
    case cluehelper_clue_falobard :
        ~cluehelper_infobox_draw_content_falobard($dbrow);
    case cluehelper_clue_cipher :
        ~cluehelper_infobox_draw_content_cipher($dbrow);
    case cluehelper_clue_fairyring :
        ~cluehelper_infobox_draw_content_fairyring($dbrow);
}
~helper_generic_build_ui;
