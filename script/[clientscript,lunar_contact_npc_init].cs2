// 1190
[clientscript,lunar_contact_npc_init](component $universe, component $contents, component $scrollbar, component $scrolllayer)
if_setscrollsize(0, if_getheight($scrolllayer), $contents);
if_setscrollpos(0, 0, $contents);
~scrollbar_vertical($scrollbar, $contents, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~scrollbar_resize($scrollbar, $contents, %lunar_contactnpc_scrollpos);
~lunar_contact_npc_draw;
if_setonstattransmit("lunar_contact_npc_draw{cooking, fishing}", $universe);
if_setonvartransmit("lunar_contact_npc_draw{handsand, misc_quest, abyssal_miniquest, dream_main, wgs_primary, zeah_alignment1, mm2_quest, elite_skill_challenges, barcrawl, scorpcatcher, porcine_main, wgs_primary_2, osb5, if1}", $universe);
