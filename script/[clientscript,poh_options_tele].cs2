// 1077
[clientscript,poh_options_tele](component $tele_on, component $tele_off)
if (%poh_tele_toggle = 1) {
    if_setgraphic("options_radio_buttons,0", $tele_on);
    if_setgraphic("options_radio_buttons,2", $tele_off);
} else {
    if_setgraphic("options_radio_buttons,2", $tele_on);
    if_setgraphic("options_radio_buttons,0", $tele_off);
}
