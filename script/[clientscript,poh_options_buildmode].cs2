// 211
[clientscript,poh_options_buildmode](component $build_mode_on, component $build_mode_off)
if (%poh_building_mode = 1) {
    if_setgraphic("options_radio_buttons,2", $build_mode_on);
    if_setgraphic("options_radio_buttons,0", $build_mode_off);
} else {
    if_setgraphic("options_radio_buttons,0", $build_mode_on);
    if_setgraphic("options_radio_buttons,2", $build_mode_off);
}
