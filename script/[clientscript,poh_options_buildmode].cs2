// 211
[clientscript,poh_options_buildmode](component $com_2, component $com_4)
if (%varplayerbit_2176 = 1) {
    if_setgraphic("options_radio_buttons,2", $com_2);
    if_setgraphic("options_radio_buttons,0", $com_4);
} else {
    if_setgraphic("options_radio_buttons,0", $com_2);
    if_setgraphic("options_radio_buttons,2", $com_4);
}
