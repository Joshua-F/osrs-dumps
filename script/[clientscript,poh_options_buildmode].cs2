// 211
[clientscript,poh_options_buildmode](component $com_5, component $com_6)
if (%varplayerbit_2176 = 1) {
    if_setgraphic("options_radio_buttons,2", $com_5);
    if_setgraphic("options_radio_buttons,0", $com_6);
} else {
    if_setgraphic("options_radio_buttons,0", $com_5);
    if_setgraphic("options_radio_buttons,2", $com_6);
}
