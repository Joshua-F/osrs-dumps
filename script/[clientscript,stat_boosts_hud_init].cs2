if (~on_enhanced_any = false) {
    return;
}
if (~on_mobile = false) {
    if_setposition(2, 2, ^setpos_abs_left, ^setpos_abs_bottom, $com_2);
    ~interface_dodger_init($com_1, $com_2, 30720, ^setpos_abs_left, ^setpos_abs_bottom, false);
} else {
    if_setposition(2, 0, ^setpos_abs_right, ^setpos_abs_bottom, $com_2);
    ~interface_dodger_init($com_1, $com_2, setbit(0, 1), ^setpos_abs_right, ^setpos_abs_bottom, false);
}
if_setonstattransmit("stat_boosts_hud_update_displays($com_2, $com_5, $com_3, $com_4)", $com_5);
if_setonvartransmit("stat_boosts_hud_update_displays($com_2, $com_5, $com_3, $com_4){varplayer_3074}", $com_5);
