if_setsize(calc(4 * 2 + 3), 35, ^setsize_abs, ^setsize_abs, $com_4);
def_int $int = 0;
$int = ~script4516($com_4, 0, $int, true);
$int = ~script4516($com_4, 1, $int, false);
cc_create($com_4, ^iftype_rectangle, $int);
$int = calc($int + 1);
cc_setcolour(0x383023);
