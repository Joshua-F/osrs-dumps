// 4130
[clientscript,stat_boosts_hud_init](component $dodger, component $content, component $universe, component $timers_container, component $stats_container, component $tooltip)
if (~on_enhanced_any = false) {
    return;
}
if (~on_mobile = false) {
    if_setposition(2, 2, ^setpos_abs_left, ^setpos_abs_bottom, $content);
    ~interface_dodger_init($dodger, $content, 30720, ^setpos_abs_left, ^setpos_abs_bottom, false);
} else {
    if_setposition(2, 0, ^setpos_abs_right, ^setpos_abs_bottom, $content);
    ~interface_dodger_init($dodger, $content, setbit(0, 1), ^setpos_abs_right, ^setpos_abs_bottom, false);
}
if_setonstattransmit("stat_boosts_hud_update_displays($content, $stats_container, $tooltip, $timers_container)", $stats_container);
if_setonvartransmit("stat_boosts_hud_update_displays($content, $stats_container, $tooltip, $timers_container){settings_varp_2}", $stats_container);
if_setonvartransmit("stat_boosts_hud_update_enabled($content, $tooltip){settings_varp_2}", $universe);
if_setsize(calc(4 * 2 + 3), 35, ^setsize_abs, ^setsize_abs, $timers_container);
def_int $int = 0;
$int = ~script4516($timers_container, 0, $int, true);
$int = ~script4516($timers_container, 1, $int, false);
cc_create($timers_container, ^iftype_rectangle, $int);
$int = calc($int + 1);
cc_setcolour(0x383023);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_create($timers_container, ^iftype_rectangle, $int);
$int = calc($int + 1);
cc_setcolour(0x5a5245);
cc_setsize(1, 1, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
if_sethide(true, $timers_container);
