// 4718
[proc,health_regen_timer](int $int0, int $int1, int $int2, int $int3)
if (~on_enhanced_any = false) {
    return;
}
def_component $health_regen = orbs:health_regen;
if (~on_mobile = false & ~toplevel_getcomponents ! enum_1129 & %minimap_toggle = 1) {
    $health_regen = orbs_nomap:health_regen;
} else if (~on_mobile = true & %osm_minimap_toggle = 0) {
    $health_regen = orbs_osm:health_regen;
} else if (~on_mobile = true & %osm_minimap_toggle = 1) {
    $health_regen = orbs_osm_nomap:health_regen;
}
cc_deleteall($health_regen);
if_setonstattransmit("health_orb_stattransmit{hitpoints}", $health_regen);
if_setonvartransmit("health_orb_vartransmit($health_regen, %regen_indicator_disabled){settings_varp_1, prayer0, prayer_ruinous_0}", $health_regen);
if (%orbs_disabled = 1) {
    return;
}
if (%regen_indicator_disabled = 1) {
    return;
}
if (stat(hitpoints) = stat_base(hitpoints)) {
    return;
}
$int0 = calc($int0 * 30);
if ($int0 = 0) {
    $int1 = 0;
} else if ($int1 >= $int0) {
    $int1 = calc($int1 % $int0);
}
$int2 = calc($int2 * 30);
if ($int2 = 0) {
    $int3 = 0;
} else if ($int3 >= $int2) {
    $int3 = calc($int3 % $int2);
}
.cc_create($health_regen, ^iftype_circle, 0);
.cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
.cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
.cc_setcolour(0x024def);
.cc_setfill(false);
.cc_setlinewid(2);
if ($int2 > 0) {
    .cc_setarc(0, calc(scale($int3, $int2, 65536) % 65536));
} else {
    .cc_setarc(0, 0);
}
cc_create($health_regen, ^iftype_circle, 1);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0xf00b04);
cc_setfill(false);
cc_setlinewid(2);
if ($int0 > 0) {
    cc_setarc(0, calc(scale($int1, $int0, 65536) % 65536));
} else {
    cc_setarc(0, 0);
}
if_setontimer("health_orb_arc($health_regen, $int0, $int1, $int2, $int3)", $health_regen);
if (~script7056($int2) = true) {
    .cc_sethide(true);
}
