// 4658
[clientscript,helper_cox_data](component $component, int $int1, int $int2)
def_int $int3 = calc(30 * %raids_timer);
if (cc_find($component, $int1) = true & .cc_find($component, $int2) = true) {
    ~helper_cox_data($component, $int3);
    if (%raids_timer > 0 & %raids_client_progress < 5) {
        cc_setontimer("helper_cox_timer($component, $int1, $int2, $int3)");
    }
    if (%raids_client_progress >= 5) {
        cc_setontimer(null);
    }
}
