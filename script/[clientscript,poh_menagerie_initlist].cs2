// 639
[clientscript,poh_menagerie_initlist](component $list, component $scrollbar)
cc_deleteall($scrollbar);
~scrollbar_vertical($scrollbar, $list, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~poh_menagerie_drawlist($list, $scrollbar, 0);
if_setoninvtransmit("poh_menagerie_drawlist($list, $scrollbar){poh_menagerie_pets}", $list);
if_setonvartransmit("poh_menagerie_drawlist($list, $scrollbar){prayer20, menagerie_contents2, poh_scry_coord1}", $list);
