// 4940
[proc,script4940]
def_component $tab_content_1 = colosseum_intermission_2:tab_content_1;
cc_deleteall($tab_content_1);
def_string $string = "Select a modifier";
~create_text($tab_content_1, 0, b12_full, 0, 0, ^setpos_abs_centre, ^setpos_abs_top, 0, 20, ^setsize_minus, ^setsize_abs, $string, true, 0xff981f, ^settextalign_centre, ^settextalign_centre, 13);
$string = "Use the buttons below to select a modifier before continuing to the next wave.<br><br>Alternatively, you may end this run now and claim the loot you've earned so far.";
~create_text($tab_content_1, 1, p11_full, 0, 0, ^setpos_abs_centre, ^setpos_abs_bottom, 0, 20, ^setsize_minus, ^setsize_minus, $string, true, 0xff981f, ^settextalign_centre, ^settextalign_centre, 11);
