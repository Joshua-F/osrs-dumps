// 6938
[clientscript,script6938](component $component, int $int, int $rgb)
if (cc_find($component, calc($int + 1)) = true) {
    cc_setcolour($rgb);
}
if (cc_find($component, calc($int + 11)) = true) {
    cc_setcolour($rgb);
}
if (cc_find($component, calc($int + 12)) = true) {
    cc_setcolour($rgb);
}
