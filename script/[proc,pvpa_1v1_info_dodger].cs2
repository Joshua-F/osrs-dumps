// 6347
[proc,pvpa_1v1_info_dodger](component $component)
def_int $int = 0;
if (%pvpa_battlearea_status = 1 & %pvpa_battlearea_timeremaining > 0) {
    $int = calc($int + 45);
}
if (%xpdrops_enabled = 1) {
    $int = calc($int + 35 + 30);
    if (%xpdrops_progress_type ! 0) {
        $int = calc($int + 9);
    }
}
if_setsize(0, $int, ^setsize_minus, ^setsize_minus, $component);
