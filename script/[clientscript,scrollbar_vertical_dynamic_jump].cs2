// 8207
[clientscript,scrollbar_vertical_dynamic_jump](component $component, int $int1)
def_int $int2 = 0;
if ($int1 = -1 & if_find($component) = true | cc_find($component, $int1) = true) {
    $int2 = cc_param(param_2351);
} else {
    return;
}
if (cc_find($component, calc($int2 + 1)) = true) {
    cc_dragpickup(0, calc(cc_getheight / 2));
}
