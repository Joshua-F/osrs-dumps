// 3501
[proc,script3501](component $component)
~script3503($component, false, false);
if_setonmouserepeat("script3502($component, true, false)", $component);
if_setonmouseleave("script3502($component, false, false)", $component);
if_setonop("script3504(event_op, $component)", $component);
if_setontimer(null, $component);
