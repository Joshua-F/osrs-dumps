// 2461
[proc,script2461](component $component, boolean $boolean)
cc_deleteall($component);
def_int $int = 0;
if (%varplayerbit_17300 = 1 & $boolean = false) {
    $int = ~v2_stone_button_filled($component);
} else {
    $int = ~v2_stone_button_in_filled($component);
}
cc_create($component, ^iftype_model, $int);
cc_setmodel(model_27231);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setmodelangle(5, 5, 501, 234, 0, 3000);
cc_setopbase("<col=ff9040>Noted items");
cc_setop(1, "Toggle");
cc_setonop("script2462");
if (~on_mobile = false & %varplayerbit_17300 = 1) {
    if_setonmouseover("shop_noted_button_redraw($component, true)", $component);
    if_setonmouseleave("shop_noted_button_redraw($component, false)", $component);
} else {
    if_setonmouseover(null, $component);
    if_setonmouseleave(null, $component);
}
