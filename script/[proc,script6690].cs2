// 6690
[proc,script6690](npc $npc)(string)
def_string $string = "2|";
$string = append($string, nc_getopbase($npc, true, false));
$string = append($string, "|");
$string = append($string, nc_getop($npc, 1, false));
$string = append($string, "|");
$string = append($string, nc_getop($npc, 2, false));
$string = append($string, "|");
$string = append($string, nc_getop($npc, 3, false));
$string = append($string, "|");
$string = append($string, nc_getop($npc, 4, false));
$string = append($string, "|");
$string = append($string, nc_getop($npc, 5, false));
return($string);
