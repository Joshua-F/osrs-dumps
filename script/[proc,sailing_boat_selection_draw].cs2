// 8623
[proc,sailing_boat_selection_draw]
def_component $universe = sailing_boat_selection:universe;
def_component $content = sailing_boat_selection:content;
~sailing_boat_selection_interface_resize($universe, $content);
def_int $int = 0;
if (%sailing_boat_selection_type = 3 & ~sailing_unlocked = true) {
    $int = 1;
}
~sailing_boat_selection_draw_button($int);
~sailing_boat_selection_draw_boats;
