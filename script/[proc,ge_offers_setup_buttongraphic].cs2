// 775
[proc,ge_offers_setup_buttongraphic](component $component, int $int1, graphic $graphic, int $int3)(int)
if (cc_find($component, $int1) = true) {
    .cc_create($component, ^iftype_graphic, $int3);
    $int3 = calc($int3 + 1);
    .cc_setsize(20, 18);
    .cc_setposition(calc(cc_getx + 8), calc(cc_gety + 8));
    .cc_setgraphic($graphic);
}
return($int3);
