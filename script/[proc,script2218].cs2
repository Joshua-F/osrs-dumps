// 2218
[proc,script2218]
def_component $component = null;
def_int $int = 0;
while ($int <= 7) {
    $component = enum(int, component, enum_1911, $int);
    if ($component ! null) {
        if (%if4 = $int) {
            if_sethide(false, $component);
        } else {
            if_sethide(true, $component);
        }
    }
    $int = calc($int + 1);
}
