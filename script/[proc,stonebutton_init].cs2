// 2425
[proc,stonebutton_init](string $string, component $component, graphic $graphic, int $int)
~stonebutton_draw(false, $string, $graphic, $int, $component);
if (~on_mobile = false) {
    if_setonmouserepeat("script2426(true, $string, event_com, $graphic, $int)", $component);
}
if_setonmouseleave("script2426(false, $string, event_com, $graphic, $int)", $component);
if_setop(1, removetags($string), $component);
if_setontimer(null, $component);
