    ~clan_stonebutton_init("<col=ff0000>Cancel</col>", $com_10, p12_full);
    ~clan_stonebutton_draw(false, "<col=808080>Invite</col>", p12_full, $com_9);
    ~clan_stonebutton_draw(false, "<col=808080>Confirm</col>", p12_full, $com_11);
