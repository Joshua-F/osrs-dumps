// 6827
[proc,script6827](string $string, dbrow $dbrow)(string)
$string = ~script4875($string, $dbrow, 1);
if (db_getfield($dbrow, dbtable_0:col27, 0) > 3) {
    $string = "<$string><~questjournal_overview_combat_requirement(db_getfield($dbrow, dbtable_0:col27, 0))><br>";
}
def_stat $stat = null;
def_int $int2 = -1;
def_int $int3 = db_getfieldcount($dbrow, dbtable_0:col23);
def_int $int4 = 0;
while ($int4 < $int3) {
    $stat, $int2 = db_getfield($dbrow, dbtable_0:col23, $int4);
    if ($stat ! null & $int2 > 1) {
        $string = "<$string><~questjournal_overview_skill_requirement($stat, $int2)><br>";
    }
    $int4 = calc($int4 + 1);
}
$string = ~script4875($string, $dbrow, 0);
return($string);
