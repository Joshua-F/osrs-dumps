// 3296
[proc,options_wiki](component $component0, component $component1)
def_string $string = "Wiki entity lookup (currently off)";
if (~wiki_icon_enabled = true) {
    $string = "Wiki entity lookup (currently on)";
    if_setgraphic("options_boxes,1", $component0);
} else {
    if_setgraphic("options_boxes,0", $component0);
}
if_setonmouserepeat("tooltip_mouserepeat($component0, -1, $component1, $string, 25, 512)", $component0);
%varclient_2 = 0;
