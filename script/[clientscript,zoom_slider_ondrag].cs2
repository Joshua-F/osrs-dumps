// 833
[clientscript,zoom_slider_ondrag](component $zoom_slider_bobble, component $component, int $int)
if ($zoom_slider_bobble ! settings_side:zoom_slider_bobble) {
    return;
}
~zoom_slider_specific_pos($zoom_slider_bobble, $component, $int);
if_setontimer(null, settings_side:zoom_slider_bobble);
if_setontimer("settings_zoom_trans_timer(0)", settings:frame);
