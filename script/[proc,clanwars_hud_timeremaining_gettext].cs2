// 744
[proc,clanwars_hud_timeremaining_gettext](int $int0)(string)
def_int $int1 = calc($int0 / 180000);
def_int $int2 = calc($int0 % 180000 / 3000);
def_int $int3 = calc($int0 % 3000 / 50);
def_string $string = tostring($int1);
if ($int2 >= 10) {
    $string = append($string, ":<tostring($int2)>");
} else {
    $string = append($string, ":0<tostring($int2)>");
}
if ($int3 >= 10) {
    $string = append($string, ":<tostring($int3)>");
} else {
    $string = append($string, ":0<tostring($int3)>");
}
if ($int0 <= 3000) {
    $string = "<col=ff0000><$string></col>";
}
return($string);
