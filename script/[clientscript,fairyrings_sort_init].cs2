// 8156
[clientscript,fairyrings_sort_init](component $contents, component $scrollbar, int $int, component $divider, component $faves, component $search)
~fairyrings_sort_update($contents, $scrollbar, $int, 1, $divider, $faves);
%fairyrings_searchstring = "";
~fairyrings_search_toggle(1, $contents, $scrollbar, $divider, $faves, $search, 0);
