// 3281
[clientscript,wear_initslots](enum $enum, boolean $boolean)
def_component $component = null;
def_int $int = inv_size(inv_94);
while ($int > 0) {
    $int = calc($int - 1);
    $component = enum(int, component, $enum, $int);
    if ($component ! null) {
        ~wear_initslot($component, $int, $boolean);
    }
}
