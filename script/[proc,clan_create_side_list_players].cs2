// 4449
[proc,clan_create_side_list_players](component $component, string $string0, string $string1, string $string2, string $string3, string $string4, string $string5)
if (if_find($component) = true) {
    cc_deleteall($component);
    ~clan_create_player_component($component, $string0, 0, $string5);
    ~clan_create_player_component($component, $string1, 1, $string5);
    ~clan_create_player_component($component, $string2, 2, $string5);
    ~clan_create_player_component($component, $string3, 3, $string5);
    ~clan_create_player_component($component, $string4, 4, $string5);
}
