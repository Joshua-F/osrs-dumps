// 3187
[clientscript,league_border_pulse](component $component, boolean $boolean, int $int2)
def_int $int3 = 30;
if_settrans(interpolate(0, 255, 0, $int3, $int2), $component);
if ($boolean = true) {
    if ($int2 >= $int3) {
        $int2, $boolean = calc($int2 - 1), false;
    } else {
        $int2 = calc($int2 + 1);
    }
} else if ($int2 <= 0) {
    $int2, $boolean = calc($int2 + 1), true;
} else {
    $int2 = calc($int2 - 1);
}
if_setontimer("league_border_pulse($component, $boolean, $int2)", $component);
