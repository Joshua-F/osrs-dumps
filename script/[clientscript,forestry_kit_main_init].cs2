[clientscript,forestry_kit_main_init]
def_component $infinity = forestry_kit_main:infinity;
if_setontimer("responsive_interface_scaler($infinity, -1)", $infinity);
if_setonresize("forestry_kit_main_setup(true)", $infinity);
if_setoninvtransmit("forestry_kit_main_setup(false){forestry_kit}", $infinity);
