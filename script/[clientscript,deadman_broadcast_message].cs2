// 2805
[clientscript,deadman_broadcast_message](string $string)
if_settext($string, interface_90:com_31);
if_sethide(false, interface_90:com_28);
~deadman_broadcast_message_sizing($string);
if_setsize(0, 60, ^setsize_abs, ^setsize_abs, interface_90:com_28);
if_setontimer("deadman_broadcast_message_timer(clientclock)", interface_90:com_27);
