// 2805
[clientscript,deadman_broadcast_message](string $string)
if_settext($string, interface_90:com_25);
if_sethide(false, interface_90:com_22);
~deadman_broadcast_message_sizing($string);
if_setsize(0, 60, ^setsize_abs, ^setsize_abs, interface_90:com_22);
if_setontimer("deadman_broadcast_message_timer(clientclock)", interface_90:com_21);
