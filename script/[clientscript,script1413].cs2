// 1413
[clientscript,script1413](component $component0, model $model, component $component2, int $int)
if (clientclock < $int) {
    return;
}
if_setmodel($model, $component0);
if_sethide(true, $component2);
if_setonmouserepeat("comp_sethide(false, $component2)", $component0);
if_setonmouseleave("comp_sethide(true, $component2)", $component0);
if_setontimer(null, $component0);
