// 304
[proc,nzone_rewards_updatepotion](obj $obj)
if ($obj = nzone1dose2rangerspotion) {
    cc_settext("(<tostring(%nzone_potion_1)>)");
} else if ($obj = nzone1dose2magicpotion) {
    cc_settext("(<tostring(%nzone_potion_2)>)");
} else if ($obj = nzone1doseoverloadpotion) {
    cc_settext("(<tostring(%nzone_potion_3)>)");
} else if ($obj = nzone1doseabsorptionpotion) {
    cc_settext("(<tostring(%nzone_potion_4)>)");
} else {
    cc_settext("");
}
