// 4964
[clientscript,colosseum_modifier_hover](boolean $boolean, component $component, int $int2, int $int3, int $int4, int $int5)
if ($boolean = true) {
    sound_synth(synth_7986, 1, 0);
    if (cc_find($component, $int3) = true) {
        cc_settrans($int5);
    }
    ~colosseum_modifier_draw_info($int2, 1);
} else {
    if (cc_find($component, $int3) = true) {
        cc_settrans($int4);
    }
    ~colosseum_modifier_draw_info($int2, 0);
}
