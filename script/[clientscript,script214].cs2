// 214
[clientscript,script214](int $int, string $string)
federated_login($string, "check");
if_settextalign(^settextalign_centre, ^settextalign_centre, 16, messagebox:text);
if_settext("Opening the <$string> store, please wait.", messagebox:text);
if_settext("<~text_device("Click", "Tap")> here to cancel", messagebox:continue);
if_setontimer("script215($string, $int, 0, 2)", messagebox:text);
