// 5957
[onclickloc,_]
if (~on_enhanced_mobile = false | %varplayerbit_13666 = 1) {
    return;
}
~entity_highlight_clear(4);
def_entityoverlay $entityoverlay = entityoverlay_create_loc(4, ^overlaytype_middle, 1, 1, 0);
~interact_entity_highlight_pulse_start($entityoverlay);
~entity_highlight_active_loc(4);
