[proc,port_task_get_slot](int $int)(int)
switch_int ($int) {
    case 0 :
        return(%port_task_slot_0_id);
    case 1 :
        return(%port_task_slot_1_id);
    case 2 :
        return(%port_task_slot_2_id);
    case 3 :
        return(%port_task_slot_3_id);
    case 4 :
        return(%port_task_slot_4_id);
}
return(-1);
