// 2503
[proc,account_billing_update]
def_component $billing_text = account:billing_text;
def_component $store_button = account:store_button;
def_component $store_button_text = account:store_button_text;
def_component $store_button_icon_left = account:store_button_icon_left;
def_component $store_button_icon_right = account:store_button_icon_right;
def_component $bond_button_text = account:bond_button_text;
def_component $bond_button_icon_left = account:bond_button_icon_left;
def_component $bond_button_icon_right = account:bond_button_icon_right;
def_string $string0 = "Membership: <col=ff0000>None</col>";
def_string $string1 = "Upgrade Now";
def_graphic $graphic8 = "acc_man_icons,6";
def_string $string2 = "Bond Pouch";
def_graphic $graphic9 = "acc_man_icons,1";
if (%playermember = 1 & %account_credit > 0) {
    if (%account_credit > 99999) {
        $string0 = "Membership: 99999+ days left";
    } else if (%account_credit = 1) {
        if (%recurring_membership = false) {
            $string0 = "Membership: <col=ff0000>1 day left</col>";
        } else {
            $string0 = "Membership: 1 day left";
        }
    } else if (%account_credit <= 3 & %recurring_membership = false) {
        $string0 = "Membership: <col=ff0000><tostring(%account_credit)> days left</col>";
    } else {
        $string0 = "Membership: <tostring(%account_credit)> days left";
    }
    $string1 = "Open Store";
    $graphic8 = "acc_man_icons,0";
} else if (%has_bonds = 0) {
    $string2 = "View Benefits";
    $graphic9 = "acc_man_icons,5";
}
if_settext($string2, $bond_button_text);
if_setop(1, $string2, $bond_button_text);
if_setgraphic($graphic9, $bond_button_icon_left);
if_setgraphic($graphic9, $bond_button_icon_right);
if_settext($string0, $billing_text);
if_setop(1, $string1, $store_button);
if_settext($string1, $store_button_text);
if_setgraphic($graphic8, $store_button_icon_left);
if_setgraphic($graphic8, $store_button_icon_right);
