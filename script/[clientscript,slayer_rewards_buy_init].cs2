            }
    }
    cc_setop(1, "Info");
    cc_setop(10, "Examine");
    cc_setopbase("<col=ff9040><oc_name($obj)></col>");
    cc_setonop("slayer_rewards_buy_op(event_op, event_com, event_comsubid, $main, $confirm, $confirm_info, $confirm_button, $back_button)");
    $int17 = calc($int17 + 1);
    $obj = enum(int, namedobj, enum_840, $int17);
}
if_setscrollpos(0, 0, $buy_contents);
if_setsize($int9, $int15, ^setsize_abs, ^setsize_abs, $buy_items);
if_setsize($int9, $int15, ^setsize_abs, ^setsize_abs, $buy_prices);
if ($int15 > if_getheight($buy_contents)) {
    if_setscrollsize(0, $int15, $buy_contents);
} else {
    if_setscrollsize(0, 0, $buy_contents);
}
~scrollbar_vertical($buy_scrollbar, $buy_contents, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
