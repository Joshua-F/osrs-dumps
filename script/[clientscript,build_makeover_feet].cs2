// 3601
[clientscript,build_makeover_feet](component $com_1, component $com_4, component $com_5, component $com_3)
def_string $string = "Yrsa's Shoe Store";
if (~pvpa_world = true) {
    $string = "Select a shoe style";
}
~steelborder($com_1, $string, 0);
~rebuild_makeover_feet($com_4, $com_5, $com_3, -1);
