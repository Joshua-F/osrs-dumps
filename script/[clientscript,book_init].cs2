// 2632
[clientscript,book_init](component $com_7, component $com_8, component $com_75, component $com_76, component $com_77, component $com_78)
def_graphic $graphic6 = "close_buttons,4";
def_graphic $graphic7 = "close_buttons,5";
def_graphic $graphic8 = leftarrow;
def_graphic $graphic9 = leftarrow_highlight;
def_graphic $graphic10 = rightarrow;
def_graphic $graphic11 = rightarrow_highlight;
if (~on_mobile = false) {
    if_setonmouseover("graphic_swapper($com_8, $graphic7)", $com_7);
    if_setonmouseleave("graphic_swapper($com_8, $graphic6)", $com_7);
    if_setonmouseover("graphic_swapper($com_76, $graphic9)", $com_75);
    if_setonmouseleave("graphic_swapper($com_76, $graphic8)", $com_75);
    if_setonmouseover("graphic_swapper($com_78, $graphic11)", $com_77);
    if_setonmouseleave("graphic_swapper($com_78, $graphic10)", $com_77);
    if_setposition(2, 2, ^setpos_abs_right, ^setpos_abs_top, $com_7);
    if_setsize(26, 23, ^setsize_abs, ^setsize_abs, $com_7);
} else {
    if_setposition(0, 0, ^setpos_abs_right, ^setpos_abs_top, $com_7);
    if_setsize(30, 27, ^setsize_abs, ^setsize_abs, $com_7);
}
if_setonop("closebutton_click", $com_7);
