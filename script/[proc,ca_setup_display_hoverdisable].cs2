// 4829
[proc,ca_setup_display_hoverdisable](component $component, int $rgb)
if (cc_find($component, 0) = true) {
    cc_settrans(255);
    cc_setonmouseover(null);
    cc_setonmouseleave(null);
}
if (cc_find($component, 3) = true) {
    cc_settrans(0);
    cc_setgraphic("scrollbar_v2,0");
}
if (cc_find($component, 4) = true) {
    cc_setcolour($rgb);
}
