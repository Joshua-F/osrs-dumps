// 3439
[proc,script3439](int $int)(int)
def_int $intbool1 = testbit(%myq5_puzzle_tile_marked, $int);
def_int $intbool2 = testbit(%myq5_puzzle_tile_flagged, $int);
if ($intbool1 = ^true & $intbool2 = ^true) {
    return(-1);
}
if ($intbool1 = ^false & $intbool2 = ^false) {
    return(0);
} else if ($intbool1 = ^true) {
    return(2);
} else if ($intbool2 = ^true) {
    return(1);
} else {
    return(-1);
}
