// 6147
[clientscript,script6147](int $int)
if (cc_find(interface_148:com_11, $int) = true) {
    if (cc_gettrans = 210) {
        return;
    }
    cc_settrans(225);
    if (.cc_find(interface_148:com_11, calc($int + 1)) = true) {
        .cc_setoutline(2);
    }
    if (.cc_find(interface_148:com_11, calc($int + 2)) = true) {
        .cc_setcolour(^white);
    }
}
