// 6542
[proc,script6542]
highlight_npc_off(npc_uid, npc_creationcycle, 9);
def_entityoverlay $entityoverlay = entityoverlay_create_npc(4, ^overlaytype_top, calc(36 * 2), calc(32 * 2), 1);
if (if_find_entityoverlay($entityoverlay) = true) {
    ~script6543($entityoverlay, npc_creationcycle, npc_uid, npc_type);
}
