// 4274
[proc,clan_banned_wipedisplay](string $string, component $component0, component $component1)
def_int $int = calc(2 * 500);
if (cc_find($component0, $int) = true) {
    cc_sethide(false);
    cc_settext($string);
}
while ($int > 0) {
    $int = calc($int - 1);
    if (cc_find($component0, $int) = true) {
        cc_sethide(true);
    }
}
