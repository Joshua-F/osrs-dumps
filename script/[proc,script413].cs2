// 413
[proc,script413](int $int, string $string, component $component1, component $component2, component $component3, component $component4, component $component5)
if ($int < 32 & testbit(%slayer_rewards_unlocks, $int) = ^true | $int >= 32 & testbit(%slayer_rewards_unlocks1, calc($int % 32)) = ^true) {
    switch_int ($int) {
        case 35 :
            ~script6068(%slayer_toggleoff_superiormobs, $int, $string, $component1, $component2, $component3, $component4, $component5);
            return;
        case 43 :
            ~script6068(%slayer_toggleoff_fossilwyvernblock, $int, $string, $component1, $component2, $component3, $component4, $component5);
            return;
        case 53 :
            ~script6068(%slayer_toggleoff_longerrevenants, $int, $string, $component1, $component2, $component3, $component4, $component5);
            return;
    }
    cc_setgraphic("options_radio_buttons,6");
    if (enum(int, boolean, enum_854, $int) = true) {
        .cc_setop(1, "Disable");
        .cc_setonop("slayer_rewards_unlock_confirm(false, $int, $string, $component1, $component2, $component3, $component4, $component5, -1)");
    } else {
        .cc_setop(1, "");
        .cc_setonop(null);
    }
} else {
    cc_setgraphic("options_radio_buttons,4");
    .cc_setop(1, "Unlock");
    .cc_setonop("slayer_rewards_unlock_confirm(true, $int, $string, $component1, $component2, $component3, $component4, $component5, -1)");
}
