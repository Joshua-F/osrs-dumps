// 6509
[clientscript,script6509](dbrow $dbrow0, dbrow $dbrow1, loc $loc, coord $coord, obj $obj, int $int)
if ($int = 1 & inv_total(inv_93, $obj) <= 0 | $int = 0 & inv_total(inv_93, $obj) > 0) {
    if (loc_find($coord, $loc) = true & entityoverlay_get_loc(6) ! null) {
        entityoverlay_delete_loc(6);
    }
    ~cluehelper_overlay($dbrow0, $dbrow1);
}
