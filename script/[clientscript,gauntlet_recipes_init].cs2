// 2917
[clientscript,gauntlet_recipes_init](component $scroll_title, component $scroll_layer_outer, component $scroll_layer_inner, component $scrollbar, component $entry1, component $entry2, component $entry3, component $entry4, component $entry5, component $entry6, component $entry7, component $entry8, component $entry9, component $entry10, component $entry11, component $entry12, component $entry13, component $entry14, component $entry15, component $entry16, component $entry17, component $entry18, component $entry19, component $entry20, component $entry21, component $entry22)
def_int $int = if_getheight($scroll_layer_inner);
if_setscrollsize(0, $int, $scroll_layer_outer);
~scrollbar_vertical($scrollbar, $scroll_layer_outer, "scrollbar_parchment_dragger_v2,3", "scrollbar_parchment_dragger_v2,0", "scrollbar_parchment_dragger_v2,1", "scrollbar_parchment_dragger_v2,2", "scrollbar_parchment_v2,0", "scrollbar_parchment_v2,1");
if_setscrollpos(0, 0, $scroll_layer_outer);
if_settext("Crystal Singing Recipes", $scroll_title);
~script2918($entry1, "Crystal Vial", "<tostring(10)> <~script2920> Shards", ~gauntlet_select_item(gauntlet_vial_empty, %gauntlet_corrupted));
def_string $string = "";
if (%gauntlet_corrupted = 1) {
    $string = "Corrupted ";
}
~script2918($entry2, "<$string>Teleport Crystal", "<tostring(40)> <~script2920> Shards", ~gauntlet_select_item(gauntlet_teleport_crystal, %gauntlet_corrupted));
~script2918($entry3, "<$string>Escape Crystal", "<tostring(200)> <~script2920> Shards", ~gauntlet_select_item(gauntlet_escape_crystal, %gauntlet_corrupted));
