// 1347
[clientscript,br_hud_init](component $dodger, component $content, component $timer)
~interface_dodger_init($dodger, $content, setbit(setbit(36582, 12), 13), ^setpos_abs_right, ^setpos_abs_top, false);
~interface_dodger_init($timer, $timer, setbit(setbit(36578, 12), 13), ^setpos_abs_right, ^setpos_abs_bottom, false);
~br_hud_writetimer($timer);
if_setonvartransmit("br_hud_writetimer($timer){br_temp_1}", $timer);
