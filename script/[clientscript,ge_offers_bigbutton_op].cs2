// 542
[clientscript,ge_offers_bigbutton_op](int $int, component $component, string $string)
if ($int ! 1) {
    return;
}
~ge_offers_bigbutton($component, $string, 1);
sound_synth(synth_2266, 1, 0);
if_setontimer("ge_offers_bigbutton_reset($component, $string, calc(clientclock + 20))", $component);
