// 2216
[proc,welcome_screen_credit](component $component)
def_string $string = "";
def_int $int = 0;
if (%varplayer_1780 > 1) {
    $string = "You have <col=00ff00><~tostring_spacer(%varplayer_1780, ",")></col> days of Old School RuneScape membership remaining.";
} else if (%varplayer_1780 = 1) {
    $string = "You have <col=00ff00><~tostring_spacer(%varplayer_1780, ",")></col> day of Old School RuneScape membership remaining.";
} else if (%varclient_103 = 1) {
    $string = "You have no Old School RuneScape membership credit remaining.<br><br><col=ff9040>Subscribe to retain your membership status!</col>";
} else if (%varclient_103 = 0) {
    $string = "You are not a member.<br>Subscribe to access extra skills, areas,<br>quests, and more.";
} else {
    $int = 1;
}
if (%varclient_226 = false & %varplayer_1780 <= 3 & %varclient_103 = 1) {
    $string = "<$string><br><br><col=ff9040>Credit low! Renew now to avoid losing your</col><br><col=ff9040>membership status!</col>";
}
if ($int = 1) {
    if_setontimer("welcome_screen_credit($component)", $component);
    if_settext("", $component);
} else {
    if_settext($string, $component);
    if_setontimer(null, $component);
}
