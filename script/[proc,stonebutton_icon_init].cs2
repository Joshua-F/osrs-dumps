// 4910
[proc,stonebutton_icon_init](component $component, int $int1, graphic $graphic, int $int3, int $int4, string $string)
~stonebutton_icon_draw(false, $component, $int1, $graphic, $int3, $int4);
if (~on_mobile = false) {
    if_setonmouserepeat("script4911(true, event_com, $int1, $graphic, $int3, $int4)", $component);
}
if_setonmouseleave("script4911(false, event_com, $int1, $graphic, $int3, $int4)", $component);
if_setop(1, removetags($string), $component);
if_setontimer(null, $component);
