// 4252
[proc,clan_members_search_drawbutton](boolean $boolean, component $component)(int)
def_int $int = 0;
if ($boolean = true) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $int = ~v2_stone_button_filled($component);
}
cc_create($component, ^iftype_graphic, $int);
cc_setsize(29, 22, ^setsize_abs, ^setsize_abs);
cc_setposition(-1, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic("bankbuttons,2");
cc_settrans(0);
return($int);
