// 6260
[proc,pvpa_stagingarea_hud_drawtimer](component $component)
cc_deleteall($component);
def_int $int = 0;
cc_create($component, ^iftype_graphic, $int);
$int = calc($int + 1);
cc_setsize(2, 2, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic(tradebacking_light);
cc_settiling(true);
cc_settrans(120);
$int = ~thinstonebox($component, $int);
cc_create($component, ^iftype_text, $int);
$int = calc($int + 1);
cc_setsize(2, 2, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextfont(quill_oblique_large);
if (%varplayerbit_14015 <= 0) {
    cc_settext("<col=9f9f9f>---</col>");
    cc_setontimer(null);
    return;
}
~pvpa_stagingarea_hud_writetime;
cc_setontimer("pvpa_stagingarea_hud_writetime(event_com, event_comsubid)");
