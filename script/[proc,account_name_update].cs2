[proc,account_name_update]
def_component $com_21 = interface_109:com_21;
def_component $com_22 = interface_109:com_22;
def_component $com_26 = interface_109:com_26;
def_string $string0 = "Name: <col=ff0000>Not Set</col>";
def_string $string1 = "Set Name";
if (%varplayerbit_8119 = 1) {
    $string0 = "Name: <chat_playername>";
    $string1 = "Name Changer";
}
if_settext($string0, $com_21);
if_setop(1, $string1, $com_22);
if_settext($string1, $com_26);
