// 2506
[proc,account_name_update]
def_component $com_44 = interface_109:com_44;
def_component $com_45 = interface_109:com_45;
def_component $com_49 = interface_109:com_49;
def_string $string0 = "Name: <col=ff0000>Not Set</col>";
def_string $string1 = "Set Name";
if (%varplayerbit_8119 = 1) {
    $string0 = "Name: <chat_playername>";
    $string1 = "Name Changer";
}
if_settext($string0, $com_44);
if_setop(1, $string1, $com_45);
if_settext($string1, $com_49);
