// 7557
[proc,orbs_toggle_runmode](int $int, component $component1, component $component2)
if ($int ! 1) {
    return;
}
if (%option_run <= 0) {
    %option_run = 1;
} else {
    %option_run = 0;
}
~orbs_update_runmode($component1, $component2);
if (~toplevel_is_mobile(~toplevel_getcomponents) = true) {
    ~script7429(22);
}
