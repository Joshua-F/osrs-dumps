// 3932
[proc,script3932](component $component0, int $int, component $component2)
if (cc_find($component0, 1) = true) {
    if ($int = 0) {
        cc_setgraphic("options_radio_buttons,6");
    } else {
        cc_setgraphic("options_radio_buttons,5");
    }
    if_setonop("script3930($component0, $int, $component2)", $component0);
}
