// 375
[clientscript,options_acceptaid_init](component $com_100, component $com_117)
if_setonmouseleave("deltooltip($com_117)", $com_100);
~options_acceptaid($com_100, $com_117);
if_setonvartransmit("options_acceptaid_resynch($com_100, $com_117){varplayer_427, varplayer_499}", $com_100);
if_setonop("options_acceptaid_op(event_op, $com_100, $com_117)", $com_100);
