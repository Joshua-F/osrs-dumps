// 375
[clientscript,options_acceptaid_init](component $com_101, component $com_118)
if_setonmouseleave("deltooltip($com_118)", $com_101);
~options_acceptaid($com_101, $com_118);
if_setonvartransmit("options_acceptaid_resynch($com_101, $com_118){varplayer_427, varplayer_499}", $com_101);
if_setonop("options_acceptaid_op(event_op, $com_101, $com_118)", $com_101);
