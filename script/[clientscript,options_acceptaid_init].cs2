[clientscript,options_acceptaid_init](component $com_70, component $com_86)
if_setonmouseleave("deltooltip($com_86)", $com_70);
~options_acceptaid($com_70, $com_86);
if_setonvartransmit("options_acceptaid_resynch($com_70, $com_86){varplayer_427, varplayer_499}", $com_70);
if_setonop("options_acceptaid_op(event_op, $com_70, $com_86)", $com_70);
