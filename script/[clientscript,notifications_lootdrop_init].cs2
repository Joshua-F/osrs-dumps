[clientscript,notifications_lootdrop_init](component $com_7)
cc_deleteall($com_7);
cc_create($com_7, ^iftype_text, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settextfont(p11_full);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
~notifications_lootdrop_redraw($com_7);
if_setonvartransmit("notifications_lootdrop_redraw($com_7, cc_getid){varplayer_427}", $com_7);
