// 2081
[clientscript,magic_flash_spell](int $int, obj $obj)
if (%spellbook ! $int) {
    return;
}
def_component $component = oc_param($obj, param_596);
if ($component = null) {
    return;
}
if_setontimer("magic_flash($component, 1, 0)", magic_spellbook:spelllayer);
if (%stored_spell ! null) {
    ~magic_stop_flash(%stored_spell);
}
%stored_spell = $obj;
