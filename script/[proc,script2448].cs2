// 2448
[proc,script2448](obj $obj, boolean $boolean)(obj, boolean)
switch_obj ($obj) {
    case transmute_upgrade :
        if (~script9464(league_relic_transmutation_alchemy_toggle) = false) {
            if (~magic_runecount(naturerune, inv_getobj(worn, 3), inv_getobj(worn, 5)) < 1) {
                $boolean = false;
            }
            $obj = 55_high_alchemy;
        }
    case transmute_downgrade :
        if (~script9464(league_relic_transmutation_alchemy_toggle) = false) {
            if (~magic_runecount(naturerune, inv_getobj(worn, 3), inv_getobj(worn, 5)) < 1) {
                $boolean = false;
            }
            $obj = 21_low_alchemy;
        }
}
return($obj, $boolean);
