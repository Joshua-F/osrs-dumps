// 8308
[proc,script8308]()(boolean)
def_component $component = cc_getparentlayer;
while ($component ! null) {
    if (if_gethide($component) = true) {
        return(true);
    }
    $component = if_getparentlayer($component);
}
if (cc_parentid = -1) {
    return(false);
}
while (cc_find_parent = true) {
    if (cc_gethide = true) {
        return(true);
    }
}
return(false);
