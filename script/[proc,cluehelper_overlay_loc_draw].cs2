// 6505
[proc,cluehelper_overlay_loc_draw](dbrow $dbrow, loc $loc, coord $coord, obj $obj)
def_entityoverlay $entityoverlay = null;
if (loc_find($coord, $loc) = true) {
    $entityoverlay = entityoverlay_get_loc(5);
    if ($entityoverlay = null) {
        $entityoverlay = entityoverlay_create_loc(5, ^overlaytype_top, 36, 32, 1);
    } else {
        cc_deleteall_entityoverlay($entityoverlay);
    }
    if (if_find_entityoverlay($entityoverlay) = true) {
        cc_setonvartransmit("cluehelper_overlay_loc_transmit($entityoverlay, $dbrow, $loc, $coord, $obj, %option_cluehelper_overlay_enabled, %cluehelper_npc_id, %cluehelper_npc_id2, %cluehelper_npc_id3, %cluehelper_npc_current_clue, %option_cluehelper_target_highlight_enabled, %option_cluehelper_enabled){cluehelper_infobox_clue, option_cluehelper, cluehelper_npc_id, cluehelper_npc_id2, cluehelper_npc_id3, cluehelper_npc_current_clue}");
    }
    if (%option_cluehelper_enabled = 0 | ~cluehelper_overlay_npc_active = 1) {
        highlight_loc_off($loc, $coord, 9, 1);
        return;
    }
    if (%option_cluehelper_overlay_enabled = 1) {
        cc_create_entityoverlay($entityoverlay, ^iftype_graphic, 0);
        cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
        cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
        cc_setobject_nonum($obj, 1);
        cc_setoutline(1);
    }
    highlight_loc_setup(9, ^green, 2, 30, 1);
    if (%option_cluehelper_target_highlight_enabled = 1) {
        highlight_loc_on($loc, $coord, 9, 1);
    }
}
