// 543
[proc,script543](component $component)
def_int $int = 0;
while ($int < 3) {
    if (cc_find($component, calc($int * 2)) = true) {
        if ($int = %varplayer_1107) {
            cc_setgraphic("options_radio_buttons,2");
        } else {
            cc_setgraphic("options_radio_buttons,0");
        }
    }
    $int = calc($int + 1);
}
