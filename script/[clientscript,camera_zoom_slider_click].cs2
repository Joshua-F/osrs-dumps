// 1047
[clientscript,camera_zoom_slider_click](component $zoom_slider_bobble, component $zoom_slider, int $int)
~settings_side_op_sound;
~zoom_slider_specific_pos($zoom_slider_bobble, $zoom_slider, calc($int - if_getwidth($zoom_slider_bobble) / 2));
if_setontimer("settings_zoom_trans_timer(0)", settings:frame);
