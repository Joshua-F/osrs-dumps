// 4395
[clientscript,clan_sidepanel_init](boolean $boolean, component $universe, component $header, component $playerlist, component $scrollbar, component $chat, component $info, component $search)
~scrollbar_vertical($scrollbar, $playerlist, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~clan_sidepanel_draw($boolean, $header, $playerlist, $scrollbar, $chat, $info, $search);
if_setonvartransmit("clan_sidepanel_draw($boolean, $header, $playerlist, $scrollbar, $chat, $info, $search){clan_temp_transmit_0, chat_filter_clan, br_temp_2}", $universe);
if_setonclansettingstransmit("clan_sidepanel_draw($boolean, $header, $playerlist, $scrollbar, $chat, $info, $search)", $universe);
if_setonclanchanneltransmit("clan_sidepanel_draw($boolean, $header, $playerlist, $scrollbar, $chat, $info, $search)", $universe);
if_setonfriendtransmit("clan_sidepanel_draw($boolean, $header, $playerlist, $scrollbar, $chat, $info, $search)", $universe);
