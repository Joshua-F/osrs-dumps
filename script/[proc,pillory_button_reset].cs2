// 3776
[proc,pillory_button_reset](component $component)
cc_settrans(255);
if_setonmouserepeat("cc_settrans(event_com, cc_getid, 245, null)", $component);
if_setonmouseleave("cc_settrans(event_com, cc_getid, 255, null)", $component);
if_setonop("pillory_button_op(event_op, event_com, cc_getid)", $component);
if_setontimer(null, $component);
