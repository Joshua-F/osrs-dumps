// 6671
[proc,script6671]
~blast_furnace_highlights;
def_entityoverlay $entityoverlay = entityoverlay_create_loc(4, ^overlaytype_middle, 1, 1, 1);
if (if_find_entityoverlay($entityoverlay) = true) {
    cc_setonvartransmit("blast_furnace_highlights{varplayer_543}");
    cc_setoninvtransmit("blast_furnace_highlights{inv_93, inv_94}");
}
