// 1533
[proc,script1533](component $component, string $string)
def_int $int = 0;
if ($component = interface_507:com_12) {
    $int = %varplayerbit_5433;
} else if ($component = interface_507:com_16) {
    $int = %varplayerbit_5426;
} else if ($component = interface_507:com_20) {
    $int = %varplayerbit_5427;
}
if ($int > 0) {
    cc_settext("<$string>: <col=ffffff><tostring($int)></col>");
} else {
    cc_settext("<$string>: ---");
}
