// 5107
[clientscript,script5107](boolean $boolean, component $component, string $string, graphic $graphic, int $int)
cc_deleteall($component);
~beige_stone_button_draw($boolean, $component, $string, $graphic, $int);
if ($boolean = true) {
    if_setontimer("beige_stone_button_hoverreset(calc(clientclock + 2), event_com, $string, $graphic, $int)", $component);
} else {
    if_setontimer(null, $component);
}
