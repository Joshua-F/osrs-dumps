// 9087
[proc,script9087]()(string)
def_dbrow $dbrow = null;
if (db_find(sailing_boat:type_id, %sailing_boarded_boat_type) = 1) {
    $dbrow = db_findnext;
}
def_string $string = db_getfield($dbrow, sailing_boat:displayname, 0);
if (string_length($string) <= 0) {
    return(~sailing_boat_name_core(%sailing_boarded_boat_name_1, %sailing_boarded_boat_name_2, %sailing_boarded_boat_name_3));
}
return($string);
