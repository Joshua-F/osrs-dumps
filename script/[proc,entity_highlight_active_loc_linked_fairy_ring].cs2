// 2496
[proc,entity_highlight_active_loc_linked_fairy_ring](coord $coord, int $int)(coord)
switch_int ($int) {
    case 0 :
        $coord = movecoord($coord, -1, 0, 1);
    case 1 :
        $coord = movecoord($coord, 1, 0, 0);
    case 2 :
        $coord = movecoord($coord, 1, 0, 0);
    case 3 :
        $coord = movecoord($coord, -2, 0, -1);
    case 4 :
        $coord = movecoord($coord, 1, 0, 0);
    case 5 :
        $coord = movecoord($coord, 1, 0, 0);
    case 6 :
        $coord = movecoord($coord, -2, 0, -1);
    case 7 :
        $coord = movecoord($coord, 1, 0, 0);
    case 8 :
        $coord = movecoord($coord, 1, 0, 0);
}
return($coord);
