// 4284
[clientscript,clan_info_init](component $universe, component $frame, component $contents, component $info_container, component $button_container, component $events, component $members, component $applications, component $hall, component $permissions, component $titles, component $banned, component $quit)
def_int $int13 = ~steelborder($frame, "", 1);
cc_deleteall($contents);
cc_create($contents, ^iftype_text, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0xff981f);
cc_settextfont(p12_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_settext("Loading...");
def_int $int14 = cc_getid;
~clan_info_draw($frame, $int13, $contents, $int14, $info_container, $button_container, $events, $members, $applications, $hall, $permissions, $banned, $quit);
if_setonvartransmit("clan_info_draw($frame, $int13, $contents, $int14, $info_container, $button_container, $events, $members, $applications, $hall, $permissions, $banned, $quit){clan_temp_transmit_0}", $universe);
if_setonclansettingstransmit("clan_info_draw($frame, $int13, $contents, $int14, $info_container, $button_container, $events, $members, $applications, $hall, $permissions, $banned, $quit)", $universe);
~stonebutton_init("Titles", $titles, p12_full, 0);
if_setonop("opsound(event_op, 2)", $titles);
if_setonop("opsound(event_op, 2)", $events);
if_setonop("opsound(event_op, 2)", $members);
if_setonop("opsound(event_op, 2)", $applications);
if_setonop("opsound(event_op, 2)", $hall);
if_setonop("opsound(event_op, 2)", $permissions);
if_setonop("opsound(event_op, 2)", $banned);
if_setonop("opsound(event_op, 2)", $quit);
