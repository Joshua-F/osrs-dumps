// 2941
[proc,silver_crafting_miscellaneous_setup](component $component, obj $obj1, int $int, obj $obj3, string $string)
if_sethide(false, $component);
if_setop(1, "Craft", $component);
if_setopbase("<col=ff9040><$string></col>", $component);
~silver_crafting_miscellaneous_draw($component, $obj1, $int, $obj3, $string);
if_setoninvtransmit("silver_crafting_miscellaneous_draw($component, $obj1, $int, $obj3, $string){inv}", $component);
if_setonstattransmit("silver_crafting_miscellaneous_draw($component, $obj1, $int, $obj3, $string){crafting}", $component);
