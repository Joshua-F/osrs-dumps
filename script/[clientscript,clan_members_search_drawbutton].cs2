// 4250
[clientscript,clan_members_search_drawbutton](boolean $boolean, component $component)
~clan_members_search_drawbutton($boolean, $component);
if ($boolean = true) {
    if_setontimer("script4251(calc(clientclock + 2), $component)", $component);
} else {
    if_setontimer(null, $component);
}
