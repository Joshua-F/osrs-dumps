// 2496
[proc,mobile_billing_open](int $int, boolean $boolean)
if (~on_mobile = true & (clienttype ! ^clienttype_ios | %varplayerbit_6617 = 1)) {
    if (clienttype = ^clienttype_ios) {
        $int = 0;
    }
    if ($int = 0) {
        shop_open;
    } else {
        shop_opensubset($int, $boolean);
    }
}
