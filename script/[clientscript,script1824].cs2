// 1824
[clientscript,script1824](int $int, component $component)
if (clientclock < $int) {
    return;
}
if_setontimer(null, $component);
if_sethide(true, vardorvis_qte:universe);
if_sethide(true, vardorvis_qte:background_gradient);
if_sethide(true, vardorvis_qte:foreground_tentacles);
if_sethide(true, vardorvis_qte:main);
if_close;
