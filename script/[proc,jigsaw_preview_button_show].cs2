// 7977
[proc,jigsaw_preview_button_show](component $component0, int $int, boolean $boolean, component $component3)
if ($boolean = true) {
    if_sethide(false, $component3);
    ~v2_stone_button_change_in($component0, $int);
    return;
}
if_sethide(true, $component3);
~v2_stone_button_change_out($component0, $int);
