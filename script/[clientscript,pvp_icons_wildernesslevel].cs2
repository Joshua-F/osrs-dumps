[clientscript,pvp_icons_wildernesslevel](component $com_58)
def_int $int = ~wilderness_level;
def_boolean $boolean = ~deadman_world;
if ($boolean = true) {
    if (%varplayer_1676 > 4) {
        if ($int > 0 & %varplayerbit_5954 = 1) {
            if_settext("Level: <tostring($int)>", $com_58);
        } else {
            if_settext("Deadman", $com_58);
        }
    } else if (%varplayerbit_4965 > 0) {
        if_settext("Protection", $com_58);
    } else if ($int > 0 & %varplayerbit_5954 = 1) {
        if_settext("Level: <tostring($int)>", $com_58);
    } else if (%varclient_78 = 1) {
        if_settext("Guarded", $com_58);
    } else if (%varclient_78 = 2) {
        if_settext("No PvP", $com_58);
    } else {
        if_settext("Deadman", $com_58);
    }
} else if ($int > 0) {
    if_settext("Level: <tostring($int)>", $com_58);
} else {
    if_settext("", $com_58);
}
~pvp_icons_comlevelrange($int);
