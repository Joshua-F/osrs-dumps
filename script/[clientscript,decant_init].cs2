// 2205
[clientscript,decant_init](component $decant_1, component $decant_2, component $decant_3, component $decant_4)
cc_deleteall($decant_1);
cc_deleteall($decant_2);
cc_deleteall($decant_3);
cc_deleteall($decant_4);
~decant_button($decant_1, false, dummy_pot1, "1 dose", "1");
~decant_button($decant_2, false, dummy_pot2, "2 doses", "2");
~decant_button($decant_3, false, dummy_pot3, "3 doses", "3");
~decant_button($decant_4, false, dummy_pot4, "4 doses", "4");
