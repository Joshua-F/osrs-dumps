// 6945
[clientscript,tgod_translations_setup](string $string)
def_component $scroll_text = tgod_translations:scroll_text;
def_component $scroll_text_layer = tgod_translations:scroll_text_layer;
def_component $scrollbar = tgod_translations:scrollbar;
def_int $int = calc(paraheight($string, if_getwidth($scroll_text), q8_full) * 15 + 6);
if ($int < 208) {
    $int = 208;
}
if_settext($string, $scroll_text);
if_setscrollsize(0, $int, $scroll_text_layer);
if_setsize(if_getwidth($scroll_text), $int, ^setsize_abs, ^setsize_abs, $scroll_text);
if_setscrollpos(0, 0, $scroll_text_layer);
~scrollbar_vertical($scrollbar, $scroll_text_layer, "scrollbar_parchment_dragger_v2,3", "scrollbar_parchment_dragger_v2,0", "scrollbar_parchment_dragger_v2,1", "scrollbar_parchment_dragger_v2,2", "scrollbar_parchment_v2,0", "scrollbar_parchment_v2,1");
