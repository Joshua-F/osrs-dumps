// 3496
[proc,death_office_resetquantity](string $string, component $component)
~death_office_drawquantity($string, $component, false, false);
if_setonmouserepeat("death_office_drawquantity($string, $component, true, false)", $component);
if_setonmouseleave("death_office_drawquantity($string, $component, false, false)", $component);
if_setonop("death_office_opquantity(event_op, $string, $component)", $component);
if_setontimer(null, $component);
