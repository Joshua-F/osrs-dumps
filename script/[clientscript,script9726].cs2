// 9726
[clientscript,script9726](component $component, int $int1, int $int2, int $int3)
if ($int1 ! -1) {
    if (cc_find($component, $int1) = true & cc_input_getfocus = true) {
        ~keyboard_show($int2, $int3);
        return;
    }
} else if (if_input_getfocus($component) = true) {
    ~keyboard_show($int2, $int3);
    return;
}
