// 4135
[proc,script4135](enum $enum, boolean $boolean)
if ($enum = enum_1130) {
    if_sethide($boolean, toplevel_osrs_stretch:side_menu);
} else if (~toplevel_is_mobile($enum) = true) {
    if_sethide($boolean, enum(component, component, $enum, toplevel_osm:side_right_tabs));
} else if ($enum = enum_1131) {
    if_sethide($boolean, toplevel_pre_eoc:side_static_layer);
    if_sethide($boolean, toplevel_pre_eoc:side_movable_layer);
}
