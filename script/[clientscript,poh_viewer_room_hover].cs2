// 1381
[clientscript,poh_viewer_room_hover](boolean $boolean, component $component, int $int, string $string)
if ($boolean = true) {
    if (cc_find($component, $int) = true) {
        cc_settrans(175);
    }
    ~tooltip_mouserepeat($component, -1, poh_viewer:tooltip, $string, 25, calc(512 / 2));
} else {
    if (cc_find($component, $int) = true) {
        cc_settrans(0);
    }
    ~deltooltip_action(poh_viewer:tooltip);
}
