// 7080
[clientscript,makeover_op_item](component $component, int $int)
if (cc_find($component, $int) = true) {
    cc_settrans(125);
    cc_setontimer("cc_settrans_temporarily_end($component, $int, 0, calc(clientclock + 10))");
    sound_synth(synth_2266, 1, 0);
    if (%makeover_current_selection ! $int) {
        %makeover_current_selection = $int;
    }
}
