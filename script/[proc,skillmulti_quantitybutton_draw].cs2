// 2058
[proc,skillmulti_quantitybutton_draw](boolean $boolean, string $string, component $component)
cc_deleteall($component);
def_int $int = 0;
if ($boolean = true) {
    $int = ~beige_stone_button_in($component, $int);
} else {
    $int = ~beige_stone_button_out($component, $int);
}
cc_create($component, ^iftype_text, $int);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_setcolour(if_getcolour(interface_270:com_5));
cc_settextshadow(false);
cc_settextfont(p11_full);
cc_settext($string);
