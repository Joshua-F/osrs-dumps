// 2124
[clientscript,fossil_underwater_training_init](component $universe, component $bottom, component $agility, component $thieving, component $both)
cc_deleteall($bottom);
cc_create($bottom, ^iftype_graphic, 0);
cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
cc_setgraphicshadow(0x333333);
cc_setoutline(1);
.cc_create($bottom, ^iftype_text, 1);
.cc_setcolour(0xff981f);
.cc_settextfont(p12_full);
.cc_settextshadow(true);
.cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
~fossil_underwater_training_bottom($bottom);
if_setoninvtransmit("fossil_underwater_training_bottom($bottom, cc_getid, .cc_getid){inv}", $universe);
~fossil_underwater_training_button_init($agility, "Agility XP", $agility, $thieving, $both);
~fossil_underwater_training_button_init($thieving, "Thieving XP", $agility, $thieving, $both);
~fossil_underwater_training_button_init($both, "Both skills", $agility, $thieving, $both);
