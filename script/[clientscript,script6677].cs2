// 6677
[clientscript,script6677](entityoverlay $entityoverlay, coord $coord, int $int)
if ($int = %rockthrower) {
    return;
}
if (cc_find_entityoverlay($entityoverlay, 0) = true) {
    cc_settext(tostring(%rockthrower));
    cc_setonvartransmit("script6677($entityoverlay, $coord, %rockthrower){rockthrower}");
    if (%rockthrower <= 0) {
        ~cannon_overlay_create($entityoverlay, $coord);
    } else if (%rockthrower <= 5) {
        cc_setcolour(^red);
    } else if (%rockthrower <= 15) {
        cc_setcolour(0xffb71e);
    } else {
        cc_setcolour(^green);
    }
}
