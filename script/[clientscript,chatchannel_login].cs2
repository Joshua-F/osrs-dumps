// 3765
[clientscript,chatchannel_login](string $string)
if (string_length($string) > 0) {
    if (string_length(friendschat_getchatownername) > 0) {
        friendschat_leavechat;
    }
    ~meslayer_initlastnames;
    %last_friendschatjoin = removetags($string);
    friendschat_joinchat($string);
}
