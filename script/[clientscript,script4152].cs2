// 4152
[clientscript,script4152](component $part_selection_frame, int $int, component $select1, component $select2, component $select3)
~steelbox($part_selection_frame, 0, 1);
~script4153($select1, 1, %slug2_piece1_show, %slug2_piece1_select, slug2_page4a, "Piece 1");
~script4153($select2, 2, %slug2_piece2_show, %slug2_piece2_select, slug2_page4b, "Piece 2");
~script4153($select3, 3, %slug2_piece3_show, %slug2_piece3_select, slug2_page4c, "Piece 3");
if_setonvartransmit("script4155($select1, $select2, $select3){smithbars}", $part_selection_frame);
if_setoninvtransmit("script4155($select1, $select2, $select3){inv}", $part_selection_frame);
