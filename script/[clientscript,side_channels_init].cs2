// 4471
[clientscript,side_channels_init](component $universe, component $tab_0, component $tab_1, component $tab_2, component $tab_3, component $tab_line)
~side_channels_tabinit($tab_0, 0);
~side_channels_tabinit($tab_1, 1);
~side_channels_tabinit($tab_2, 2);
~side_channels_tabinit($tab_3, 3);
~side_channels_setall($tab_0, $tab_1, $tab_2, $tab_3, null, $tab_line);
if_setonvartransmit("side_channels_setall($tab_0, $tab_1, $tab_2, $tab_3, null, $tab_line){chat_filter_clan, chat_filter_assist}", $universe);
