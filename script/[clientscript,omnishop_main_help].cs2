// 7154
[clientscript,omnishop_main_help](dbrow $dbrow, inv $inv, int $int)
def_component $r_col = omnishop_main:r_col;
def_component $help_button_layer = omnishop_main:help_button_layer;
if ($int = 1) {
    sound_synth(synth_2266, 1, 0);
    ~omnishop_main_list_setup($dbrow, $inv, -1, 0);
    ~omnishop_main_info_setup($dbrow, $inv, -1, 0, 0, 0, null, "", true);
    if_sethide(false, $r_col);
    if (cc_find($help_button_layer, 0) = true) {
        cc_setgraphic("menu_buttons,2");
    }
}
