// 5106
[proc,beige_stone_button_init](component $component, string $string, graphic $graphic, int $int)
cc_deleteall($component);
~beige_stone_button_draw(false, $component, $string, $graphic, $int);
if (~on_mobile = false) {
    if_setonmouserepeat("script5107(true, $component, $string, $graphic, $int)", $component);
    if_setonmouseleave("script5107(false, $component, $string, $graphic, $int)", $component);
    if_setontimer(null, $component);
}
