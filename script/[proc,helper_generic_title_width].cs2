// 5851
[proc,helper_generic_title_width]()(int)
if (~helper_generic_test_bit(0) = ^false) {
    return(%helper_generic_current_width);
}
def_enum $enum = ~toplevel_getcomponents;
def_component $component = enum(component, component, $enum, toplevel_osrs_stretch:helper_content);
def_int $int = if_getwidth($component);
$int = ~max(%helper_generic_current_width, calc($int - 8));
return($int);
