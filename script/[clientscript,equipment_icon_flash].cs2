// 2643
[clientscript,equipment_icon_flash](component $component)
if (%tutorial ! 400) {
    if (%tutorial_2 > 0 & %tutorial_2 ! 400) {
        if_setgraphic("options_icons,16", $component);
        return;
    } else if (%tutorial_2 = 0) {
        if_setgraphic("options_icons,16", $component);
        return;
    }
}
if (calc(clientclock % 20) < 10) {
    if_setgraphic("options_icons,16", $component);
} else {
    if_setgraphic(null, $component);
}
