// 5869
[proc,fsw_world_check](int $int)(int)
def_int $intbool = testbit($int, 27);
if (~fsw_player = 0) {
    if ($intbool = ^true) {
        return(0);
    } else {
        return(1);
    }
}
if (testbit($int, 15) = ^true) {
    return(1);
}
if (testbit($int, 29) = ^true) {
    return(1);
}
if (testbit($int, 30) = ^true) {
    return(1);
}
if (testbit($int, 6) = ^true) {
    return(1);
}
if ($intbool = ^false) {
    return(0);
}
return(1);
