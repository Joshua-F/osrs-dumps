// 2916
[clientscript,gauntlet_timer_end]
def_component $timer_text = gauntlet_overlay:timer_text;
if_setontimer(null, gauntlet_overlay:timer);
if_setsize(0, if_getheight($timer_text), ^setsize_minus, ^setsize_abs, $timer_text);
if_setposition(0, if_gety($timer_text), ^setpos_abs_centre, ^setpos_abs_top, $timer_text);
if_settextalign(^settextalign_centre, ^settextalign_centre, 0, $timer_text);
if_settext("Final Encounter", $timer_text);
if_setcolour(0xfcfce7, $timer_text);
