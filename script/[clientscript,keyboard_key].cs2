// 1661
[clientscript,keyboard_key](component $component, string $string)
cc_deleteall($component);
def_int $int = 0;
cc_create($component, ^iftype_graphic, $int);
$int = calc($int + 1);
if (if_getwidth($component) <= 32) {
    cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
    cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
    cc_setgraphic("options_icons,47");
} else {
    cc_setsize(16, 0, ^setsize_abs, ^setsize_minus);
    cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_centre);
    cc_setgraphic(keyboard_key_left);
    cc_create($component, ^iftype_graphic, $int);
    $int = calc($int + 1);
    cc_setsize(32, 0, ^setsize_minus, ^setsize_minus);
    cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
    cc_setgraphic(keyboard_key_middle);
    cc_create($component, ^iftype_graphic, $int);
    $int = calc($int + 1);
    cc_setsize(16, 0, ^setsize_abs, ^setsize_minus);
    cc_setposition(0, 0, ^setpos_abs_right, ^setpos_abs_centre);
    cc_setgraphic(keyboard_key_right);
}
cc_create($component, ^iftype_text, $int);
$int = calc($int + 1);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0x202020);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextfont(b12_full);
cc_settextshadow(false);
cc_settext($string);
