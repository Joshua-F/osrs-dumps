// 2728
[proc,collection_draw_tab](component $component, struct $struct, int $int2)
cc_deleteall($component);
def_int $int3 = struct_param($struct, param_684);
cc_create($component, ^iftype_graphic, 0);
cc_setsize(20, 20, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_centre);
cc_create($component, ^iftype_graphic, 1);
cc_setsize(40, 20, ^setsize_minus, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settiling(true);
cc_create($component, ^iftype_graphic, 2);
cc_setsize(20, 20, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_right, ^setpos_abs_centre);
cc_create($component, ^iftype_text, 3);
cc_setsize(10, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_settextshadow(true);
cc_settextfont(p12_full);
cc_settextalign(^settextalign_left, ^settextalign_centre, 0);
cc_settext(struct_param($struct, param_682));
if ($int3 = $int2) {
    if (cc_find($component, 0) = true) {
        cc_setgraphic("tabs_split,0");
    }
    if (cc_find($component, 1) = true) {
        cc_setgraphic("tabs_split,1");
    }
    if (cc_find($component, 2) = true) {
        cc_setgraphic("tabs_split,2");
    }
    if (cc_find($component, 3) = true) {
        cc_setcolour(0xffa82f);
    }
    if_setonmouseover(null, $component);
    if_setonmouseleave(null, $component);
} else {
    if (cc_find($component, 0) = true) {
        cc_setgraphic("tabs_split,3");
    }
    if (cc_find($component, 1) = true) {
        cc_setgraphic("tabs_split,4");
    }
    if (cc_find($component, 2) = true) {
        cc_setgraphic("tabs_split,5");
    }
    if (cc_find($component, 3) = true) {
        cc_setcolour(0xff981f);
    }
    if_setonmouseover("collection_hover_tab($component, true)", $component);
    if_setonmouseleave("collection_hover_tab($component, false)", $component);
}
