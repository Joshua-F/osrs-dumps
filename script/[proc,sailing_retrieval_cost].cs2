// 9090
[proc,sailing_retrieval_cost](dbrow $dbrow, int $int1, boolean $boolean2, boolean $boolean3)(int)
def_int $int4 = db_getfield($dbrow, sailing_boat:retrieval_cost, 0);
def_int $int5 = $int4;
if ($boolean2 = true) {
    $int5 = calc($int5 + scale(50, 100, $int4));
}
if ($boolean3 = true) {
    $int5 = calc($int5 + $int4);
}
$int5 = calc($int5 + scale(~script7333($dbrow, ~sailing_boat_get_hull($int1, $dbrow)), 100, $int4));
return($int5);
