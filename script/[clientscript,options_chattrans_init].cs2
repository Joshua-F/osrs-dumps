// 852
[clientscript,options_chattrans_init](component $com_24, component $com_26, component $com_30)
if_setonmouseleave("deltooltip($com_30)", $com_24);
if_setop(1, "Transparent Chatbox", $com_24);
if_setop(1, "<~text_device("Click", "tap")> through chatbox", $com_26);
~options_gfx_togglebox($com_26, "Transparent chatbox...", "Can be <~text_device("clicked", "tapped")> through.", "In resizable mode, if the chatbox is transparent, should it be possible to <~text_device("click", "tap")> through the chatbox on the ground beneath?", $com_30);
~options_chattrans($com_24, $com_26, $com_30);
if_setonvartransmit("options_chattrans_resynch($com_24, $com_26, $com_30){varplayer_1055}", $com_24);
if_setonop("options_chattrans_op(event_op, false, $com_24, $com_26, $com_30)", $com_24);
