// 852
[clientscript,options_chattrans_init](component $com_12, component $com_14, component $com_18)
if_setonmouseleave("deltooltip($com_18)", $com_12);
if_setop(1, "Transparent Chatbox", $com_12);
if_setop(1, "Click through chatbox", $com_14);
~options_gfx_togglebox($com_14, "Transparent chatbox...", "Can be clicked through.", "In resizable mode, if the chatbox is transparent, should it be possible to click through the chatbox on the ground beneath?", $com_18);
~options_chattrans($com_12, $com_14, $com_18);
if_setonvartransmit("options_chattrans_resynch($com_12, $com_14, $com_18){varplayer_1055}", $com_12);
if_setonop("options_chattrans_op(event_op, false, $com_12, $com_14, $com_18)", $com_12);
