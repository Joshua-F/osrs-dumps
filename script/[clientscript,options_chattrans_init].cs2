// 852
[clientscript,options_chattrans_init](component $com_20, component $com_22, component $com_26)
if_setonmouseleave("deltooltip($com_26)", $com_20);
if_setop(1, "Transparent Chatbox", $com_20);
if_setop(1, "<~text_device("Click", "tap")> through chatbox", $com_22);
~options_gfx_togglebox($com_22, "Transparent chatbox...", "Can be <~text_device("clicked", "tapped")> through.", "In resizable mode, if the chatbox is transparent, should it be possible to <~text_device("click", "tap")> through the chatbox on the ground beneath?", $com_26);
~options_chattrans($com_20, $com_22, $com_26);
if_setonvartransmit("options_chattrans_resynch($com_20, $com_22, $com_26){varplayer_1055}", $com_20);
if_setonop("options_chattrans_op(event_op, false, $com_20, $com_22, $com_26)", $com_20);
