// 852
[clientscript,options_chattrans_init](component $com_18, component $com_20, component $com_24)
if_setonmouseleave("deltooltip($com_24)", $com_18);
if_setop(1, "Transparent Chatbox", $com_18);
if_setop(1, "<~text_device("Click", "tap")> through chatbox", $com_20);
~options_gfx_togglebox($com_20, "Transparent chatbox...", "Can be <~text_device("clicked", "tapped")> through.", "In resizable mode, if the chatbox is transparent, should it be possible to <~text_device("click", "tap")> through the chatbox on the ground beneath?", $com_24);
~options_chattrans($com_18, $com_20, $com_24);
if_setonvartransmit("options_chattrans_resynch($com_18, $com_20, $com_24){varplayer_1055}", $com_18);
if_setonop("options_chattrans_op(event_op, false, $com_18, $com_20, $com_24)", $com_18);
