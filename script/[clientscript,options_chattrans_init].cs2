// 852
[clientscript,options_chattrans_init](component $com_22, component $com_24, component $com_28)
if_setonmouseleave("deltooltip($com_28)", $com_22);
if_setop(1, "Transparent Chatbox", $com_22);
if_setop(1, "<~text_device("Click", "tap")> through chatbox", $com_24);
~options_gfx_togglebox($com_24, "Transparent chatbox...", "Can be <~text_device("clicked", "tapped")> through.", "In resizable mode, if the chatbox is transparent, should it be possible to <~text_device("click", "tap")> through the chatbox on the ground beneath?", $com_28);
~options_chattrans($com_22, $com_24, $com_28);
if_setonvartransmit("options_chattrans_resynch($com_22, $com_24, $com_28){varplayer_1055}", $com_22);
if_setonop("options_chattrans_op(event_op, false, $com_22, $com_24, $com_28)", $com_22);
