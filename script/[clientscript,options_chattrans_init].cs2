// 852
[clientscript,options_chattrans_init](component $com_16, component $com_18, component $com_22)
if_setonmouseleave("deltooltip($com_22)", $com_16);
if_setop(1, "Transparent Chatbox", $com_16);
if_setop(1, "<~text_device("Click", "tap")> through chatbox", $com_18);
~options_gfx_togglebox($com_18, "Transparent chatbox...", "Can be <~text_device("clicked", "tapped")> through.", "In resizable mode, if the chatbox is transparent, should it be possible to <~text_device("click", "tap")> through the chatbox on the ground beneath?", $com_22);
~options_chattrans($com_16, $com_18, $com_22);
if_setonvartransmit("options_chattrans_resynch($com_16, $com_18, $com_22){varplayer_1055}", $com_16);
if_setonop("options_chattrans_op(event_op, false, $com_16, $com_18, $com_22)", $com_16);
