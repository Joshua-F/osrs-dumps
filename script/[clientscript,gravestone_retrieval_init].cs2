// 1985
[clientscript,gravestone_retrieval_init](component $universe, component $frame, component $items, component $scrollbar, component $button, component $button_gfx, component $discard, component $discard_gfx, component $info, component $fee)
def_int $int10 = ~steelborder($frame, "", 0);
~gravestone_retrieval_unlockstatus($frame, $int10, $button, $button_gfx, $info, $fee);
if_setonvartransmit("gravestone_retrieval_unlockstatus($frame, $int10, $button, $button_gfx, $info, $fee){if1, if2}", $universe);
if_setgraphic("miscgraphics,0", $discard);
if_setop(1, "Discard-All", $discard);
if_setontimer(null, $discard);
if_setonmouserepeat("gravestone_retrieval_buttonhover(true, $discard_gfx, null, null)", $discard);
if_setonmouseleave("gravestone_retrieval_buttonhover(false, $discard_gfx, null, null)", $discard);
if_setonop("gravestone_retrieval_buttonop(event_op, $discard, $discard_gfx, null, null)", $discard);
def_int $int11 = calc(36 + 10);
def_int $int12 = calc(32 + 8);
cc_deleteall($items);
def_int $int13 = 0;
while ($int13 < 120) {
    cc_create($items, ^iftype_graphic, $int13);
    cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
    cc_setposition(calc(1 + $int13 % 8 * $int11), calc(3 + $int13 / 8 * $int12), ^setpos_abs_left, ^setpos_abs_top);
    cc_setgraphicshadow(0x333333);
    cc_setoutline(1);
    cc_setop(2, "Take-All");
    cc_setop(9, "Value");
    cc_setop(10, "Examine");
    cc_sethide(true);
    $int13 = calc($int13 + 1);
}
~scrollbar_vertical($scrollbar, $items, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~gravestone_retrieval_items($items, $scrollbar);
if_setoninvtransmit("gravestone_retrieval_items($items, $scrollbar){gravestone}", $universe);
