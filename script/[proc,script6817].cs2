// 6817
[proc,script6817](component $component)
def_string $string = ~tostring_spacer(%qp, ",");
if (~speedrunning_world = true) {
    $string = ~tostring_spacer(~min(%speedrun_points, 800000), ",");
    if_settext("Speedrun Points: <$string>", $component);
} else {
    if_settext("Total Quest Points: <$string>", $component);
}
