// 1249
[clientscript,script1249](component $component, string $string)
sound_synth(synth_2266, 1, 0);
~script1248(true, $component, "---");
if_setonmouseover(null, $component);
if_setonmouseleave(null, $component);
if_setonclick(null, $component);
if_setontimer("script1250(calc(clientclock + 60), $component, $string)", $component);
