// 2560
[proc,membership_benefits_button_init](component $component, string $string)
~membership_benefits_button_draw($component, $string, false);
if_setop(1, $string, $component);
if_setonmouserepeat("membership_benefits_button_draw(event_com, $string, true)", $component);
if_setonmouseleave("membership_benefits_button_draw(event_com, $string, false)", $component);
