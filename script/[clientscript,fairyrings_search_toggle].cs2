// 8082
[clientscript,fairyrings_search_toggle](int $int, component $component1, component $component2, component $component3, component $component4, component $component5)
if (%settings_fairyring_mobile_keyboard_autoopen_disabled = 0) {
    ~fairyrings_search_toggle($int, $component1, $component2, $component3, $component4, $component5, 1, 1);
} else {
    ~fairyrings_search_toggle($int, $component1, $component2, $component3, $component4, $component5, 1, 0);
}
