// 6252
[proc,pvpa_hud_drawtimer](component $component)
cc_deleteall($component);
if (%varplayerbit_14017 = 0 | %varplayerbit_14016 <= 0) {
    return;
}
def_graphic $graphic = quill_oblique_large;
if (%varplayerbit_14017 = 1) {
    if_setsize(55, 23, ^setsize_abs, ^setsize_abs, $component);
    $graphic = b12_full;
} else {
    if_setsize(75, 36, ^setsize_abs, ^setsize_abs, $component);
}
def_int $int = 0;
cc_create($component, ^iftype_graphic, $int);
$int = calc($int + 1);
cc_setsize(2, 2, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic(tradebacking_light);
cc_settiling(true);
cc_settrans(120);
$int = ~thinstonebox($component, $int);
cc_create($component, ^iftype_text, $int);
$int = calc($int + 1);
cc_setsize(2, 2, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(^red);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextfont($graphic);
~pvpa_hud_writetime;
cc_setontimer("pvpa_hud_writetime(event_com, event_comsubid)");
