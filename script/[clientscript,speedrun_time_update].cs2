// 5907
[clientscript,speedrun_time_update](dbrow $dbrow, int $int)
if ($dbrow = null | $dbrow ! %latest_speedrun_panel | $int = -1) {
    if_setontimer(null, speedrunning_panel:current_time_text);
    if_settext("-", speedrunning_panel:current_time_text);
    return;
}
$int = calc($int * 30 - clientclock);
if_setontimer("speedrun_time_update_timer($int, %option_precise_timing, %option_separate_hours)", speedrunning_panel:current_time_text);
