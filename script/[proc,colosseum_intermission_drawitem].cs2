// 4959
[proc,colosseum_intermission_drawitem](obj $obj, int $int1)(boolean)
cc_clearops;
def_int $int2 = 0;
if ($obj ! null) {
    cc_setobject($obj, $int1);
    cc_setopbase("<col=ff9040><oc_name($obj)></col>");
    cc_settrans(0);
    cc_setop(1, "Examine");
    cc_setonop("cc_settrans_temporarily(event_com, event_comsubid, 100, 0)");
    $int2 = 1;
} else {
    cc_settrans(255);
    cc_setobject(obj_6512, 1);
    cc_setonop(null);
}
cc_setontimer(null);
if ($int2 = 1) {
    return(false);
}
return(true);
