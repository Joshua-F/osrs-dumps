// 1736
[clientscript,worldmap_search_start](component $component, int $int1, int $int2)
if (cc_find($component, $int1) = true & .cc_find($component, $int2) = true) {
    sound_synth(synth_2266, 1, 0);
    cc_setgraphic(tradebacking);
    cc_setonmouserepeat(null);
    cc_setonmouseleave(null);
    cc_setop(1, "Quit");
    cc_setonop("worldmap_search_off($component, cc_getid, .cc_getid)");
    %varclientstring_138 = "";
    ~worldmap_search_update("", $component);
    ~keyboard_show(0, 25);
}
