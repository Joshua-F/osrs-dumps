// 8764
[proc,script8764](dbrow $dbrow)(graphic)
def_graphic $graphic = "icon_sailing_facilities_24x24,18";
if ($dbrow = null) {
    return($graphic);
}
$graphic = db_getfield($dbrow, sailing_sidepanel_facility:icon, 0);
if ($graphic = null) {
    $graphic = "icon_sailing_facilities_24x24,18";
}
return($graphic);
