// 359
[clientscript,options_mouse_init](component $com_59, component $com_60, component $com_91)
if_setonmouseleave("deltooltip($com_91)", $com_59);
~options_mouse($com_59, $com_60, $com_91);
if_setonvartransmit("options_mouse_resynch($com_59, $com_60, $com_91){varplayer_170}", $com_59);
if_setop(1, ~text_device("Toggle number of Mouse Buttons", "Toggle single-tap mode"), $com_59);
if_setonop("options_mouse_op(event_op, $com_59, $com_60, $com_91)", $com_59);
