// 359
[clientscript,options_mouse_init](component $com_72, component $com_73, component $com_112)
if_setonmouseleave("deltooltip($com_112)", $com_72);
~options_mouse($com_72, $com_73, $com_112);
if_setonvartransmit("options_mouse_resynch($com_72, $com_73, $com_112){varplayer_170}", $com_72);
if_setop(1, ~text_device("Toggle number of Mouse Buttons", "Toggle single-tap mode"), $com_72);
if_setonop("options_mouse_op(event_op, $com_72, $com_73, $com_112)", $com_72);
