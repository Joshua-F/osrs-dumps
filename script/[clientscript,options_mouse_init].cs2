// 359
[clientscript,options_mouse_init](component $com_50, component $com_70)
if_setonmouseleave("deltooltip($com_70)", $com_50);
~options_mouse($com_50, $com_70);
if_setonvartransmit("options_mouse_resynch($com_50, $com_70){varplayer_170}", $com_50);
if_setonop("options_mouse_op(event_op, $com_50, $com_70)", $com_50);
