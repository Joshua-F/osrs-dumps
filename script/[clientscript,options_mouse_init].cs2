// 359
[clientscript,options_mouse_init](component $com_60, component $com_61, component $com_92)
if_setonmouseleave("deltooltip($com_92)", $com_60);
~options_mouse($com_60, $com_61, $com_92);
if_setonvartransmit("options_mouse_resynch($com_60, $com_61, $com_92){varplayer_170}", $com_60);
if_setop(1, ~text_device("Toggle number of Mouse Buttons", "Toggle single-tap mode"), $com_60);
if_setonop("options_mouse_op(event_op, $com_60, $com_61, $com_92)", $com_60);
