// 359
[clientscript,options_mouse_init](component $com_71, component $com_72, component $com_111)
if_setonmouseleave("deltooltip($com_111)", $com_71);
~options_mouse($com_71, $com_72, $com_111);
if_setonvartransmit("options_mouse_resynch($com_71, $com_72, $com_111){varplayer_170}", $com_71);
if_setop(1, ~text_device("Toggle number of Mouse Buttons", "Toggle single-tap mode"), $com_71);
if_setonop("options_mouse_op(event_op, $com_71, $com_72, $com_111)", $com_71);
