// 359
[clientscript,options_mouse_init](component $com_77, component $com_78, component $com_117)
if_setonmouseleave("deltooltip($com_117)", $com_77);
~options_mouse($com_77, $com_78, $com_117);
if_setonvartransmit("options_mouse_resynch($com_77, $com_78, $com_117){varplayer_170}", $com_77);
if_setop(1, ~text_device("Toggle number of Mouse Buttons", "Toggle single-tap mode"), $com_77);
if_setonop("options_mouse_op(event_op, $com_77, $com_78, $com_117)", $com_77);
