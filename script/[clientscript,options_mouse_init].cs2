// 359
[clientscript,options_mouse_init](component $com_78, component $com_79, component $com_118)
if_setonmouseleave("deltooltip($com_118)", $com_78);
~options_mouse($com_78, $com_79, $com_118);
if_setonvartransmit("options_mouse_resynch($com_78, $com_79, $com_118){varplayer_170}", $com_78);
if_setop(1, ~text_device("Toggle number of Mouse Buttons", "Toggle single-tap mode"), $com_78);
if_setonop("options_mouse_op(event_op, $com_78, $com_79, $com_118)", $com_78);
