// 440
[clientscript,settings_client_type](component $client_type, component $client_type_buttons, component $dropdown_container, component $dropdown_panel, component $dropdown_scrollbar, component $tooltip, component $universe)
if (~on_mobile = true) {
    if_sethide(true, $client_type);
    return;
}
~settings_side_dropdown_create($client_type, $client_type_buttons, $dropdown_container, $dropdown_panel, $dropdown_scrollbar, $tooltip, $universe, "Game client layout", struct_2732);
