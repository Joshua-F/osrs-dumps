// 6988
[clientscript,script6988](component $component, string $string, int $int, boolean $boolean)
if (clientclock < $int) {
    return;
}
if ($boolean = true) {
    ~directional_lock_initbutton_confirm($component, $string);
} else {
    ~directional_lock_initbutton_confirm($component, $string);
}
