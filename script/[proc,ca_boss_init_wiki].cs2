// 4837
[proc,ca_boss_init_wiki](component $component0, component $component1, struct $struct, string $string)
if_setonop("ca_boss_lookup($struct, $string)", $component0);
if_setop(1, "Lookup-boss", $component0);
if_setopbase("<col=ff9040><$string></col>", $component0);
~dynamic_stone_button_filled($component0, $component1, "", if_getx($component0), if_gety($component0), if_getwidth($component0), if_getheight($component0), 0, 0, 1, false);
