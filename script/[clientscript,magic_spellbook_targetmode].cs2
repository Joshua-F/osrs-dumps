// 2617
[clientscript,magic_spellbook_targetmode](boolean $boolean, component $component)
if ($boolean = true) {
    if_setoutline(2, $component);
    if (testbit(if_gettargetmask($component), 4) = ^true) {
        ~toplevel_sidebutton_switch(3, ~toplevel_getcomponents);
    }
} else {
    if_setoutline(0, $component);
}
