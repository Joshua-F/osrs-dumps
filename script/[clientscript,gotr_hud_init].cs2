// 5979
[clientscript,gotr_hud_init](component $dodger, component $content)
~interface_dodger_init($dodger, $content, 52968, ^setpos_abs_left, ^setpos_abs_top, true);
if_sethide(true, gotr_hud:portal_shortcut_layer);
if_setsize(scale(0, 100, if_getwidth(gotr_hud:energy_bar_back)), 0, ^setsize_abs, ^setsize_minus, gotr_hud:energy_bar);
if_settext("Guardian's Power: 0%", gotr_hud:energy_title);
