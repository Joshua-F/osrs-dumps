// 5166
[proc,helper_agility_highlight_shortcuts]
def_enum $enum = enum_4023;
def_loc $loc = null;
def_int $int = 0;
highlight_loctype_clear(12);
if (%varplayerbit_12976 = 1) {
    highlight_loctype_setup(12, ^green, 1, 30, 5);
    if ($enum ! null) {
        while ($int < enum_getoutputcount($enum)) {
            $loc = enum(int, loc, $enum, $int);
            if ($loc ! null) {
                highlight_loctype_on($loc, 12);
            }
            $int = calc($int + 1);
        }
    }
} else {
    highlight_loctype_setup(12, ^green, 2, 0, 0);
}
