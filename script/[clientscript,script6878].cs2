// 6878
[clientscript,script6878](component $component, int $int1, int $int2)
if (clientclock < $int2) {
    return;
}
if (cc_find($component, $int1) = true) {
    cc_setontimer(null);
}
if (cc_find($component, calc($int1 + 1)) = true) {
    cc_setcolour(0xff981f);
}
if (cc_find($component, calc($int1 + 12)) = true) {
    cc_setcolour(^white);
}
