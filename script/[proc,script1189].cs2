// 1189
[proc,script1189](component $component, int $int)
if ($int <= 50) {
    cc_settrans(calc(255 - $int * 5));
    return;
}
if ($int <= 105) {
    cc_settrans(0);
    return;
}
if ($int <= 155) {
    $int = calc($int - 105);
    cc_settrans(calc(5 + $int * 5));
    return;
}
cc_deleteall($component);
