// 2940
[proc,silver_crafting_jewellery_draw](component $component, obj $obj1, int $int2, obj $obj3, string $string, obj $obj4, obj $obj5)
cc_deleteall($component);
if (inv_total(inv, $obj3) <= 0) {
    if_clearops($component);
    if_setonmouserepeat(null, $component);
    if_setonmouseleave(null, $component);
    return;
}
def_int $int6 = 0;
if_setop(1, "Craft", $component);
if_setopbase("<col=ff9040><$string></col>", $component);
def_int $int7 = 0;
if (inv_total(inv, $obj4) > 0 & stat(crafting) >= $int2 & (map_members = true | oc_members($obj1) = 0)) {
    $int7 = 1;
}
if (%crafting_silver_item_lasttype = enum(component, int, enum_4319, $component) & %crafting_silver_item_lasttype ! 0 & $int7 = 1) {
    cc_create($component, ^iftype_rectangle, $int6);
    $int6 = calc($int6 + 1);
    cc_setcolour(^white);
    cc_settrans(200);
    cc_setcolour(0xffffcc);
    cc_setcolour(0x9b8268);
    cc_settrans(150);
    cc_setfill(true);
    cc_setsize(if_getwidth($component), if_getheight($component), ^setsize_abs, ^setsize_abs);
    if_setopkey(1, ^key_space, 0, $component);
}
cc_create($component, ^iftype_graphic, $int6);
$int6 = calc($int6 + 1);
cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
cc_setposition(2, 3, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setoutline(1);
cc_setgraphicshadow(0x333333);
if ($int7 = 1) {
    cc_setobject_nonum($obj1, 1);
    cc_settrans(0);
} else {
    cc_setobject_nonum($obj5, 1);
    cc_settrans(150);
}
cc_create($component, ^iftype_text, $int6);
$int6 = calc($int6 + 1);
.cc_create($component, ^iftype_text, $int6);
$int6 = calc($int6 + 1);
cc_setsize(4, 18, ^setsize_minus, ^setsize_abs);
.cc_setsize(4, 4, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 2, ^setpos_abs_centre, ^setpos_abs_top);
.cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
def_int $int8 = if_getwidth($component);
if (parawidth($string, $int8, p12_full) <= $int8 & paraheight($string, $int8, p12_full) <= 1) {
    cc_settextfont(p12_full);
} else {
    cc_settextfont(p11_full);
}
.cc_settextfont(p11_full);
cc_settextshadow(true);
.cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
.cc_settextalign(^settextalign_centre, ^settextalign_bottom, 0);
cc_settext($string);
if ($int7 = 1) {
    .cc_settext("");
    cc_setcolour(0xff981f);
    .cc_setcolour(0xff981f);
    if_setonmouserepeat("silver_crafting_mouseeffect(^white, event_com, cc_getid, .cc_getid)", $component);
    if_setonmouseleave("silver_crafting_mouseeffect(0xff981f, event_com, cc_getid, .cc_getid)", $component);
} else {
    if (map_members = false & oc_members($obj1) = 1) {
        .cc_settext("");
    } else {
        .cc_settext("Level <tostring($int2)>");
    }
    cc_setcolour(^red);
    .cc_setcolour(0x7f7f7f);
    if_setonmouserepeat(null, $component);
    if_setonmouseleave(null, $component);
}
