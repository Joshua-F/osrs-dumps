// 1531
[proc,script1531](component $component, int $int, string $string)
if_setontimer(null, $component);
if_setonmouserepeat("cc_colour_swapper(event_com, $int, 16754735)", $component);
if_setonmouseleave("cc_colour_swapper(event_com, $int, 16750623)", $component);
if_setop(1, "Set", $component);
if_setopbase("<col=ff9040><$string></col>", $component);
if_setonop("script1534(event_op, $component, $int, $string)", $component);
