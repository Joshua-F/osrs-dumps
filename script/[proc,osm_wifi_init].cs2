// 868
[proc,osm_wifi_init](component $component)
cc_deleteall($component);
cc_create($component, ^iftype_graphic, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
~osm_wifi_resynch;
~osm_wifi_pos($component);
if_setontimer("osm_wifi_resynch(event_com, cc_getid)", $component);
if_setonvartransmit("osm_wifi_transmit($component, %osm_minimap_toggle){toplevel_temp}", $component);
