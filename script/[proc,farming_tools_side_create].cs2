// 1058
[proc,farming_tools_side_create](component $component, obj $obj, string $string)
if_setonmouserepeat("farming_tools_side_recreate($component, $obj, $string, true)", $component);
if_setonmouseleave("farming_tools_side_recreate($component, $obj, $string, false)", $component);
~farming_tools_side_recreate($component, $obj, $string, false);
