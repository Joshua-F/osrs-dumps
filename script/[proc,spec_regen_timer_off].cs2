// 6058
[proc,spec_regen_timer_off]
if (~on_enhanced_any = false) {
    return;
}
def_component $spec_regen = orbs:spec_regen;
if (~on_enhanced_desktop = true & ~toplevel_getcomponents ! enum_1129 & %minimap_toggle = 1) {
    $spec_regen = orbs_nomap:spec_regen;
} else if (~on_mobile = true & %osm_minimap_toggle = 1) {
    $spec_regen = orbs_osm_nomap:spec_regen;
}
if_setontimer(null, $spec_regen);
cc_deleteall($spec_regen);
