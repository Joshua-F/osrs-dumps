// 4698
[proc,helper_generic_reset]
def_int $int = 0;
while ($int < 45) {
    ~helper_generic_set_type($int, 0);
    ~helper_generic_set_string($int, null);
    $int = calc($int + 1);
}
cc_deleteall(helper_generic:content);
~helper_generic_set_size(140, 300);
%helper_generic_current_width = 0;
%helper_generic_current_height = 0;
%helper_generic_current_id = 0;
