// 1611
[proc,raids_storage_drawbutton](string $string, component $component, graphic $graphic)(int)
cc_deleteall($component);
def_int $int = ~options_button_off($component, 0);
cc_create($component, ^iftype_text, $int);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setcolour(0xff981f);
cc_settextfont($graphic);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_settext($string);
if_setonmouserepeat("cc_colour_swapper(event_com, $int, ^white)", $component);
if_setonmouseleave("cc_colour_swapper(event_com, $int, 0xff981f)", $component);
if_setop(1, $string, $component);
if_setonop("raids_storage_opbutton(event_op, $component, $string, $graphic)", $component);
if_setontimer(null, $component);
return($int);
