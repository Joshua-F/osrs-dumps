// 7097
[proc,settings_slider_choose_bobble](int $int0, int $int1, component $component, graphic $graphic)
switch_int ($int0) {
    case 30, 31, 32 :
        if (%option_master_volume <= 0) {
            cc_setgraphic("settings_slider,12");
        } else {
            cc_setgraphic($graphic);
        }
        cc_setonvartransmit("settings_slider_choose_bobble_transmit($int0, $int1, $component, $graphic){option_master_volume}");
    case default :
        cc_setgraphic($graphic);
}
