// 2686
[proc,telenexus_keyinput_matched](component $component, int $int1, int $key, string $string0, string $string1, int $int3, int $int4)
if ($int1 ! -1 & cc_find($component, $int1) = true) {
    cc_resume_pausebutton;
    cc_setonkey("telenexus_keyinput_listener(event_keycode, event_keychar, event_com, event_comsubid, $key, $string0, $string1, $int3, calc(clientclock + 20))");
}
