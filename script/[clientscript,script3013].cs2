// 3013
[clientscript,script3013](component $extra_task_info, component $extra_back_button, component $task_list, component $path_menu, component $banner)
~v2_stone_button_out_filled($extra_back_button);
if_setonmouseleave("script3015($extra_back_button)", $extra_back_button);
if_setonmouserepeat("script3014($extra_back_button)", $extra_back_button);
if_setonop("script3017($extra_task_info, $task_list, $path_menu, $banner, $extra_back_button)", $extra_back_button);
if_setop(1, "Back", $extra_back_button);
~script3016($extra_back_button, 9);
