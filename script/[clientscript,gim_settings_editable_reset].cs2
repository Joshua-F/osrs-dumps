// 5515
[clientscript,gim_settings_editable_reset](component $component, int $int1, int $int2, int $int3, int $int4)
if (clientclock < $int2) {
    return;
}
if (cc_find($component, $int1) = true) {
    cc_settrans($int3);
}
if_setontimer("cc_settrans_temporarily_end(event_com, $int1, $int4, calc(clientclock + 2))", $component);
~script5512($component, $int1, $int3, $int4);
