// 6877
[proc,fsw_sp_button_click](component $component, int $int)
~fsw_sp_button_click_sound;
if (cc_find($component, $int) = true) {
    cc_setontimer("script6878($component, $int, calc(clientclock + 10))");
}
if (cc_find($component, calc($int + 1)) = true) {
    cc_setcolour(0xe6dbca);
}
if (cc_find($component, calc($int + 12)) = true) {
    cc_setcolour(0xe6dbca);
}
