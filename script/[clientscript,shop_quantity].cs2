// 2229
[clientscript,shop_quantity](component $value, component $quantity1, component $quantity5, component $quantity10, component $quantity50, component $quantityx)
if (~on_mobile = false) {
    if_sethide(true, $quantityx);
}
~shop_quantity($value, $quantity1, $quantity5, $quantity10, $quantity50, $quantityx);
