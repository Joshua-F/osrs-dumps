// 3571
[proc,hallowed_tools_side_create](component $component, obj $obj, string $string)
if_setonmouserepeat("hallowed_tools_side_recreate($component, $obj, $string, true)", $component);
if_setonmouseleave("hallowed_tools_side_recreate($component, $obj, $string, false)", $component);
~hallowed_tools_side_recreate($component, $obj, $string, false);
