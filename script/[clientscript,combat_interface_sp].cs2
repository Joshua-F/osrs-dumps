// 327
[clientscript,combat_interface_sp](component $component)
~combat_interface_sp_redraw($component);
if_setonvartransmit("combat_interface_sp_redraw($component){sa_attack, sa_energy, soulreaper_stacks, weapon_of_sol_stacks, duel2accept, league_6_temp_varp1}", $component);
if_setonstattransmit("combat_interface_sp_redraw($component){hitpoints}", $component);
if_setoninvtransmit("combat_interface_sp_redraw($component){worn}", $component);
