// 9063
[proc,script9063](dbtable $dbtable, dbrow $dbrow, int $int)(obj, int)
if ($dbtable = null) {
    $dbtable = db_getrowtable($dbrow);
}
switch_dbtable ($dbtable) {
    case sailing_boat_facility :
        return(db_getfield($dbrow, sailing_boat_facility:material, $int));
    case sailing_boat_keel :
        return(db_getfield($dbrow, sailing_boat_keel:material, $int));
    case sailing_boat_hull :
        return(db_getfield($dbrow, sailing_boat_hull:material, $int));
    case sailing_boat_sail :
        return(db_getfield($dbrow, sailing_boat_sail:material, $int));
    case sailing_boat_steering :
        return(db_getfield($dbrow, sailing_boat_steering:material, $int));
    case sailing_boat_flag :
        return(db_getfield($dbrow, sailing_boat_flag:material, $int));
    case sailing_boat_brazier :
        return(db_getfield($dbrow, sailing_boat_brazier:material, $int));
    case sailing_boat_trim :
        return(db_getfield($dbrow, sailing_boat_trim:material, $int));
    case default :
        return(null, -1);
}
