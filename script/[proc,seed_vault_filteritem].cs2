// 2863
[proc,seed_vault_filteritem](obj $obj)(boolean)
def_string $string0 = "";
def_string $string1 = "";
if (~seed_vault_searching = true) {
    $string1 = ~seed_vault_filterstring;
    if (string_length($string1) > 0) {
        if ($obj ! null) {
            $string0 = lowercase(oc_name($obj));
        }
        if (string_indexof_string($string0, $string1, 0) ! -1) {
            return(true);
        }
        return(false);
    }
}
return(true);
