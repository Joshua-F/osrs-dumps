// 9328
[proc,script9328](component $component0, component $component1, component $component2, component $component3, component $component4)
def_string $string = "";
if (if_gethide($component1) = true) {
    if_sethide(false, $component1);
    if_sethide(true, $component3);
    if_sethide(true, $component4);
    if_setop(1, "Hide menu", $component0);
    $string = "Deposit Box settings menu";
} else {
    if_sethide(true, $component1);
    if_sethide(false, $component3);
    if_sethide(false, $component4);
    if_setop(1, "Show menu", $component0);
    $string = "The Bank of Gielinor - Deposit Box";
}
if (cc_find($component2, 1) = true) {
    cc_settext($string);
}
