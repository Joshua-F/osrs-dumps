// 741
[clientscript,pest_activity_init](component $com_10, component $com_12)
cc_deleteall($com_10);
cc_deleteall($com_12);
cc_create($com_10, ^iftype_rectangle, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setfill(false);
.cc_create($com_12, ^iftype_rectangle, 0);
.cc_setfill(true);
~pest_activity_update;
if_setonvartransmit("pest_activity_update($com_10, cc_getid, $com_12, .cc_getid){varplayer_243}", $com_10);
