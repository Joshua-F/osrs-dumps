[clientscript,pest_activity_init](component $com_12, component $com_14)
cc_deleteall($com_12);
cc_deleteall($com_14);
cc_create($com_12, ^iftype_rectangle, 0);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setfill(false);
.cc_create($com_14, ^iftype_rectangle, 0);
.cc_setfill(true);
~pest_activity_update;
if_setonvartransmit("pest_activity_update($com_12, cc_getid, $com_14, .cc_getid){varplayer_243}", $com_12);
