// 6619
[proc,cluehelper_key_npc](dbrow $dbrow0, dbrow $dbrow1, entityoverlay $entityoverlay, npc_uid $npc_uid, int $int4)
if ($dbrow0 = null | $dbrow1 = null) {
    return;
}
def_obj $obj = db_getfield($dbrow1, cluehelper_target_key:key, 0);
if ($obj = null) {
    return;
}
def_int $int6 = 0;
if (inv_total(inv, $obj) > 0) {
    $int6 = 1;
}
if (if_find_entityoverlay($entityoverlay) = true) {
    cc_setonvartransmit("cluehelper_key_npc_vartransmit($dbrow0, $dbrow1, $entityoverlay, $int4, $npc_uid, %option_cluehelper_overlay_enabled, %option_cluehelper_target_highlight_enabled, $obj, $int6){cluehelper_infobox_clue, option_cluehelper}");
    cc_setoninvtransmit("cluehelper_key_npc_invtransmit($dbrow0, $dbrow1, $entityoverlay, $int4, $npc_uid, $obj, $int6){inv}");
}
~cluehelper_key_npc_draw($dbrow0, $dbrow1, $entityoverlay, $int4, $npc_uid, $obj, $int6);
