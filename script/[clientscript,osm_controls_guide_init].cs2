// 2368
[clientscript,osm_controls_guide_init](component $universe, component $next, component $previous, component $1, component $2, component $3, component $4, component $5, component $6)
cc_deleteall($universe);
~steelbox($universe, 0, 0);
~osm_controls_guide_set($next, $previous, $1, $2, $3, $4, $5, $6);
if_setonvartransmit("osm_controls_guide_set($next, $previous, $1, $2, $3, $4, $5, $6){if1}", $universe);
if_setonop("osm_controls_guide_op(1, event_op, $next, $previous, $1, $2, $3, $4, $5, $6)", $next);
if_setonop("osm_controls_guide_op(-1, event_op, $next, $previous, $1, $2, $3, $4, $5, $6)", $previous);
