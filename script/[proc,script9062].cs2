// 9062
[proc,script9062](dbtable $dbtable, dbrow $dbrow)(int)
if ($dbtable = null) {
    $dbtable = db_getrowtable($dbrow);
}
switch_dbtable ($dbtable) {
    case sailing_boat_facility :
        return(db_getfieldcount($dbrow, sailing_boat_facility:material));
    case sailing_boat_keel :
        return(db_getfieldcount($dbrow, sailing_boat_keel:material));
    case sailing_boat_hull :
        return(db_getfieldcount($dbrow, sailing_boat_hull:material));
    case sailing_boat_sail :
        return(db_getfieldcount($dbrow, sailing_boat_sail:material));
    case sailing_boat_steering :
        return(db_getfieldcount($dbrow, sailing_boat_steering:material));
    case sailing_boat_flag :
        return(db_getfieldcount($dbrow, sailing_boat_flag:material));
    case sailing_boat_brazier :
        return(db_getfieldcount($dbrow, sailing_boat_brazier:material));
    case sailing_boat_trim :
        return(db_getfieldcount($dbrow, sailing_boat_trim:material));
    case default :
        return(0);
}
