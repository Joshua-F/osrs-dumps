// 8114
[proc,script8114](component $component)
if (if_gethide($component) = true) {
    if (%bingo_show_rewards = false & keyheld(^key_control_left) = false) {
        if_sethide(false, $component);
    }
} else if (%bingo_show_rewards = true | keyheld(^key_control_left) = true) {
    if_sethide(true, $component);
}
