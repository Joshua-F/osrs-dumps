// 5904
[proc,speedrunning_button_draw](component $component, string $string, boolean $boolean1, boolean $boolean2)
cc_deleteall($component);
def_int $int = 0;
if ($boolean1 = true | $boolean2 = true) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $int = ~v2_stone_button_filled($component);
}
cc_create($component, ^iftype_text, $int);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setsize(4, 0, ^setsize_minus, ^setsize_minus);
cc_settextfont(p12_full);
if ($boolean2 = true) {
    cc_setcolour(0xaaaaaa);
} else {
    cc_setcolour(0xff981f);
}
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_settext($string);
if ($boolean2 = true) {
    if_setop(1, "", $component);
} else {
    if_setop(1, removetags($string), $component);
}
