// 57
[clientscript,script57]
def_component $componentarray(calc(1 + 1));
def_int $int = 0;
while ($int <= 1) {
    $componentarray($int) = ~script55($int);
    $int = calc($int + 1);
}
~quicksort(componentarray0, 0, 1);
$int = 0;
while ($int <= 1) {
    if_setposition(10, calc(0 + 1 * 15 + $int * 15), $componentarray($int));
    $int = calc($int + 1);
}
if_setscrollsize(167, calc(95 + 1 * 15), interface_259:com_0);
~scrollbar_vertical(interface_259:com_13, interface_259:com_0, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
