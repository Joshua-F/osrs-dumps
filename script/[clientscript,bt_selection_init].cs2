// 8614
[clientscript,bt_selection_init](component $frame, component $content_left, component $content_right, component $click_layer, component $reward_click_layer)
if (%sailing_bt_trial_data_if = null) {
    return;
}
~steelborder($frame, "The <db_getfield(%sailing_bt_trial_data_if, sailing_bt_trial_core:trial_name, 0)>", 0);
~bt_selection_draw(%sailing_bt_trial_data_if, $frame, $content_left, $content_right, $click_layer, $reward_click_layer);
