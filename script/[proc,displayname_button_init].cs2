// 1672
[proc,displayname_button_init](component $component, string $string)
~displayname_button_draw($component, $string, false);
if_setop(1, removetags($string), $component);
if_setonmouserepeat("displayname_button_draw(event_com, $string, true)", $component);
if_setonmouseleave("displayname_button_draw(event_com, $string, false)", $component);
if_setonop("displayname_button_op(event_op, event_com, $string)", $component);
if_setontimer(null, $component);
