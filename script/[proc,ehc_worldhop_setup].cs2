// 7572
[proc,ehc_worldhop_setup]
if (~on_enhanced_any = false) {
    return;
}
cc_deleteall(interface_896:com_1);
def_int $int = 0;
while ($int <= 600) {
    cc_create(interface_896:com_1, ^iftype_graphic, $int);
    cc_setsize(1, 1, ^setsize_minus, ^setsize_abs);
    cc_sethide(true);
    $int = calc($int + 1);
}
