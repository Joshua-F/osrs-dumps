// 52
[clientscript,pattern_cards_setmodel](component $component, model $model)
if_setmodel($model, $component);
if_setmodelangle(0, 0, random(2048), random(2048), 0, calc(randominc(25) + enum(model, int, enum_1922, $model)), $component);
if (random(2) = 0) {
    if_setontimer("spinner(calc(randominc(25) + 10), calc(randominc(25) + 20), 0, event_com)", $component);
} else {
    if_setontimer("spinner(calc(randominc(25) + 20), calc(randominc(25) + 10), 0, event_com)", $component);
}
