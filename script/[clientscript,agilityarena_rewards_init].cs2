// 197
[clientscript,agilityarena_rewards_init](component $universe, component $experience_1, component $experience_10, component $experience_25, component $experience_100, component $experience_1000, component $toadflax, component $snapdragon, component $graceful, component $piratehook, component $graceful_options, component $graceful_hood, component $graceful_top, component $graceful_legs, component $graceful_cape, component $graceful_gloves, component $graceful_boots, component $graceful_set, component $graceful_cancel)
~agilityarena_rewards_initbutton($experience_1, "Experience", 1, null);
~agilityarena_rewards_initbutton($experience_10, "Experience", 10, null);
~agilityarena_rewards_initbutton($experience_25, "Experience", 25, null);
~agilityarena_rewards_initbutton($experience_100, "Experience", 100, null);
~agilityarena_rewards_initbutton($experience_1000, "Experience", 1000, null);
~agilityarena_rewards_initbutton($toadflax, oc_name(toadflax), 3, null);
~agilityarena_rewards_initbutton($snapdragon, oc_name(snapdragon), 10, null);
~agilityarena_rewards_initbutton($piratehook, oc_name(piratehook), 800, null);
if_sethide(true, $graceful_options);
cc_deleteall($graceful_options);
~thinstonebox($graceful_options, 0);
~agilityarena_rewards_gracefulbutton_init($graceful_hood, graceful_hood_skillcapecolour, graceful_hood, "Hood", 45);
~agilityarena_rewards_gracefulbutton_init($graceful_top, graceful_top_skillcapecolour, graceful_top, "Top", 45);
~agilityarena_rewards_gracefulbutton_init($graceful_legs, graceful_legs_skillcapecolour, graceful_legs, "Legs", 45);
~agilityarena_rewards_gracefulbutton_init($graceful_cape, graceful_cape_skillcapecolour, graceful_cape, "Cape", 45);
~agilityarena_rewards_gracefulbutton_init($graceful_gloves, graceful_gloves_skillcapecolour, graceful_gloves, "Gloves", 45);
~agilityarena_rewards_gracefulbutton_init($graceful_boots, graceful_boots_skillcapecolour, graceful_boots, "Boots", 45);
~agilityarena_rewards_gracefulbutton_init($graceful_set, null, null, "Whole set", 250);
def_string $string = "Dismiss";
if_setsize(calc(50 + parawidth($string, 512, p12_full)), if_getheight($graceful_cancel), ^setsize_abs, ^setsize_abs, $graceful_cancel);
~agilityarena_rewards_gracefulcancel($graceful_cancel, $string, false);
if_setonmouserepeat("agilityarena_rewards_gracefulcancel($graceful_cancel, $string, true)", $graceful_cancel);
if_setonmouseleave("agilityarena_rewards_gracefulcancel($graceful_cancel, $string, false)", $graceful_cancel);
if_setop(1, $string, $graceful_cancel);
if_setonop("agilityarena_rewards_hidelayer(true, $graceful_options)", $graceful_cancel);
~agilityarena_rewards_setgracefulbutton($graceful, $graceful_options);
if_setonvartransmit("agilityarena_rewards_setgracefulbutton($graceful, $graceful_options){agilityarena_varbit}", $universe);
