// 197
[clientscript,agilityarena_rewards_init](component $component, string $string, int $int)
if ($int = 1) {
    if_setop(1, "Buy for 1 ticket", $component);
} else {
    if_setop(1, "Buy for <~tostring_spacer($int, ",")> tickets", $component);
}
~agilityarena_rewards_draw($component, $string, $int, false);
if_setoninvtransmit("agilityarena_rewards_draw($component, $string, $int, false){inv_93}", $component);
if_setonmouserepeat("agilityarena_rewards_draw($component, $string, $int, true)", $component);
if_setonmouseleave("agilityarena_rewards_draw($component, $string, $int, false)", $component);
