// 1062
[proc,farming_tools_side_update](component $component, obj $obj1, string $string, int $int2)
def_int $int3 = 0;
def_obj $obj4 = null;
$int3, $obj4 = ~farming_tools_getcarried($obj1);
def_int $rgb = 0xbb0000;
if ($int3 > 0) {
    $rgb = 0x20df20;
}
if ($obj1 = obj_6797) {
    if ($obj4 = null) {
        $obj4 = obj_6797;
    }
    $string = oc_name($obj4);
}
if (cc_find($component, $int2) = true & .cc_find($component, calc($int2 + 1)) = true) {
    cc_settext($string);
    cc_setcolour($rgb);
    .cc_setcolour($rgb);
    .cc_settext(~magic_tostring($int3));
}
if (cc_find($component, calc($int2 + 2)) = true) {
    cc_setobject_nonum($obj4, $int3);
}
if_setopbase("<col=ff9040><oc_name($obj4)></col>", $component);
if_clearops($component);
if_setop(10, "Examine", $component);
def_int $int6 = enum(obj, int, enum_2193, $obj1);
if ($int6 <= 1) {
    if_setop(1, "Store", $component);
} else {
    switch_int (~get_selected_quantity(enum_2193)) {
        case 0 :
            if_setop(1, "Store-1", $component);
            if_setop(2, "Store-5", $component);
            if_setop(3, "Store-X", $component);
            if_setop(4, "Store-All", $component);
        case 1 :
            if_setop(1, "Store-5", $component);
            if_setop(2, "Store-1", $component);
            if_setop(3, "Store-X", $component);
            if_setop(4, "Store-All", $component);
        case 3 :
            if_setop(1, "Store-X", $component);
            if_setop(2, "Store-1", $component);
            if_setop(3, "Store-5", $component);
            if_setop(4, "Store-All", $component);
        case 2 :
            if_setop(1, "Store-All", $component);
            if_setop(2, "Store-1", $component);
            if_setop(3, "Store-5", $component);
            if_setop(4, "Store-X", $component);
    }
}
