// 3342
[clientscript,adventurepath_disable_notification_op](component $component, int $int)
sound_synth(synth_2266, 1, 0);
if (%adventurepath_disable_notification = 0) {
    ~script3034($component, $int, 1);
    %adventurepath_disable_notification = 1;
} else {
    ~script3034($component, $int, 0);
    %adventurepath_disable_notification = 0;
}
