// 614
[clientscript,poll_resetlink](component $component, int $int1, int $int2, string $string0, string $string1, int $int3)
if (clientclock < $int3) {
    return;
}
if (cc_find($component, $int1) = true & .cc_find($component, $int2) = true) {
    cc_setontimer(null);
    ~poll_setuplink($component, $int1, $int2, $string0, $string1);
}
