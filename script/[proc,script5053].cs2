// 5053
[proc,script5053](int $int)(string)
switch_int ($int) {
    case 0 :
        return("He's");
    case 1 :
        return("She's");
    case 2 :
        return("They're");
    case default :
        ~debug_mes_warning("Pronouns not correctly set. Pronouns are set to <tostring($int)> but should be 0, 1 or 2.");
        return("They're");
}
