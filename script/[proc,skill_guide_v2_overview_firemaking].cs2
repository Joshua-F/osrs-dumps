// 9158
[proc,skill_guide_v2_overview_firemaking](component $component)
~script9182($component, "", "Firemaking is a skill used to light fires and light sources. Use the tabs on the left to see what types of logs and light sources can be lit and the Firemaking level required to light them.<"||::p||">To level your Firemaking, simply make fires from logs. Increasing your Firemaking level increases the speed at which you light logs.<"||::p||">||::hl||<"To light a fire"><"||::/hl||">, use a Tinderbox on some logs gathered with the ||skill:<18>::<19>:: Woodcutting skill||. Tinderboxes can be purchased from ||::<115>::General Stores||, such as the one in Lumbridge.<"||::p||">Logs can also be added to an existing fire by using a log on the fire. This burns logs at a slower rate but the logs are added automatically.");
~script9182($component, "Getting Started", "To get started, gather some basic logs from normal trees and light them with a Tinderbox. You can continue to light individual fires for faster XP or add more logs to a single fire which requires less attention but provides slower XP.");
def_stringarray $stringarray = array_create(string, 2, -1);
$stringarray(0) = "||skill:<18>::<19>::Woodcutting:::|| Logs cut with the Woodcutting skill can be lit with the Firemaking skill.";
$stringarray(1) = "||skill:<16>::<17>::Cooking:::|| Fires lit with the Firemaking skill can be used to cook food with the Cooking skill.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
