// 248
[clientscript,nzone_rewards_init](component $universe, component $tabs, component $resources, component $upgrades, component $benefits)
~nzone_rewards_tabs($tabs, $resources, $upgrades, $benefits, $resources);
~nzone_rewards_lists($resources, $benefits);
if_setoninvtransmit("nzone_rewards_lists($resources, $benefits){ranging_guild_bowshop_skillcape_trimmed, smithing_iron3}", $universe);
~nzone_rewards_upgrades($upgrades);
if_setoninvtransmit("nzone_rewards_upgrades($upgrades){inv, ranging_guild_bowshop_skillcape_trimmed, smithing_iron3}", $upgrades);
