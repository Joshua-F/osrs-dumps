// 248
[clientscript,nzone_rewards_init](component $com_0, component $com_2, component $com_4, component $com_5, component $com_6)
~nzone_rewards_tabs($com_2, $com_4, $com_5, $com_6, $com_4);
~nzone_rewards_lists($com_4, $com_6);
if_setoninvtransmit("nzone_rewards_lists($com_4, $com_6){inv_464, inv_108}", $com_0);
~nzone_rewards_upgrades($com_5);
if_setoninvtransmit("nzone_rewards_upgrades($com_5){inv_93, inv_464, inv_108}", $com_5);
