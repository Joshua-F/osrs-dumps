// 6787
[clientscript,pendant_of_ates_keypress](char $char, component $component, int $int, string $string0, string $string1, string $string2)
if (~keypress_permit(pendant_of_ates, null) = false) {
    return;
}
if ($char ! null & (string_indexof_char($string1, $char) ! -1 | string_indexof_char($string2, $char) ! -1) & cc_find($component, 0) = true & .cc_find(pendant_of_ates:universe, calc($int - 1)) = true) {
    ~pendant_of_ates_activate($component, $int, $string0, $string1, $string2);
}
