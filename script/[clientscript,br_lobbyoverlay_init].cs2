// 2539
[clientscript,br_lobbyoverlay_init](component $com_1, component $com_2, component $com_3)
~interface_dodger_init($com_1, $com_2, 36582, ^setpos_abs_right, ^setpos_abs_top, false);
~br_lobbyoverlay_drawsettings(false, $com_3);
if_setonmouserepeat("br_lobbyoverlay_drawsettings(true, event_com)", $com_3);
if_setonmouseleave("br_lobbyoverlay_drawsettings(false, event_com)", $com_3);
if_setonop("opsound(event_op, 2)", $com_3);
