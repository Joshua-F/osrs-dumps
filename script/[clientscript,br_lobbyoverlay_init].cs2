// 2539
[clientscript,br_lobbyoverlay_init](component $dodger, component $content, component $settings)
~interface_dodger_init($dodger, $content, 36582, ^setpos_abs_right, ^setpos_abs_top, false);
~br_lobbyoverlay_drawsettings(false, $settings);
if_setonmouserepeat("br_lobbyoverlay_drawsettings(true, event_com)", $settings);
if_setonmouseleave("br_lobbyoverlay_drawsettings(false, event_com)", $settings);
if_setonop("opsound(event_op, 2)", $settings);
