// 9059
[proc,script9059](dbtable $dbtable, dbrow $dbrow, int $int)(stat, int)
if ($dbtable = null) {
    $dbtable = db_getrowtable($dbrow);
}
switch_dbtable ($dbtable) {
    case sailing_boat_facility :
        return(db_getfield($dbrow, sailing_boat_facility:other_stat_requirement, $int));
    case sailing_boat_keel :
        return(db_getfield($dbrow, sailing_boat_keel:other_stat_requirement, $int));
    case sailing_boat_hull :
        return(db_getfield($dbrow, sailing_boat_hull:other_stat_requirement, $int));
    case sailing_boat_sail :
        return(db_getfield($dbrow, sailing_boat_sail:other_stat_requirement, $int));
    case sailing_boat_steering :
        return(db_getfield($dbrow, sailing_boat_steering:other_stat_requirement, $int));
    case sailing_boat_flag :
        return(db_getfield($dbrow, sailing_boat_flag:other_stat_requirement, $int));
    case sailing_boat_brazier :
        return(db_getfield($dbrow, sailing_boat_brazier:other_stat_requirement, $int));
    case sailing_boat_trim :
        return(db_getfield($dbrow, sailing_boat_trim:other_stat_requirement, $int));
    case default :
        return(null, -1);
}
