// 3992
[proc,script3992](component $component)
def_struct $struct = null;
if (~fsw_player = 1) {
    if_setgraphic("achievement_diary_icons,11", $component);
} else if (~league_world = true) {
    $struct = enum(int, struct, enum_2670, %varplayerbit_10032);
    if ($struct ! null) {
        if_setgraphic(struct_param($struct, param_2054), $component);
    } else {
        if_setgraphic("achievement_diary_icons,13", $component);
    }
} else if (~deadman_world = 1) {
    if_setgraphic("achievement_diary_icons,12", $component);
}
