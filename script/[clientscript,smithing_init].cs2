// 415
[clientscript,smithing_init](component $universe)
%smithing_listening = 1;
~smithing_setup;
if_setonvartransmit("smithing_setup{smithbars, tutorial, desertrescue, death_equiproom, zeah_alignment1, zeah_alignment2}", $universe);
if_setonstattransmit("smithing_setup{smithing}", $universe);
if_setoninvtransmit("smithing_setup{inv}", $universe);
