// 9633
[proc,script9633]
if (%myq6 < 114 | %myq6 > 124 | %myq6_hideout_defence_music <= 1 | %musicplay ! 0) {
    return;
}
switch_int (%myq6_hideout_defence_music) {
    case 1 :
        ~script9628(music_hideout_defence_part_1, 30);
    case 2 :
        ~script9628(music_hideout_defence_part_2, 30);
    case 3 :
        ~script9628(music_hideout_defence_part_3, 30);
    case 4 :
        ~script9628(music_hideout_defence_part_4, 30);
}
