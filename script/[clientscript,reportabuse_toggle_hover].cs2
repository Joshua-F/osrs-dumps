// 5099
[clientscript,reportabuse_toggle_hover](boolean $boolean, component $component, int $int)
if ($boolean = true) {
    if (cc_find($component, $int) = true) {
        cc_settrans(220);
    }
    if_setontimer("reportabuse_toggle_reset(calc(clientclock + 2), event_com, $int)", $component);
} else {
    if (cc_find($component, $int) = true) {
        cc_settrans(255);
    }
    if_setontimer(null, $component);
}
