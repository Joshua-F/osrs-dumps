// 815
[proc,confirmdestroy_setupbutton](component $component, string $string0, int $int, string $string1)
cc_deleteall($component);
cc_create($component, ^iftype_text, 0);
cc_setsize(40, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_right, ^setpos_abs_centre);
cc_setcolour(^black);
cc_settextfont(q8_full);
cc_settextalign(^settextalign_left, ^settextalign_centre, 0);
cc_settext($string0);
if_setonmouserepeat("cc_colour_swapper(event_com, cc_getid, 16777215)", $component);
if_setonmouseleave("cc_colour_swapper(event_com, cc_getid, 0)", $component);
if_setop(1, $string0, $component);
if_setonop("confirmdestroy_triggerbutton(event_op, null, $component, $string0, $int, $string1, cc_getid)", $component);
if_setonkey("confirmdestroy_triggerbutton(-1, event_keychar, $component, $string0, $int, $string1, cc_getid)", $component);
if_setontimer(null, $component);
