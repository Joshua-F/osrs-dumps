// 6950
[clientscript,eaa_shameometer_init](component $outer_border, component $inner_border, component $title_backing, component $bar_back, component $bar_sliding, component $bar_progress, component $title_text, component $bar_text)
if_setonvartransmit("eaa_shameometer_update($bar_text, $bar_back, $bar_sliding, $bar_progress, false){eaa_primary}", $bar_text);
~eaa_shameometer_open($outer_border, $inner_border, $title_backing, $bar_back, $bar_sliding, $bar_progress, $title_text, $bar_text);
