// 9621
[proc,script9621](component $component, int $int)
if (if_find($component) = true) {
    cc_setparam(param_2018, $int);
}
cc_deleteall($component);
switch_int ($int) {
    case 0 :
        ~dynamic_builders_demo($component);
    case default :
        if (~rental_world = true) {
            ~create_filler($component, ^red, "reusable floater <tostring($int)>");
        }
}
