// 3584
[clientscript,teletab_steelborder](component $frame)
def_string $string = "";
switch_int (%tablet_spellbook) {
    case 1 :
        $string = "Ancient Teleport Tablets";
    case 2 :
        $string = "Lunar Teleport Tablets";
    case 3 :
        $string = "Arceuus Teleport Tablets";
    case default :
        $string = "Spell Tablets";
}
~steelborder($frame, $string, 0);
