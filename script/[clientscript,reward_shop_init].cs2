// 6082
[clientscript,reward_shop_init]
def_component $infinity = giants_foundry_reward_shop:infinity;
if_setontimer("responsive_interface_scaler($infinity, -1)", $infinity);
if_setonresize("giants_foundry_reward_shop_setup(true)", $infinity);
if_setonvartransmit("giants_foundry_reward_shop_setup(false){giants_foundry_reward_shop_points}", $infinity);
