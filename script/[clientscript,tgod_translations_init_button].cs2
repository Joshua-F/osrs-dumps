// 6946
[clientscript,tgod_translations_init_button](string $string, component $translate)
~tgod_translations_draw_button(false, $string, $translate);
if_setop(1, $string, $translate);
if (~on_mobile = false) {
    if_setonmouserepeat("tgod_translations_draw_button(true, $string, $translate)", $translate);
    if_setonmouseleave("tgod_translations_draw_button(false, $string, $translate)", $translate);
}
