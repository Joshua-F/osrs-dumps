// 6946
[clientscript,tgod_translations_init_button](string $string, component $com_5)
~tgod_translations_draw_button(false, $string, $com_5);
if_setop(1, $string, $com_5);
if (~on_mobile = false) {
    if_setonmouserepeat("tgod_translations_draw_button(true, $string, $com_5)", $com_5);
    if_setonmouseleave("tgod_translations_draw_button(false, $string, $com_5)", $com_5);
}
