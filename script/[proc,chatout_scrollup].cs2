// 75
[proc,chatout_scrollup]
def_int $int = %chatout_readpos;
def_string $string = null;
if ($int = -1) {
    $int = %chatout_writepos;
}
if (%chatout_readpos ! %chatout_writepos) {
    $int = calc($int - 1);
    if ($int < 0) {
        $int = 19;
    }
    $string = ~chatout_get($int);
    if (string_length($string) > 0) {
        %chatinput = $string;
        %chatout_readpos = $int;
    }
}
