// 3614
[proc,partydrop_main_quantitybutton](boolean $boolean0, boolean $boolean1, component $component, string $string)
cc_deleteall($component);
def_int $int = 0;
if ($boolean0 = true) {
    $int = ~options_button_on($component, 0);
    if_setonmouserepeat(null, $component);
    if_setonmouseleave(null, $component);
} else {
    $int = ~options_button_off($component, 0);
    if_setonmouserepeat("partydrop_main_quantitybutton(false, true, $component, $string)", $component);
    if_setonmouseleave("partydrop_main_quantitybutton(false, false, $component, $string)", $component);
}
cc_create($component, ^iftype_text, $int);
cc_setsize(0, 0, ^setsize_minus, ^setsize_minus);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
if ($boolean0 = true | $boolean1 = true) {
    cc_setcolour(^white);
} else {
    cc_setcolour(0xff981f);
}
cc_settextfont(p12_full);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settextshadow(true);
cc_settext($string);
