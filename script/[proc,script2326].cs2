// 2326
[proc,script2326](component $component, int $int1, string $string, int $int2)
if_setontimer(null, $component);
if_setonmouserepeat("cc_colour_swapper(event_com, $int1, 16754735)", $component);
if_setonmouseleave("cc_colour_swapper(event_com, $int1, 16750623)", $component);
if_setop(1, "Set", $component);
if_setopbase("<col=ff9040><$string></col>", $component);
if_setonop("script2327(event_op, $component, $int1, $string, $int2)", $component);
