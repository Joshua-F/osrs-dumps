// 495
[clientscript,wilderness_lootingbag_setup](int $int, string $string)
if_settext($string, wilderness_lootingbag:title);
def_inv $inv = looting_bag;
if ($int = 1) {
    $inv = inv;
}
~wilderness_lootingbag_draw($inv);
if_setoninvtransmit("wilderness_lootingbag_draw($inv){$inv}", wilderness_lootingbag:title);
