// 1627
[clientscript,options_shiftclickdrop_init](component $com_85, component $com_86, component $com_117)
if_setonmouseleave("deltooltip($com_117)", $com_85);
~options_shiftclickdrop($com_85, $com_86, $com_117);
if_setonvartransmit("options_shiftclickdrop_resynch($com_85, $com_86, $com_117){varplayer_1055}", $com_85);
if_setop(1, ~text_device("Toggle shift click to drop", "Toggle tap to drop"), $com_85);
if_setonop("options_shiftclickdrop_op(event_op, $com_85, $com_86, $com_117)", $com_85);
