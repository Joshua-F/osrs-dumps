[clientscript,options_shiftclickdrop_init](component $com_79, component $com_80, component $com_111)
if_setonmouseleave("deltooltip($com_111)", $com_79);
~options_shiftclickdrop($com_79, $com_80, $com_111);
if_setonvartransmit("options_shiftclickdrop_resynch($com_79, $com_80, $com_111){varplayer_1055}", $com_79);
if_setop(1, ~text_device("Toggle shift click to drop", "Toggle tap to drop"), $com_79);
if_setonop("options_shiftclickdrop_op(event_op, $com_79, $com_80, $com_111)", $com_79);
