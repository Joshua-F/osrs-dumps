// 1627
[clientscript,options_shiftclickdrop_init](component $com_80, component $com_81, component $com_112)
if_setonmouseleave("deltooltip($com_112)", $com_80);
~options_shiftclickdrop($com_80, $com_81, $com_112);
if_setonvartransmit("options_shiftclickdrop_resynch($com_80, $com_81, $com_112){varplayer_1055}", $com_80);
if_setop(1, ~text_device("Toggle shift click to drop", "Toggle tap to drop"), $com_80);
if_setonop("options_shiftclickdrop_op(event_op, $com_80, $com_81, $com_112)", $com_80);
