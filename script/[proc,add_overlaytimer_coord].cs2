// 5477
[proc,add_overlaytimer_coord](coord $coord, int $int1, int $int2, int $rgb, int $int4)
if (~on_enhanced = false | ~script5479($coord, $int1, $int2) = false) {
    return;
}
def_entityoverlay $entityoverlay = entityoverlay_create_coord($coord, 1, ^overlaytype_middle, 25, 25, 0);
~add_overlaytimer_inner($int1, $entityoverlay, $int2, $rgb, $int4);
