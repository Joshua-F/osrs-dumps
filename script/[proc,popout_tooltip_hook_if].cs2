// 5539
[proc,popout_tooltip_hook_if](component $component)
if (~on_mobile = true) {
    if_setnoclickthrough(true, $component);
    if_setonmouserepeat(null, $component);
    if_setonmouseleave(null, $component);
} else {
    if_setonmouseleave("popout_tooltip_clear_clientscript", $component);
    if_setonclick(null, $component);
    if_setnoclickthrough(false, $component);
}
