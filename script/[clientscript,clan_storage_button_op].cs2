// 4350
[clientscript,clan_storage_button_op](int $int, string $string, component $component)
if ($int ! 1) {
    return;
}
sound_synth(synth_2266, 1, 0);
~clan_storage_button_draw($string, $component, 1);
if_setontimer("clan_storage_button_reset(calc(clientclock + 30), $string, $component)", $component);
if_setonop(null, $component);
