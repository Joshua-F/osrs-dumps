// 9614
[proc,script9614](string $string, boolean $boolean)(int, obj)
def_int $int = oc_find($string, $boolean);
if ($int = 0) {
    return(0, null);
}
def_obj $obj2 = null;
def_obj $obj3 = null;
$obj2 = oc_findnext;
while ($obj2 ! null) {
    if (compare(oc_name($obj2), $string) = 0) {
        $obj3 = $obj2;
        $obj2 = null;
    } else {
        $obj2 = oc_findnext;
    }
}
return($int, $obj3);
