// 885
[clientscript,script885](component $dropdown_league, component $league_filter, component $dropdown_container, component $dropdown_box)
cc_deleteall($league_filter);
def_int $rgb = ^white;
def_int $int5 = 0;
.cc_create($league_filter, ^iftype_graphic, $int5);
$int5 = calc($int5 + 1);
.cc_setsize(0, 20, ^setsize_minus, ^setsize_abs);
.cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_top);
.cc_setgraphic(tradebacking);
.cc_settiling(true);
cc_create($league_filter, ^iftype_rectangle, $int5);
$int5 = calc($int5 + 1);
cc_setsize(0, 20, ^setsize_minus, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_top);
cc_setfill(false);
cc_setcolour(0x0e0e0c);
cc_create($league_filter, ^iftype_rectangle, $int5);
$int5 = calc($int5 + 1);
cc_setsize(2, 18, ^setsize_minus, ^setsize_abs);
cc_setposition(0, 1, ^setpos_abs_centre, ^setpos_abs_top);
cc_setfill(false);
cc_setcolour(0x474745);
cc_create($league_filter, ^iftype_graphic, $int5);
$int5 = calc($int5 + 1);
cc_setsize(16, 16, ^setsize_abs, ^setsize_abs);
cc_setposition(2, 2, ^setpos_abs_right, ^setpos_abs_top);
cc_create($league_filter, ^iftype_text, $int5);
def_int $int6 = $int5;
$int5 = calc($int5 + 1);
cc_setsize(20, 16, ^setsize_minus, ^setsize_abs);
cc_setposition(2, 2, ^setpos_abs_left, ^setpos_abs_top);
cc_settextfont(p11_full);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
~league_firsts_dropdown_updatetext($league_filter, 5);
if_sethide(true, $dropdown_container);
.cc_setonclick("script886($dropdown_league, $league_filter, $int6, $dropdown_container, $dropdown_box, $rgb)");
~league_setup_display_hoveroff($league_filter, $rgb);
