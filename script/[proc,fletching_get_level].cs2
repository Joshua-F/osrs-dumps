// 8590
[proc,fletching_get_level](dbrow $dbrow)(int)
switch_dbtable (db_getrowtable($dbrow)) {
    case fletching_bow_crafting :
        return(db_getfield($dbrow, fletching_bow_crafting:level_required, 0));
    case fletching_crossbow_crafting :
        return(db_getfield($dbrow, fletching_crossbow_crafting:level_required, 0));
    case fletching_arrow_crafting :
        return(db_getfield($dbrow, fletching_arrow_crafting:level_required, 0));
    case fletching_bolt_crafting :
        return(db_getfield($dbrow, fletching_bolt_crafting:level_required, 0));
    case fletching_bolt_tip_crafting :
        return(db_getfield($dbrow, fletching_bolt_tip_crafting:level_required, 0));
    case fletching_darts_crafting :
        return(db_getfield($dbrow, fletching_darts_crafting:level_required, 0));
    case fletching_javelin_crafting :
        return(db_getfield($dbrow, fletching_javelin_crafting:level_required, 0));
    case fletching_shield_crafting :
        return(db_getfield($dbrow, fletching_shield_crafting:level_required, 0));
    case fletching_ogre_arrow_crafting :
        return(db_getfield($dbrow, fletching_ogre_arrow_crafting:level_required, 0));
    case fletching_ballista_crafting :
        return(db_getfield($dbrow, fletching_ballista_crafting:level_required, 0));
    case fletching_grapple_crafting :
        return(db_getfield($dbrow, fletching_grapple_crafting:level_required, 0));
    case fletching_battlestaff_crafting :
        return(db_getfield($dbrow, fletching_grapple_crafting:level_required, 0));
    case fletching_blowpipe_crafting :
        return(db_getfield($dbrow, fletching_blowpipe_crafting:level_required, 0));
}
return(1);
