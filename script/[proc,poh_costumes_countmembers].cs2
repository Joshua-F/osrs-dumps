// 3540
[proc,poh_costumes_countmembers](obj $obj)(int)
def_enum $enum = enum(obj, enum, enum_3077, $obj);
if ($enum = null) {
    return(~poh_costumes_countalternates($obj));
}
def_int $int2 = enum_getoutputcount($enum);
def_int $int3 = 0;
def_int $int4 = 0;
while ($int4 < $int2) {
    $int3 = calc($int3 + ~poh_costumes_countalternates(enum(int, namedobj, $enum, $int4)));
    $int4 = calc($int4 + 1);
}
return($int3);
