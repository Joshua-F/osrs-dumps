// 7773
[proc,cc_create_graphic](component $component, int $int1, graphic $graphic, int $int3, int $int4, int $setposh, int $setposv, int $int7, int $int8, int $setsize9, int $setsize10)(int)
cc_create($component, ^iftype_graphic, $int1);
cc_setposition($int3, $int4, $setposh, $setposv);
cc_setsize($int7, $int8, $setsize9, $setsize10);
cc_setgraphic($graphic);
cc_settiling(true);
return(calc($int1 + 1));
