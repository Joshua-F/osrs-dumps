// 6266
[clientscript,pvpa_sidepanel_init](component $universe, component $header, component $groupname, component $playerlist, component $scrollbar, component $hint, component $left, component $right, component $worldhop)
~scrollbar_vertical($scrollbar, $playerlist, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
~pvpa_sidepanel_draw($header, $groupname, $playerlist, $scrollbar, $hint, $left, $right, $worldhop);
if_setonvartransmit("pvpa_sidepanel_draw($header, $groupname, $playerlist, $scrollbar, $hint, $left, $right, $worldhop){gim_temp_1, clan_temp_transmit_0, pvpa_temp_transmit_0}", $universe);
if_setonclansettingstransmit("pvpa_sidepanel_draw($header, $groupname, $playerlist, $scrollbar, $hint, $left, $right, $worldhop)", $universe);
if_setonclanchanneltransmit("pvpa_sidepanel_draw($header, $groupname, $playerlist, $scrollbar, $hint, $left, $right, $worldhop)", $universe);
if_setonfriendtransmit("pvpa_sidepanel_draw($header, $groupname, $playerlist, $scrollbar, $hint, $left, $right, $worldhop)", $universe);
