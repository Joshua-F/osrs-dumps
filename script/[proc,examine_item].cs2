// 6004
[proc,examine_item](obj $obj, int $int1, string $string, boolean $boolean2, int $int3, boolean $boolean4, int $int5, int $int6)
if ($int1 >= 100000) {
    mes("<~tostring_spacer($int1, ",")> x <oc_name($obj)>.");
    ~examine_price_info($obj, $int1, 0, $boolean2, $int3, $boolean4, $int5, $int6);
} else {
    mes($string);
    ~examine_price_info($obj, $int1, 1, $boolean2, $int3, $boolean4, $int5, $int6);
}
