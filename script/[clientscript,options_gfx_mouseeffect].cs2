// 121
[clientscript,options_gfx_mouseeffect](boolean $boolean, component $component)
if (cc_find($component, 0) = true & .cc_find($component, 1) = true) {
    if ($boolean = true) {
        cc_setcolour(0xffb82f);
        .cc_setcolour(0xffb82f);
    } else {
        cc_setcolour(0xff981f);
        .cc_setcolour(0xff981f);
    }
}
