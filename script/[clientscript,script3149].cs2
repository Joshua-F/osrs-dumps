// 3149
[clientscript,script3149](int $int0, int $int1, component $component)
if (clientclock < $int0) {
    return;
}
~script3150($int1, $component);
if ($int1 > 0) {
    if_setontimer("script3149(calc($int0 + 50), calc($int1 - 1), $component)", $component);
