def_int $int = 0;
if ($boolean = true) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $int = ~v2_stone_button_out_filled($component);
}
cc_create($component, ^iftype_model, $int);
cc_setsize(42, 42, ^setsize_abs, ^setsize_abs);
