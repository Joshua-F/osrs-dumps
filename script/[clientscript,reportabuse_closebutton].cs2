// 5086
[clientscript,reportabuse_closebutton](component $close)
def_graphic $graphic = "close_buttons,6";
if_setgraphic($graphic, $close);
if_setonmouseleave("script2809(event_com, $graphic)", $close);
$graphic = "close_buttons,7";
if_setonmouseover("script2809(event_com, $graphic)", $close);
if_setonop("opsound(event_op, 2)", $close);
if_setonkey("reportabuse_closebutton_onkey(event_keycode, event_keychar, event_com)", $close);
