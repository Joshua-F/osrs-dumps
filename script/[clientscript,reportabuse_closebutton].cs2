// 5086
[clientscript,reportabuse_closebutton](component $com_23)
def_graphic $graphic = "close_buttons,6";
if_setgraphic($graphic, $com_23);
if_setonmouseleave("script2809(event_com, $graphic)", $com_23);
$graphic = "close_buttons,7";
if_setonmouseover("script2809(event_com, $graphic)", $com_23);
if_setonop("opsound(event_op, 2)", $com_23);
if_setonkey("reportabuse_closebutton_onkey(event_keycode, event_keychar, event_com)", $com_23);
