// 930
[proc,bankmain_toggleplaceholders](component $component)
if (%bank_leaveplaceholders = 1) {
    if_setgraphic("miscgraphics,9", $component);
    if_setop(1, "Disable", $component);
    if_setonop("bankmain_toggleplaceholders_op(event_op, $component, 0)", $component);
} else {
    if_setgraphic("miscgraphics,0", $component);
    if_setop(1, "Enable", $component);
    if_setonop("bankmain_toggleplaceholders_op(event_op, $component, 1)", $component);
}
