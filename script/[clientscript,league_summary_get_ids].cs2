// 7742
[clientscript,league_summary_get_ids](component $component)
def_int $int = 0;
def_string $string = "";
while ($int <= 500) {
    if (cc_find($component, $int) = true & string_length(cc_gettext) > 0) {
        ~debug_mes("Component found - ID = <tostring($int)> - text = <cc_gettext>");
    }
    $int = calc($int + 1);
}
