// 2132
[clientscript,fossil_driftnet_init](component $universe, component $confirmation, component $message, component $bin, component $bank, component $inv, component $cancel, component $confirm_destroy, component $confirm_bank)
if_sethide(true, $confirmation);
~script2136($cancel, "Cancel", $confirmation);
~script2136($confirm_destroy, "Discard all", $confirmation);
~script2136($confirm_bank, "Bank all", $confirmation);
~script2133($bin, "Discard all", "bankbuttons,6", "Are you sure you want to <col=ff0000>destroy</col><br>everything you've caught?", $confirmation, $message, $confirm_destroy, $confirm_bank);
~script2133($bank, "Bank all", "bankbuttons,5", "Pay <tostring(5)> numulites to <col=ffffff>bank</col><br>everything you've caught?", $confirmation, $message, $confirm_bank, $confirm_destroy);
~script2133($inv, "Take all", "bankbuttons,0", "", null, null, null, null);
