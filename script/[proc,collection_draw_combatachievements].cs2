// 4853
[proc,collection_draw_combatachievements](component $component, boolean $boolean)
def_int $int = 0;
if ($boolean = true) {
    $int = ~v2_stone_button_in_filled($component);
} else {
    $int = ~v2_stone_button_filled($component);
}
cc_create($component, ^iftype_graphic, $int);
cc_setsize(18, 18, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setgraphic("account_icons,3");
