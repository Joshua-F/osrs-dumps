// 8617
[proc,sailing_bt_rank_info](component $component, int $int1, int $int2, graphic $graphic, int $int4)(int)
$int1 = ~create_graphic($component, $int1, $graphic, 5, $int2, ^setpos_abs_left, ^setpos_abs_top, 32, 32, ^setsize_abs, ^setsize_abs, false);
def_string $string = "-";
if ($int4 > 0) {
    $string = append("Best Time: ", ~script4159(calc($int4 * 60 / 100), 0));
}
$int1 = ~create_text($component, $int1, p11_full, 42, calc($int2 + 6), ^setpos_abs_left, ^setpos_abs_top, 90, 20, ^setsize_abs, ^setsize_abs, $string, true, ^white, ^settextalign_centre, ^settextalign_centre, 0);
return($int1);
