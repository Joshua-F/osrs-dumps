// 7687
[proc,script7687](int $rgb)
def_int $int = if_getwidth(league_combat_mastery:summary_tab);
if_setsize(scale(40, 100, $int), 10, ^setsize_minus, ^setsize_minus, league_combat_mastery:mastery_summary);
if_setsize(calc(scale(60, 100, $int) + 5), 10, ^setsize_minus, ^setsize_minus, league_combat_mastery:passive_summary);
~script7689($rgb);
~script7690($rgb);
