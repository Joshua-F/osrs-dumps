[clientscript,raids_partydetails_init](int $int, component $list, component $scrollbar, component $preferred_size, component $preferred_comlevel, component $preferred_skilltotal, component $scaling_layer, component $challenge_layer, component $mappool_layer, component $sort_name, component $sort_comlevel, component $sort_skilltotal, component $sort_killtotal, component $join, component $advertise, component $disband, component $back, component $refresh)
~steelborder(raids_lobby_partydetails:frame, "Loading...", 0);
if_setscrollsize(0, 0, $list);
if_setscrollpos(0, 0, $list);
~scrollbar_vertical($scrollbar, $list, "scrollbar_dragger_v2,3", "scrollbar_dragger_v2,0", "scrollbar_dragger_v2,1", "scrollbar_dragger_v2,2", "scrollbar_v2,0", "scrollbar_v2,1");
if_sethide(true, $sort_name);
if_sethide(true, $sort_comlevel);
if_sethide(true, $sort_skilltotal);
if_sethide(true, $sort_killtotal);
cc_deleteall($list);
if_sethide(true, $list);
%raids_count = 0;
cc_deleteall(raids_lobby_partydetails:contents);
if_sethide(true, $join);
cc_deleteall($join);
cc_create(raids_lobby_partydetails:contents, ^iftype_rectangle, enum(component, int, enum_1539, $join));
cc_sethide(true);
if_sethide(true, $advertise);
cc_deleteall($advertise);
cc_create(raids_lobby_partydetails:contents, ^iftype_rectangle, enum(component, int, enum_1539, $advertise));
cc_sethide(true);
if_sethide(true, $disband);
