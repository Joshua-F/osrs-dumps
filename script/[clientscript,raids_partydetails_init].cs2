cc_sethide(true);
if_sethide(true, $back);
cc_deleteall($back);
cc_create(raids_lobby_partydetails:contents, ^iftype_rectangle, enum(component, int, enum_1539, $back));
cc_sethide(true);
if_sethide(true, $preferred_size);
cc_create(raids_lobby_partydetails:contents, ^iftype_rectangle, enum(component, int, enum_1539, $preferred_size));
cc_sethide(true);
if_sethide(true, $preferred_comlevel);
cc_create(raids_lobby_partydetails:contents, ^iftype_rectangle, enum(component, int, enum_1539, $preferred_comlevel));
cc_sethide(true);
if_sethide(true, $preferred_skilltotal);
