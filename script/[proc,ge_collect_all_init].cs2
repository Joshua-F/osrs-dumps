// 141
[proc,ge_collect_all_init](component $component, string $string0, string $string1)
def_int $int1 = if_getwidth($component);
def_int $int2 = if_getheight($component);
cc_deleteall($component);
cc_create($component, ^iftype_graphic, 0);
cc_setsize($int1, $int2, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
cc_settiling(false);
.cc_create($component, ^iftype_text, 1);
.cc_setsize($int1, $int2, ^setsize_abs, ^setsize_abs);
.cc_setposition(0, 0, ^setpos_abs_left, ^setpos_abs_top);
.cc_settextfont(p11_full);
.cc_settextshadow(true);
.cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
.cc_settext($string0);
if_setop(1, $string1, $component);
~ge_collect_all_draw($component);
if_setoninvtransmit("ge_collect_all_draw($component, cc_getid, .cc_getid){inv_518, inv_519, inv_520, inv_521, inv_522, inv_523}", $component);
