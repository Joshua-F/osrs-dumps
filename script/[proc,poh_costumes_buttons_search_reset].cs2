// 3565
[proc,poh_costumes_buttons_search_reset](enum $enum, component $component, graphic $graphic)
if_clearops($component);
if_setop(1, "Search", $component);
~poh_costumes_buttons_draw($component, $graphic, null, false);
if_setontimer(null, $component);
if_setonop("poh_costumes_buttons_searchop(event_op, $enum, $component, $graphic)", $component);
