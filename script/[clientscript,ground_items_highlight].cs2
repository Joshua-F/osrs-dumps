// 7233
[clientscript,ground_items_highlight](obj $obj)
if (~script7225(stringvector_4, $obj, false) = true) {
    ~script7224(stringvector_4, $obj, 1);
} else {
    if (~script7225(stringvector_3, $obj, false) = true) {
        ~script7224(stringvector_3, $obj, 0);
    }
    if (~script7225(stringvector_3, $obj, true) = true) {
        mes_typed(^chattype_spam, "<removetags(oc_name($obj))> is being highlighted via a wildcard entry.");
    }
    ~script7223(stringvector_4, $obj, 1);
}
