// 1134
[clientscript,script1134](component $component, int $int1, int $int2)
def_int $int3 = 0;
if (cc_find($component, $int1) = true) {
    $int3 = calc($int2 - clientclock);
    if ($int3 <= 0) {
        cc_settrans(0);
        cc_setontimer(null);
        return;
    }
    cc_settrans(interpolate(0, $int3, 0, 50, 255));
}
