// 4105
[proc,emote_op1_configure](int $int)
def_string $string = "Perform";
if (enum(int, boolean, enum_4999, $int) = true & enum(int, boolean, enum_4998, $int) = true) {
    $string = "Loop";
}
if ($int = 50) {
    cc_setop(1, "<$string> <col=ff9040><~emote_get_name($int)></col>");
} else {
    cc_setop(1, $string);
}
