// 7155
[clientscript,omnishop_main_view_toggle](dbrow $dbrow, inv $inv)
if (%omnishop_view_expanded = 1) {
    %omnishop_view_expanded = 0;
} else {
    %omnishop_view_expanded = 1;
}
%omnishop_selected_id = -1;
~omnishop_main_info_setup($dbrow, $inv, -1, 0, 0, 0, null, "", true);
~omnishop_main_setup($dbrow, $inv, true);
