// 9121
[proc,cc_set_button_text](string $string)
def_component $component = cc_getlayer;
def_int $int1 = cc_getid;
def_int $int2 = 0;
def_int $int3 = cc_query(1);
if ($int3 > 0) {
    $int3 = if_query_refine(param_2518, $int2);
    if ($int3 > 0) {
        while (if_query_next = true) {
            cc_settext($string);
        }
    }
}
cc_find($component, $int1);
