// 1356
[proc,questlist_qp](component $component)
def_string $string = ",";
if (~speedrunning_world = false) {
    if_settext("Quest Points: <~tostring_spacer(%varplayer_101, $string)>", $component);
} else {
    if_settext("Speedrun Points: <~tostring_spacer(~min(%varplayer_3365, 800000), $string)>", $component);
}
