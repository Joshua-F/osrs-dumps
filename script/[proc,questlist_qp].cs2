// 1356
[proc,questlist_qp](component $component)
def_string $string = ",";
if (~speedrunning_world = false) {
    if_settext("Quest Points: <~tostring_spacer(%qp, $string)>/<~tostring_spacer(%qp_max, $string)>", $component);
} else {
    if_settext("Speedrun Trophies: <~tostring_spacer(~speedrunning_total_trophies, $string)>", $component);
}
