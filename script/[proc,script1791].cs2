// 1791
[proc,script1791](component $component, int $int, string $string)
if (stringvector_contains(stringvector_1, $string, false, false) = false) {
    loottracker_ignoresourceadd($string);
    stringvector_addunique(stringvector_1, $string, false);
} else {
    loottracker_ignoresourcedel($string);
    stringvector_remove(stringvector_1, $string, false);
}
if (stringvector_size(stringvector_1) > 0) {
    %option_loottracker_ignorelist_sources_has_text = 1;
} else {
    %option_loottracker_ignorelist_sources_has_text = 0;
}
