// 3217
[clientscript,league_info_init](component $league_general_header, component $league_specific_header, component $league_general, component $league_specific, component $league_general_content, component $league_specific_content, component $league_general_scrollbar, component $league_specific_scrollbar, component $league_btn_menu, component $league_menu_frame, component $league_menu_overlay, component $close_button)
~leagues_close_button($close_button, false, 0);
def_string $string = "League Info";
def_int $int = ~steelborder(league_info:frame, $string, 1);
def_component $infinity = league_info:infinity;
if_setontimer("responsive_interface_scaler($infinity, -1)", $infinity);
if_setonresize("league_info_draw_interface($league_general_header, $league_specific_header, $league_general, $league_specific, $league_general_content, $league_specific_content, $league_general_scrollbar, $league_specific_scrollbar, $league_btn_menu, $league_menu_frame, $league_menu_overlay, 0, 0, $int)", $infinity);
