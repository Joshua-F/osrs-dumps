// 8809
[clientscript,script8809]
def_component $component0 = sailing_customisation:infinity;
def_component $component1 = sailing_customisation:frame;
if_setontimer("script6110($component0, -1)", $component0);
if_setonresize("script8810", $component0);
if_setonstattransmit("script8810{sailing, construction}", $component0);
if_setoninvtransmit("script8810{inv}", $component0);
if (%sailing_boat_customisation_last_type ! %sailing_boat_customisation_type | %sailing_boat_customisation_last_hotspot_id ! %sailing_boat_customisation_hotspot_id) {
    %sailing_boat_customisation_tab = 0;
    %sailing_boat_customisation_scroll_pos = 0;
    %sailing_boat_customisation_last_type = %sailing_boat_customisation_type;
    %sailing_boat_customisation_last_hotspot_id = %sailing_boat_customisation_hotspot_id;
}
~steelborder($component1, "Boat Customisation", 0);
~script8811;
