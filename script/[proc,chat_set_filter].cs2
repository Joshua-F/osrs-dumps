// 184
[proc,chat_set_filter](int $int, int $chatfilter)
switch_int ($int) {
    case 2 :
        chat_setfilter($chatfilter, chat_getfilter_private, chat_getfilter_trade);
    case 3 :
        chat_setfilter(chat_getfilter_public, $chatfilter, chat_getfilter_trade);
    case 4 :
        %varplayer_1054 = $chatfilter;
    case 5 :
        chat_setfilter(chat_getfilter_public, chat_getfilter_private, $chatfilter);
}
