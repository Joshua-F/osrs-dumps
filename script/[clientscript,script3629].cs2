// 3629
[clientscript,script3629](component $component)
cc_deleteall($component);
cc_create($component, ^iftype_text, 0);
cc_setsize(30, 30, ^setsize_abs, ^setsize_abs);
cc_setposition(0, 0, ^setpos_abs_centre, ^setpos_abs_centre);
cc_setcolour(0xff981f);
cc_settextfont(quill_oblique_large);
cc_settextshadow(true);
cc_settext(tostring(%follower_space_track));
cc_setonvartransmit("script3632($component){follower_food_track_3}");
