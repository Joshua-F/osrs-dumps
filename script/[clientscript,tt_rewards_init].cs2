// 8070
[clientscript,tt_rewards_init](component $text, component $icons, component $title, component $desc, component $buybutton_container)
if_setonvartransmit("tt_reward_selected($icons, $text, $desc, $title, $buybutton_container){templetrek_temp_var}", $title);
cc_deleteall($text);
cc_deleteall($icons);
if_sethide(true, $title);
if_sethide(true, $buybutton_container);
if_settext("Select a reward<br><br>on the left to<br><br>display information<br><br>here.", $desc);
def_int $int5 = 0;
def_int $int6 = calc(if_getwidth($text) / 3);
def_int $int7 = calc(($int6 - 36) / 2);
def_int $int8 = 20;
while ($int5 < 9) {
    cc_create($icons, ^iftype_graphic, $int5);
    cc_setsize(36, 32, ^setsize_abs, ^setsize_abs);
    cc_setposition(calc($int7 + ($int7 * 2 + 36) * ($int5 % 3)), $int8, ^setpos_abs_left, ^setpos_abs_top);
    cc_setobject_nonum(enum(int, obj, enum_1382, $int5), 0);
    cc_setop(1, "Details");
    cc_setonop("tt_reward_selected_onclick(event_comsubid, $icons, $text, $desc, $title, $buybutton_container)");
    cc_setonmouseover("tt_reward_highlight(event_comsubid, $icons, $text)");
    cc_setonmouseleave("tt_reward_highlight_off(event_comsubid, $icons, $text)");
    cc_create($text, ^iftype_text, $int5);
    cc_setsize(56, 62, ^setsize_abs, ^setsize_abs);
    cc_setposition(calc($int7 - 10 + (($int7 - 10) * 2 + 56) * ($int5 % 3)), $int8, ^setpos_abs_left, ^setpos_abs_top);
    cc_settext(enum(int, string, enum_1383, $int5));
    cc_settextalign(^settextalign_centre, ^settextalign_bottom, 0);
    cc_setcolour(0xff981f);
    cc_settextfont(p12_full);
    $int5 = calc($int5 + 1);
    if (calc($int5 % 3) = 0) {
        $int8 = calc($int8 + 80);
    }
}
