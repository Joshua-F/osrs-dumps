// 7149
[clientscript,omnishop_main_info_closebutton_key](int $key)
if (~keypress_permit(null, null) = false) {
    return;
}
def_enum $enum = ~toplevel_getcomponents;
if ($enum = null) {
    return;
}
def_component $component = enum(component, component, $enum, toplevel_osrs_stretch:mainmodal);
if ($component ! null & $key = ^key_escape & %keybinding_esc_to_close = 1 & if_hassub($component) = true) {
    ~omnishop_main_info_closebutton;
}
