// 8878
[proc,script8878](component $component, string $string, obj $obj, graphic $graphic, coord $coord)
if_setop(1, "Deposit", $component);
if_setopbase("<col=ff9040><$string></col>", $component);
~script8880(0, $component, $obj, $graphic, $coord);
if (~on_mobile = false) {
    if_setonmouseover("script8879(1, $component, $obj, $graphic, $coord)", $component);
}
if_setonmouseleave("script8879(0, $component, $obj, $graphic, $coord)", $component);
