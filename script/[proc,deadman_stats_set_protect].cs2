// 1145
[proc,deadman_stats_set_protect](component $component, int $int)
if (cc_find($component, 3) = true) {
    cc_sethide(true);
}
if (cc_find($component, 4) = true) {
    cc_sethide(true);
}
if (cc_find($component, 5) = true) {
    cc_sethide(true);
}
if (cc_find($component, 6) = true) {
    cc_settext(tostring(stat_base(enum(int, stat, enum_681, $int))));
}
if (cc_find($component, 7) = true) {
    cc_sethide(true);
}
if_setop(1, "Unprotect", $component);
