// 1442
[proc,2d_intarray_get](intarray $intarray, int $int0, int $int1)(int)
if (~2d_intarray_num_rows($intarray) <= 0 | ~2d_intarray_num_cols($intarray) <= 0) {
    ~debug_mes_error("2D Array", "Rows or columns metadata is empty, call <col=0059de>~2d_intarray_init</col> before using the array!");
    return(0);
}
return($intarray(calc(2 + (~2d_intarray_num_cols($intarray) * $int0 + $int1))));
