// 1959
[proc,storage_side_create](enum $enum, component $component, obj $obj, string $string)
if_setonmouserepeat("storage_side_recreate($enum, $component, $obj, $string, true)", $component);
if_setonmouseleave("storage_side_recreate($enum, $component, $obj, $string, false)", $component);
~storage_side_recreate($enum, $component, $obj, $string, false);
