// 6652
[proc,script6652](dbrow $dbrow)(loc, coord)
switch_dbtable (db_getrowtable($dbrow)) {
    case dbtable_8 :
        return(db_getfield($dbrow, dbtable_8:col8, 0), db_getfield($dbrow, dbtable_8:col9, 0));
    case dbtable_9 :
        return(db_getfield($dbrow, dbtable_9:col7, 0), db_getfield($dbrow, dbtable_9:col8, 0));
}
return(null, null);
