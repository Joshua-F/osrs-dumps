// 6652
[proc,script6652](dbrow $dbrow)(loc, coord)
switch_dbtable (db_getrowtable($dbrow)) {
    case cluehelper_clue_cryptic :
        return(db_getfield($dbrow, cluehelper_clue_cryptic:hidey_hole_loc, 0), db_getfield($dbrow, cluehelper_clue_cryptic:hidey_hole_coord, 0));
    case cluehelper_clue_emote :
        return(db_getfield($dbrow, cluehelper_clue_emote:hidey_hole_loc, 0), db_getfield($dbrow, cluehelper_clue_emote:hidey_hole_coord, ~script1291($dbrow)));
}
return(null, null);
