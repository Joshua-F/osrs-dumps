// 3499
[clientscript,death_office_opquantity](int $int, string $string, component $component)
if ($int ! 1) {
    return;
}
sound_synth(synth_2266, 1, 0);
~death_office_drawquantity($string, $component, false, true);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_setontimer("death_office_resetquantity(calc(clientclock + 20), $string, $component)", $component);
