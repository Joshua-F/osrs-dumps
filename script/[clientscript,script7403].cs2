// 7403
[clientscript,script7403](component $component, int $int1, boolean $boolean, int $int3, int $int4)
if ($boolean = true) {
    if (cc_find($component, $int1) = true) {
        cc_settrans($int3);
    }
    if_setontimer("script7404(calc(clientclock + 2), event_com, $int1, $int4)", $component);
} else {
    if (cc_find($component, $int1) = true) {
        cc_settrans($int4);
    }
    if_setontimer(null, $component);
}
