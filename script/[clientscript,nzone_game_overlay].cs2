// 255
[clientscript,nzone_game_overlay](coord $coord, string $string)
def_component $com_2 = interface_202:com_2;
def_component $com_1 = interface_202:com_1;
if_sethide(false, interface_202:com_0);
if_sethide(false, $com_2);
if_sethide(true, $com_1);
if_setonvartransmit(null, $com_1);
if_setposition(0, 0, interface_202:com_0);
if_setsize(1, 1, interface_202:com_0);
if_settext("", interface_202:com_0);
if_setontimer("nzone_game_hide($com_2, $coord)", interface_202:com_0);
if_setposition(0, 0, $com_2);
if_setsize(512, 334, $com_2);
cc_deleteall($com_2);
cc_create($com_2, ^iftype_rectangle, 0);
cc_setcolour(0x7f460f);
cc_setfill(true);
cc_settrans(100);
cc_create($com_2, ^iftype_rectangle, 1);
cc_setcolour(0x7f460f);
cc_setfill(false);
cc_create($com_2, ^iftype_graphic, 2);
cc_setgraphic(tradebacking_light);
cc_settiling(true);
cc_settrans(100);
cc_create($com_2, ^iftype_text, 3);
cc_settextfont(p11_full);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
~nzone_game_points_set($com_2, %varplayerbit_3949);
cc_create($com_2, ^iftype_rectangle, 4);
cc_setposition(5, 15);
cc_setsize(70, 60);
cc_setcolour(0x7f460f);
cc_setfill(true);
cc_settrans(200);
cc_create($com_2, ^iftype_rectangle, 5);
cc_setposition(5, 15);
cc_setsize(70, 60);
cc_setcolour(0x7f460f);
cc_setfill(false);
cc_create($com_2, ^iftype_graphic, 6);
cc_setposition(5, 15);
cc_setsize(70, 60);
cc_setgraphic(tradebacking_light);
cc_settiling(true);
cc_settrans(200);
cc_create($com_2, ^iftype_model, 7);
cc_setposition(15, 25);
cc_setsize(50, 50);
cc_create($com_2, ^iftype_text, 8);
cc_setposition(5, 18);
cc_setsize(70, 12);
cc_settextfont(p11_full);
cc_setcolour(0xff981f);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
cc_settext("Absorption");
cc_create($com_2, ^iftype_text, 9);
cc_setposition(5, 30);
cc_setsize(70, 40);
cc_settextfont(quill_oblique_large);
cc_settextshadow(true);
cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
~nzone_game_absorption_set($com_2, %varplayerbit_3956);
if (string_length($string) <= 0) {
    return;
}
cc_create($com_2, ^iftype_rectangle, 10);
cc_setsize(512, 30);
cc_setposition(0, 25);
cc_setcolour(0x7f7fff);
cc_setfill(true);
cc_settrans(255);
.cc_create($com_2, ^iftype_text, 11);
.cc_setsize(512, 30);
.cc_setposition(512, 25);
.cc_setcolour(^white);
.cc_settextshadow(true);
.cc_settextalign(^settextalign_centre, ^settextalign_centre, 0);
.cc_settextfont(quill_oblique_large);
.cc_settext($string);
cc_setontimer("nzone_game_subtitle(event_com, cc_getid, .cc_getid, clientclock)");
