// 7526
[clientscript,script7526](component $component, int $int)
def_string $string = "";
if ($int ! -1) {
    if (cc_find($component, $int) = true) {
        if (cc_input_getfocus = true) {
            return;
        }
        $string = removetags(cc_gettext);
    }
} else if (if_input_getfocus($component) = true) {
    return;
}
