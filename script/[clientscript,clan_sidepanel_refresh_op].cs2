// 4403
[clientscript,clan_sidepanel_refresh_op](int $int0, component $component, int $int2)
if ($int0 ! 1) {
    return;
}
if (cc_find($component, $int2) = true) {
    sound_synth(synth_2266, 1, 0);
    cc_settrans(175);
    if_setonmouserepeat(null, $component);
    if_setonmouseleave(null, $component);
    if_setontimer("clan_sidepanel_refresh_reset(calc(clientclock + 20), event_com, cc_getid)", $component);
}
