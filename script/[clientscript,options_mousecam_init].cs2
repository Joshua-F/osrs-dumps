// 50
[clientscript,options_mousecam_init](component $com_74, component $com_112)
if_setonmouseleave("deltooltip($com_112)", $com_74);
~options_mousecam($com_74, $com_112);
if_setonvartransmit("options_mousecam_resynch($com_74, $com_112){varplayer_1055}", $com_74);
if (~on_mobile = true) {
    if_setop(1, "Drag to Rotate Camera", $com_74);
}
if_setonop("options_mousecam_op(event_op, $com_74, $com_112)", $com_74);
