// 50
[clientscript,options_mousecam_init](component $com_80, component $com_118)
if_setonmouseleave("deltooltip($com_118)", $com_80);
~options_mousecam($com_80, $com_118);
if_setonvartransmit("options_mousecam_resynch($com_80, $com_118){varplayer_1055}", $com_80);
if (~on_mobile = true) {
    if_setop(1, "Drag to Rotate Camera", $com_80);
}
if_setonop("options_mousecam_op(event_op, $com_80, $com_118)", $com_80);
