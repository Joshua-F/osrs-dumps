// 50
[clientscript,options_mousecam_init](component $com_79, component $com_109)
if_setonmouseleave("deltooltip($com_109)", $com_79);
~options_mousecam($com_79, $com_109);
if_setonvartransmit("options_mousecam_resynch($com_79, $com_109){varplayer_1055}", $com_79);
if (~on_mobile = true) {
    if_setop(1, "Drag to Rotate Camera", $com_79);
}
if_setonop("options_mousecam_op(event_op, $com_79, $com_109)", $com_79);
