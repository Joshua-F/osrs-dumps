// 50
[clientscript,options_mousecam_init](component $com_73, component $com_111)
if_setonmouseleave("deltooltip($com_111)", $com_73);
~options_mousecam($com_73, $com_111);
if_setonvartransmit("options_mousecam_resynch($com_73, $com_111){varplayer_1055}", $com_73);
if (~on_mobile = true) {
    if_setop(1, "Drag to Rotate Camera", $com_73);
}
if_setonop("options_mousecam_op(event_op, $com_73, $com_111)", $com_73);
