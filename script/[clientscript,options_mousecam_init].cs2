// 50
[clientscript,options_mousecam_init](component $com_61, component $com_91)
if_setonmouseleave("deltooltip($com_91)", $com_61);
~options_mousecam($com_61, $com_91);
if_setonvartransmit("options_mousecam_resynch($com_61, $com_91){varplayer_1055}", $com_61);
if (~on_mobile = true) {
    if_setop(1, "Drag to Rotate Camera", $com_61);
}
if_setonop("options_mousecam_op(event_op, $com_61, $com_91)", $com_61);
