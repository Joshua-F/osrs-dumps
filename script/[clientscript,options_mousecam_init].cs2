// 50
[clientscript,options_mousecam_init](component $com_62, component $com_92)
if_setonmouseleave("deltooltip($com_92)", $com_62);
~options_mousecam($com_62, $com_92);
if_setonvartransmit("options_mousecam_resynch($com_62, $com_92){varplayer_1055}", $com_62);
if (~on_mobile = true) {
    if_setop(1, "Drag to Rotate Camera", $com_62);
}
if_setonop("options_mousecam_op(event_op, $com_62, $com_92)", $com_62);
