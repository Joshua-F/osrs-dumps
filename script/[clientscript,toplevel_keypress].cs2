// 905
[clientscript,toplevel_keypress](int $key, enum $enum, boolean $boolean)
if (if_gettop = interface_80 & %varplayerbit_1463 = 1) {
    ~spectator_keypress($key);
} else if (if_gettop = interface_165 & %varplayerbit_6331 = 1) {
    ~deadman_map_keypress($key);
} else {
    ~toplevel_keypress($key, $enum, $boolean);
}
