// 1131
[clientscript,script1131](int $int)
def_component $boat = ship_journey:boat;
def_component $title = ship_journey:title;
if_setmodel(model_3065, $boat);
def_string $string = "You Journey on the ship....";
if_setmodelorthog(false, $boat);
switch_int ($int) {
    case 1 :
        if_setmodelanim(sarim_entrana, $boat);
        $string = "You sail to Entrana.";
    case 2 :
        if_setmodelanim(entrana_sarim, $boat);
        $string = "You sail to Port Sarim.";
    case 3 :
        if_setmodelanim(sarim_crandor, $boat);
        $string = "You sail to Crandor.";
    case 4 :
        if_setmodelanim(sarim_karamja, $boat);
        $string = "You sail to Karamja.";
    case 5 :
        if_setmodelanim(karamja_sarim, $boat);
        $string = "You sail to Port Sarim.";
    case 6 :
        if_setmodelorthog(true, $boat);
        if_setmodelanim(cairn_khazzard, $boat);
        $string = "You sail to Port Khazard.";
    case 7 :
        if_setmodelanim(khazzard_trawler, $boat);
        $string = "You sail out to Sea.";
    case 8 :
        if_setmodelanim(trawler_khazzard, $boat);
        $string = "You sail back to Port Khazard.";
    case 9 :
        if_setmodelanim(cairn_sarim, $boat);
        $string = "You sail to Port Sarim.";
    case 10 :
        if_setmodelanim(sarim_voidknight, $boat);
        $string = "You sail to the Void Knight outpost.";
    case 11 :
        if_setmodelanim(voidknight_sarim, $boat);
        $string = "You sail to Port Sarim.";
    case 12 :
        if_setmodel(model_13370, $boat);
        if_setmodelanim(ogre_boat_feldip_to_tai, $boat);
        $string = "You're ogre propelled to the beach of Karamja!";
    case 13 :
        if_setmodel(model_13371, $boat);
        if_setmodelanim(ogre_boat_tai_to_feldip, $boat);
        $string = "You're ogre propelled to the Feldip Hills!";
}
if_settext($string, $title);
