// 1131
[clientscript,script1131](int $int)
def_component $com_6 = interface_299:com_6;
def_component $com_19 = interface_299:com_19;
if_setmodel(model_3065, $com_6);
def_string $string = "You Journey on the ship....";
if_setmodelorthog(false, $com_6);
switch_int ($int) {
    case 1 :
        if_setmodelanim(seq_632, $com_6);
        $string = "You sail to Entrana.";
    case 2 :
        if_setmodelanim(seq_633, $com_6);
        $string = "You sail to Port Sarim.";
    case 3 :
        if_setmodelanim(seq_630, $com_6);
        $string = "You sail to Crandor.";
    case 4 :
        if_setmodelanim(seq_634, $com_6);
        $string = "You sail to Karamja.";
    case 5 :
        if_setmodelanim(seq_635, $com_6);
        $string = "You sail to Port Sarim.";
    case 6 :
        if_setmodelorthog(true, $com_6);
        if_setmodelanim(seq_638, $com_6);
        $string = "You sail to Port Khazard.";
    case 7 :
        if_setmodelanim(seq_639, $com_6);
        $string = "You sail out to Sea.";
    case 8 :
        if_setmodelanim(seq_640, $com_6);
        $string = "You sail back to Port Khazard.";
    case 9 :
        if_setmodelanim(seq_641, $com_6);
        $string = "You sail to Port Sarim.";
    case 10 :
        if_setmodelanim(seq_3545, $com_6);
        $string = "You sail to the Void Knight outpost.";
    case 11 :
        if_setmodelanim(seq_3546, $com_6);
        $string = "You sail to Port Sarim.";
    case 12 :
        if_setmodel(model_13370, $com_6);
        if_setmodelanim(seq_3476, $com_6);
        $string = "You're ogre propelled to the beach of Karamja!";
    case 13 :
        if_setmodel(model_13371, $com_6);
        if_setmodelanim(seq_3477, $com_6);
        $string = "You're ogre propelled to the Feldip Hills!";
}
if_settext($string, $com_19);
