// 2556
[clientscript,membership_benefits_init](component $com_9, component $com_11, component $com_12, component $com_13, component $com_5, component $com_6)
cc_deleteall($com_9);
cc_deleteall($com_11);
def_int $int6 = 0;
def_int $int7 = 0;
def_string $string = "";
def_graphic $graphic = null;
while ($int7 < 5) {
    switch_int ($int7) {
        case 0 :
            $graphic = "oge_title,0";
            $string = "Explore a world three times larger!";
        case 1 :
            $graphic = "oge_title,1";
            $string = "Master eight extra skills!";
        case 2 :
            $graphic = "oge_title,2";
            $string = "Take on a hundred more quests!";
        case 3 :
            $graphic = "oge_title,3";
            $string = "Defeat twenty additional bosses!";
        case 4 :
            $graphic = "oge_title,4";
            $string = "And much more...";
    }
    cc_create($com_9, ^iftype_graphic, $int7);
    cc_setsize(0, 33, ^setsize_minus, ^setsize_abs);
    cc_setposition(0, $int6, ^setpos_abs_centre, ^setpos_abs_top);
    cc_setgraphic(tradebacking_light);
    cc_settiling(true);
    cc_setop(1, "View");
    cc_setopbase("<col=ff9040>Benefits</col>");
    cc_setonop("membership_benefits_view($int7)");
    cc_setonmouserepeat("membership_benefits_hover(event_comsubid, $int6, true)");
    cc_setonmouseleave("membership_benefits_hover(event_comsubid, $int6, false)");
    cc_create($com_11, ^iftype_text, $int7);
    cc_setsize(0, 33, ^setsize_minus, ^setsize_abs);
    cc_setposition(62, $int6, ^setpos_abs_centre, ^setpos_abs_top);
    cc_settext($string);
    cc_settextalign(^settextalign_left, ^settextalign_centre, 0);
    cc_settextfont(b12_full);
    cc_setcolour(0xff981f);
    cc_settextshadow(true);
    cc_create($com_12, ^iftype_graphic, $int7);
    cc_setsize(42, 33, ^setsize_abs, ^setsize_abs);
    cc_setposition(10, $int6, ^setpos_abs_left, ^setpos_abs_top);
    cc_setgraphic($graphic);
    cc_create($com_13, ^iftype_graphic, $int7);
    cc_setsize(24, 23, ^setsize_abs, ^setsize_abs);
    cc_setposition(5, calc($int6 + 5), ^setpos_abs_right, ^setpos_abs_top);
    cc_setgraphic("open_buttons,0");
    $int6 = calc($int6 + 33 + 10);
    $int7 = calc($int7 + 1);
}
~membership_benefits_button_init($com_5, "Open Store");
if (~on_mobile = true & clienttype = ^clienttype_ios) {
    ~membership_benefits_hide_bonds($com_5, $com_6);
} else {
    ~membership_benefits_button_init($com_6, "Bond Pouch");
}
