// 6167
[clientscript,pvpa_legacyduel_options_opconfirm](int $int, component $component)
if ($int ! 1) {
    return;
}
sound_synth(synth_2266, 1, 0);
~clan_stonebutton_draw(true, "<col=9f9f9f>---</col>", p12_full, $component);
if_clearops($component);
if_setonmouserepeat(null, $component);
if_setonmouseleave(null, $component);
if_setonop(null, $component);
if_setontimer("pvpa_legacyduel_options_resetconfirm(calc(clientclock + 40), event_com)", $component);
