// 9061
[proc,script9061](dbtable $dbtable, dbrow $dbrow, int $int)(dbrow)
if ($dbtable = null) {
    $dbtable = db_getrowtable($dbrow);
}
switch_dbtable ($dbtable) {
    case sailing_boat_facility :
        return(db_getfield($dbrow, sailing_boat_facility:quest_requirement, $int));
    case sailing_boat_keel :
        return(db_getfield($dbrow, sailing_boat_keel:quest_requirement, $int));
    case sailing_boat_hull :
        return(db_getfield($dbrow, sailing_boat_hull:quest_requirement, $int));
    case sailing_boat_sail :
        return(db_getfield($dbrow, sailing_boat_sail:quest_requirement, $int));
    case sailing_boat_steering :
        return(db_getfield($dbrow, sailing_boat_steering:quest_requirement, $int));
    case sailing_boat_flag :
        return(db_getfield($dbrow, sailing_boat_flag:quest_requirement, $int));
    case sailing_boat_brazier :
        return(db_getfield($dbrow, sailing_boat_brazier:quest_requirement, $int));
    case sailing_boat_trim :
        return(db_getfield($dbrow, sailing_boat_trim:quest_requirement, $int));
    case default :
        return(null);
}
