// 9161
[proc,skill_guide_v2_overview_herblore](component $component)
~script9182($component, "", "Herblore is a skill about brewing potions that provide skill boosts and other powerful effects. Use the tabs on the left to see what level is required to brew a certain potion and what ingredients it requires.<"||::p||">||::hl||<"To brew a potion"><"||::/hl||">, you first need to clean a grimy herb of the desired type then combine it with a vial of water to make an unfinished potion. You can then add the secondary ingredient(s) to complete the potion.<"||::p||">Basic supplies, including vials, can be purchased from ||::<118>::Herbalists|| around Gielinor, such as Jatix in Taverley.");
~script9182($component, "Getting Started", "To get started, first complete the <~script9191(quest_druidicritual)> to unlock the ability to brew potions. Then collect herbs and secondary ingredients for the potion you want to make by growing them with the ||skill:<21>::<21>::Farming skill||, purchasing them or defeating enemies that drop them. For example, an Attack Potion requires a Guam Leaf, which can be grown with the Farming skill or obtained by defeating Men and Women, and an Eye of Newt, which can be purchased from ||::<118>::Jatix|| in Taverley.");
def_stringarray $stringarray = array_create(string, 2, -1);
$stringarray(0) = "||::hl||<"All"><"||::/hl||">: Created potions can be used to aid many other skills and activities.";
$stringarray(1) = "||skill:<21>::<21>::Farming:::|| Many key potion ingredients can be grown with the Farming skill.";
~script9182($component, "Skill Interactions", "");
~script9184($component, $stringarray, 2);
