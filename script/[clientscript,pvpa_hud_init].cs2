// 6248
[clientscript,pvpa_hud_init](component $universe, component $timer_dodger, component $timer, component $info_dodger, component $info)
~interface_dodger_init($timer_dodger, $timer, 65256, ^setpos_abs_centre, ^setpos_abs_top, true);
~interface_dodger_init($info_dodger, $info, setbit(65256, 2), ^setpos_abs_right, ^setpos_abs_top, true);
~pvpa_hud_drawtimer($timer);
if_setonvartransmit("pvpa_hud_drawtimer(event_com){pvpa_temp_transmit_0}", $timer);
~pvpa_hud_drawinfo($info);
if_setonsubchange("pvpa_hud_drawinfo(event_com)", $info);
if_setonvartransmit("pvpa_hud_drawinfo(event_com){pvpa_temp_transmit_0}", $info);
