// 2476
[proc,on_enhanced_mobile]()(boolean)
def_int $clienttype = clienttype;
if (%osm_simulate = 1 & ($clienttype = ^clienttype_enhanced_windows | $clienttype = ^clienttype_enhanced_mac | $clienttype = ^clienttype_enhanced_linux)) {
    return(true);
}
if ($clienttype = ^clienttype_enhanced_android | $clienttype = ^clienttype_enhanced_ios) {
    return(true);
}
return(false);
