// 971
[clientscript,ntk_init](component $universe, component $dodger, component $content, component $timer, component $bar)
~ntk_layout($content, $dodger);
if_setonsubchange("ntk_layout($content, $dodger)", $content);
if_setonvartransmit("ntk_layout($content, $dodger){chat_filter_assist, xpdrops_options}", $content);
~ntk_timer_resynch($timer, $bar);
if_setonvartransmit("ntk_timer_resynch($timer, $bar){ntk_var2}", $timer);
