// 5473
[proc,add_overlaytimer_loc](loc $loc, int $int1, int $int2, int $int3, int $rgb, int $int5)
if (~on_enhanced_any = false | ~script5476($int1, $int3) = false) {
    return;
}
def_int $overlaytype = ^overlaytype_middle;
if (lc_param($loc, param_1545) = true) {
    $overlaytype = ^overlaytype_bottom;
}
def_entityoverlay $entityoverlay = entityoverlay_create_loc(1, $overlaytype, 25, 25, 0);
~add_overlaytimer_inner($int1, $entityoverlay, $int2, $int3, $rgb, $int5);
