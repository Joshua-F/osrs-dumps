// 788
[clientscript,ge_collect_init](component $com_0, component $com_3, component $com_4, component $com_13)
def_int $int = 0;
def_component $component = enum(int, component, enum_1011, $int);
while ($component ! null) {
    ~ge_collect_initslot($component, $int, $com_13);
    $int = calc($int + 1);
    $component = enum(int, component, enum_1011, $int);
}
~ge_collect_all_init($com_3, "Inventory", "Collect to inventory");
~ge_collect_all_init($com_4, "Bank", "Collect to bank");
