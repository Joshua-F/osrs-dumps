// 542:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre

// 542:1
[com_1]
type=rectangle
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe
colour=0x7878a0
fill=yes
trans=150

// 542:2
[dodger]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe

// 542:3
[content]
type=text
width=85
height=20
xmode=abs_right
ymode=abs_bottom
layer=dodger
textfont=b12_full
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xffff00
onload=macro_pinball_score_init(pinball_overlay:dodger, pinball_overlay:content)

