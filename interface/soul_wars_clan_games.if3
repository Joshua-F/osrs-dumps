// 492:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=soul_wars_clan_games_init(soul_wars_clan_games:confirm)

// 492:1
[content]
type=layer
width=350
height=186
xmode=abs_centre
ymode=abs_centre
layer=universe

// 492:2
[frame]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=content
onload=steelborder(event_com, "")

// 492:3
[title]
type=text
y=6
width=12
height=24
widthmode=minus
xmode=abs_centre
layer=content
textfont=b12_full
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 492:4
[display]
type=layer
x=10
y=40
width=22
height=94
widthmode=minus
heightmode=minus
layer=content

// 492:5
[display_text]
type=text
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=display
textfont=p12_full
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 492:6
[confirm]
type=layer
y=12
width=120
height=34
xmode=abs_centre
ymode=abs_bottom
layer=content
