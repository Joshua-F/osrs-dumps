// 513:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=raids_overlay_init(event_com, raids_overlay:dodger, raids_overlay:data)

// 513:1
[fader]
type=rectangle
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe
hide=yes
colour=0x000000
fill=yes

// 513:2
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 513:3
[data]
type=layer
x=2
y=2
width=200
height=50
layer=dodger

