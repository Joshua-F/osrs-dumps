// 400:0
[universe]
type=layer
width=512
height=334

// 400:1
[contents]
type=layer
width=484
height=304
xmode=abs_centre
ymode=abs_centre
layer=universe

// 400:2
[frame]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=contents
onload=steelborder(event_com, "")

// 400:3
[title]
type=text
y=4
height=28
widthmode=minus
layer=contents
textfont=b12_full
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 400:4
[main]
type=layer
y=6
width=12
height=41
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=contents

// 400:5
[left]
type=layer
width=236
height=263
layer=main

// 400:6
[model_layer]
type=layer
x=6
width=9
height=12
widthmode=minus
heightmode=minus
ymode=abs_centre
layer=left
onload=thinbox(event_com)

// 400:7
[model_back]
type=graphic
width=4
height=4
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=model_layer
graphic=tradebacking_light
tiling=yes

// 400:8
[model]
type=model
width=32
height=32
xmode=abs_centre
ymode=abs_centre
layer=model_layer
model=null
modeloriginy=400
modelangley=1938
modelzoom=900

// 400:9
[right]
type=layer
width=236
height=263
xmode=abs_right
layer=main

// 400:10
[text_layer]
type=layer
x=6
width=9
height=12
widthmode=minus
heightmode=minus
xmode=abs_right
ymode=abs_centre
layer=right
