// 180:0
[global]
type=layer
width=24
height=20
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre

// 180:1
[frame]
type=layer
widthmode=minus
heightmode=minus
layer=global
onload=steelborder(event_com, "Impling Tracker")

// 180:2
[contents]
type=layer
y=35
width=10
height=35
widthmode=minus
heightmode=minus
xmode=abs_centre
layer=global

// 180:3
[surface_scrollbar]
type=layer
x=10
y=25
width=16
height=30
heightmode=minus
xmode=abs_right
layer=contents

// 180:4
[surface_grid]
type=layer
x=10
y=25
width=36
height=30
widthmode=minus
heightmode=minus
layer=contents

// 180:5
[surface_models]
type=layer
widthmode=minus
heightmode=minus
layer=surface_grid

// 180:6
[surface_text]
type=layer
widthmode=minus
heightmode=minus
layer=surface_grid

// 180:7
[puro_scrollbar]
type=layer
x=10
y=25
width=16
height=30
heightmode=minus
xmode=abs_right
layer=contents

// 180:8
[puro_grid]
type=layer
x=10
y=25
width=36
height=30
widthmode=minus
heightmode=minus
layer=contents
