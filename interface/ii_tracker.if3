// 180:9
[puro_models]
type=layer
widthmode=minus
heightmode=minus
layer=puro_grid

// 180:10
[puro_text]
type=layer
widthmode=minus
heightmode=minus
layer=puro_grid

// 180:11
[tabs]
type=layer
height=20
widthmode=minus
xmode=abs_centre
layer=contents

// 180:12
[com_12]
type=rectangle
width=303
height=1
widthmode=minus
xmode=abs_right
ymode=abs_bottom
layer=tabs
colour=0x32320a

// 180:13
[tab_1]
type=layer
x=3
width=150
heightmode=minus
layer=tabs
events=2
op1=Select
onop=ii_tracker_tab_select(event_com, ii_tracker:tab_1, ii_tracker:l_tab_1, ii_tracker:m_tab_1, ii_tracker:r_tab_1, ii_tracker:tab_2, ii_tracker:l_tab_2, ii_tracker:m_tab_2, ii_tracker:r_tab_2, ii_tracker:surface_grid, ii_tracker:surface_scrollbar, ii_tracker:puro_grid, ii_tracker:puro_scrollbar)

// 180:14
[l_tab_1]
type=graphic
width=20
height=20
layer=tab_1
graphic="tabs_split,0"

// 180:15
[m_tab_1]
type=graphic
width=40
height=20
widthmode=minus
xmode=abs_centre
layer=tab_1
graphic="tabs_split,1"
tiling=yes

// 180:16
[r_tab_1]
type=graphic
width=20
height=20
xmode=abs_right
layer=tab_1
graphic="tabs_split,2"

// 180:17
[text_tab_1]
type=text
widthmode=minus
heightmode=minus
layer=tab_1
textfont=b12_full
text=Surface World
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff9820

