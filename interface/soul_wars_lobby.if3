// 434:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=soul_wars_lobby_hud_init(soul_wars_lobby:dodger, soul_wars_lobby:content)

// 434:1
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 434:2
[content]
type=layer
x=2
y=2
width=129
height=82
layer=dodger
onload=stonepanel(event_com, -1)

// 434:3
[content_background]
type=graphic
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=content
graphic=tradebacking
tiling=yes
trans=80

// 434:4
[players]
type=layer
y=7
width=4
height=33
widthmode=minus
xmode=abs_centre
layer=content

// 434:5
[players_title]
type=text
height=16
widthmode=minus
xmode=abs_centre
layer=players
textfont=p12_full
text=Players Waiting
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xffa53d

// 434:6
[players_text]
type=text
height=16
widthmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=players
textfont=p12_full
text=0
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xffa53d

// 434:7
[time]
type=layer
y=6
width=4
height=33
widthmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=content

// 434:8
[time_title]
type=text
height=16
widthmode=minus
xmode=abs_centre
layer=time
textfont=p12_full
text=Next Game Start
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xffa53d

// 434:9
[time_text]
type=text
height=16
widthmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=time
textfont=p12_full
text=-
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xffa53d

