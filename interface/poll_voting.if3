// 400:0
[infinite]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=script1487(event_com, poll_voting:universe, poll_voting:questions, poll_voting:scrollbar)

// 400:1
[universe]
type=layer
width=500
height=10
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=infinite

// 400:2
[answers]
type=layer
width=1
height=1
layer=universe
onload=script622(event_com)

// 400:3
[frame]
type=layer
widthmode=minus
heightmode=minus
layer=universe
onload=steelborder(event_com, "")

// 400:4
[status]
