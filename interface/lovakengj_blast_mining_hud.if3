// 598:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=blast_mining_hud_init(lovakengj_blast_mining_hud:dodger, lovakengj_blast_mining_hud:data, lovakengj_blast_mining_hud:coal, lovakengj_blast_mining_hud:gold, lovakengj_blast_mining_hud:mithril, lovakengj_blast_mining_hud:addy, lovakengj_blast_mining_hud:rune, lovakengj_blast_mining_hud:text_coal, lovakengj_blast_mining_hud:text_gold, lovakengj_blast_mining_hud:text_mithril, lovakengj_blast_mining_hud:text_addy, lovakengj_blast_mining_hud:text_rune)

