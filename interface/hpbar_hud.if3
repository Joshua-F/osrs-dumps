// 303:4
[hpdodger]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe

// 303:5
[hp]
type=layer
y=2
width=300
height=42
xmode=abs_centre
layer=hpdodger
hide=yes

// 303:6
[outer_border]
type=rectangle
y=1
width=2
height=2
widthmode=minus
heightmode=minus
xmode=abs_centre
layer=hp
colour=0x191511
trans=255

// 303:7
[name_backing]
