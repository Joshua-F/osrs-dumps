// 303:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=hp_hud_init(hpbar_hud:universe, hpbar_hud:hpdodgerside, hpbar_hud:hpdodger, hpbar_hud:hp, hpbar_hud:name_area, hpbar_hud:hp_bar, hpbar_hud:hp_bar_text, hpbar_hud:health_bar_back, hpbar_hud:health_bar_sliding, hpbar_hud:health_bar_remaining, hpbar_hud:creature_name, 19857414, 19857415, 19857419, hpbar_hud:health_bar_lower_threshold, hpbar_hud:health_bar_upper_threshold, hpbar_hud:hp_bar_1, hpbar_hud:hp_bar_2, hpbar_hud:hpcontentside)

// 303:1
[container]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe

// 303:2
[hpdodgerside]
type=layer
widthmode=minus
heightmode=minus
