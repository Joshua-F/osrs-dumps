y=100
width=29
height=32
widthmode=minus
xmode=abs_centre
layer=confirm_layer
textfont=q8_full
text=Are you SURE you want to destroy the contents of this inventory?
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff0000

// 234:6
[confirm_body]
