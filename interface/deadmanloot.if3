y=132
width=80
height=65
widthmode=minus
xmode=abs_centre
layer=confirm_layer
textfont=p11_full
text=All items will be destroyed.<br>This action cannot be undone.
textlineheight=12
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 234:7
[confirm_buttons]
