// 555:0
[universal]
type=layer
width=480
height=300
xmode=abs_centre
ymode=abs_centre

// 555:1
[template]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universal
onload=stoneborder(event_com, "Gemstone switch panel", 0)

// 555:2
[gems]
