// 100:0
[universe]
type=layer
width=480
height=320
xmode=abs_centre
ymode=abs_centre
onload=tournament_supplies_init(event_com, tournament_supplies:switchlayer, tournament_supplies:item_container, tournament_supplies:list, tournament_supplies:scrollbar, tournament_supplies:search, tournament_supplies:loadout_container, tournament_supplies:inv)

// 100:1
[frame]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe
onload=steelborder(event_com, "Tournament Supplies")

// 100:2
[switchlayer]
