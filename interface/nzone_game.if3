// 202:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=nzone_game_init(nzone_game:dodger_left, nzone_game:content_left, nzone_game:dodger_mid, nzone_game:content_mid, nzone_game:dodger_right, nzone_game:content_right)

// 202:1
[dodger_left]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 202:2
[content_left]
type=layer
widthmode=minus
heightmode=minus
layer=dodger_left

// 202:3
[content_mid]
type=layer
widthmode=minus
heightmode=minus
layer=dodger_mid

// 202:4
[dodger_right]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 202:5
[dodger_mid]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 202:6
[content_right]
type=layer
widthmode=minus
heightmode=minus
layer=dodger_right

// 202:7
[control]
type=text
width=1
height=1
xmode=abs_centre
textfont=p11_full
textalignh=centre
textalignv=top
textshadow=yes
colour=0xcccccc

