// 429:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=friend_init(event_com, friends:ignore, friends:header, friends:list_container, friends:sort_name, friends:sort_recent, friends:sort_world, friends:sort_legacy, friends:list, friends:scrollbar, friends:loading, friends:tooltip)

// 429:1
[ignore]
type=layer
width=21
height=21
xmode=abs_right
layer=universe
events=2
op1=View Ignore List
onmouseover=settrans(friends:ignore_icon, 100)
onmouseleave=settrans(friends:ignore_icon, 0)

// 429:2
[ignore_icon]
type=graphic
x=2
y=1
width=17
height=18
xmode=abs_right
layer=ignore
graphic="options_icons_small,5"

// 429:3
[header]
type=text
y=1
width=20
height=20
widthmode=minus
layer=universe
textfont=b12_full
text=Friends List
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 429:4
[border]
type=layer
y=20
width=4
height=56
widthmode=minus
heightmode=minus
xmode=abs_centre
layer=universe
onload=steelbox(event_com)

