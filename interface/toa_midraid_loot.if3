// 777:0
[universe]
type=layer
widthmode=minus
heightmode=minus
onload=toa_midraidloot_init(toa_midraid_loot:bundle_1, toa_midraid_loot:bundle_2, toa_midraid_loot:bundle_3, toa_midraid_loot:select_button_1, toa_midraid_loot:select_button_2, toa_midraid_loot:select_button_3)

// 777:1
[contents]
type=layer
width=490
height=250
xmode=abs_centre
ymode=abs_centre
layer=universe

// 777:2
[frame]
type=layer
widthmode=minus
heightmode=minus
ymode=abs_centre
layer=contents
onload=steelborder(event_com, "Supply Bundles")

// 777:3
[content]
type=layer
height=35
widthmode=minus
heightmode=minus
ymode=abs_bottom
layer=contents

// 777:4
[bundle_1]
type=layer
x=10
y=4
width=154
height=201
layer=content

// 777:5
[bundle_1_title]
type=text
width=94
height=32
xmode=abs_centre
layer=bundle_1
textfont=b12_full
text=Life
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 777:6
[select_button_1]
type=layer
y=7
width=130
height=28
xmode=abs_centre
ymode=abs_bottom
layer=bundle_1
events=2
op1=Choose

// 777:7
[bundle_2]
type=layer
y=4
width=154
height=201
xmode=abs_centre
layer=content

// 777:8
[bundle_2_title]
type=text
width=94
height=32
xmode=abs_centre
layer=bundle_2
textfont=b12_full
text=Chaos
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 777:9
[select_button_2]
type=layer
y=7
width=130
height=28
xmode=abs_centre
ymode=abs_bottom
layer=bundle_2
events=2
op1=Choose

// 777:10
[bundle_3]
