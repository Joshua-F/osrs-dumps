// 636:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=sote_upass_battle_init(sote_upass_battle:dodger, sote_upass_battle:content)

// 636:1
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 636:2
[content]
type=layer
width=160
height=55
layer=dodger

// 636:3
[health]
type=layer
y=2
width=4
height=26
widthmode=minus
xmode=abs_centre
layer=content

// 636:4
[health_background]
type=rectangle
x=3
y=3
width=150
height=20
xmode=abs_right
layer=health
colour=0xff0000
fill=yes

// 636:5
[health_foreground]
type=rectangle
x=3
y=3
width=150
height=20
layer=health
colour=0x00ff00
fill=yes

// 636:6
[health_border]
type=rectangle
x=2
y=2
width=152
height=22
layer=health
colour=0x000000

// 636:7
[health_text]
type=text
x=3
y=3
width=150
height=20
layer=health
textfont=b12_full
text=Barrier Strength
textalignh=centre
textalignv=centre
colour=0x000000

// 636:8
[timer]
type=layer
y=2
width=4
height=24
widthmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=content

// 636:9
[timer_text]
type=text
x=29
y=2
width=125
height=20
layer=timer
textfont=b12_full
text=Time Left: 4:00
