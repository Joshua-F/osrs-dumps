// 780:0
[infinity]
type=layer
width=512
height=334

// 780:1
[universe]
type=layer
width=480
height=314
xmode=abs_centre
ymode=abs_centre
layer=infinity
onload=speedrunning_rewards_init(event_com, speedrunning_rewards:rewards_text, speedrunning_rewards:rewards_select_frame, speedrunning_rewards:rewards_select, speedrunning_rewards:rewards_graphics, speedrunning_rewards:rewards_holder, speedrunning_rewards:rewards_button, speedrunning_rewards:rewards_btngfx, speedrunning_rewards:confirm, speedrunning_rewards:confirm_frame, speedrunning_rewards:confirm_text, speedrunning_rewards:confirm_button, speedrunning_rewards:confirm_cancel, speedrunning_rewards:rewards_scrollbar)

// 780:2
[frame]
type=layer
width=480
height=314
layer=universe
onload=steelborder(event_com, "Speedrunning Reward Shop")

// 780:3
[content]
type=layer
width=480
height=314
layer=universe

// 780:4
[rewards_frame]
type=layer
y=5
width=10
height=40
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=content

// 780:5
[confirm]
type=layer
width=480
height=314
layer=content
hide=yes
noclickthrough=yes

// 780:6
[rewards_select_frame]
type=layer
y=10
width=20
height=55
widthmode=minus
heightmode=minus
xmode=abs_centre
layer=rewards_frame
onload=thinbox(event_com)

// 780:7
[rewards_backing_1]
type=graphic
x=1
y=1
width=2
height=2
widthmode=minus
heightmode=minus
layer=rewards_select_frame
graphic=tradebacking_dark
tiling=yes

// 780:8
[rewards_holder]
