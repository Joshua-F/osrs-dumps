// 171:0
[universe]
type=layer
widthmode=minus
heightmode=minus
onload=flamtaer_init(flamtaer_status:dodger, flamtaer_status:temple_layer)

// 171:1
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 171:2
[temple_layer]
type=layer
x=4
y=4
width=139
height=62
xmode=abs_right
layer=dodger
onload=flamtaer_status(flamtaer_status:repair, flamtaer_status:resources, flamtaer_status:sanctity)
onvartransmit=flamtaer_status(flamtaer_status:repair, flamtaer_status:resources, flamtaer_status:sanctity){temple_repaired_p, temple_resources_p, temple_sanctity_p}

// 171:3
[com_3]
type=text
height=16
widthmode=minus
layer=temple_layer
textfont=p12_full
text=* Temple Repair *
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xffff00

