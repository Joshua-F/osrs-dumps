// 820:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=worldswitcher_filter_init(event_com, worldswitcher_filter:clamp, worldswitcher_filter:fader, worldswitcher_filter:window, worldswitcher_filter:frame, worldswitcher_filter:options, worldswitcher_filter:scrollbar, worldswitcher_filter:clear, worldswitcher_filter:close)

// 820:1
[clamp]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe

// 820:2
[fader]
type=rectangle
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=clamp
colour=0x000000
fill=yes
trans=255

// 820:3
[window]
type=layer
width=200
height=200
xmode=abs_centre
ymode=abs_centre
layer=clamp

// 820:4
[frame]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=window

// 820:5
[container]
type=layer
y=40
width=20
height=80
widthmode=minus
heightmode=minus
xmode=abs_centre
layer=window
onload=thinbox(event_com)

// 820:6
[com_6]
type=graphic
width=2
height=2
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=container
graphic=tradebacking_light
tiling=yes
trans=120

// 820:7
[options]
type=layer
x=3
width=22
height=4
widthmode=minus
heightmode=minus
ymode=abs_centre
layer=container

// 820:8
[scrollbar]
type=layer
x=2
width=16
height=4
heightmode=minus
xmode=abs_right
ymode=abs_centre
layer=container

// 820:9
[clear]
type=layer
x=-45
y=10
width=80
height=26
xmode=abs_centre
ymode=abs_bottom
layer=window
events=2
op1=*

// 820:10
[close]
type=layer
x=45
y=10
width=80
height=26
xmode=abs_centre
ymode=abs_bottom
layer=window

