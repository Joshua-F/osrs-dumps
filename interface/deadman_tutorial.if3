// 419:30
[tut_1_text_4]
type=text
x=20
y=75
width=40
height=175
widthmode=minus
layer=tut_4_layer
textfont=verdana_13pt_regular
text=To help you get started, you'll receive <col=ffffff>60 minutes of immunity</col> before anyone can attack you. Speak to the <col=ffffff>Doomsayer</col> in Lumbridge to waive your immunity and get on with the killing!<br><br>Once you reach <col=ffffff>combat levels 61, 81 and 96</col>, you will need to move to a higher level bracket world. Each time you move up a bracket, you'll be granted a further <col=ffffff>60 minutes of PvP immunity</col>. <br><br>You'll receive a <col=ffffff>Deadman Starter Pack</col> which holds some handy items for you.
textlineheight=14
textalignh=left
textalignv=top
textshadow=yes
colour=0xff981f

