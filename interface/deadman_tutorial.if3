// 419:24
[tut_1_text_3]
type=text
x=20
y=75
width=40
height=175
widthmode=minus
layer=tut_3_layer
textfont=verdana_13pt_regular
text=The Deadman's skull can be used to <col=ffffff>purchase sigils</col> and unlocks with <col=ffffff>Skull Points</col> you earn. For every <col=ffffff>Deadman Point</col> you earn, you'll also receive a <col=ffffff>Skull Point</col>.<br><br><col=ffffff>Sigils</col> are powerful enhancements similar to League Relics. They provide XP boosts, combat boosts and other benefits. Some sigils are <col=ffffff>unlocked permanently</col>, while others must be <col=ffffff>attuned</col> to take effect. You can have up to <col=ffffff>three PvP combat sigils attuned</col> at the same time.<br><br>You can view the state of all sigils through the <col=ffffff>unlocks view</col> on the <col=ffffff>Deadman's Skull</col>. You <col=ffffff>can also toggle</col> those that allow it through the <col=ffffff>toggle section</col> of the <col=ffffff>unlocks view</col>.
textlineheight=14
textalignh=left
textalignv=top
textshadow=yes
colour=0xff981f

