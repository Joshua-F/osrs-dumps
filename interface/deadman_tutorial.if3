// 419:17
[tut_1_text_2]
type=text
x=20
y=75
width=40
height=175
widthmode=minus
layer=tut_2_layer
textfont=verdana_13pt_regular
text=<col=ffffff>Experience</col> gained in Deadman is significantly boosted. <col=ffffff>Drop rates</col> of unique items are also <col=ffffff>significantly buffed</col>. Some <col=ffffff>quests are completed automatically</col> upon logging in.<br><br>In <col=ffffff>guarded areas</col>, other players <col=ffffff>can't attack you</col>. Guarded areas are indicated by a red circle over the skull icon.<br><br><col=ffffff>Logging out</col> outside of a guarded area will take <col=ffffff>7 seconds</col>. <col=ffffff>Teleporting</col> when skulled will also take <col=ffffff>7 seconds</col>. You receive a <col=ffffff>1 minute grace period </col>when killing another player in a single combat zone. This is lost when logging out or teleporting.
textlineheight=14
textalignh=left
textalignv=top
textshadow=yes
colour=0xff981f

