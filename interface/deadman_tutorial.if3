widthmode=minus
layer=tut_5_layer
textfont=verdana_13pt_regular
text=Beware, at 02:00, 10:00 and 19:00 UTC, a <col=ffffff>Breach</col> will occur, where deadly monsters spawn. You can earn <col=ffffff>unique loot and Deadman Points</col> by fighting these monsters. You can check the next breach time through the <col=ffffff>Breach Check option</col> on the <col=ffffff>Deadman's Skull</col>.<br><br>Speak to <col=ffffff>Nigel</col> in the Lumbridge Graveyard if you seek further information.
textlineheight=14
textalignh=left
textalignv=top
