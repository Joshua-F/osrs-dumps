// 419:12
[tut_1_text_1]
type=text
x=20
y=75
width=40
height=175
widthmode=minus
layer=tut_1_layer
textfont=verdana_13pt_regular
text=Deadman is a <col=ffffff>time-limited game mode</col>. Everyone starts with a <col=ffffff>fresh save</col> which can only be used on a Deadman: Annihilation world. Beware of other players, for the <col=ffffff>majority of Gielinor is dangerous</col>!<br><br>The aim of Deadman is to <col=ffffff>acquire Deadman Points</col> which can be used to purchase <col=ffffff>rewards in the main game</col> at the end of the event. You can find more detail on <col=ffffff>how to earn Deadman Points</col> by <col=ffffff>clicking the Skull icon</col><br>under the Quest tab.<br><br>To begin your journey in Deadman, use the <col=ffffff>Get Started</col> button below. Otherwise you can use the <col=ffffff>Exit</col> button to logout.
textlineheight=14
textalignh=left
textalignv=top
textshadow=yes
colour=0xff981f

// 419:13
[continue_1]
type=layer
x=112
y=19
width=168
height=30
xmode=abs_centre
ymode=abs_bottom
layer=tut_1_layer
events=2
op1=*
onload=player_design_button_draw(event_com, "Get Started", false)

