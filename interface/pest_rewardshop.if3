// 243:0
[universe]
type=layer
width=490
height=320
xmode=abs_centre
ymode=abs_centre
onload=pest_rewards_init(event_com, pest_rewardshop:total, pest_rewardshop:options, pest_rewardshop:scrollbar, pest_rewardshop:confirm, pest_rewardshop:buttongfx)

// 243:1
[frame]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe
onload=steelborder(event_com, "Void Knights' Reward Options")

// 243:2
[options_container]
type=layer
y=50
width=20
height=90
widthmode=minus
heightmode=minus
