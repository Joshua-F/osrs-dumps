ymode=abs_centre
layer=options_container

// 243:5
[bottom]
type=layer
y=10
width=20
height=35
widthmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=universe

// 243:6
[confirm]
type=layer
width=150
heightmode=minus
