// 207:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=nzone_lobby_init(nzone_lobby:dodger_left, nzone_lobby:left_content, nzone_lobby:dodger_mid, nzone_lobby:mid_content, nzone_lobby:dodger_right, nzone_lobby:right_content)

// 207:1
[dodger_mid]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 207:2
[mid_content]
type=layer
widthmode=minus
heightmode=minus
layer=dodger_mid

// 207:3
[dodger_left]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 207:4
[left_content]
type=layer
widthmode=minus
heightmode=minus
layer=dodger_left

// 207:5
[dodger_right]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 207:6
[right_content]
type=layer
widthmode=minus
heightmode=minus
layer=dodger_right

// 207:7
[control]
type=text
width=1
height=1
textfont=p11_full
textalignh=centre
textalignv=top
textshadow=yes
colour=0xcccccc

