// 373:0
[universe]
type=layer
widthmode=minus
heightmode=minus
onload=tzhaar_fightpit_init(tzhaar_fightpit:dodger, tzhaar_fightpit:content)

// 373:1
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 373:2
[content]
type=layer
y=6
width=253
height=43
xmode=abs_centre
layer=dodger

// 373:3
[tzhaar_fightpit_champion]
type=text
y=2
width=240
height=11
xmode=abs_centre
layer=content
textfont=p11_full
text=Current Champion: TzHaar-Xil-Huz
textalignh=centre
textalignv=top
textshadow=yes
colour=0xcccccc

// 373:4
[tzhaar_fightpit_foes]
