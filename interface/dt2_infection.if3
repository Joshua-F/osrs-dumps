// 836:0
[universe]
type=layer
width=16384
height=16384
widthmode=rel
heightmode=rel
onload=dt2_infection_init(dt2_infection:dodger, dt2_infection:overlay, true)

// 836:1
[fade]
type=layer
widthmode=minus
heightmode=minus
layer=universe
hide=yes

// 836:2
[fader]
type=rectangle
widthmode=minus
heightmode=minus
layer=fade
colour=0x000000
fill=yes

// 836:3
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 836:4
[overlay]
