// 375:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=soul_wars_game_hud_init(event_com, soul_wars_game:dodger, soul_wars_game:content, soul_wars_game:graveyard_west, soul_wars_game:graveyard_west_fill, soul_wars_game:graveyard_west_bar, soul_wars_game:obelisk, soul_wars_game:obelisk_fill, soul_wars_game:obelisk_bar, soul_wars_game:graveyard_east, soul_wars_game:graveyard_east_fill, soul_wars_game:graveyard_east_bar, soul_wars_game:activity_bar_fill)

