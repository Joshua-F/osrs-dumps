// 381:0
[universe]
type=layer
width=190
height=261

// 381:1
[com_1]
type=graphic
width=190
height=261
layer=universe
graphic=tradebacking
tiling=yes

// 381:2
[titlebox]
type=layer
width=190
height=40
layer=frame
onload=steelbox(event_com)

// 381:3
[sort]
type=layer
x=164
y=10
width=20
height=20
layer=titlebox
onload=fairyrings_sort_init(fairyrings_log:contents, fairyrings_log:scrollbar, 1, fairyrings_log:divider, fairyrings_log:faves, fairyrings_log:search)
onmouseover=fairyrings_sort_mouseeffect(fairyrings_log:sort_1, fairyrings_log:sort_2, 0)
onmouseleave=fairyrings_sort_mouseeffect(fairyrings_log:sort_1, fairyrings_log:sort_2, 50)
onclick=fairyrings_sort_update(fairyrings_log:contents, fairyrings_log:scrollbar, 0, 1, fairyrings_log:divider, fairyrings_log:faves)

// 381:4
[sort_1]
type=graphic
x=6
y=4
width=7
height=5
layer=sort
graphic="sortarrows,0"
trans=50

// 381:5
[sort_2]
type=graphic
x=6
y=10
width=7
height=5
layer=sort
graphic="sortarrows,1"
trans=50

// 381:6
[com_6]
type=text
width=190
height=40
layer=titlebox
textfont=q8_full
text=Travel log
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff981f

// 381:7
[search]
type=graphic
x=6
width=29
height=22
ymode=abs_centre
layer=titlebox
graphic="bankbuttons,2"
events=2
op1=Search
onload=fairyrings_init(event_com, fairyrings_log:contents, fairyrings_log:scrollbar, fairyrings_log:divider, fairyrings_log:faves)
onmouseover=settrans(event_com, 170)
onmouseleave=settrans(event_com, 0)

// 381:8
[contents]
type=layer
x=6
y=42
width=163
height=215
layer=universe

// 381:9
[faves]
type=layer
height=100
widthmode=minus
layer=contents

// 381:10
[divider]
type=rectangle
y=3
height=1
widthmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=faves
colour=0x333333

// 381:11
[frame]
type=layer
width=190
height=261
onload=steelbox(event_com)

