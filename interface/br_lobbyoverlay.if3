// 333:0
[universe]
type=layer
widthmode=minus
heightmode=minus
onload=br_lobbyoverlay_init(br_lobbyoverlay:dodger, br_lobbyoverlay:content, br_lobbyoverlay:settings)

// 333:1
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 333:2
[content]
