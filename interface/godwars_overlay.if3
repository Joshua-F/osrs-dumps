// 406:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
onload=godwars_hideshow_init(event_com, godwars_overlay:contents, godwars_overlay:fader, godwars_overlay:dodger, godwars_overlay:kills_layer)

// 406:1
[contents]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe

// 406:2
[tint_box]
type=rectangle
widthmode=minus
heightmode=minus
layer=contents
colour=0x010000
fill=yes
trans=255
ontimer=nex_fadetimer

// 406:3
[darkness]
type=rectangle
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=contents
colour=0x000000
fill=yes
trans=255
onload=godwars_darkness(event_com)
ontimer=godwars_darkness(event_com)

// 406:4
[dodger]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=contents

// 406:5
[kills_layer]
type=layer
x=2
y=2
width=120
height=113
layer=dodger

// 406:6
[background]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=kills_layer
onload=helper_background(event_com)

// 406:7
[kills]
type=layer
width=10
height=10
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=kills_layer

// 406:8
[title]
type=text
width=2
height=18
widthmode=minus
xmode=abs_centre
layer=kills
textfont=b12_full
text=Essence
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xff991f

