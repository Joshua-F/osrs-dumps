// 606:0
[universe]
type=layer
widthmode=minus
heightmode=minus
onload=fossil_pool_overlay_init(fossil_pool_overlay:dodger, fossil_pool_overlay:content)

// 606:1
[dodger]
type=layer
widthmode=minus
heightmode=minus
layer=universe

// 606:2
[content]
type=layer
x=8
width=100
height=100
ymode=abs_centre
layer=dodger

// 606:3
[process_layer]
type=layer
width=100
height=30
layer=content

// 606:4
[calcium_layer]
