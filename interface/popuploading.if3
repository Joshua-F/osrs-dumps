// 916:0
[universe]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre

// 916:1
[clamp]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=universe

// 916:2
[fader]
type=rectangle
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=clamp
colour=0x000000
fill=yes
trans=255

// 916:3
[window]
type=layer
width=200
height=200
xmode=abs_centre
ymode=abs_centre
layer=clamp

// 916:4
[frame]
type=layer
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_centre
layer=window

// 916:5
[container]
type=layer
y=10
width=20
height=20
widthmode=minus
heightmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=window
onload=thinbox(event_com)

// 916:6
[body]
type=layer
height=21
widthmode=minus
heightmode=minus
xmode=abs_centre
layer=container

// 916:7
[text]
type=text
height=21
widthmode=minus
xmode=abs_centre
ymode=abs_bottom
layer=container
textfont=p12_full
textalignh=centre
textalignv=centre
textshadow=yes
colour=0xffffff

