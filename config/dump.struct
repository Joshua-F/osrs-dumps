// 4726
[struct_4726]
param=param_879,Executioner
param=param_880,- The axe is a thrown ranged weapon which can be used to execute targets below 20% hitpoints.<br><br>- The axe has an attack range of 6 tiles.<br><br>- The axe's damage respects any ranged damage reduction effects and immunities the target has.<br><br>- The axe will not work against <col=#>Yama</col>.<br><br>- Throwing the axe doesn't consume it, but the primary hit does trigger regeneration effects from <col=#>Demonic Pacts</col>.<br><br>- Execute damage can hit additional targets with <col=#>Demonic Pacts</col>.<br><br>- This perk will also work inside The Gauntlet.
param=param_884,"league_6_relics_large,21"
