// 4722
[struct_4722]
param=param_879,Farmer's Fortune
param=param_880,- You will harvest patches at a rate of up to 20x per action, noting any contents you receive.<br><br>- All patches will give 3x the yield.<br><br>- Farming patches grow instantly.<br><br>- Your plants will never die.<br><br>- You have a 20%~ chance to not use a seed or sapling when planting items in patches.
param=param_884,"league_4_relics_large,14"
