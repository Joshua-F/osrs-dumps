// 6260
[struct_6260]
param=param_879,Rune Saviour
param=param_880,You gain the <col=#>Rune Saviour</col> perk. Magic spells no longer require or consume Runes. This includes charges when using powered staves or tomes such as the Tome of Fire, Trident of the Seas, Trident of the Swamp, Sanguinesti Staff and the Enchanted Slayer Staff.
param=param_1855,false

// 6261
[struct_6261]
param=param_879,Minimum Potential
param=param_880,You gain the <col=#>Minimum Potential</col> perk. Your Melee, Ranged & Magic hits will never deal below 5 damage.
param=param_1855,false

// 6262
[struct_6262]
param=param_879,Spiky Aura
param=param_880,You gain the <col=#>Spiky Aura</col> perk. Whenever you take damage you'll reflect at least 25% of the damage received. This effect stacks with other recoil effects.
param=param_1855,false

// 6263
[struct_6263]
param=param_879,Bottomless Brew
param=param_880,You gain the <col=#>Bottomless Brew</col> perk.<br>Potions will no longer be consumed when you drink them.
param=param_1855,false

