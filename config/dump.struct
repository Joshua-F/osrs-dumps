param=param_1613,1
param=param_1614,Group Boss Bash
param=param_1615,Group Boss Bash will have you and your group participate in various group activities around Gielinor. This raffle will start on <col=ffffff>26th May 2022</col> and will end at <col=ffffff>23:59 UTC</col> on <col=ffffff>9th June 2022</col>.<br><br>Tickets can be earned by receiving loot from the following non-combat activities:<br>    - Tempoross, <col=ffffff>1 ticket</col><br>    - Wintertodt, <col=ffffff>1 ticket</col><br>    - Zalcano, <col=ffffff>3 tickets</col><br>    - Barbarian Assault, <col=ffffff>10 tickets</col><br>        (Upon finishing wave 10)<br><br>Tickets can be earned by receiving loot from the following combat activities:<br>    - Sarachnis, <col=ffffff>1 ticket</col><br>    - King Black Dragon, <col=ffffff>1 ticket</col><br>    - Dagannoth Kings, <col=ffffff>1 ticket</col><br>    - Kalphite Queen, <col=ffffff>2 tickets</col><br>    - Commander Zilyana, <col=ffffff>5 tickets</col><br>    - General Graardor, <col=ffffff>5 tickets</col><br>    - K'ril Tsutsaroth, <col=ffffff>5 tickets</col><br>    - Kree'arra, <col=ffffff>5 tickets</col><br>    - The Nightmare, <col=ffffff>2 tickets</col><br>        (Phosani's Nightmare excl.)<br>    - Nex, <col=ffffff>2 tickets</col><br>    - Corporeal Beast, <col=ffffff>5 tickets</col><br>    - Chambers of Xeric, <col=ffffff>10 tickets</col><br>        - Challenge Mode, <col=ffffff>20 tickets</col><br>    - Theatre of Blood, <col=ffffff>15 tickets</col><br>        - Story Mode, <col=ffffff>3 tickets</col><br>        - Hard Mode, <col=ffffff>20 tickets</col>
param=param_1616,7393
param=param_1617,7408
param=param_1618,true

